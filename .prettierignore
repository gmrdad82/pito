# Prettier ignore list — directories that prettier should never format.
#
# Rationale: prettier walks the repo when run with broad globs (e.g.
# `prettier --check '**/*.md'`). Without this file it descends into
# vendored deps, generated build artefacts, and the scratch staging area
# at `_temp/` — wasting time and surfacing diffs in files the repo does
# not own. Each entry below is a directory we explicitly disclaim.

# Scratch / staging area at the repo root. Out of formatting scope.
_temp/

# Vendored / generated dependency trees.
node_modules/
vendor/

# Rust build artefacts (workspace root + CLI workspace member).
target/
extras/cli/target/

# Rails-managed transient directories.
tmp/
public/

# Astro landing-page build output.
extras/website/dist/
extras/website/.astro/
