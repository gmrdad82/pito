# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (except .env.example).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# ActiveStorage dev blobs (avatars / thumbnails / cover art) — live under public/
# so they survive tmp cleanups; never checked in.
/public/pito-storage

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Install-level pito config — operator-managed, not secrets. Tracked
# via `config/pito.yml.example`; the actual file is per-install.
/config/pito.yml

.claude/

# Local-only agent/working docs (plans, briefs, the 0.7.0 checklist) — never checked in.
/docs/claude/

/app/assets/builds/*
!/app/assets/builds/.keep

node_modules/

# Local backups produced by `pito:tools:backup` (db dump + assets).
/backup/
# Host backups produced by `pito backup` (db dump + active storage).
/backups/

# crush (Charm) local state/cache — the config (crush.json) is tracked.
/.crush/
