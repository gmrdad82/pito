# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (except .env.example).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Phase 27 follow-up (2026-05-17) — `public/<sub>` symlinks created by
# `bin/rails pito:assets:setup_symlinks` that point at the pito-assets
# volume (covers, thumbnails). Per-install / per-environment — the
# task is operator-run, the symlinks themselves are NOT source.
/public/covers
/public/thumbnails

# Ignore key files for decrypting credentials and more.
/config/*.key

# Install-level pito config — operator-managed, not secrets. Tracked
# via `config/pito.yml.example`; the actual file is per-install.
/config/pito.yml


/app/assets/builds/*
!/app/assets/builds/.keep

# Rust workspace target dirs (root + per-crate fallback).
/target/
/extras/*/target/
.claude/
