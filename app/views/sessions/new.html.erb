<% content_for(:title, "log in") %>
<% content_for(:hide_chrome, true) %>

<div style="max-width: 420px; margin: 24px 0;">
  <h1>log in</h1>

  <%= form_with url: login_path, method: :post, scope: nil,
                data: { turbo: false } do %>
    <div style="margin-bottom: 12px;">
      <label class="form-label">authenticator code</label>
      <%= render Tui::TotpCodeComponent.new(field: :code, mode: :digits, autofocus: true) %>
    </div>

    <details style="margin-bottom: 12px;">
      <summary class="muted">use a backup code instead</summary>
      <div style="margin-top: 8px;">
        <label for="login_backup_code" class="form-label">backup code</label>
        <input type="text" name="backup_code" id="login_backup_code"
               autocomplete="off" inputmode="text" spellcheck="false"
               style="width: 100%;">
      </div>
    </details>

    <div class="dot-list">
      <button type="submit">[log in]</button>
    </div>
  <% end %>
</div>
