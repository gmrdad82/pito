<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pito" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Pito">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-black font-sans text-sm leading-tight">
    <header class="border-b border-gray-200 py-2 px-4">
      <div class="max-w-6xl mx-auto flex flex-wrap items-baseline gap-x-1">
        <a href="/" class="font-bold text-base no-underline text-black mr-3">P</a>
        <nav class="flex flex-wrap items-baseline gap-x-1 text-xs">
          <%= nav_link "Dashboard", root_path %>
          <span class="text-gray-400">&middot;</span>
          <%= nav_link "Channels", channels_path %>
          <span class="text-gray-400">&middot;</span>
          <%= nav_link "Compare", compare_path %>
          <span class="text-gray-400">&middot;</span>
          <%= nav_link "Production", productions_path %>
          <span class="text-gray-400">&middot;</span>
          <%= nav_link "Notes", notes_path %>
          <span class="text-gray-400">&middot;</span>
          <%= nav_link "Settings", settings_path %>
          <span class="text-gray-400">&middot;</span>
          <%= nav_link "Sidekiq", sidekiq_web_path %>
        </nav>
      </div>
    </header>

    <% if flash[:notice] %>
      <div class="max-w-6xl mx-auto px-4 pt-2 text-xs text-green-800"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="max-w-6xl mx-auto px-4 pt-2 text-xs text-red-800"><%= flash[:alert] %></div>
    <% end %>

    <main class="max-w-6xl mx-auto px-4 py-3">
      <%= yield %>
    </main>

    <footer class="border-t border-gray-200 py-2 px-4 mt-6">
      <div class="max-w-6xl mx-auto text-xs text-gray-500">
        &copy; <%= Date.current.year %> Pito
      </div>
    </footer>
  </body>
</html>
