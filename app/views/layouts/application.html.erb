<!DOCTYPE html>
<html data-theme-preference="<%= AppSetting.get('theme') || 'auto' %>">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} ~ pito" : "pito ~ best YouTube tool" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Pito">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/Pito.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script>
      (function() {
        var s = localStorage.getItem("pito-theme");
        if (s === "light" || s === "dark") { document.documentElement.setAttribute("data-theme", s); return; }
        var p = document.documentElement.dataset.themePreference;
        if (p === "light" || p === "dark") { document.documentElement.setAttribute("data-theme", p); return; }
        document.documentElement.setAttribute("data-theme", window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      })();
    </script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header style="position: fixed; top: 0; left: 0; right: 0; height: 32px; background: var(--color-bg); border-bottom: 1px solid var(--color-border); padding: 0 12px; z-index: 100;" data-controller="theme">
      <div style="display: flex; align-items: center; height: 32px; gap: 6px;">
        <a href="/" style="text-decoration: none; display: flex; align-items: center; line-height: 0;" aria-label="Dashboard">
          <img src="/Pito.png" alt="Pito" class="header-logo">
        </a>
        <nav style="display: flex; align-items: center; gap: 4px;"><span class="hide-mobile"><%= nav_link "home", root_path %> <span class="text-muted">&middot;</span> </span><%= nav_link "channels", channels_path, short: "C" %> <span class="text-muted">&middot;</span> <%= nav_link "videos", videos_path, short: "V" %> <span class="text-muted">&middot;</span> <%= nav_link "projects", projects_path, short: "P" %> <span class="text-muted">&middot;</span> <%= nav_link "settings", settings_path, short: "S" %></nav>
        <span class="text-muted hide-mobile">&middot;</span>
        <%= form_with url: search_path, method: :get, class: "search-form", style: "display: flex; align-items: center; gap: 4px;", data: { turbo_action: "replace" } do %>
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="search..." autocomplete="off" class="search-input" style="width: 200px; height: 22px; font-size: 13px; padding: 0 6px; border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text); font-family: inherit;">
          <button type="submit" class="bracketed hide-mobile" style="white-space: nowrap;">[<span class="bl">search</span>]</button>
        <% end %>
        <a href="#" class="keycap keycap-theme" style="margin-left: auto;" data-action="click->theme#toggle" data-theme-target="toggle">n</a>
      </div>
    </header>

    <%= render "shared/flash_toasts" %>

    <div style="padding-top: 36px;">
      <main style="padding: 8px 12px;">
        <% if content_for?(:breadcrumbs) %>
          <nav style="margin-bottom: 6px; display: flex; align-items: baseline; gap: 6px;"><%= yield :breadcrumbs %><% if content_for?(:breadcrumb_actions) %><span class="text-muted">&middot;</span><%= yield :breadcrumb_actions %><% end %></nav>
        <% end %>
        <%= yield %>
      </main>
    </div>

    <footer style="border-top: 1px solid var(--color-border); padding: 8px 12px; margin-top: 24px;">
      <div style="display: flex; align-items: center; gap: 4px; font-size: 11px; flex-wrap: wrap;">
        <span class="hide-mobile"><%= nav_link "home", root_path %> <span class="text-muted">&middot;</span> </span><%= nav_link "channels", channels_path, short: "C" %> <span class="text-muted">&middot;</span> <%= nav_link "videos", videos_path, short: "V" %> <span class="text-muted">&middot;</span> <%= nav_link "projects", projects_path, short: "P" %> <span class="text-muted">&middot;</span> <%= nav_link "settings", settings_path, short: "S" %> <span class="text-muted">&middot;</span>
        <a href="/" style="display: flex; align-items: center; gap: 4px; text-decoration: none; color: inherit;"><img src="/Pito.png" alt="Pito" style="height: 10px; width: auto; display: block; position: relative; top: -1px;"></a>
        <span class="text-muted">&copy; <%= Date.current.year %><span class="hide-mobile"> &mdash; all rights reserved.</span></span>
        <span class="text-muted" style="margin-left: auto;"><%= version_label %></span>
      </div>
    </footer>

    <div data-controller="keyboard">
      <dialog data-keyboard-target="dialog" data-action="click->keyboard#clickOutside" class="pane-dialog" style="max-width: 360px;">
        <div style="padding: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px;">
            <h2>keyboard shortcuts</h2>
            <%= render(BracketedLinkComponent.new(label: "close", href: "#", data: { action: "click->keyboard#close" })) %>
          </div>
          <table class="detail-table" style="width: 100%;">
            <tr><td><span class="keycap">n</span></td><td>toggle dark/light theme</td></tr>
            <tr><td><span class="keycap">/</span></td><td>focus search</td></tr>
            <tr><td><span class="keycap">?</span></td><td>show this dialog</td></tr>
          </table>
          <p class="form-hint" style="margin-top: 8px; font-size: 11px;">shortcuts are disabled when typing in inputs.</p>
        </div>
      </dialog>
    </div>
  </body>
</html>
