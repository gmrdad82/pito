<!DOCTYPE html>
<html lang="en" data-theme="tokyo-night">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>pito</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%# Prevent Turbo from showing a stale cached snapshot (no-preview) while the
      fresh page loads. Auth state (○/● auth, auth-gate) must always reflect the
      current server-side session — never a cached pre-login DOM. %>
  <meta name="turbo-cache-control" content="no-preview">
  <%= stylesheet_link_tag "tailwind", media: "all" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-root text-fg font-mono" data-controller="pito--audio" <%= "data-audio-chat-page=\"true\"".html_safe if controller_name == "conversations" %>>
  <div id="pito-auth-gate" class="hidden" data-authenticated="<%= Current.session.present? %>"></div>
  <div id="pito-sidebar" data-controller="pito--resume"></div>
  <%= yield %>

  <%# Global Ctrl+K command palette — always in DOM, toggled by pito--command-palette controller %>
  <div id="pito-command-palette"
       data-controller="pito--command-palette"
       class="hidden fixed inset-0 z-50 flex items-center justify-center"
       style="background: rgba(0,0,0,0.45);">
    <%= render(Pito::Palette::CtrlK::Component.new(
          sections: Pito::Palette::CommandCatalog.sections
        )) %>
  </div>
</body>
</html>
