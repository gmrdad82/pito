<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pito" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Pito">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/Pito.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header style="position: fixed; top: 0; left: 0; right: 0; height: 32px; background: #fff; border-bottom: 1px solid #ddd; padding: 0 12px; z-index: 100;">
      <div style="display: flex; align-items: center; height: 32px; gap: 6px;">
        <a href="/" style="text-decoration: none; display: flex; align-items: center; line-height: 0;" aria-label="Dashboard">
          <img src="/Pito.png" alt="Pito" class="header-logo">
        </a>
        <nav style="display: flex; align-items: center; gap: 4px;">
          <%= nav_link "Channels", channels_path %>
          <span class="text-muted">&middot;</span>
          <%= nav_link "Videos", videos_path %>
          <span class="text-muted">&middot;</span>
          <%= nav_link "Settings", settings_path %>
        </nav>
      </div>
    </header>

    <div style="padding-top: 36px;">
      <% if flash[:notice] %>
        <div class="flash-notice" style="max-width: 900px; margin: 4px auto 0; padding: 4px 12px;"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-error" style="max-width: 900px; margin: 4px auto 0; padding: 4px 12px;"><%= flash[:alert] %></div>
      <% end %>

      <main style="padding: 8px 12px;">
        <%= yield %>
      </main>
    </div>

    <footer style="border-top: 1px solid #ddd; padding: 8px 12px; margin-top: 24px;">
      <div class="text-muted" style="display: flex; justify-content: space-between;">
        <span>&copy; <%= Date.current.year %> Pito. All rights reserved.</span>
        <span>Version 0.0.1.alpha</span>
      </div>
    </footer>
  </body>
</html>
