<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} ~ pito" : "pito ~ best YouTube tool" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Pito">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/Pito.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header style="position: fixed; top: 0; left: 0; right: 0; height: 32px; background: #fff; border-bottom: 1px solid #ddd; padding: 0 12px; z-index: 100;">
      <div style="display: flex; align-items: center; height: 32px; gap: 6px;">
        <a href="/" style="text-decoration: none; display: flex; align-items: center; line-height: 0;" aria-label="Dashboard">
          <img src="/Pito.png" alt="Pito" class="header-logo">
        </a>
        <nav style="display: flex; align-items: center; gap: 4px;"><%= nav_link "home", root_path %> <span class="text-muted">&middot;</span> <%= nav_link "channels", channels_path %> <span class="text-muted">&middot;</span> <%= nav_link "videos", videos_path %> <span class="text-muted">&middot;</span> <%= nav_link "settings", settings_path %></nav>
      </div>
    </header>

    <div style="padding-top: 36px;">
      <main style="padding: 8px 12px;">
        <% if content_for?(:breadcrumbs) %>
          <nav style="margin-bottom: 6px;"><%= yield :breadcrumbs %></nav>
        <% end %>
        <% if flash[:notice] %>
          <div class="flash-notice" style="margin-bottom: 8px; padding: 4px 8px;"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="flash-error" style="margin-bottom: 8px; padding: 4px 8px;"><%= flash[:alert] %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>

    <footer style="border-top: 1px solid #ddd; padding: 8px 12px; margin-top: 24px;">
      <nav style="font-size: 11px; margin-bottom: 6px;"><%= nav_link "home", root_path %> <span class="text-muted">&middot;</span> <%= nav_link "channels", channels_path %> <span class="text-muted">&middot;</span> <%= nav_link "videos", videos_path %> <span class="text-muted">&middot;</span> <%= nav_link "settings", settings_path %></nav>
      <div class="text-muted" style="display: flex; justify-content: space-between; align-items: center; font-size: 11px;">
        <a href="/" style="display: flex; align-items: center; gap: 4px; text-decoration: none; color: inherit;"><img src="/Pito.png" alt="Pito" style="height: 10px; width: auto; display: block; position: relative; top: -1px;"> &copy; <%= Date.current.year %>. all rights reserved.</a>
        <span>version 0.0.1.alpha</span>
      </div>
    </footer>
  </body>
</html>
