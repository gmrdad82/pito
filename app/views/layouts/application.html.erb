<!DOCTYPE html>
<html lang="en" data-theme="<%= AppSetting.theme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PITO</title>
  <%# Dev-only: swap in a RED favicon (vs the pito-blue production icon) so a
      development tab is never mistaken for the real thing. SVG favicons take
      precedence over /favicon.ico in modern browsers; production links nothing. %>
  <% if Rails.env.development? %>
    <link rel="icon" type="image/svg+xml" href="/favicon-dev.svg">
  <% end %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%# Prevent Turbo from showing a stale cached snapshot (no-preview) while the
      fresh page loads. Auth state (●/■ auth, auth-gate) must always reflect the
      current server-side session — never a cached pre-login DOM. %>
  <meta name="turbo-cache-control" content="no-preview">
  <%# The build this page was rendered by: pito--cable-health compares it
      with GET /version after a cable reconnect — a mismatch means the server
      updated under this tab and the refresh nudge appears. %>
  <meta name="pito-version" content="<%= Pito::Version.suffix %>">
  <%= stylesheet_link_tag "tailwind", media: "all" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-root text-fg font-mono" data-controller="pito--audio" <%= "data-audio-chat-page=\"true\"".html_safe if controller_name == "conversations" %>>
  <div id="pito-auth-gate" class="hidden" data-authenticated="<%= Current.session.present? %>"></div>
  <div id="pito-settings" class="hidden" data-sound="<%= AppSetting.sound_enabled? %>" data-theme="<%= AppSetting.theme %>"></div>
  <%# The version heartbeat's landing pad: VersionHeartbeatJob replaces
      this node on pito:global every 5 min; pito--version-watch compares its
      value against the pito-version meta and raises the refresh nudge when
      the server has moved on under this page. Rendered with the CURRENT
      version so the initial mount is always a no-op. %>
  <div id="pito-server-version" class="hidden" data-controller="pito--version-watch" data-pito--version-watch-version-value="<%= Pito::Version.suffix %>"></div>
  <%# Global Turbo Stream subscription: receives mini-status and row
      replacements that must propagate to every open browser instance
      (unread-count sync after notification toggle, sidebar row sync after rename). %>
  <%= turbo_stream_from "pito:global" %>
  <%# Shell row — main content fills the full width; the sidebar is ALWAYS a
      fixed overlay (never in-flow). On mobile it slides in full-width; on
      desktop it slides in at 480px — both sit ON TOP of the conversation so
      the layout never shifts when toggling. The backdrop dims the content on
      desktop (managed by pito--resume). %>
  <%# h-dvh, not h-screen: 100vh includes the strip behind the mobile
      browser's collapsing address bar, which pushed the chatbox under it
      (owner screenshot 2026-07-12) — dvh tracks the VISIBLE viewport. %>
  <div class="flex h-dvh overflow-hidden">
    <main class="flex-1 min-w-0"><%= yield %></main>
    <%# Desktop geometry (owner DRAWING, 2026-07-12): the classic 480px panel
        whose RIGHT edge sits ON the conversation column's right edge (the
        964px centered column ends at 50vw+482px → right offset 50vw-482px,
        floored at 0 for narrow windows), hanging OVER the column's right
        half. Mobile: full width from the viewport edge. %>
    <div id="pito-sidebar" data-controller="pito--resume"
         class="shrink-0 overflow-hidden transition-[width] duration-200 fixed inset-y-0 right-0 md:right-[max(0px,calc(50vw-482px))] z-40 w-0 has-[aside]:w-full md:w-0 md:has-[aside]:w-[480px]"></div>
  </div>
  <%# Desktop sidebar overlay backdrop — semi-transparent scrim behind the
      sidebar on desktop. Shown via CSS :has() when the sidebar is open.
      Clicking it dismisses the sidebar (pito--resume backdrop listener). %>
  <div id="pito-sidebar-backdrop" class="pito-sidebar-backdrop"></div>

  <%# The /config ai picker's landing pad: the fast-path turbo stream mounts
      the overlay here; pito--ai-picker removes it on close. %>
  <div id="pito-ai-picker-slot"></div>

  <%# Global Ctrl+K command palette — always in DOM, toggled by pito--command-palette controller %>
  <div id="pito-command-palette"
       data-controller="pito--command-palette"
       class="pito-modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center">
    <%= render(Pito::Palette::CtrlK::Component.new(
          sections: Pito::Palette::CommandCatalog.sections(authenticated: Current.session.present?)
        )) %>
  </div>

  <%# Dev-only red "DEVELOPMENT" banner pinned to the bottom (see favicon above). %>
  <% if Rails.env.development? %>
    <%= render(Pito::DevelopmentBannerComponent.new) %>
  <% end %>

  <%# "Get the app" top banner — Android browsers only (the component's
      render? bows out for non-Android UAs and inside the Hotwire Native
      shell; a localStorage dismissal keeps it hidden client-side). %>
  <%= render(Pito::GetAppBannerComponent.new(user_agent: request.user_agent)) %>

  <%# The refresh nudge template — inert until pito--cable-health clones
      it into the scrollback after a reconnect onto a NEWER server build.
      Layout-level so it survives the start→conversation morph. %>
  <%= render(Pito::Shell::RefreshNudgeComponent.new) %>

  <%# The pull-to-refresh spinner template — floated in from the bottom edge by
      pito--pull-refresh during a bottom drag (native shell + mobile web). %>
  <%= render(Pito::Shell::PullRefreshSpinnerComponent.new) %>
</body>
</html>
