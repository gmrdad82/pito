<%# Phase 14 §3 — single row in the "linked games / bundles" table on
    the video edit form.
    Locals:
      link   the VideoGameLink row.
      video  the parent Video (so the toggle / remove URLs nest correctly).

    The `[★]` toggle flips `is_primary`; the `[remove]` link routes
    through `/deletions/video_game_link/:id` so the action-screen
    pattern (no JS confirms — CLAUDE.md hard rule) gates the actual
    destroy.
%>
<%
  target = link.target
  target_label = if target.respond_to?(:title) && target.title.present?
                   target.title
                 elsif target.respond_to?(:name)
                   target.name
                 else
                   "—"
                 end
%>
<tr>
  <td><%= link.link_type %></td>
  <td>
    <% if target.is_a?(Game) %>
      <%= link_to target_label, game_path(target) %>
    <% elsif target.is_a?(Bundle) %>
      <%= link_to target_label, bundle_path(target) %>
    <% else %>
      <%= target_label %>
    <% end %>
  </td>
  <td class="num">
    <%# Toggle is_primary via PATCH. The bracketed `★` reads as the
        active state; the empty `[ ]` invites toggling on. %>
    <% next_value = link.is_primary? ? "no" : "yes" %>
    <%= button_to video_link_path(video, link),
                  method: :patch,
                  params: { is_primary: next_value },
                  class: "bracketed",
                  form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>
      [<span class="bl"><%= link.is_primary? ? "★" : " " %></span>]
    <% end %>
  </td>
  <td>
    <%= render(BracketedLinkComponent.new(label: "remove",
                                          href: deletions_path(type: "video_game_link", ids: link.id),
                                          destructive: true)) %>
  </td>
</tr>
