<%# Phase 14 §1 — IGDB type-ahead results.
    Locals:
      results:       Array of IGDB game hashes (id, name, slug,
                     cover.image_id, first_release_date)
      query:         the (sanitized) query string the user typed
      search_error:  optional error string from the IGDB client

    Phase 14 §1 polish (2026-05-10) — IGDB-search modal context.
    The partial is rendered inside `<turbo-frame id="igdb_search_results">`,
    which now lives on the layout-level IGDB-search modal
    (`shared/_igdb_search_modal`). Each row renders either:
      - `[add]` when no local Game has the IGDB id yet — POSTs to
        `/games` with `params[:game][:igdb_id]`. Phase 14 default flow.
      - `[update]` when a local Game already maps to the IGDB id —
        opens the shared overwrite-confirmation modal
        (`shared/_igdb_overwrite_modal`) targeting the existing
        `POST /games/:id/resync` endpoint. Per CLAUDE.md hard rule,
        the warning travels through an in-page modal, NOT
        `window.confirm` / `data-turbo-confirm`. %>
<%= turbo_frame_tag "igdb_search_results" do %>
  <% if search_error.present? %>
    <p class="text-danger"><%= search_error %></p>
  <% elsif query.blank? %>
    <p class="text-muted">type to search igdb.</p>
  <% elsif results.empty? %>
    <p class="text-muted">no results for '<%= query %>'.</p>
  <% else %>
    <%
      # Bulk lookup: every IGDB id in the result set, mapped to its
      # existing local Game (if any). The N+1 a per-row find_by would
      # introduce becomes a single `WHERE igdb_id IN (...)` query.
      result_igdb_ids = results.map { |row| row["id"] }.compact
      existing_games_by_igdb_id =
        Game.where(igdb_id: result_igdb_ids).index_by(&:igdb_id)
    %>
    <ul class="igdb-search-results" style="list-style: none; padding: 0; margin: 0;">
      <% results.each do |row| %>
        <% release_year = row["first_release_date"].present? ? Time.at(row["first_release_date"]).utc.year : nil %>
        <% cover_image_id = row.dig("cover", "image_id") %>
        <% existing = existing_games_by_igdb_id[row["id"]] %>
        <li style="display: flex; gap: 8px; align-items: center; padding: 4px 0; border-bottom: 1px solid var(--color-border);">
          <% if cover_image_id.present? %>
            <%= image_tag "https://images.igdb.com/igdb/image/upload/t_cover_small/#{cover_image_id}.jpg",
                          alt: row["name"], loading: "lazy",
                          style: "width: 45px; height: auto;" %>
          <% else %>
            <span class="text-muted" style="display: inline-block; width: 45px; text-align: center;">[?]</span>
          <% end %>
          <span style="flex: 1;"><%= row["name"] %><% if release_year %> <span class="text-muted">(<%= release_year %>)</span><% end %></span>
          <% if existing %>
            <%# Existing game: open the overwrite-confirmation modal
                pointed at this game's resync endpoint. The trigger
                controller copies the path into the dialog's <form>
                action before showing the dialog. %>
            <a href="#"
               class="bracketed"
               data-controller="igdb-overwrite-trigger"
               data-igdb-overwrite-trigger-path-value="<%= resync_game_path(existing) %>"
               data-action="click->igdb-overwrite-trigger#open">[<span class="bl">update</span>]</a>
          <% else %>
            <%# Phase 27 spec 04 (2026-05-17) — eager title pre-seed.
                The IGDB result row's `name` is forwarded as a hidden
                form param so `GamesController#create` can seed the
                new Game's `title` synchronously. Without this, the
                model's `"Untitled game"` attribute default lands as
                the persisted title until the async `GameIgdbSync`
                job overwrites it — the breadcrumb on the redirect
                target would briefly read "Untitled game" instead of
                the IGDB-canonical title. %>
            <%= button_to games_path,
                          params: { game: { igdb_id: row["id"], title: row["name"] } },
                          method: :post,
                          class: "bracketed",
                          form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl">add</span>]<% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
