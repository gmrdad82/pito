<%# Phase 27 §01c-v2 — Collection sub-shelf row.
    One sub-shelf per non-empty collection. Renders an `<h3>` row with
    the collection name (left) and a `[see all]` bracketed link
    (right, only when the bucket exceeds the visible cap). Inside, a
    horizontally scrolling row with a leading composite cover tile
    (the existing `games/_collection_sub_shelf` partial, sized to the
    `:shelf` cover variant) followed by individual game tiles.

    Game ordering — alphabetical by `LOWER(games.title)`. Cap — 30
    tiles; the leading composite cover does NOT consume one of the 30
    slots (it's a separate visual element). The `[see all]` link
    targets `/games?collection=<slug-or-id>` (slug when present).

    Note on naming: the partial filename is
    `_collection_sub_shelf_row.html.erb` (sub-shelf ROW) to avoid
    colliding with the already-shipped `_collection_sub_shelf.html.erb`
    (which renders just the leading composite-cover tile per 01h). The
    01c-v2 spec ahead-of-time reserved the unsuffixed name for this
    purpose; the 01h delivery snagged it first. Both partials co-exist;
    the row partial calls the tile partial.

    Locals:
      collection  Collection — the row whose sub-shelf this represents.
%>
<%
  collection = local_assigns.fetch(:collection)
  cap = 30
  total_count = collection.games.count
  games = collection.games.order(Arel.sql("LOWER(games.title)")).limit(cap).to_a
  href = if collection.respond_to?(:slug) && collection.slug.present?
           games_path(collection: collection.slug)
         else
           games_path(collection: collection.id)
         end
%>
<section class="shelf sub-shelf sub-shelf--collection" data-shelf="collection-sub" data-collection-id="<%= collection.id %>" data-controller="steam-shelf" style="margin-top: 12px;">
  <div class="dot-list" style="margin-bottom: 4px;">
    <h3 style="margin: 0; font-size: 13px;"><%= collection.name %></h3>
    <% if total_count > cap %>
      <%= render(BracketedLinkComponent.new(label: "see all", href: href)) %>
    <% end %>
  </div>

  <div class="shelf-row sub-shelf-row" data-steam-shelf-target="row"
       style="display: flex; gap: 6px; overflow-x: auto; padding-bottom: 6px;">
    <%# Leading composite cover tile — wraps the existing 01h partial
        in an anchor that navigates to /collections/<slug>. The 01h
        partial branches on game count (empty / passthrough / composite)
        and renders the right element. %>
    <a href="<%= collection.respond_to?(:slug) && collection.slug.present? ? "/collections/#{collection.slug}" : "/collections/#{collection.id}" %>"
       class="sub-shelf-leading-tile"
       style="flex: 0 0 auto; display: inline-block; text-decoration: none; color: inherit; cursor: pointer;"
       title="<%= collection.name %>"
       data-collection-id="<%= collection.id %>">
      <%= render "games/collection_sub_shelf", collection: collection %>
    </a>

    <% games.each do |game| %>
      <%= render(Games::CoverComponent.new(game: game, variant: :shelf)) %>
    <% end %>
  </div>
</section>
