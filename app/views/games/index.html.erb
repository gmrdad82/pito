<%# Phase 27 v2 spec 05 — `/games` is a single shelves-by-letter
    layout. The display-mode switcher and the three per-mode partials
    (`_grid_mode` / `_list_mode` / `_shelves_by_letter_mode`) are gone;
    the page renders one stack of shelves top-to-bottom:

      1. Page title `games` + `[+]`.
      2. Filter row (spec 06 reworks the row's internal layout).
      3. Bundles shelf (only when at least one bundle exists).
      4. Recently-played shelf (only when at least one game has
         `played_at` set).
      5. Hairline.
      6. Genres outer shelf (one sub-shelf per non-empty genre, short
         heading labels per `GenresHelper#genre_short_name`).
      7. Hairline.
      8. Collections outer shelf (one tile per non-empty collection;
         clicking a tile opens the collections-modal pane).
      9. Hairline.
      10. Letter shelves (one shelf per non-empty letter A..Z, then
          `#` bucket at the end if non-empty).

    Each shelf carries the `steam-shelf` Stimulus controller for
    drag-scroll + mouse-wheel-to-horizontal scroll, with the project's
    themed slim scrollbar (6 px on both axes — see the global
    `::-webkit-scrollbar` rules in `app/assets/tailwind/application.css`).

    Phase 14 §1 polish (2026-05-10) — the inline IGDB type-ahead
    `_add_form` partial was retired. The H1 carries a `[+]`
    bracketed link that opens the layout-level IGDB-search modal
    (`shared/_igdb_search_modal`). The same modal is reachable from
    anywhere via the `i` keypress. %>
<% content_for(:title, "games") %>

<div style="max-width: 1100px;">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <div class="dot-list">
      <h1>games</h1>
      <%= render(BracketedLinkComponent.new(
            label: "+",
            href: "#",
            data: {
              controller: "modal-trigger",
              action: "click->modal-trigger#open",
              modal_trigger_target_id_value: "igdb-search-modal"
            }
          )) %>
    </div>
  </div>

  <%# Phase 27 §01b — filter row sits directly under the page title and
      above every shelf. Chip clicks toggle tokens in the `?filters=`
      CSV URL param; `[clear all]` clears the set while preserving
      `?genre=` / `?collection=` overrides. v2 spec 05 dropped the
      `?display=` query-string passthrough — the display-mode switcher
      retired with the per-mode partials. %>
  <%= render Games::FilterRowComponent.new(
        active_tokens:          @filter_tokens,
        dropped_tokens:         @dropped_filter_tokens,
        request_path:           games_path,
        query_string_overrides: { genre:      params[:genre],
                                  collection: params[:collection] }.compact_blank,
        contradiction:          @filter_contradiction
      ) %>

  <% has_any_content = @bundles_shelf.any? || @recently_played.any? ||
                       @genres_for_shelf.any? || @collections_for_shelf.any? ||
                       @letter_buckets.any? %>

  <% if has_any_content %>
    <% if @bundles_shelf.any? %>
      <%= render "games/shelf",
                 title: "bundles",
                 collection: @bundles_shelf,
                 tile_partial: "bundles/tile",
                 more_link: bundles_path %>
    <% end %>

    <% if @recently_played.any? %>
      <%= render "games/shelf",
                 title: "recently played",
                 collection: @recently_played,
                 tile_partial: "games/tile" %>
    <% end %>

    <%# Phase 27 §01c-v2 — Genres outer shelf. One sub-shelf per non-
        empty genre, alphabetical. Empty buckets hidden. %>
    <% if @genres_for_shelf.any? %>
      <hr class="hairline">
      <%= render "games/genres_shelf", genres: @genres_for_shelf %>
    <% end %>

    <%# Collections outer shelf — one tile per non-empty collection. %>
    <% if @collections_for_shelf.any? %>
      <hr class="hairline">
      <%= render "games/collections_shelf", collections: @collections_for_shelf %>
    <% end %>

    <%# Phase 27 v2 spec 05 — Letter shelves. One `<section>` per non-
        empty letter; `#` bucket renders LAST when present. %>
    <% if @letter_buckets.any? %>
      <hr class="hairline">
      <%= render "games/letter_shelves", buckets: @letter_buckets %>
    <% end %>
  <% else %>
    <p class="text-muted">no games yet. press <span class="keycap">i</span> or click [+] to add one from igdb.</p>
  <% end %>
</div>
