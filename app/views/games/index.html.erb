<%# Phase 14 §3 — Steam-shelf rewrite of `/games`.
    - Bundles shelf at the top (only when Bundle.exists?).
    - Recently-played shelf (games with `played_at` set).
    - Per-genre shelves (limit GENRE_SHELF_CAP genres × 12 games).
    - Per-platform shelves (one per Platform with an active ownership
      row — see `game_platform_ownerships`, Phase 27 §1a).
    - All-games grid at the bottom; filterable via
      `/games?genre=<id-or-slug>` / `/games?platform_owned=<id-or-slug>`.

    Each shelf is a `<section class="shelf">` carrying the
    `steam-shelf` Stimulus controller for drag-scroll +
    mouse-wheel-to-horizontal scroll.

    Phase 14 §1 polish (2026-05-10) — the inline IGDB type-ahead
    `_add_form` partial was retired. The H1 now carries a `[+]`
    bracketed link (`channels` / `videos` parity) that opens the
    layout-level IGDB-search modal (`shared/_igdb_search_modal`).
    The same modal is reachable from anywhere via the `i` keypress. %>
<% content_for(:title, "games") %>

<div style="max-width: 1100px;">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <div class="dot-list">
      <h1>games</h1>
      <%= render(BracketedLinkComponent.new(
            label: "+",
            href: "#",
            data: {
              controller: "modal-trigger",
              action: "click->modal-trigger#open",
              modal_trigger_target_id_value: "igdb-search-modal"
            }
          )) %>
    </div>

    <%# Phase 27 §01d — display mode switcher, flush right of the H1.
        Three bracketed-link button_to forms PATCH `/users/games_preferences`
        to persist the choice; the controller redirects to
        `/games?display=<mode>` so the same render reflects the chosen mode
        immediately. %>
    <div style="margin-left: auto;">
      <%= render "games/display_mode_switcher", active_mode: @display_mode %>
    </div>
  </div>

  <%# Phase 27 §01c-v2 — Genres + Custom collections shelves render
      above everything else (and above the Phase 27 §01b filter row).
      Both shelves are nested (outer shelf iterates per-genre /
      per-collection sub-shelves of game-cover tiles). Empty buckets
      are hidden — the partial only renders when at least one bucket
      has games. %>
  <%= render "games/genres_shelf", genres: @genres_for_shelf %>
  <%= render "games/collections_shelf", collections: @collections_for_shelf %>

  <%# Phase 27 §01b — filter row sits BELOW the shelves and ABOVE the
      main listing. Chip clicks toggle tokens in the `?filters=` CSV
      URL param; `[clear all]` clears the set while preserving
      `?genre=`, `?collection=`, and `?display=` overrides. %>
  <%= render Games::FilterRowComponent.new(
        active_tokens:          @filter_tokens,
        dropped_tokens:         @dropped_filter_tokens,
        request_path:           games_path,
        query_string_overrides: { genre:      params[:genre],
                                  collection: params[:collection],
                                  display:    params[:display] }.compact_blank,
        contradiction:          @filter_contradiction
      ) %>

  <% has_any_shelf = @bundles_shelf.any? || @recently_played.any? ||
                     @genres_shelves.any? || @platforms_shelves.any? ||
                     @all_games.any? %>

  <% if has_any_shelf %>
    <% if @bundles_shelf.any? %>
      <%= render "games/shelf",
                 title: "bundles",
                 collection: @bundles_shelf,
                 tile_partial: "bundles/tile",
                 more_link: bundles_path %>
    <% end %>

    <% if @recently_played.any? %>
      <%= render "games/shelf",
                 title: "recently played",
                 collection: @recently_played,
                 tile_partial: "games/tile" %>
    <% end %>

    <% @genres_shelves.each do |(genre, games)| %>
      <%= render "games/shelf",
                 title: genre_short_name(genre).to_s.downcase,
                 collection: games,
                 tile_partial: "games/tile",
                 more_link: games_path(genre: genre.id) %>
    <% end %>

    <% @platforms_shelves.each do |(platform, games)| %>
      <%= render "games/shelf",
                 title: platform.name.downcase,
                 collection: games,
                 tile_partial: "games/tile",
                 more_link: games_path(platform_owned: platform.id) %>
    <% end %>

    <%# Phase 27 §01d — display-mode partition for the all-games surface.
        The resolved mode (`@display_mode`) drives which partial renders.
        Grid is the legacy / default tile grid; list is the alpha-grouped
        sortable table; shelves_by_letter is one horizontal shelf per
        first-letter bucket. The switcher above persists the choice. %>
    <% case @display_mode %>
    <% when :list %>
      <%= render "games/list_mode", games: @all_games %>
    <% when :shelves_by_letter %>
      <%= render "games/shelves_by_letter_mode", games: @all_games %>
    <% else %>
      <%= render "games/grid_mode", games: @all_games %>
    <% end %>
  <% else %>
    <p class="text-muted">no games yet. press <span class="keycap">i</span> or click [+] to add one from igdb.</p>
  <% end %>
</div>
