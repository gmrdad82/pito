<%# Games screen v1 layout shell (2026-05-25).
    2-row CSS Grid using `.home-grid.games-grid`:
      Row 1 (40/60): games releasing (upcoming owned) | top games
      Row 2 (library): full-width cell with nested rows:
        Row 2A (60/40): genres | bundles
        Row 2B (full):  library table

    The existing turbo_stream_from, filter row, omnisearch modals, and
    games_listing turbo frame are preserved below the grid for
    compatibility with the current controller + IGDB add flow. They are
    intentionally invisible in this shell — a future dispatch will
    migrate that surface into the TableSubPanelComponent (Row 2B). %>
<% content_for(:title, t("games.index.title")) %>

<%# Live refresh subscription — see original view comment for details. %>
<%= turbo_stream_from "games" %>

<div class="pito-workspace home-grid games-grid" data-controller="tui-cursor">
  <%# Row 1 — 40/60 split: upcoming releases + top games. %>
  <div class="home-row home-row--40-60">
    <%= render Pito::GamesReleasingPanelComponent.new %>
    <%= render Pito::TopGamesPanelComponent.new %>
  </div>

  <%# Row 2 — library row. Full-width grid cell containing two nested
      sub-rows rendered via `.games-library-row`. %>
  <div class="games-library-row">
    <%# Row 2A — 60/40: genres (left) + bundles (right). %>
    <div class="games-library-row__top">
      <%= render Pito::Games::GenresPanelComponent.new %>
      <%= render Pito::Games::BundlesPanelComponent.new %>
    </div>

    <%# Row 2B — full width: library table. %>
    <div class="games-library-row__bottom">
      <%= render Pito::Games::TableSubPanelComponent.new %>
    </div>
  </div>
</div>

<%# ============================================================
    Legacy filter + listing surface — preserved for the IGDB add
    flow and games_listing turbo frame. Rendered off-screen until
    the TableSubPanelComponent dispatch migrates this content.
    ============================================================ %>
<div style="display: none;" aria-hidden="true">
  <%= render Game::FilterRowComponent.new(
        checked_tokens: @checked_tokens,
        request_path:   games_path
      ) %>

  <%= turbo_frame_tag "games_listing" do %>
    <% has_any_listing_content = @recently_played.any? ||
                                 @genres_for_shelf.any? ||
                                 @letter_buckets.any? %>

    <% if @recently_played.any? %>
      <%= render(::ShelfComponent.new(
            heading: t("games.index.recently_played_heading"),
            show_count: false,
            heading_level: :h2,
            row_gap: "8px"
          )) do %>
        <% @recently_played.each do |game| %>
          <%= render(Game::GameTileComponent.new(game: game, variant: :grid)) %>
        <% end %>
      <% end %>
    <% end %>

    <% if @genres_for_shelf.any? %>
      <hr class="hairline">
      <%= render "games/genres_shelf", genres: @genres_for_shelf %>
    <% end %>

    <% if @bundles_for_shelf.any? || params[:filters].nil? %>
      <hr class="hairline">
      <%= render "games/bundles_for_shelf", bundles: @bundles_for_shelf %>
    <% end %>

    <% if @letter_buckets.any? %>
      <hr class="hairline">
      <%= render "games/letter_shelves", buckets: @letter_buckets %>
    <% end %>

    <% unless has_any_listing_content %>
      <p class="text-muted" style="margin: 16px 0 0;"><%= t("games.index.no_matches") %></p>
    <% end %>
  <% end %>
</div>

<%# Omnisearch modals — must remain in the DOM for the IGDB add-game
    flow ([+] in the title row) and the / search keybind. %>
<%= render Search::OmnisearchModalComponent.new(
      mode: :games_search,
      dialog_id: "omnisearch-modal-games-search",
      url: omnisearch_games_path,
      placeholder: t("games.omnisearch.placeholder"),
      results_frame_id: "omnisearch_results_games_search"
    ) %>

<%= render Search::OmnisearchModalComponent.new(
      mode: :game_index,
      dialog_id: "omnisearch-modal-games-index",
      url: search_games_path,
      placeholder: t("games.search.placeholder_igdb"),
      results_frame_id: "igdb_search_results"
    ) %>
