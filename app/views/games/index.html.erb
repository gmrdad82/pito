<% content_for(:title, "games") %>

<div style="max-width: 1100px;">
  <div class="dot-list" style="margin-bottom: 6px;">
    <h1>games</h1>
    <%= button_to games_path, form: { style: "display: inline;", data: { turbo: false } }, class: "bracketed", method: :post do %>[<span class="bl">+</span>]<% end %>
  </div>

  <%= render "add_form" %>

  <% if @games.any? %>
    <table>
      <thead>
        <tr>
          <th class="col-action"></th>
          <th>title</th>
          <th>release</th>
          <th>rating</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @games.each do |game| %>
          <tr>
            <td class="col-action">
              <%= render(BracketedLinkComponent.new(label: "o", href: game_path(game))) %>
            </td>
            <td><%= game.title %></td>
            <td><%= game.release_year || "—" %></td>
            <td><%= game.igdb_rating ? "#{game.igdb_rating.to_i} / 100" : "—" %></td>
            <td>
              <% if game.igdb_id.present? %>
                <%= button_to "[resync]", resync_game_path(game),
                              method: :post,
                              class: "bracketed",
                              form: { style: "display: inline; margin: 0;", data: { turbo: false } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no games yet. [search igdb] to add one.</p>
  <% end %>
</div>
