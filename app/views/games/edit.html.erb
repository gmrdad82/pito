<%# Phase 14 §1 polish (2026-05-10) — game edit page. The form
    that used to live inline on `show.html.erb` moved here so the
    show page reads as canonical read-only metadata. Layout matches
    the show page (narrow cover pane + wide form pane) so the
    transition reads as "same page, the right column is now
    editable".
    NO sync pane. NO linked videos. NO `[resync]`. The `[edit]` /
    `[-]` strip on the show page is what carries the user here;
    here, the breadcrumb is `games / <title> / edit` and the
    bottom of the form carries `[update]` / `[cancel]`.
%>
<% content_for(:title, "edit #{@game.title}") %>
<% breadcrumb([ "games", games_path ], [ @game.title, game_path(@game) ], "edit") %>

<div class="pane-row">
  <div class="pane pane--narrow">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>
    <p class="text-muted" style="margin: 0 0 8px 0;">
      <% if @game.release_year %><%= @game.release_year %><% else %>—<% end %>
      <% developer_names = @game.developers.map(&:name) %>
      <% if developer_names.any? %> &middot; dev: <%= developer_names.join(", ") %><% end %>
    </p>
  </div>

  <div class="pane pane--wide">
    <h2 style="margin-top: 0;">local fields</h2>
    <%= form_with(model: @game, url: game_path(@game), method: :patch) do |f| %>
      <% if @game.errors.any? %>
        <div class="text-danger" style="margin: 0 0 12px 0;">
          <% @game.errors.full_messages.each do |msg| %>
            <p style="margin: 0;"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <table class="detail-table" style="margin-bottom: 12px;">
        <%# Phase 27 §1a — `platform_owned_id` is gone. Per-platform
            ownership lives in `game_platform_ownerships` and is edited
            from `01f`'s dedicated editor (linked from the show page).
            The edit page only carries the remaining local-only fields. %>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">played on</td>
          <td><%= f.date_field :played_at %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">notes</td>
          <td><%= f.text_area :notes, rows: 6, style: "width: 100%; max-width: 380px;" %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">footage hours (manual)</td>
          <td>
            <%= f.number_field :hours_of_footage_manual, min: 0, style: "width: 80px;" %>
            <span class="text-muted" style="font-size: 11px;">leave blank to compute from linked videos.</span>
          </td>
        </tr>
        <%# Phase 28 §01a — version-grouping fields. The picker resolves
            a `version_parent_id` (integer) via typeahead; `version_title`
            is a free-text label ("Deluxe", "Standard", "Game of the
            Year"). Disabled when the row has editions of its own. %>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">version of</td>
          <td>
            <%= render(Games::VersionParentPickerComponent.new(game: @game, form: f)) %>
          </td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">version title</td>
          <td>
            <%= f.text_field :version_title,
                             maxlength: 100,
                             placeholder: 'e.g. "Deluxe", "Standard", "Game of the Year"',
                             style: "width: 100%; max-width: 380px;" %>
          </td>
        </tr>
      </table>

      <div class="dot-list">
        <button type="submit" class="bracketed" style="background: none; border: none; padding: 0; cursor: pointer;">[<span class="bl">update</span>]</button>
        <%= render(BracketedLinkComponent.new(label: "cancel", href: game_path(@game))) %>
      </div>
    <% end %>
  </div>
</div>
