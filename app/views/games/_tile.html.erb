<%# Phase 14 §3 — single game tile (Steam-shelf shape).
    Phase 27 metadata refresh — two explicit caption lines below the
    cover art:

      line 1: title, single line, ellipsis-truncated to the cover width.
              Rendered in BOLD when the game is not yet released
              (release_date nil or in the future) per the 2026-05-11
              polish pass (Fix 6).
      line 2: `<NN> · <YYYY>` — rating + year, middle-dot separator.
              2026-05-11 polish (Fix 2): the legacy `/100` suffix was
              retired in favor of the colored bold
              `Games::RatingBadgeComponent` (the rating segment now
              carries a per-tier color). Missing pieces drop out
              gracefully.

    Locals:
      item or game  the Game record (the partial accepts either local
                    via the `as:` collection rendering convention).
      variant       optional, :grid (default) or :shelf. The shelf
                    variant trims the caption font slightly (matches
                    the smaller `Games::CoverComponent` :shelf footprint
                    when it lands at a callsite that opts in). All
                    existing callsites omit this and inherit the :grid
                    default, so this is a pure-additive change.

    Bracketed-link convention applies to the title (the whole tile is
    a link, but the design system expects a bracketed legend on hover).
%>
<%
  game     = local_assigns[:game] || local_assigns[:item]
  variant  = (local_assigns[:variant] || :grid).to_sym
  rating_present = game.igdb_rating.present?
  release_year_str = game.release_year.presence&.to_s
  has_meta = rating_present || release_year_str.present?
  meta_line = game_meta_line(game) # legacy plain-text shape for the title attribute

  # 2026-05-11 polish (Fix 6) — a game is "not yet released" when its
  # `release_date` is nil OR in the future. The title renders bold via
  # the `.not-released` class so the workspace surfaces upcoming
  # entries at a glance.
  not_released = game.release_date.blank? || game.release_date > Date.current

  # Variant-keyed caption typography. Cover width stays 150px on both
  # variants because the existing surrounding containers size the slot;
  # only the font size changes (per the spec's "same layout, just
  # smaller font on the shelf variant" directive).
  caption_font_size = variant == :shelf ? "10px" : "11px"
  meta_font_size    = variant == :shelf ?  "9px" : "10px"

  # Hover/native title attribute keeps the legacy single-line caption
  # so screen readers and tooltip-on-truncation surfaces still see the
  # full string.
  title_attr_parts = [ game.title ]
  title_attr_parts << meta_line if meta_line.present?
  title_attr = title_attr_parts.join(" — ")
%>
<%# `data-keyboard-tile` opts each tile into the global keyboard
    controller's tile-grid navigation when the surrounding container
    declares `data-keyboard-grid="true"` (the all-games grid on
    `/games` and the bundles grid on `/bundles`; the horizontally
    scrolling shelves do NOT opt in). The geometry-driven row
    computation in `keyboard_controller.js#moveTileGrid` walks tiles
    by `getBoundingClientRect()` so the same partial works at any
    `repeat(auto-fill, minmax(...))` column count. %>
<a href="<%= game_path(game) %>" class="tile tile--<%= variant %>"
   style="flex: 0 0 150px; width: 150px; display: block; text-decoration: none; color: inherit; cursor: pointer;"
   data-tile-game-id="<%= game.id %>"
   data-variant="<%= variant %>"
   data-keyboard-tile
   title="<%= title_attr %>">
  <div class="tile-cover" style="position: relative; width: 150px; height: 200px; overflow: hidden; background: var(--color-bg); display: flex; align-items: center; justify-content: center;">
    <% if game.cover_url.present? %>
      <%= image_tag game.cover_url(size: "t_cover_big"),
                    alt: game.title, loading: "lazy",
                    style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
    <% else %>
      <%# 2026-05-11 polish (Fix 7) — theme-aware fallback. Both SVGs
          are absolutely positioned to occupy the same 150x200 slot,
          and inline `display` is omitted on the fallback `<img>`
          tags so the `.game-cover-fallback--{light,dark}` class
          rules in `application.css` win the cascade (no inline-style
          override). The off-theme variant is hidden via
          `display: none`; the active variant inherits the default
          `display: inline` of `<img>`, which is enough since
          `position: absolute; inset: 0;` sizes it to the slot. The
          dual-stacked artefact (two fallback SVGs rendering on top of
          each other) is gone. %>
      <%= image_tag image_path("game_cover_fallback_grid_light.svg"),
                    alt: "no cover available", loading: "lazy",
                    width: 150, height: 200,
                    data: { theme: "light" },
                    class: "game-cover-fallback game-cover-fallback--light",
                    style: "position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" %>
      <%= image_tag image_path("game_cover_fallback_grid_dark.svg"),
                    alt: "no cover available", loading: "lazy",
                    width: 150, height: 200,
                    data: { theme: "dark" },
                    class: "game-cover-fallback game-cover-fallback--dark",
                    style: "position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;" %>
    <% end %>
  </div>
  <div class="tile-caption" style="padding: 4px 0 0 0; font-size: <%= caption_font_size %>; max-width: 150px;">
    <%# Phase 28 §01a — when an edition tile is rendered in flat mode
        (`?include_editions=yes`), show a muted parent pointer above
        the title so the user can navigate up to the primary. %>
    <% if game.edition? && game.version_parent.present? %>
      <div class="tile-caption-parent-pointer text-muted"
           style="font-size: <%= meta_font_size %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
        ↳ <%= game.version_parent.title %>
      </div>
    <% end %>
    <div class="tile-caption-title<%= " not-released" if not_released %>"
         style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;<%= " font-weight: bold;" if not_released %>">
      <%= game.title %>
    </div>
    <% if has_meta %>
      <%# Fix 2 (2026-05-11) — rating segment carries the per-tier
          colored bold badge. Year stays muted plain text. The line
          renders the same `<rating> · <year>` shape; either side drops
          out cleanly when its source value is missing. %>
      <div class="tile-caption-meta text-muted"
           style="font-size: <%= meta_font_size %>; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">
        <% if rating_present %>
          <%= render(Games::RatingBadgeComponent.new(rating: game.igdb_rating)) %>
        <% end %>
        <% if rating_present && release_year_str.present? %>
          <span aria-hidden="true">·</span>
        <% end %>
        <% if release_year_str.present? %>
          <%= release_year_str %>
        <% end %>
      </div>
    <% end %>
    <%# Phase 28 §01a — `+N editions` badge on primary tiles with at
        least one edition. The outer tile is already wrapped in an
        anchor, so the badge renders bare (no nested link). %>
    <% if game.primary? %>
      <div class="tile-caption-editions-badge"
           style="font-size: <%= meta_font_size %>; margin-top: 2px;">
        <%= render(Games::EditionsBadgeComponent.new(game: game, bare: true)) %>
      </div>
    <% end %>
  </div>
</a>
