<%# Phase 27 v2 spec 05 — letter-shelf iteration on `/games`.

    One shelf per non-empty letter bucket. Buckets arrive in render
    order from the controller's `build_letter_buckets` (A..Z first,
    `#` last). The heading is the bucket key uppercased (already done
    in the controller). Tiles render through `Games::GameTileComponent`
    at the `:shelf` variant; shelf chrome (heading + count badge +
    horizontal scroll row + `steam-shelf` controller) is emitted by
    `Games::ShelfComponent`.

    Locals:
      buckets  Array of `[letter, [Game, ...]]` tuples. Empty buckets
               are NOT present (the controller filtered them out).
%>
<%
  buckets = local_assigns.fetch(:buckets, [])
%>
<% if buckets.any? %>
  <%# 2026-05-17 (Wave F consolidation) — the wrapper no longer sets
      `margin-top: 12px`; the first letter shelf inside it inherits
      the shared `.shelf { margin-top: 16px }` default (see
      `app/assets/tailwind/application.css`) and subsequent shelves
      are tightened to `8px` by the hairline rule
      `.games-shelves-by-letter-mode > section[data-shelf="letter"]:not(:first-of-type)`. %>
  <section class="all-games-shelves-by-letter games-shelves-by-letter-mode">
    <% buckets.each do |(letter, games)| %>
      <% next if games.empty? %>
      <%= render(Games::ShelfComponent.new(
            heading: letter,
            count: games.size,
            heading_level: :h3,
            extra_classes: "shelf--letter",
            shelf_kind: "letter",
            data: { letter: letter },
            row_classes: "letter-shelf-row"
          )) do %>
        <% games.each do |game| %>
          <%= render(Games::GameTileComponent.new(game: game, variant: :shelf)) %>
        <% end %>
      <% end %>
    <% end %>
  </section>
<% end %>
