<%# Phase 27 — 01d. Grid display mode (default).
    The original Steam-shelf all-games grid extracted into its own
    partial so `games/index.html.erb` can branch by display mode.

    Locals:
      games  enumerable of Game records (typically @all_games).

    `data-keyboard-grid="true"` opts this tile grid into the global
    keyboard controller's grid navigation (j/k between rows, h/l
    within row). Each tile renders `data-keyboard-tile`. The
    surrounding shelves above intentionally stay opt-out — they have
    their own drag-scroll affordance.
%>
<section class="shelf all-games-grid games-grid-mode"
         data-display-mode="grid"
         style="margin-top: 24px;">
  <h2 style="margin-bottom: 8px;">all</h2>
  <% if games.any? %>
    <div class="grid"
         data-keyboard-grid="true"
         style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px;">
      <% games.each do |game| %>
        <%= render "games/tile", game: game %>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">no games match this filter.</p>
  <% end %>
</section>
