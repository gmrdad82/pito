<%# Phase 14 §1 polish (2026-05-10) — game show page revamped to a
    READ-ONLY surface. The inline form moved to `/games/:id/edit`.
    Layout is three rows of `.pane-row`s:
      Row 1 — narrow cover pane + wide read-only metadata pane.
      Row 2 — wide standalone sync pane (status + animated indicator
              while the resync job is in flight, `[resync]` link
              otherwise).
      Row 3 — wide linked-videos pane.
    The breadcrumb-action strip carries `[edit]` and `[-]` (delete);
    `[resync]` is NOT in the breadcrumb action strip — it lives
    inside the sync pane so the moving indicator can replace it
    without re-flowing the breadcrumb. The muted re-sync caveat
    reads one sentence per line per the lead-paragraph rule.
%>
<% content_for(:title, @game.title) %>
<% breadcrumb(["games", games_path], @game.title) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "edit", href: edit_game_path(@game))) %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/game/#{@game.id}", destructive: true)) %>
  </div>
<% end %>

<% if @game.resyncing? %>
  <%# Auto-refresh fallback. While the resync flag is set we reload
      every ~5s so the show page picks up the cleared flag without a
      manual refresh. The controller no-ops once the next render
      drops it (because the wrapper div is conditional on
      `resyncing?`). %>
  <div data-controller="auto-refresh"
       data-auto-refresh-interval-value="5000"
       style="display: none;"></div>
<% end %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. The wrapper is invisible (display: contents)
    so it does not affect the existing flex / pane layout below. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@game, scope: Game, path_helper: method(:game_path)) %>></div>

<%# Row 1 — cover + read-only metadata. The `pane-row--game-show`
    modifier flips this specific row to `flex-wrap: nowrap` so the
    280px cover and 640px details panes stay side-by-side at standard
    workspace widths instead of stacking. Narrower viewports get a
    horizontal scrollbar instead of wrap. Rows 2 (sync) and 3 (linked
    videos) keep the default `.pane-row` (single wide pane each, no
    wrap concern).
%>
<div class="pane-row pane-row--game-show">
  <div class="pane pane--narrow">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>
    <%# Meta block: one label per line. Skip lines whose value is
        missing entirely (no `pub: —` placeholder). Uses `<br>`
        between lines inside one `<p class="text-muted">` so the
        existing margin / lead-paragraph styling holds. %>
    <%
      meta_lines = []
      meta_lines << "released: #{@game.release_year}" if @game.release_year
      developer_names = @game.developers.map(&:name)
      meta_lines << "dev: #{developer_names.join(", ")}" if developer_names.any?
      publisher_names = @game.publishers.map(&:name)
      meta_lines << "pub: #{publisher_names.join(", ")}" if publisher_names.any?
    %>
    <% if meta_lines.any? %>
      <p class="text-muted" style="margin: 0 0 8px 0;">
        <%= safe_join(meta_lines, tag.br) %>
      </p>
    <% end %>
  </div>

  <div class="pane pane--game-detail">
    <% if @game.last_sync_error.present? %>
      <p class="text-danger" style="margin: 0 0 8px 0;">igdb error: <%= @game.last_sync_error %></p>
    <% end %>

    <h2 style="margin-top: 0;">ratings</h2>
    <table class="detail-table">
      <tr>
        <td class="text-muted" style="padding-right: 12px;">igdb</td>
        <td><%= @game.igdb_rating ? "#{@game.igdb_rating.to_i} / 100 (#{@game.igdb_rating_count.to_i} votes)" : "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">aggregated</td>
        <td><%= @game.aggregated_rating ? "#{@game.aggregated_rating.to_i} / 100 (#{@game.aggregated_rating_count.to_i} votes)" : "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">total</td>
        <td><%= @game.total_rating ? "#{@game.total_rating.to_i} / 100 (#{@game.total_rating_count.to_i} votes)" : "—" %></td>
      </tr>
    </table>

    <h2 style="margin-top: 16px;">time to beat</h2>
    <table class="detail-table">
      <tr><td class="text-muted" style="padding-right: 12px;">main</td><td><%= format_seconds(@game.ttb_main_seconds) %></td></tr>
      <tr><td class="text-muted" style="padding-right: 12px;">extras</td><td><%= format_seconds(@game.ttb_extras_seconds) %></td></tr>
      <tr><td class="text-muted" style="padding-right: 12px;">completionist</td><td><%= format_seconds(@game.ttb_completionist_seconds) %></td></tr>
    </table>

    <h2 style="margin-top: 16px;">genres / platforms</h2>
    <p>
      <span class="text-muted">genres:</span> <%= @game.genres.map(&:name).join(", ").presence || "—" %><br>
      <span class="text-muted">platforms:</span> <%= @game.platforms_available.map(&:name).join(", ").presence || "—" %>
    </p>

    <%# External store links. `[open on igdb]` was retired per spec —
        only the platform-store links remain. %>
    <% if @game.external_steam_app_id.present? || @game.external_gog_id.present? || @game.external_epic_id.present? %>
      <h2 style="margin-top: 16px;">stores</h2>
      <div class="dot-list">
        <% if @game.external_steam_app_id.present? %>
          <%= render(BracketedLinkComponent.new(label: "steam",
                                                href: "https://store.steampowered.com/app/#{@game.external_steam_app_id}/",
                                                target: "_blank",
                                                rel: "noopener")) %>
        <% end %>
        <% if @game.external_gog_id.present? %>
          <%= render(BracketedLinkComponent.new(label: "gog",
                                                href: "https://www.gog.com/game/#{@game.external_gog_id}",
                                                target: "_blank",
                                                rel: "noopener")) %>
        <% end %>
        <% if @game.external_epic_id.present? %>
          <%= render(BracketedLinkComponent.new(label: "epic",
                                                href: "https://store.epicgames.com/p/#{@game.external_epic_id}",
                                                target: "_blank",
                                                rel: "noopener")) %>
        <% end %>
      </div>
    <% end %>

    <% if @game.summary.present? %>
      <h2 style="margin-top: 16px;">summary</h2>
      <p style="white-space: pre-line;"><%= @game.summary %></p>
    <% end %>

    <h2 style="margin-top: 16px;">local fields</h2>
    <table class="detail-table">
      <%# Phase 27 §1a — per-platform ownership now lives in the
          `game_platform_ownerships` join (multi-valued). The dedicated
          ownership editor lands in `01f`; while that's in flight, the
          show page lists owned platforms inline so the user can still
          see what they own this game on. %>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">owned on</td>
        <td><%= @game.owned_platforms.map(&:name).presence&.join(", ") || "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">played on</td>
        <td><%= @game.played_at&.to_fs(:long) || "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">notes</td>
        <td style="white-space: pre-line;"><%= @game.notes.presence || "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">footage hours</td>
        <td>
          <%= @game.hours_of_footage.presence || "—" %>
          <% if @game.hours_of_footage_manual.present? %>
            <span class="text-muted" style="font-size: 11px;">(manual override)</span>
          <% end %>
        </td>
      </tr>
    </table>
  </div>
</div>

<%# Row 2 — combined sync state pane (heading + last-synced + caveat
    + [resync] button OR animated indicator). Standalone wide pane
    so the indicator has breathing room and the caveat keeps its
    one-sentence-per-line shape.
%>
<div class="pane-row">
  <div class="pane pane--wide">
    <h2 style="margin-top: 0;">sync</h2>
    <p class="text-muted" style="margin: 0 0 8px 0;">
      <% if @game.igdb_synced_at.present? %>
        synced <%= time_ago_in_words(@game.igdb_synced_at) %> ago.
      <% else %>
        not synced yet.
      <% end %>
    </p>
    <p class="text-muted" style="margin: 0 0 12px 0; font-size: 11px;">
      re-syncing overwrites igdb-sourced fields.<br>
      local notes, played-on, footage hours, and platform-owned survive.
    </p>

    <% if @game.resyncing? %>
      <span data-controller="sync-indicator"
            data-sync-indicator-frames-value='["=---","-=--","--=-","---="]'
            data-sync-indicator-interval-value="200"
            class="sync-indicator"
            style="font-family: var(--font-mono); letter-spacing: 0.1em;">=---</span>
    <% elsif @game.igdb_id.present? %>
      <%= button_to resync_game_path(@game),
                    method: :post,
                    class: "bracketed",
                    form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl">resync</span>]<% end %>
    <% end %>
  </div>
</div>

<%# Row 3 — linked videos. Standalone wide pane so each title row
    can breathe horizontally; this matches the bundle show page's
    members list rhythm.
%>
<div class="pane-row">
  <div class="pane pane--wide">
    <h2 style="margin-top: 0;">linked videos</h2>
    <% game_links = @game.video_game_links.includes(:video).order(:id) %>
    <% if game_links.any? %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% game_links.each do |link| %>
          <% next unless link.video %>
          <li style="padding: 2px 0;">
            <%= link_to link.video.title.presence || link.video.youtube_video_id, video_path(link.video) %>
            <% if link.is_primary? %>
              <span class="bracketed-active">[★]</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted" style="margin: 0;">no linked videos yet.</p>
    <% end %>
  </div>
</div>
