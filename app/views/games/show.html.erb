<%# Phase 14 §1 polish (2026-05-10) — game show page revamped to a
    READ-ONLY surface. The inline form moved to `/games/:id/edit`.
    Layout is three rows of `.pane-row`s:
      Row 1 — narrow cover pane + wide read-only metadata pane.
      Row 2 — wide standalone sync pane (status + animated indicator
              while the resync job is in flight, `[resync]` link
              otherwise).
      Row 3 — wide linked-videos pane.
    The breadcrumb-action strip carries `[edit]` and `[-]` (delete);
    `[resync]` is NOT in the breadcrumb action strip — it lives
    inside the sync pane so the moving indicator can replace it
    without re-flowing the breadcrumb. The muted re-sync caveat
    reads one sentence per line per the lead-paragraph rule.
%>
<% content_for(:title, @game.title) %>
<% breadcrumb(["games", games_path], @game.title) %>

<%# Phase 27 v2 spec 03 — permanent Turbo-Stream subscription so the
    sync-status pane swaps live whenever a resync starts / finishes
    (whether triggered by this tab, the CLI, MCP, or another browser
    tab). The `GameResyncJob` broadcasts a replace of
    `game_sync_status_<id>` on the `"game_resync:<id>"` stream. %>
<%= turbo_stream_from "game_resync:#{@game.id}" %>

<%# Phase 28 §01a — muted parent pointer for editions. Bracketed link
    above the page chrome so the user can hop up to the primary's show
    page. Rendered only when the row is an edition AND the pointer
    resolves (a row in mid-detach renders no pointer). %>
<% if @game.edition? && @game.version_parent.present? %>
  <p class="text-muted edition-parent-pointer" style="margin: 0 0 8px 0;">
    <%= render(BracketedLinkComponent.new(
          label: "↳ #{@game.version_parent.title}",
          href: game_path(@game.version_parent))) %>
  </p>
<% end %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "edit", href: edit_game_path(@game))) %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/game/#{@game.id}", destructive: true)) %>
  </div>
<% end %>

<% if @game.resyncing? %>
  <%# Auto-refresh fallback. While the resync flag is set we reload
      every ~5s so the show page picks up the cleared flag without a
      manual refresh. The controller no-ops once the next render
      drops it (because the wrapper div is conditional on
      `resyncing?`). %>
  <div data-controller="auto-refresh"
       data-auto-refresh-interval-value="5000"
       style="display: none;"></div>
<% end %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. The wrapper is invisible (display: contents)
    so it does not affect the existing flex / pane layout below. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@game, scope: Game, path_helper: method(:game_path)) %>></div>

<%# Row 1 — cover + read-only metadata. The `pane-row--game-show`
    modifier flips this specific row to `flex-wrap: nowrap` so the
    280px cover and 640px details panes stay side-by-side at standard
    workspace widths instead of stacking. Narrower viewports get a
    horizontal scrollbar instead of wrap. Rows 2 (sync) and 3 (linked
    videos) keep the default `.pane-row` (single wide pane each, no
    wrap concern).
%>
<div class="pane-row pane-row--game-show">
  <div class="pane pane--narrow">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>
    <%# Meta block: one label per line. Skip lines whose value is
        missing entirely (no `pub: —` placeholder). Uses `<br>`
        between lines inside one `<p class="text-muted">` so the
        existing margin / lead-paragraph styling holds. %>
    <%
      # 2026-05-11 polish (Fix 3) — the `released:` line now renders
      # the full date in `MM-DD-YYYY` format (was previously the year
      # only). The label is suppressed entirely when `release_date`
      # is nil — there is no `released: —` placeholder.
      meta_lines = []
      if @game.release_date.present?
        meta_lines << "released: #{@game.release_date.strftime("%m-%d-%Y")}"
      end
      developer_names = @game.developers.map(&:name)
      meta_lines << "dev: #{developer_names.join(", ")}" if developer_names.any?
      publisher_names = @game.publishers.map(&:name)
      meta_lines << "pub: #{publisher_names.join(", ")}" if publisher_names.any?
    %>
    <% if meta_lines.any? %>
      <p class="text-muted" style="margin: 0 0 8px 0;">
        <%= safe_join(meta_lines, tag.br) %>
      </p>
    <% end %>
  </div>

  <div class="pane pane--game-detail">
    <% if @game.last_sync_error.present? %>
      <p class="text-danger" style="margin: 0 0 8px 0;">igdb error: <%= @game.last_sync_error %></p>
    <% end %>

    <h2 style="margin-top: 0;">ratings</h2>
    <%# 2026-05-11 polish (Fix 2) — the `/ 100` literal is gone from
        every rating cell. Each row renders the colored bold badge
        followed by the vote count. Missing ratings render the badge's
        muted em-dash in place of the integer. %>
    <table class="detail-table">
      <tr>
        <td class="text-muted" style="padding-right: 12px;">igdb</td>
        <td>
          <%= render(Games::RatingBadgeComponent.new(rating: @game.igdb_rating)) %>
          <% if @game.igdb_rating %>
            <span class="text-muted">(<%= @game.igdb_rating_count.to_i %> votes)</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">aggregated</td>
        <td>
          <%= render(Games::RatingBadgeComponent.new(rating: @game.aggregated_rating)) %>
          <% if @game.aggregated_rating %>
            <span class="text-muted">(<%= @game.aggregated_rating_count.to_i %> votes)</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">total</td>
        <td>
          <%= render(Games::RatingBadgeComponent.new(rating: @game.total_rating)) %>
          <% if @game.total_rating %>
            <span class="text-muted">(<%= @game.total_rating_count.to_i %> votes)</span>
          <% end %>
        </td>
      </tr>
    </table>

    <h2 style="margin-top: 16px;">time to beat</h2>
    <table class="detail-table">
      <tr><td class="text-muted" style="padding-right: 12px;">main</td><td><%= format_seconds(@game.ttb_main_seconds) %></td></tr>
      <tr><td class="text-muted" style="padding-right: 12px;">extras</td><td><%= format_seconds(@game.ttb_extras_seconds) %></td></tr>
      <tr><td class="text-muted" style="padding-right: 12px;">completionist</td><td><%= format_seconds(@game.ttb_completionist_seconds) %></td></tr>
    </table>

    <%# Phase 27 v2 spec 01 — single main genre per Game. The legacy
        comma-joined `@game.genres.map(&:name)` list is gone; the row
        renders ONE primary genre (or "—" when none has been picked
        yet). Spec 08 supersedes this layout entirely with the
        primary-bold / secondary-normal arrangement; until that ships,
        this interim guards the spec-01 single-genre rendering rule. %>
    <h2 style="margin-top: 16px;">genre / platforms</h2>
    <p>
      <span class="text-muted">genre:</span> <%= @game.primary_genre&.name.presence || "—" %><br>
      <span class="text-muted">platforms:</span> <%= display_platforms(@game) %>
    </p>

    <%# Phase 27 v2 spec 07 — platform logo row. Renders 0..3
        56-px favicons from the Rake-downloaded asset set, in the
        locked PS5 / Switch2 / Steam order (GoG + Epic collapsed
        into Steam per the 2026-05-17 PC store collapse). Empty list
        renders nothing — no placeholder block.

        v7 (theme-aware) — uses `platform_logo_tag` with `color: :auto`
        (default) so the helper emits both black + white variants and
        CSS picks the visible one off `<html data-theme>`. The 64-px
        asset is downloaded; the helper renders at 56 px via
        `display_size:` to keep high-DPI displays crisp. %>
    <% detail_logo_slugs = game_detail_logo_slugs(@game) %>
    <% if detail_logo_slugs.any? %>
      <div class="game-detail-platform-logos"
           style="display: flex; flex-direction: row; gap: 8px; align-items: center; margin: 8px 0 0 0;">
        <% detail_logo_slugs.each do |slug| %>
          <%= platform_logo_tag(slug, size: 64, display_size: 56) %>
        <% end %>
      </div>
    <% end %>

    <%# External store links. `[open on igdb]` was retired per spec —
        only the Steam store link remains (GoG + Epic collapsed into
        Steam per the 2026-05-17 PC store collapse; the IGDB GoG /
        Epic external ids are no longer mapped onto local columns).
        2026-05-16 polish — the component auto-detects external hrefs
        and applies `target="_blank" rel="noopener noreferrer"`;
        callers drop the explicit attrs. %>
    <% if @game.external_steam_app_id.present? %>
      <h2 style="margin-top: 16px;">stores</h2>
      <div class="dot-list">
        <%= render(BracketedLinkComponent.new(label: "steam",
                                              href: "https://store.steampowered.com/app/#{@game.external_steam_app_id}/")) %>
      </div>
    <% end %>

    <% if @game.summary.present? %>
      <h2 style="margin-top: 16px;">summary</h2>
      <p style="white-space: pre-line;"><%= @game.summary %></p>
    <% end %>

    <h2 style="margin-top: 16px;">local fields</h2>
    <table class="detail-table">
      <%# Phase 27 §1a + §01f — per-platform ownership chip list +
          link to the dedicated editor. The chip list renders one
          bracketed chip per owned platform (alphabetical); each
          chip links to the filtered `/games?filters=<slug>,owned`
          URL the 01b filter row consumes. The `[edit ownership]`
          link routes to the editor page. %>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">owned on</td>
        <td>
          <%= render(Games::OwnedPlatformsChipListComponent.new(game: @game)) %>
          &middot;
          <%= render(BracketedLinkComponent.new(label: "edit ownership",
                                                href: edit_game_platform_ownerships_path(@game))) %>
        </td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">played on</td>
        <td><%= @game.played_at&.to_fs(:long) || "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">notes</td>
        <td style="white-space: pre-line;"><%= @game.notes.presence || "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">footage hours</td>
        <td>
          <%= @game.hours_of_footage.presence || "—" %>
          <% if @game.hours_of_footage_manual.present? %>
            <span class="text-muted" style="font-size: 11px;">(manual override)</span>
          <% end %>
        </td>
      </tr>
    </table>
  </div>
</div>

<%# Row 2 — combined sync state pane (heading + last-synced + caveat
    + [resync] button OR animated indicator). Standalone wide pane
    so the indicator has breathing room and the caveat keeps its
    one-sentence-per-line shape. The pane body lives in the
    `games/_sync_status` partial so the `GameResyncJob` Turbo-Stream
    broadcast can replace it in place (target id
    `game_sync_status_<id>` on stream `game_resync:<id>`).
%>
<div class="pane-row">
  <div class="pane pane--wide">
    <%= render "sync_status", game: @game %>
  </div>
</div>

<%# Phase 28 §01a — editions sub-section. Rendered only when the
    game is a primary with at least one edition. Anchored `#editions`
    so the tile badge / list-mode badge can scroll-to. %>
<% if @game.primary? && @game.editions.exists? %>
  <div class="pane-row">
    <div class="pane pane--wide">
      <%= render(Games::EditionsSectionComponent.new(game: @game)) %>
    </div>
  </div>
<% end %>

<%# Row 3 — linked videos. Standalone wide pane so each title row
    can breathe horizontally; this matches the bundle show page's
    members list rhythm.
%>
<div class="pane-row">
  <div class="pane pane--wide">
    <h2 style="margin-top: 0;">linked videos</h2>
    <% game_links = @game.video_game_links.includes(:video).order(:id) %>
    <% if game_links.any? %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% game_links.each do |link| %>
          <% next unless link.video %>
          <li style="padding: 2px 0;">
            <%= link_to link.video.title.presence || link.video.youtube_video_id, video_path(link.video) %>
            <% if link.is_primary? %>
              <span class="bracketed-active">[★]</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted" style="margin: 0;">no linked videos yet.</p>
    <% end %>
  </div>
</div>
