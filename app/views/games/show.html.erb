<%# Phase 14 §1 polish (2026-05-10) — game show page revamped to the
    canonical two-pane layout used by channels/videos: detail (cover +
    breadcrumb-style identifier) on the left, IGDB metadata + local
    fields form + sync state on the right, both inside a `.pane-row`.
    Bracketed-link convention `[label]` (no inner spaces) applies. The
    muted re-sync caveat reads one sentence per line per the
    lead-paragraph rule. %>
<% content_for(:title, @game.title) %>
<% breadcrumb(["games", games_path], @game.title) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <% if @game.igdb_id.present? %>
      <%= button_to resync_game_path(@game),
                    method: :post,
                    class: "bracketed",
                    form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl">resync</span>]<% end %>
    <% end %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/game/#{@game.id}", destructive: true)) %>
  </div>
<% end %>

<div class="pane-row">
  <%# Left pane — cover art + heading + IGDB-side context. The cover
      fills the pane width (`max-width: 100%` is on the shared
      `_igdb_cover` partial) so the column reads as a Steam-style card. %>
  <div class="pane">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>
    <p class="text-muted" style="margin: 0 0 8px 0;">
      <% if @game.release_year %><%= @game.release_year %><% else %>—<% end %>
      <% developer_names = @game.developers.map(&:name) %>
      <% if developer_names.any? %> &middot; dev: <%= developer_names.join(", ") %><% end %>
      <% publisher_names = @game.publishers.map(&:name) %>
      <% if publisher_names.any? %> &middot; pub: <%= publisher_names.join(", ") %><% end %>
    </p>

    <div class="dot-list" style="margin-bottom: 8px;">
      <% if @game.igdb_slug.present? %>
        <%= render(BracketedLinkComponent.new(label: "open on igdb",
                                              href: "https://www.igdb.com/games/#{@game.igdb_slug}",
                                              target: "_blank",
                                              rel: "noopener")) %>
      <% end %>
      <% if @game.external_steam_app_id.present? %>
        <%= render(BracketedLinkComponent.new(label: "steam",
                                              href: "https://store.steampowered.com/app/#{@game.external_steam_app_id}/",
                                              target: "_blank",
                                              rel: "noopener")) %>
      <% end %>
      <% if @game.external_gog_id.present? %>
        <%= render(BracketedLinkComponent.new(label: "gog",
                                              href: "https://www.gog.com/game/#{@game.external_gog_id}",
                                              target: "_blank",
                                              rel: "noopener")) %>
      <% end %>
      <% if @game.external_epic_id.present? %>
        <%= render(BracketedLinkComponent.new(label: "epic",
                                              href: "https://store.epicgames.com/p/#{@game.external_epic_id}",
                                              target: "_blank",
                                              rel: "noopener")) %>
      <% end %>
    </div>

    <% if @game.summary.present? %>
      <h2 style="margin-top: 16px;">summary</h2>
      <p style="white-space: pre-line;"><%= @game.summary %></p>
    <% end %>
  </div>

  <%# Right pane — ratings, time-to-beat, genres / platforms, the local-
      fields form, and sync metadata. The re-sync caveat is split onto
      two lines via `<br>` to honor the one-sentence-per-line rule. %>
  <div class="pane">
    <p class="text-muted" style="margin: 0 0 8px 0; font-size: 11px;">
      re-syncing overwrites igdb-sourced fields.<br>
      local notes, played-on, footage hours, and platform-owned survive.
    </p>

    <% if @game.last_sync_error.present? %>
      <p class="text-danger" style="margin: 8px 0;">igdb error: <%= @game.last_sync_error %></p>
    <% end %>

    <h2 style="margin-top: 8px;">ratings</h2>
    <table class="detail-table">
      <tr>
        <td class="text-muted" style="padding-right: 12px;">igdb</td>
        <td><%= @game.igdb_rating ? "#{@game.igdb_rating.to_i} / 100 (#{@game.igdb_rating_count.to_i} votes)" : "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">aggregated</td>
        <td><%= @game.aggregated_rating ? "#{@game.aggregated_rating.to_i} / 100 (#{@game.aggregated_rating_count.to_i} votes)" : "—" %></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px;">total</td>
        <td><%= @game.total_rating ? "#{@game.total_rating.to_i} / 100 (#{@game.total_rating_count.to_i} votes)" : "—" %></td>
      </tr>
    </table>

    <h2 style="margin-top: 16px;">time to beat</h2>
    <table class="detail-table">
      <tr><td class="text-muted" style="padding-right: 12px;">main</td><td><%= format_seconds(@game.ttb_main_seconds) %></td></tr>
      <tr><td class="text-muted" style="padding-right: 12px;">extras</td><td><%= format_seconds(@game.ttb_extras_seconds) %></td></tr>
      <tr><td class="text-muted" style="padding-right: 12px;">completionist</td><td><%= format_seconds(@game.ttb_completionist_seconds) %></td></tr>
    </table>

    <h2 style="margin-top: 16px;">genres / platforms</h2>
    <p>
      <strong>genres:</strong> <%= @game.genres.map(&:name).join(", ").presence || "—" %><br>
      <strong>platforms:</strong> <%= @game.platforms_available.map(&:name).join(", ").presence || "—" %>
    </p>

    <h2 style="margin-top: 16px;">local fields</h2>
    <%= form_with(model: @game, url: game_path(@game), method: :patch) do |f| %>
      <table class="detail-table" style="margin-bottom: 8px;">
        <tr>
          <td class="text-muted" style="padding-right: 12px;">platform owned</td>
          <td>
            <%= f.collection_select :platform_owned_id,
                                    @game.platforms_available.order(:name),
                                    :id, :name, include_blank: "—" %>
          </td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">played on</td>
          <td><%= f.date_field :played_at %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">notes</td>
          <td><%= f.text_area :notes, rows: 4, style: "width: 100%; max-width: 380px;" %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">footage hours (manual)</td>
          <td>
            <%= f.number_field :hours_of_footage_manual, min: 0, style: "width: 80px;" %>
            <span class="text-muted" style="font-size: 11px;">leave blank to compute from linked videos.</span>
          </td>
        </tr>
      </table>
      <button type="submit">[<b>update</b>]</button>
    <% end %>

    <h2 style="margin-top: 16px;">sync</h2>
    <p class="text-muted" style="margin: 0;">
      <% if @game.igdb_synced_at.present? %>
        synced <%= time_ago_in_words(@game.igdb_synced_at) %> ago.
      <% else %>
        not synced yet.
      <% end %>
    </p>

    <%# Phase 14 §3 — linked videos. Lists every Video tied to this
        Game via `video_game_links` plus a primary star where applicable. %>
    <h2 style="margin-top: 16px;">linked videos</h2>
    <% game_links = @game.video_game_links.includes(:video).order(:id) %>
    <% if game_links.any? %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% game_links.each do |link| %>
          <% next unless link.video %>
          <li style="padding: 2px 0;">
            <%= link_to link.video.title.presence || link.video.youtube_video_id, video_path(link.video) %>
            <% if link.is_primary? %>
              <span class="bracketed-active">[★]</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted" style="margin: 0;">no linked videos yet.</p>
    <% end %>
  </div>
</div>
