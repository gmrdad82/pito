<%# Phase 14 §1 polish (2026-05-10) — game show page is a READ-ONLY
    surface. The inline form lives at `/games/:id/edit`. Layout is two
    rows of `.pane-row`s:
      Row 1 — narrow cover pane + wide read-only metadata pane.
      Row 2 — wide linked-videos pane.
    The breadcrumb-action strip carries `[sync]` (Wave C8 — muted
    while a resync is in flight, an active button otherwise) and
    `[delete]` (Wave C9 — opens an in-page `ConfirmModalComponent`
    rendered at the bottom of this template; the old action-screen at
    `/deletions/game/:id` is no longer reached from this surface).
    The dedicated sync pane and the LEFT-pane sync banner were
    removed — the breadcrumb [sync] is the single resync control,
    and the page-level `auto-refresh` div below picks up the cleared
    `resyncing` flag with a full reload.
%>
<% content_for(:title, @game.title) %>
<% breadcrumb(["games", games_path], @game.title) %>

<%# Phase 28 §01a — muted parent pointer for editions. Bracketed link
    above the page chrome so the user can hop up to the primary's show
    page. Rendered only when the row is an edition AND the pointer
    resolves (a row in mid-detach renders no pointer). %>
<% if @game.edition? && @game.version_parent.present? %>
  <p class="text-muted edition-parent-pointer" style="margin: 0 0 8px 0;">
    <%= render(BracketedLinkComponent.new(
          label: "↳ #{@game.version_parent.title}",
          href: game_path(@game.version_parent))) %>
  </p>
<% end %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <% if @game.resyncing? %>
      <%= render(BracketedMutedLinkComponent.new(label: "sync", href: resync_game_path(@game))) %>
    <% else %>
      <%= button_to resync_game_path(@game),
                    method: :post,
                    class: "bracketed",
                    form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl">sync</span>]<% end %>
    <% end %>
    <%# Wave C9 (spec 08 §"Per-game delete confirm modal") — breadcrumb
        `[delete]` opens an in-page `ConfirmModalComponent` (native
        `<dialog>` via `confirm-modal` + `modal-trigger` controllers).
        The bulk-deletion action-screen at `/deletions/game/:id` is no
        longer reached from this surface — the modal POSTs directly to
        `DELETE /games/:id` (Game#destroy + dependent cascades + the
        `Collections::CompositeRebuildQueue.enqueue_for_game_destroy`
        hook). The modal markup itself is rendered at the bottom of
        this template so it sits outside all pane rows. %>
    <a href="#"
       class="bracketed text-danger"
       data-controller="modal-trigger"
       data-action="click->modal-trigger#open"
       data-modal-trigger-target-id-value="confirm_delete_game_<%= @game.id %>">[<span class="bl">-</span>]</a>
  </div>
<% end %>

<% if @game.resyncing? %>
  <%# Auto-refresh fallback. While the resync flag is set we reload
      every ~5s so the show page picks up the cleared flag without a
      manual refresh. The controller no-ops once the next render
      drops it (because the wrapper div is conditional on
      `resyncing?`). %>
  <div data-controller="auto-refresh"
       data-auto-refresh-interval-value="5000"
       style="display: none;"></div>
<% end %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. The wrapper is invisible (display: contents)
    so it does not affect the existing flex / pane layout below. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@game, scope: Game, path_helper: method(:game_path)) %>></div>

<%# Row 1 — cover + read-only metadata. The `pane-row--game-show`
    modifier flips this specific row to `flex-wrap: nowrap` so the
    280px cover and 640px details panes stay side-by-side at standard
    workspace widths instead of stacking. Narrower viewports get a
    horizontal scrollbar instead of wrap. Row 2 (linked videos) keeps
    the default `.pane-row` (single wide pane, no wrap concern).
%>
<div class="pane-row pane-row--game-show">
  <div class="pane pane--narrow">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>

    <%# Wave C2 (spec 08 §"Genres") — primary-bold + up-to-2 secondaries
        rendered between the `<h1>` and the `released:` meta line.
        Primary genre (`@game.primary_genre`) renders in `<strong>`;
        secondaries are `@game.genres` MINUS the primary, sorted by
        name, capped at 2 (so 1 + 2 = 3 max). Separator is ` · `
        (space-dot-space). When no genres at all, the block renders an
        em-dash `<em>—</em>` for the muted "unknown" signal. Labels
        flow through `genre_display_name` (GenresHelper) — IGDB names
        render verbatim except for the cosmetic renames declared in
        `GENRE_DISPLAY_RENAMES`. %>
    <% if @game.primary_genre || @game.genres.any? %>
      <div class="game-genres" style="margin: 0 0 4px 0;">
        <%
          primary  = @game.primary_genre
          secondaries = @game.genres
                              .where.not(id: primary&.id)
                              .order(:name)
                              .limit(2)
          genres_list = ([primary] + secondaries.to_a).compact
        %>
        <% if genres_list.any? %>
          <% genres_list.each_with_index do |g, i| %>
            <% if i.zero? %>
              <strong><%= genre_display_name(g) %></strong>
            <% else %>
              <span><%= genre_display_name(g) %></span>
            <% end %>
            <% if i < genres_list.length - 1 %> · <% end %>
          <% end %>
        <% else %>
          <em class="text-muted">—</em>
        <% end %>
      </div>
    <% end %>

    <%# Meta block: released / dev / pub rendered as a borderless,
        header-less two-column `kv-table` (label / value). Rows
        zebra-stripe horizontally to match the /settings stack-pane
        treatment (`.kv-table tbody tr:nth-child(even)` shares the
        same alt-row background with `.stack-table tbody tr:nth-child(even)`
        — see `application.css`).
        Skip a row entirely when its value is missing (no `pub: —`
        placeholder). Date formatted as `MM-DD-YYYY` per 2026-05-11
        polish (Fix 3). %>
    <%
      meta_rows = []
      if @game.release_date.present?
        meta_rows << ["released", @game.release_date.strftime("%m-%d-%Y")]
      end
      developer_names = @game.developers.map(&:name)
      meta_rows << ["dev", developer_names.join(", ")] if developer_names.any?
      publisher_names = @game.publishers.map(&:name)
      meta_rows << ["pub", publisher_names.join(", ")] if publisher_names.any?
    %>
    <% if meta_rows.any? %>
      <table class="kv-table" style="margin: 0 0 8px 0;">
        <tbody>
          <% meta_rows.each do |label, value| %>
            <tr>
              <td class="kv-table__label"><%= label %></td>
              <td class="kv-table__value"><%= value %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <%# Wave C5 (spec 08 §"Rating heat-bar synthesis") — vote-weighted
        synthesized score across the three IGDB rating triplets,
        rendered as a heat-bar. 2026-05-17 two-variant compare —
        both finalists render stacked so the user can re-lock:
          red-only — gradient starts at `--color-rating-bad` (bright
                     red); no dark muddy red tone at all.
          very-bad — gradient starts at `--color-rating-very-bad`
                     (dark muddy red) then transitions to
                     `--color-rating-bad` at 25%, then climbs.
        AR carve-out: red (`--color-rating-bad`) covers bad (25–49)
        and the dark muddy red (`--color-rating-very-bad`) anchors
        the worst-of-worst (<25) in the very-bad variant. The
        numeric label is gone on purpose — the bar's color encodes
        the score. Sits below the meta block (release / dev / pub)
        so the LEFT pane reads: cover → title → genres → meta →
        heat-bar → ownership. The compare scaffolding collapses
        back to a single render once the user picks. %>
    <div class="rating-heat-bar-compare">
      <div>
        <div class="rating-heat-bar-compare-label">red-only worst</div>
        <%= render(Games::RatingHeatBarComponent.new(game: @game, variant: :red_only)) %>
      </div>
      <div>
        <div class="rating-heat-bar-compare-label">very-bad (dark shit) + red</div>
        <%= render(Games::RatingHeatBarComponent.new(game: @game, variant: :very_bad)) %>
      </div>
    </div>

    <%# Wave C4 (spec 08 §"Ownership chips") — LEFT-pane ownership
        section. Sits below the heat-bar (Wave C5) as the LEFT pane's
        terminal block. Rows:
          platforms — one per-platform toggle chip per applicable
                      brand slug (PS5 / Switch / Steam). Each chip
                      flips ownership via the existing
                      `Games::PlatformOwnershipsController#update`
                      endpoint.
          played    — single chip (user-confirmed 2026-05-17 single
                      chip override; not per-platform).
          recorded  — single chip (single override; derived from
                      linked-video count).
          footage   — `StatusTbdBadgeComponent` placeholder (Wave C11
                      shared badge).
        Hairline `<hr>` above acts as the visual divider between the
        rating heat-bar and the ownership block. %>
    <hr class="hairline">

    <section class="ownership">
      <h2>ownership</h2>

      <%
        applicable_slugs = Platforms::ChipComponent::SLUG_BRAND.keys.select { |s|
          game_detail_logo_slugs(@game).include?(s)
        }
      %>

      <div class="ownership-row">
        <span class="ownership-label">platforms</span>
        <% applicable_slugs.each do |slug| %>
          <%= render(Games::PlatformOwnershipChipComponent.new(game: @game, slug: slug)) %>
        <% end %>
        <% if applicable_slugs.empty? %>
          <em class="text-muted">—</em>
        <% end %>
      </div>

      <div class="ownership-row">
        <span class="ownership-label">played</span>
        <%= render(Games::PlayedChipComponent.new(game: @game)) %>
      </div>

      <div class="ownership-row">
        <span class="ownership-label">footage</span>
        <%= render(StatusTbdBadgeComponent.new) %>
      </div>
    </section>

  </div>

  <%# Wave C7 (spec 08 §"RIGHT-pane sections" line 301 + §"RIGHT pane
      Time-to-beat" lines 318-333) — the RIGHT pane collapses to two
      focused sections: `summary` (skipped entirely when blank — both
      heading and body) + `time to beat` (always rendered as a single
      row with three columns; nil/zero cells render an em-dash via
      `ttb_hours`). The previous ratings / platforms / stores /
      local-fields stack moved out:
        ratings   → LEFT-pane heat-bar (Wave C5).
        platforms → LEFT-pane ownership block (Wave C4).
        stores    → REMOVED per spec (§"Stores section — REMOVED"
                    line 343); platform availability is communicated
                    by the LEFT-pane platforms chips.
        local fields (owned-on / played-on / notes / footage hours)
                  → live on `/games/:id/edit` and the dedicated
                    ownership editor; the show page is read-only +
                    summary-focused.
      `pane--game-detail` is preserved so row 1 still totals 904px
      (narrow 280 + detail 624) and the LEFT-pane multi-wave layout
      keeps its established width contract with row 2 / row 3 wide
      panes. %>
  <div class="pane pane--game-detail">
    <% if @game.last_sync_error.present? %>
      <p class="text-danger" style="margin: 0 0 8px 0;">igdb error: <%= @game.last_sync_error %></p>
    <% end %>

    <% if @game.summary.present? %>
      <section class="game-summary">
        <h2 style="margin-top: 0;">summary</h2>
        <%= simple_format(@game.summary, class: "summary-body") %>
      </section>

      <hr class="hairline">
    <% end %>

    <%# 2026-05-17 variants pass — time-to-beat visualization
        showcase. Renders 10 candidate treatments stacked vertically,
        separated by full-width hairlines, so the user can pick one
        visually. Once chosen, this block collapses back to a single
        `<%= "Games::TimeToBeatComponent.new(game: @game, variant: :X)" %>`
        call and the showcase scaffolding gets deleted. %>
    <%
      ttb_variants = [
        [ :concentric,       "Variant 1 — concentric arcs (nested rings)" ],
        [ :discs,            "Variant 2 — sized discs in a row" ],
        [ :rings,            "Variant 3 — activity rings (donut)" ],
        [ :bars,             "Variant 4 — horizontal labeled bars" ],
        [ :columns,          "Variant 5 — vertical bar trio (column chart)" ],
        [ :pyramid,          "Variant 6 — stepped pyramid / staircase" ],
        [ :clocks,           "Variant 7 — stopwatch / clock-face metaphor" ],
        [ :ladder,           "Variant 8 — sparkline / cumulative ladder" ],
        [ :stacked_timeline, "Variant 9 — stacked timeline (single segmented bar)" ],
        [ :fuel_gauge,       "Variant 10 — fuel gauge with milestone ticks" ]
      ]
    %>
    <section class="ttb-showcase" aria-label="time to beat variants">
      <h2 style="margin-top: 0;">time to beat — pick a variant</h2>
      <% ttb_variants.each_with_index do |(variant_key, label), idx| %>
        <div class="ttb-showcase__variant">
          <h4 class="h4-content"><%= label %></h4>
          <%= render(Games::TimeToBeatComponent.new(game: @game, variant: variant_key)) %>
        </div>
        <% unless idx == ttb_variants.length - 1 %>
          <hr class="ttb-hairline">
        <% end %>
      <% end %>
    </section>
  </div>
</div>

<%# Phase 28 §01a — editions sub-section. Rendered only when the
    game is a primary with at least one edition. Anchored `#editions`
    so the tile badge / list-mode badge can scroll-to. %>
<% if @game.primary? && @game.editions.exists? %>
  <div class="pane-row">
    <div class="pane pane--wide">
      <%= render(Games::EditionsSectionComponent.new(game: @game)) %>
    </div>
  </div>
<% end %>

<%# Row 3 — linked videos. Standalone wide pane so each title row
    can breathe horizontally; this matches the bundle show page's
    members list rhythm.
%>
<div class="pane-row">
  <div class="pane pane--wide">
    <h2 style="margin-top: 0;">videos</h2>
    <% game_links = @game.video_game_links.includes(:video).order(:id) %>
    <% if game_links.any? %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% game_links.each do |link| %>
          <% next unless link.video %>
          <li style="padding: 2px 0;">
            <%= link_to link.video.title.presence || link.video.youtube_video_id, video_path(link.video) %>
            <% if link.is_primary? %>
              <span class="bracketed-active">[★]</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= render(StatusTbdBadgeComponent.new) %>
    <% end %>
  </div>
</div>

<%# Wave C9 (spec 08 §"Per-game delete confirm modal") — page-level
    `<dialog>` rendered outside all pane rows so it overlays the page
    when the breadcrumb `[delete]` trigger fires `modal-trigger#open`.
    The dialog id matches the trigger's
    `data-modal-trigger-target-id-value`. `ConfirmModalComponent` wires
    up the native `<dialog>` element, the `confirm-modal` controller
    (Escape + click-outside close), and a hidden form that POSTs DELETE
    to `game_path(@game)` — the same endpoint the deprecated
    `/deletions/game/:id` action-screen used to redirect to. %>
<%= render(ConfirmModalComponent.new(
      id: "confirm_delete_game_#{@game.id}",
      title: "delete #{@game.title}?",
      body: "linked videos detach and any bundle composites regenerate. this cannot be undone.",
      confirm_path: game_path(@game),
      confirm_method: :delete,
      confirm_label: "delete",
      cancel_label: "cancel",
      destructive: true
    )) %>
