<%# Phase 14 §1 polish (2026-05-10) — game show page is a READ-ONLY
    surface. The inline form lives at `/games/:id/edit`. Layout is now
    a single `.pane-row` (Row 1):
      LEFT pane (narrow) — cover + title + genres + meta kv-table +
        rating heat-bar + ownership matrix.
      RIGHT pane (game-detail) — summary + time-to-beat fuel gauge +
        videos `[TBD]` placeholder.
    Item 9 of the 2026-05-17 reshape list collapsed the standalone
    Row 2 (`<div class="pane-row"><div class="pane pane--wide">...`
    that listed `video_game_links`) into a `[TBD]` heading inside the
    RIGHT pane; the link table is gone until the surface is re-specd.
    The breadcrumb-action strip carries `[sync]` (Wave C8 — muted
    while a resync is in flight, an active button otherwise) and
    `[delete]` (Wave C9 — opens an in-page `ConfirmModalComponent`
    rendered at the bottom of this template; the old action-screen at
    `/deletions/game/:id` is no longer reached from this surface).
    The dedicated sync pane and the LEFT-pane sync banner were
    removed — the breadcrumb [sync] is the single resync control,
    and the page-level `auto-refresh` div below picks up the cleared
    `resyncing` flag with a full reload.
%>
<% content_for(:title, @game.title) %>
<% breadcrumb(["games", games_path], @game.title) %>

<%# Phase 28 §01a — muted parent pointer for editions. Bracketed link
    above the page chrome so the user can hop up to the primary's show
    page. Rendered only when the row is an edition AND the pointer
    resolves (a row in mid-detach renders no pointer). %>
<% if @game.edition? && @game.version_parent.present? %>
  <p class="text-muted edition-parent-pointer" style="margin: 0 0 8px 0;">
    <%= render(BracketedLinkComponent.new(
          label: "↳ #{@game.version_parent.title}",
          href: game_path(@game.version_parent))) %>
  </p>
<% end %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%# `data-page-action="sync"` is the SPACE-s leader binding hook
        (see `config/keybindings.yml` `page_actions.games_show` →
        `s sync` + `leader_menu_controller.js#pageSync`). The leader
        handler does a direct `.click()` on the matching element. The
        hook is ONLY attached to the active-state `<button>` — when a
        resync is already in flight the muted-state branch renders as
        a non-interactive `<span class="bracketed-muted">` (plain bold
        muted text, `cursor: default`, no click handler, no href, no
        hover lift), so SPACE-s becomes a no-op and the cursor / mouse
        cannot trigger a second resync while one is in flight. The
        page's `auto-refresh` controller below is the only thing that
        changes while a resync is in flight — when the flag clears the
        full reload swaps the `<span>` back to the live `<button>`.
        2026-05-18 polish — switched from `BracketedMutedLinkComponent`
        (which renders an `<a href>`, still receives clicks, still
        shows the link cursor) to the existing non-interactive
        `.bracketed-muted` primitive so the muted state reads as plain
        muted text, not a "lesser link". %>
    <% if @game.resyncing? %>
      <span class="bracketed-muted" aria-disabled="true">[<span class="bl">sync</span>]</span>
    <% else %>
      <%# 2026-05-18 — `[sync]` becomes an in-page confirm-modal trigger
          (red / dangerous) because firing a resync consumes from the
          IGDB request quota. Mirrors the `[delete]` pattern below: raw
          `<a href="#">` carrying `modal-trigger` so SPACE-s (the leader
          handler does a `.click()` on this anchor) opens the same
          `<dialog>`. The form-submit lives inside the modal — the
          underlying `POST /games/:id/resync` endpoint is unchanged. %>
      <a href="#"
         class="bracketed text-danger"
         data-controller="modal-trigger"
         data-action="click->modal-trigger#open"
         data-page-action="sync"
         data-modal-trigger-target-id-value="confirm_sync_game_<%= @game.id %>">[<span class="bl">sync</span>]</a>
    <% end %>
    <%# Wave C9 (spec 08 §"Per-game delete confirm modal") — breadcrumb
        `[delete]` opens an in-page `ConfirmModalComponent` (native
        `<dialog>` via `confirm-modal` + `modal-trigger` controllers).
        The bulk-deletion action-screen at `/deletions/game/:id` is no
        longer reached from this surface — the modal POSTs directly to
        `DELETE /games/:id` (Game#destroy + dependent cascades + the
        `Collections::CompositeRebuildQueue.enqueue_for_game_destroy`
        hook). The modal markup itself is rendered at the bottom of
        this template so it sits outside all pane rows.
        `data-page-action="delete"` is the SPACE-- leader binding
        hook (see `config/keybindings.yml` `page_actions.games_show`
        → `- delete` + `leader_menu_controller.js#pageDelete`). The
        leader handler does a `.click()` on this anchor, which fires
        the existing `click->modal-trigger#open` action and opens the
        same `<dialog>`. %>
    <a href="#"
       class="bracketed text-danger"
       data-controller="modal-trigger"
       data-action="click->modal-trigger#open"
       data-page-action="delete"
       data-modal-trigger-target-id-value="confirm_delete_game_<%= @game.id %>">[<span class="bl">-</span>]</a>
  </div>
<% end %>

<% if @game.resyncing? %>
  <%# Auto-refresh fallback. While the resync flag is set we reload
      every ~5s so the show page picks up the cleared flag without a
      manual refresh. The controller no-ops once the next render
      drops it (because the wrapper div is conditional on
      `resyncing?`). %>
  <div data-controller="auto-refresh"
       data-auto-refresh-interval-value="5000"
       style="display: none;"></div>
<% end %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. The wrapper is invisible (display: contents)
    so it does not affect the existing flex / pane layout below. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@game, scope: Game, path_helper: method(:game_path)) %>></div>

<%# Row 1 — cover + read-only metadata. The `pane-row--game-show`
    modifier flips this specific row to `flex-wrap: nowrap` so the
    280px cover and 640px details panes stay side-by-side at standard
    workspace widths instead of stacking. Narrower viewports get a
    horizontal scrollbar instead of wrap. Row 2 (linked videos) keeps
    the default `.pane-row` (single wide pane, no wrap concern).
%>
<div class="pane-row pane-row--game-show">
  <div class="pane pane--narrow">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>

    <%# Wave C2 (spec 08 §"Genres") — primary-bold + up-to-2 secondaries
        rendered between the `<h1>` and the `released:` meta line.
        Primary genre (`@game.primary_genre`) renders in `<strong>`;
        secondaries are `@game.genres` MINUS the primary, sorted by
        name, capped at 2 (so 1 + 2 = 3 max). Separator is ` · `
        (space-dot-space). When no genres at all, the block renders an
        em-dash `<em>—</em>` for the muted "unknown" signal. Labels
        flow through `genre_display_name` (GenresHelper) — IGDB names
        render verbatim except for the cosmetic renames declared in
        `GENRE_DISPLAY_RENAMES`. %>
    <% if @game.primary_genre || @game.genres.any? %>
      <div class="game-genres" style="margin: 0 0 4px 0;">
        <%
          primary  = @game.primary_genre
          secondaries = @game.genres
                              .where.not(id: primary&.id)
                              .order(:name)
                              .limit(2)
          genres_list = ([primary] + secondaries.to_a).compact
        %>
        <% if genres_list.any? %>
          <% genres_list.each_with_index do |g, i| %>
            <% if i.zero? %>
              <strong><%= genre_display_name(g) %></strong>
            <% else %>
              <span><%= genre_display_name(g) %></span>
            <% end %>
            <% if i < genres_list.length - 1 %> · <% end %>
          <% end %>
        <% else %>
          <em class="text-muted">—</em>
        <% end %>
      </div>
    <% end %>

    <%# 2026-05-17 polish — hairline between the genres line and the
        meta kv-table so the LEFT pane reads as three distinct blocks
        (genres / meta / heat-bar). Uses the canonical `.hairline`
        rule (8px top + 8px bottom margin). %>
    <hr class="hairline">

    <%# Meta block: released / dev / pub rendered as a borderless,
        header-less two-column `kv-table` (label / value). Rows
        zebra-stripe horizontally to match the /settings stack-pane
        treatment (`.kv-table tbody tr:nth-child(even)` shares the
        same alt-row background with `.stack-table tbody tr:nth-child(even)`
        — see `application.css`).
        Skip a row entirely when its value is missing (no `pub: —`
        placeholder). Date formatted as `MM-DD-YYYY` per 2026-05-11
        polish (Fix 3). %>
    <%
      meta_rows = []
      if @game.release_date.present?
        meta_rows << ["date", @game.release_date.strftime("%m-%d-%Y")]
      end
      developer_names = @game.developers.map(&:name)
      meta_rows << ["dev", developer_names.join(", ")] if developer_names.any?
      publisher_names = @game.publishers.map(&:name)
      meta_rows << ["pub", publisher_names.join(", ")] if publisher_names.any?
      # 2026-05-18 — sync row sits below dev/pub. While a resync is in
      # flight (`resyncing?` true) the value renders as `---` so the
      # row visibly signals "stale, refreshing"; once the job clears
      # the flag the page's `auto-refresh` controller above reloads
      # and the cell flips back to a fresh `compact_time_ago` string
      # off `igdb_synced_at`. `compact_time_ago(nil)` returns
      # `"never"` so games that have never synced still show the row
      # rather than dropping it.
      meta_rows << ["sync", @game.resyncing? ? "---" : compact_time_ago(@game.igdb_synced_at)]
    %>
    <% if meta_rows.any? %>
      <%# 2026-05-17 polish — `.kv-table__value` truncates via
          `text-overflow: ellipsis` (white-space: nowrap + overflow:
          hidden + explicit max-width on the value cell); a `title`
          attribute on the value `<td>` surfaces the full string as a
          native browser tooltip on hover, which is the standard
          truncation affordance (most relevant for long publisher lists
          such as "Rockstar Games, Take-Two Interactive"). Browsers
          handle non-truncated values gracefully (they may even
          suppress the tooltip when the rendered text already shows in
          full).
          Item 1 polish (2026-05-17) — `margin-top` reduced from 16px
          to 6px so the title-hairline → kv-table reads as one tight
          visual cluster (genres / hairline / meta). The hairline that
          previously sat below the kv-table was removed (item 3) —
          the heat-bar's own `margin-top: 28px` already provides the
          vertical break above the bar. %>
      <table class="kv-table" style="margin: 6px 0 0 0;">
        <tbody>
          <% meta_rows.each do |label, value| %>
            <tr>
              <td class="kv-table__label"><%= label %></td>
              <td class="kv-table__value" title="<%= value %>"><%= value %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <%# Wave C5 (spec 08 §"Rating heat-bar synthesis") — vote-weighted
        synthesized score across the three IGDB rating triplets,
        rendered as a heat-bar. Three-zone layout: solid dark muddy
        red 0-25, solid bright red 25-50, gradient transition zone
        50-90 (poor → meh → fair → good → excellent), solid green
        90-100 — hard edges at 25/50/90 so the end zones read as
        unambiguous blocks. AR carve-out: red (`--color-rating-bad`)
        covers 25-50 and the dark muddy red (`--color-rating-very-bad`)
        anchors 0-25. The numeric label is gone on purpose — the
        bar's color encodes the score. Sits below the meta block
        (release / dev / pub) so the LEFT pane reads: cover → title
        → genres → meta → heat-bar → ownership. %>
    <%= render Games::RatingHeatBarComponent.new(game: @game) %>

    <%# 2026-05-17 BP slice (item 7 of the 10-item /games/:id reshape
        list) — LEFT-pane ownership section, now a per-platform
        matrix. One row per applicable platform (PS / Switch / Steam
        intersected with `game_detail_logo_slugs`); each row carries
        `[owned]` (bordered green) and / or `[played]` (filled green)
        chips. Multiple rows can be `[owned]` (boolean per platform);
        at most one row across the matrix is `[played]` (singular —
        "I can choose only 1 platform for played").
        The previous flat `platforms` / `played` / `footage` rows
        are gone. Footage is REMOVED from the ownership UI (BP slice
        scope: drop footage from this block); the underlying
        `Game#footage_*` columns are preserved on the model and will
        be consumed by the BQ TTB fuel-gauge footage tick.
        Hairline `<hr>` above acts as the visual divider between the
        rating heat-bar and the ownership block. %>
    <hr class="hairline">

    <section class="ownership">
      <h2>ownership</h2>
      <%= render(Games::OwnershipMatrixComponent.new(game: @game)) %>
    </section>

  </div>

  <%# Wave C7 (spec 08 §"RIGHT-pane sections" line 301 + §"RIGHT pane
      Time-to-beat" lines 318-333) — the RIGHT pane collapses to two
      focused sections: `summary` (skipped entirely when blank — both
      heading and body) + `time to beat` (always rendered as a single
      row with three columns; nil/zero cells render an em-dash via
      `ttb_hours`). The previous ratings / platforms / stores /
      local-fields stack moved out:
        ratings   → LEFT-pane heat-bar (Wave C5).
        platforms → LEFT-pane ownership block (Wave C4).
        stores    → REMOVED per spec (§"Stores section — REMOVED"
                    line 343); platform availability is communicated
                    by the LEFT-pane platforms chips.
        local fields (owned-on / played-on / notes / footage hours)
                  → live on `/games/:id/edit` and the dedicated
                    ownership editor; the show page is read-only +
                    summary-focused.
      `pane--game-detail` is preserved so row 1 still totals 904px
      (narrow 280 + detail 624) and the LEFT-pane multi-wave layout
      keeps its established width contract with row 2 / row 3 wide
      panes. %>
  <div class="pane pane--game-detail">
    <% if @game.last_sync_error.present? %>
      <p class="text-danger" style="margin: 0 0 8px 0;">igdb error: <%= @game.last_sync_error %></p>
    <% end %>

    <% if @game.summary.present? %>
      <section class="game-summary">
        <h2 style="margin-top: 0;">summary</h2>
        <%= simple_format(@game.summary, class: "summary-body") %>
      </section>
    <% end %>

    <%# 2026-05-17 BQ slice (item 8, post-validation polish 1-3) — the
        10-variant TTB showcase is gone. Variant 10 (fuel gauge) won;
        the RIGHT pane now renders ONE canonical TTB visualization,
        full pane width, directly under the summary block (no hairline
        between — the bar itself carries its own "TTB" watermark
        label, left-aligned inside the bar, so no standalone heading
        is needed). The bar's color encodes effort weight via a smooth
        multi-stop gradient (low → some → commitment → insanity); a
        bordered footage tick overlays the pillar ticks for the focal
        "here is where I am" notch. See `time_to_beat_component.rb`
        for the full rationale. %>
    <section class="time-to-beat" aria-label="time to beat">
      <%= render(Games::TimeToBeatComponent.new(game: @game)) %>
    </section>

    <%# 2026-05-18 — `bundles` section (DW slice). Two halves on a
        single horizontal shelf row:
          LEFT  — bundles the game is a MEMBER OF (`game.bundles`).
                  Each tile opens the layout-level `<dialog
                  id="bundles-modal">` (same trigger as `/games`).
          RIGHT — up to 3 `Bundles::SuggestedFor` recommendations
                  (nearest-neighbor cosine on the bundle centroid).
                  Each tile is a `button_to` POSTing
                  `/bundles/:slug/members?game_id=…&source=games_show`,
                  adding the game and flashing
                  "added to <bundle name>." on the next render.
        Vertical hairline divider (`.bundles-section-divider`) sits
        between halves ONLY when both halves render. If neither half
        has rows the whole section (heading + hairline + shelf) is
        skipped — no empty "bundles" heading. Tiles use the bare 98×130
        cover (`size: :shelf`) matching the genre / similar shelves on
        this page. The bundles modal partial + per-bundle confirm-delete
        dialogs for the LEFT bundles are rendered as siblings at the
        bottom of the page so the LEFT tiles' Stimulus trigger has the
        dialog ids it needs. %>
    <%
      bundles_in   = @game.bundles.order(Arel.sql("LOWER(name)")).to_a
      bundles_suggested_raw = Bundles::SuggestedFor.call(@game, limit: 3).to_a
      bundles_suggested = bundles_suggested_raw - bundles_in
    %>
    <hr class="hairline">
    <section class="game-bundles" aria-label="bundles">
      <h2>bundles</h2>
      <div class="shelf-row" data-controller="steam-shelf">
        <% if bundles_in.any? || bundles_suggested.any? %>
          <% bundles_in.each do |bundle| %>
            <%= render(Games::BundleTileComponent.new(bundle: bundle)) %>
          <% end %>
          <% if bundles_in.any? && bundles_suggested.any? %>
            <div class="bundles-section-divider" aria-hidden="true"></div>
          <% end %>
          <% bundles_suggested.each do |bundle| %>
            <%= render(Games::BundleTileComponent.new(
                  bundle: bundle,
                  mode: :suggest, target_game: @game)) %>
          <% end %>
        <% else %>
          <div class="shelf-empty-tile" aria-label="nothing yet">
            <span>nothing</span>
            <span>yet</span>
          </div>
        <% end %>
      </div>
    </section>

    <%# 2026-05-18 — `similar` section. Single shelf of up to 10
        pgvector-cosine-nearest games via `Games::SimilarGames`. The
        whole section (heading + hairline + shelf) is skipped when the
        service returns an empty list (e.g., game has no embedding yet
        or no other embedded rows to compare against), so the page
        does not display an empty "similar" heading. Tiles render via
        `Games::GenreTileComponent` — the bare-cover style used in
        genre sub-shelves (98×130). Click navigates to `/games/:slug`
        via the CoverComponent's `_top` turbo-frame escape. Sits below
        the (future) bundles section and above videos so the
        right-pane order reads: summary → TTB → bundles → similar →
        videos. %>
    <% similar = Games::SimilarGames.call(@game, limit: 10) %>
    <hr class="hairline">
    <section class="game-similar" aria-label="similar games">
      <h2>similar</h2>
      <div class="shelf-row" data-controller="steam-shelf">
        <% if similar.any? %>
          <% similar.each do |game| %>
            <%= render Games::GenreTileComponent.new(game: game) %>
          <% end %>
        <% else %>
          <div class="shelf-empty-tile" aria-label="nothing yet">
            <span>nothing</span>
            <span>yet</span>
          </div>
        <% end %>
      </div>
    </section>

    <%# 2026-05-17 item 9 of the /games/:id reshape list — videos
        section is reduced to a TBD placeholder living in the RIGHT
        pane below the TTB fuel gauge. The old standalone `.pane-row`
        listing linked videos (with [★] primary marker) is removed
        entirely; nothing about the videos surface is decided yet, so
        the heading + `[TBD]` chip stand in until the real surface is
        spec'd. Hairline above acts as the visual divider between the
        TTB block and the videos block, mirroring the LEFT pane's
        rhythm. %>
    <hr class="hairline">

    <section class="game-videos" aria-label="videos">
      <h2 style="margin-top: 0;">videos <%= render(StatusTbdBadgeComponent.new) %></h2>
    </section>
  </div>
</div>

<%# Phase 28 §01a — editions sub-section. Rendered only when the
    game is a primary with at least one edition. Anchored `#editions`
    so the tile badge / list-mode badge can scroll-to. %>
<% if @game.primary? && @game.editions.exists? %>
  <div class="pane-row">
    <div class="pane pane--wide">
      <%= render(Games::EditionsSectionComponent.new(game: @game)) %>
    </div>
  </div>
<% end %>

<%# Wave C9 (spec 08 §"Per-game delete confirm modal") — page-level
    `<dialog>` rendered outside all pane rows so it overlays the page
    when the breadcrumb `[delete]` trigger fires `modal-trigger#open`.
    The dialog id matches the trigger's
    `data-modal-trigger-target-id-value`. `ConfirmModalComponent` wires
    up the native `<dialog>` element, the `confirm-modal` controller
    (Escape + click-outside close), and a hidden form that POSTs DELETE
    to `game_path(@game)` — the same endpoint the deprecated
    `/deletions/game/:id` action-screen used to redirect to. %>
<%= render(ConfirmModalComponent.new(
      id: "confirm_delete_game_#{@game.id}",
      title: "delete #{@game.title}?",
      body: "linked videos detach and any bundle composites regenerate. this cannot be undone.",
      confirm_path: game_path(@game),
      confirm_method: :delete,
      confirm_label: "delete",
      cancel_label: "cancel",
      destructive: true
    )) %>

<%# 2026-05-18 — per-game `[sync]` confirm modal. Sync is a dangerous
    action because it consumes from the IGDB request quota (rate-limited
    external API), so the breadcrumb [sync] no longer fires on raw click
    — it opens this dialog instead. The confirm POSTs to the same
    `resync_game_path` endpoint the old `button_to` used. Carries
    `modal_actions_key: "sync_confirm"` so once the dialog is open the
    leader popup becomes modal-scoped to the matching `modal_actions`
    list in `config/keybindings.yml` (`l` dark mode + `s` confirm sync).
%>
<%= render(ConfirmModalComponent.new(
      id: "confirm_sync_game_#{@game.id}",
      title: "resync #{@game.title}?",
      body: "this will consume from your IGDB request quota.",
      confirm_path: resync_game_path(@game),
      confirm_method: :post,
      confirm_label: "sync",
      cancel_label: "cancel",
      destructive: true,
      modal_actions_key: "sync_confirm"
    )) %>

<%# 2026-05-18 — bundles modal + per-bundle confirm-delete dialogs for
    the bundles section above (DW slice). Rendered only when the game
    is in at least one bundle (the LEFT-half tiles are the only ones
    that open the modal; the RIGHT-half suggested tiles POST directly).
    The modal partial is a no-op when no tile opens it; rendering the
    per-bundle confirm-delete dialogs gives the modal's `[-]` button a
    matching `<dialog id="confirm_delete_bundle_<id>">` target. %>
<% if @game.bundles.exists? %>
  <% @game.bundles.each do |bundle| %>
    <%= render(ConfirmModalComponent.new(
          id: "confirm_delete_bundle_#{bundle.id}",
          title: "delete #{bundle.name}?",
          body: "this action cannot be undone.",
          confirm_label: "delete",
          cancel_label: "cancel",
          confirm_path: bundle_path(bundle),
          confirm_method: :delete,
          destructive: true,
          turbo: true,
          modal_actions_key: "bundle_delete_confirm")) %>
  <% end %>
  <%= render "games/bundles_modal" %>
<% end %>
