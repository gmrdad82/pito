<%# 2026-05-18 — Bundle-tile cover-wrap partial. Extracted from the
    duplicated `<div class="bundle-cover-wrap">…</div>` block that
    previously lived inline in both branches of
    `app/components/games/bundle_tile_component.html.erb`
    (`suggest_mode?` and default).

    Single render target for two surfaces:
      1. Initial render through `Games::BundleTileComponent` — the
         component template renders this partial inside its `<a>`
         (default) or `<form>` (suggest) wrapper.
      2. Turbo Stream `replace` from `BundleCoverBuild` after a
         membership change rebuilds the composite — the job
         broadcasts a `<turbo-stream action="replace">` targeting
         `bundle_cover_<id>` and pointing at this same partial so the
         live-updated cover lands inside the same wrapper without a
         page reload.

    Cache-buster: the composite `<img>` src appends
    `?v=<bundle.updated_at.to_i>` so the browser never serves a
    stale cached cover after the on-disk JPEG is rewritten — the
    builder calls `bundle.update!` to stamp the new path + checksum,
    which bumps `updated_at` for free.

    Locals:
      bundle   — the Bundle record. Drives composite presence,
                 overflow count, name (alt + placeholder aria/title).
      width    — cover slot pixel width  (150 for grid, 98 for shelf).
      height   — cover slot pixel height (200 for grid, 130 for shelf).
      overflow_n — integer, bundle.bundle_members.size - 9. The
                 caller computes this so the partial stays display-
                 only and reuses the component's existing accessor.
%>
<% composite_url = bundle.composite_cover_url %>
<div id="bundle_cover_<%= bundle.id %>"
     class="bundle-cover-wrap"
     style="position: relative; display: block; width: <%= width %>px; height: <%= height %>px;">
  <% if composite_url.present? %>
    <img src="<%= composite_url %>?v=<%= bundle.updated_at.to_i %>"
         width="<%= width %>"
         height="<%= height %>"
         loading="lazy"
         alt="<%= bundle.name %>"
         class="bundle-cover-composite"
         style="display: block; object-fit: cover;">
  <% else %>
    <%# 2026-05-18 (Bug 4) — netflix-3 placeholder for empty
        bundles. Replaces the generic game-cover fallback SVG
        (which read as "a single missing game") with a 3-cell
        grid that visually previews the netflix-style composite
        layout a 3-member bundle would render. The single large
        left cell + two stacked right cells mirror
        `Composite::CellMap.for(3)` so the empty bundle looks
        like a bundle, not a generic game.

        Each cell embeds the shared game-cover fallback SVG (the
        stylised controller icon) so the placeholder reads as
        "bundle of missing games" instead of three empty boxes.
        The main left cell uses the `--large` size; the two right
        cells use `--small` because their 40% × 50% slot is much
        tighter. Single-dark since the THEME-REMOVE-COMPONENTS
        phase 1 sweep. %>
    <div class="bundle-tile__nocover-netflix3"
         aria-label="<%= bundle.name %>"
         title="<%= bundle.name %>">
      <div class="cell cell--main">
        <%= image_tag image_path("controller_icon_dark.svg"),
                      alt: "", loading: "lazy",
                      class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--large" %>
      </div>
      <div class="cell">
        <%= image_tag image_path("controller_icon_dark.svg"),
                      alt: "", loading: "lazy",
                      class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small" %>
      </div>
      <div class="cell">
        <%= image_tag image_path("controller_icon_dark.svg"),
                      alt: "", loading: "lazy",
                      class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small" %>
      </div>
    </div>
  <% end %>
  <%# 2026-05-17 — HTML `+N` overflow overlay. Mirrors the
      `.tile-cover-chip-overlay` pattern from `_tile.html.erb`, but
      tuned for parity with the `:sm` platform chips: the inner
      StatusBadge is scoped-stripped of its bordered-pill chrome and
      renormalised to the `--sm` chip's 11px / `padding: 0 5px`
      dimensions, and the overlay container itself is offset
      `-1px` on right + bottom so its edge OVERLAPS the cover's
      1px border instead of stacking alongside it (the double-line
      artifact on dark theme). All styling lives in
      `.bundle-cover-overflow-overlay` in `application.css`. %>
  <% if overflow_n > 0 %>
    <div class="bundle-cover-overflow-overlay">
      <%= render(StatusBadgeComponent.new(label: "+#{overflow_n}", kind: :neutral)) %>
    </div>
  <% end %>
</div>
