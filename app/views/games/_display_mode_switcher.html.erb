<%# Phase 27 — 01d. Display mode switcher.

    2026-05-11 polish — three options in this fixed order:
      `[default][grid][list]`

    `default` is the canonical nested-shelves layout (the enum value
    `shelves_by_letter`). The URL alias `default` resolves to that
    enum on the GET round-trip, so links / shareable URLs read as
    `?display=default` instead of leaking the verbose enum key.

    Three `button_to` forms PATCHing `/users/games_preferences` with
    `mode=default|grid|list`. No JS — pure form posts. The controller
    redirects back to `/games?display=<mode>` so the resolved mode
    renders immediately AND the user's preference persists for
    fresh-tab visits.

    Active mode renders with the `active` class (no red — the
    bracketed-link convention reserves red for destructive actions).

    Renders inside the filter row's right slot (was previously above
    the filter row).

    Locals:
      active_mode  Symbol — one of :shelves_by_letter, :grid, :list.
%>
<%
  # `default` is the URL/UI alias for the canonical enum
  # `shelves_by_letter`. The form `mode=` input still carries the
  # alias so the Users::GamesPreferencesController re-resolves the
  # alias on PATCH.
  modes = [
    [ "default", "default", :shelves_by_letter ],
    [ "grid",    "grid",    :grid              ],
    [ "list",    "list",    :list              ]
  ]
%>
<div class="display-mode-switcher"
     data-active-mode="<%= active_mode %>"
     style="display: inline-flex; gap: 4px; align-items: baseline;">
  <% modes.each do |mode_value, mode_label, mode_enum_key| %>
    <% is_active = (active_mode.to_sym == mode_enum_key) %>
    <%= button_to users_games_preferences_path,
                  params: { mode: mode_value },
                  method: :patch,
                  form: { style: "display: inline;", data: { turbo: false } },
                  class: ("bracketed" + (is_active ? " active" : "")),
                  data: { display_mode: mode_value } do %>
      [<span class="bl"><%= mode_label %></span>]
    <% end %>
  <% end %>
</div>
