<%# Phase 27 — 01d. List display mode.
    Flat alphabetically-sorted table — no letter-group headings.

    Columns (post 2026-05-11 polish v2):
      1. Bulk-select header checkbox `[ ]` + per-row checkbox `[ ]`
         (real checkboxes, drive the bulk action toolbar).
      2. Cover thumbnail (small — uses `t_cover_small` IGDB variant).
      3. Title (linked to /games/:slug, no inline year). Bold when
         the game is not-yet-released.
      4. Genre — primary genre only (one chip per row). Falls back to
         the first linked genre when `primary_genre` isn't pinned yet.
         Singular header (`genre`), was previously plural (`genres`).
      5. Released (full date `mm-dd-yyyy`; em-dash when nil).
         Right-aligned (`.num`).
      6. Rating (`Games::RatingBadgeComponent` — bold colored integer;
         em-dash when `igdb_rating` is nil). Right-aligned (`.num`).
         2026-05-11 polish (Fix 2) retired the legacy `<NN>/100`
         literal here in favor of the tiered-color badge.
      7. Owned (was `platforms owned`). Renders the bracketed
         per-platform owned chips (placeholder em-dash until 01a/01f
         land the per-platform ownership shape on the row).

    Column widths are pinned via a `<colgroup>` whose `col` classes
    map to `--col-width-*` CSS variables (Fix 1, 2026-05-11). The
    select column is the canonical app-wide bulk-select width so
    listings across notifications, channels, projects, games, and
    videos share one footprint.

    Bulk-action toolbar (2026-05-11 polish v2):
      The table is wrapped in a `bulk-select` Stimulus controller.
      Header checkbox toggles all rows; per-row checkboxes drive a
      live `[sync N]` + `[delete N]` toolbar that navigates to
      `/syncs/game/:ids` / `/deletions/game/:ids` (full page) for
      action-screen confirmation. No JS confirm / alert anywhere.

    Locals:
      games  enumerable of Game records (typically @all_games).
%>
<%
  sorted_games = games.sort_by do |g|
    title = g.title.to_s.strip
    first = title[0]
    bucket = first && first.match?(/[A-Za-z]/) ? first.upcase : "{"
    [ bucket, title.downcase ]
  end
%>
<%# 2026-05-11 polish (Fix 3) — the `<h2>all</h2>` heading was hoisted
    out into `games/index.html.erb` so it sits ABOVE the filter row.
    The section's `margin-top` was tightened from `24px` to `12px` so
    the gap between the filter row's row 2 and the table reads as a
    single bound region — the filter chips scope the listing directly
    below them, not a 24-pixel gulf away. %>
<section class="all-games-list games-list-mode"
         data-display-mode="list"
         data-controller="bulk-select"
         data-bulk-select-entity-name-value="games"
         data-bulk-select-delete-type-value="game"
         data-bulk-select-sync-type-value="game"
         style="margin-top: 12px;">
  <% if games.any? %>
    <%# Bulk-action toolbar — `[sync N]` + `[delete N]` appear when
        at least one row is selected. Each action navigates full-page
        (`_top`) to the confirmation screen. The `count` target is the
        live `N` mirrored into both action labels via the controller. %>
    <div class="games-bulk-toolbar" data-bulk-select-target="actions" data-turbo-frame="_top">
      <div class="bulk-toolbar">
        <span class="action" data-bulk-select-target="count" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="syncAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="deleteAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
      </div>
    </div>

    <table class="list-table">
      <%# Fix 1 (2026-05-11) — pinned column widths via colgroup so the
          select / cover / genre / released / rating / owned columns
          stay narrow and the title column absorbs the leftover space. %>
      <colgroup>
        <col class="col-select">
        <col class="col-cover">
        <col class="col-title">
        <col class="col-genre">
        <col class="col-released">
        <col class="col-rating">
        <col class="col-owned">
      </colgroup>
      <thead>
        <tr>
          <th class="select-cell">
            <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
          </th>
          <th></th>
          <th>title</th>
          <th>genre</th>
          <th class="num">released</th>
          <th class="num">rating</th>
          <th>owned</th>
        </tr>
      </thead>
      <tbody>
        <% sorted_games.each do |game| %>
          <%
            not_released = game.release_date.blank? || game.release_date > Date.current
            released_display = game.release_date.present? ? game.release_date.strftime("%m-%d-%Y") : "—"
          %>
          <tr class="game-row" data-game-id="<%= game.id %>" data-game-job-state="idle" id="game_row_<%= game.id %>">
            <td class="select-cell job-indicator-cell">
              <%# Real `<input type="checkbox">` driving the bulk-select
                  controller. Per-row indicator (data-game-job-state)
                  is updated by the bulk job's Turbo Stream broadcasts
                  via the row's id. %>
              <%= render(CheckboxComponent.new(value: game.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
            </td>
            <td class="cover-cell">
              <% if game.cover_url.present? %>
                <%= image_tag game.cover_url(size: "t_cover_small"),
                              alt: game.title, loading: "lazy" %>
              <% else %>
                <%= image_tag image_path("game_cover_fallback_shelf_light.svg"),
                              alt: "no cover available", loading: "lazy",
                              data: { theme: "light" },
                              class: "game-cover-fallback game-cover-fallback--light" %>
                <%= image_tag image_path("game_cover_fallback_shelf_dark.svg"),
                              alt: "no cover available", loading: "lazy",
                              data: { theme: "dark" },
                              class: "game-cover-fallback game-cover-fallback--dark" %>
              <% end %>
            </td>
            <td class="title-cell">
              <%# Phase 28 §01a — edition rows show a muted parent
                  pointer above the title in flat mode. %>
              <% if game.edition? && game.version_parent.present? %>
                <div class="text-muted" style="font-size: 10px; margin-bottom: 2px;">
                  <%= render(BracketedLinkComponent.new(
                        label: "↳ #{game.version_parent.title}",
                        href: game_path(game.version_parent))) %>
                </div>
              <% end %>
              <%= link_to game.title, game_path(game),
                          class: ("not-released" if not_released) %>
              <%# `+N editions` badge for primaries with editions. %>
              <% if game.primary? %>
                <%= render(Games::EditionsBadgeComponent.new(game: game)) %>
              <% end %>
            </td>
            <td class="genre-cell">
              <%
                # Primary genre only. Falls back to the first linked
                # genre when `primary_genre` isn't pinned yet.
                primary = if game.respond_to?(:primary_genre) && game.primary_genre.present?
                            game.primary_genre
                          else
                            game.genres.first
                          end
                short = genre_short_name(primary)
              %>
              <% if short.present? %>
                <%= short %>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
            <td class="released-cell num text-muted">
              <%= released_display %>
            </td>
            <td class="rating-cell num">
              <%# Fix 2 (2026-05-11) — colored bold rating badge. Renders
                  the integer rating with a per-tier color; the missing-
                  rating case renders a muted em-dash inside the badge
                  so the cell never goes empty. %>
              <%= render(Games::RatingBadgeComponent.new(rating: game.igdb_rating)) %>
            </td>
            <%# 2026-05-11 polish (Fix 2) — owned cell now renders the
                shared `StatusBadgeComponent` with `yes` / `no` kinds so
                the column reads as a status, not a platform list. A
                game qualifies as `yes` when it has at least one
                `game_platform_ownership` row; otherwise `no`. The
                em-dash placeholder is reserved for genuinely
                indeterminate values (none arise on this surface today
                — every game can answer the question — but the fallback
                stays for defensive symmetry with the other cells). %>
            <td class="owned-cell">
              <% if game.game_platform_ownerships.any? %>
                <%= render(StatusBadgeComponent.new(label: "yes", kind: :yes)) %>
              <% else %>
                <%= render(StatusBadgeComponent.new(label: "no", kind: :no)) %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no games match this filter.</p>
  <% end %>
</section>
