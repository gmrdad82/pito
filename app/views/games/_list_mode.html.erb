<%# Phase 27 тАФ 01d. List display mode.
    Flat alphabetically-sorted table тАФ no letter-group headings. The
    earlier sticky `<tr class="letter-head">` rows rendered with a hard
    `background: #fff`, which in the dark theme manifested as harsh
    white spacer bars between rows. Users read them as unexplained
    whitespace rather than as section dividers, so they're gone. Sort
    order is preserved: titles are listed alphabetically (#-bucket
    items sink to the bottom via the same key the picker used).

    Columns (post-polish layout):
      1. Cover thumbnail (small тАФ uses `t_cover_small` IGDB variant)
      2. Title (linked to /games/:slug, no inline year)
      3. Release year (muted, blank when missing)
      4. Rating (`тШЕ NN` muted via GamesHelper::STAR_GLYPH; blank when
         `igdb_rating` is nil)
      5. Platforms owned (placeholder тАФ Phase 27 01a/01f land the
         per-platform ownership shape; until then we render a "тАФ".)
      6. Genres тАФ primary genre only (one chip per row). When
         `primary_genre` isn't yet shipped on the model, falls back to
         the first linked genre so multi-genre rows still surface a
         single label instead of a comma-joined list.
      7. Status (single token тАФ `recorded`, `released`, `scheduled`,
         `unreleased`).

    Locals:
      games  enumerable of Game records (typically @all_games).
%>
<%
  sorted_games = games.sort_by do |g|
    title = g.title.to_s.strip
    first = title[0]
    bucket = first && first.match?(/[A-Za-z]/) ? first.upcase : "{"
    [ bucket, title.downcase ]
  end
%>
<section class="all-games-list games-list-mode"
         data-display-mode="list"
         style="margin-top: 24px;">
  <h2 style="margin-bottom: 8px;">all games</h2>

  <% if games.any? %>
    <style>
      .games-list-mode table.list-table { width: 100%; border-collapse: collapse; }
      .games-list-mode table.list-table th,
      .games-list-mode table.list-table td { text-align: left; padding: 4px 8px; border-bottom: 1px solid var(--color-border); vertical-align: middle; }
      .games-list-mode td.cover-cell img { width: 32px; height: 42px; object-fit: cover; display: block; }
    </style>

    <table class="list-table">
      <thead>
        <tr>
          <th></th>
          <th>title</th>
          <th>release year</th>
          <th>rating</th>
          <th>platforms owned</th>
          <th>genres</th>
          <th>status</th>
        </tr>
      </thead>
      <tbody>
        <% sorted_games.each do |game| %>
          <tr class="game-row" data-game-id="<%= game.id %>">
            <td class="cover-cell">
              <% if game.cover_url.present? %>
                <%= image_tag game.cover_url(size: "t_cover_small"),
                              alt: game.title, loading: "lazy" %>
              <% else %>
                <%# Theme-aware fallback. Mirrors the `Games::CoverComponent`
                    and `_tile.html.erb` missing-cover treatment: emit both
                    light + dark SVGs, let the `.game-cover-fallback--{light,dark}`
                    CSS rule pick the visible one based on `<html data-theme>`.
                    The shelf-variant SVG is the smallest existing asset and
                    downscales cleanly into the 32x42 list-cell slot. %>
                <%= image_tag image_path("game_cover_fallback_shelf_light.svg"),
                              alt: "no cover available", loading: "lazy",
                              data: { theme: "light" },
                              class: "game-cover-fallback game-cover-fallback--light" %>
                <%= image_tag image_path("game_cover_fallback_shelf_dark.svg"),
                              alt: "no cover available", loading: "lazy",
                              data: { theme: "dark" },
                              class: "game-cover-fallback game-cover-fallback--dark" %>
              <% end %>
            </td>
            <td class="title-cell">
              <%= link_to game.title, game_path(game) %>
            </td>
            <td class="release-year-cell text-muted">
              <%= game.release_year.presence || "тАФ" %>
            </td>
            <td class="rating-cell text-muted">
              <% if game.igdb_rating.present? %>
                <%= GamesHelper::STAR_GLYPH %> <%= format_game_rating(game.igdb_rating) %>
              <% else %>
                тАФ
              <% end %>
            </td>
            <td class="platforms-cell text-muted">тАФ</td>
            <td class="genres-cell">
              <%
                # Primary genre only. `Game#primary_genre` association is
                # being added by the in-flight games-polish v2 agent
                # (column `primary_genre_id` is already in schema). Until
                # the model API + backfill land, fall back to the first
                # linked genre via `game.genres.first` тАФ keeps the cell
                # single-valued instead of a comma-joined list.
                primary = if game.respond_to?(:primary_genre) && game.primary_genre.present?
                            game.primary_genre
                          else
                            game.genres.first
                          end
                short = genre_short_name(primary)
              %>
              <% if short.present? %>
                <%= short %>
              <% else %>
                <span class="text-muted">тАФ</span>
              <% end %>
            </td>
            <td class="status-cell">
              <%
                status = if game.videos.exists?
                           "recorded"
                         elsif game.release_date.present? && game.release_date <= Date.current
                           "released"
                         elsif game.release_date.present?
                           "scheduled"
                         else
                           "unreleased"
                         end
              %>
              <%= status %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no games match this filter.</p>
  <% end %>
</section>
