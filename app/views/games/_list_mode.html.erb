<%# Phase 27 — 01d. List display mode.
    Alphabetic, grouped by first letter of the game title. Each
    letter group is preceded by a sticky `<tr class="letter-head">`
    row carrying CSS `position: sticky`. Empty letters do not render
    a heading row — letters with zero games are simply absent.

    Non-alphabetic title starts (digits, symbols) bucket into "#".
    The grouping uses `title.to_s.strip.first.upcase` and falls back
    to "#" when the first character is outside [A-Z].

    Columns (locked decisions in the umbrella spec):
      1. Cover thumbnail (small — uses `t_cover_small` IGDB variant)
      2. Title (linked to /games/:slug)
      3. Platforms owned (placeholder — Phase 27 01a/01f land the
         per-platform ownership shape; until then we render a "—".)
      4. Genres (comma-separated, blank when empty)
      5. Status (single token — `recorded`, `released`, `scheduled`,
         `unreleased`).

    Sticky-heading CSS is intentionally inlined here (rather than
    `app/assets`) so the partial is self-contained and the system
    spec can verify the `position: sticky` declaration without
    chasing across files.

    Locals:
      games  enumerable of Game records (typically @all_games).
%>
<%
  bucketed = games.group_by do |game|
    first = game.title.to_s.strip[0]
    if first && first.match?(/[A-Za-z]/)
      first.upcase
    else
      "#"
    end
  end

  ordered_letters = bucketed.keys.sort_by do |letter|
    letter == "#" ? "{" : letter
  end
%>
<section class="all-games-list games-list-mode"
         data-display-mode="list"
         style="margin-top: 24px;">
  <h2 style="margin-bottom: 8px;">all games</h2>

  <% if games.any? %>
    <style>
      .games-list-mode table.list-table { width: 100%; border-collapse: collapse; }
      .games-list-mode table.list-table th,
      .games-list-mode table.list-table td { text-align: left; padding: 4px 8px; border-bottom: 1px solid #eee; vertical-align: middle; }
      .games-list-mode tr.letter-head td {
        position: sticky;
        top: 0;
        background: #fff;
        font-weight: bold;
        border-bottom: 1px solid #ddd;
        z-index: 1;
      }
      .games-list-mode td.cover-cell img { width: 32px; height: 42px; object-fit: cover; display: block; }
      .games-list-mode td.cover-cell .text-muted { font-size: 10px; }
    </style>

    <table class="list-table">
      <thead>
        <tr>
          <th></th>
          <th>title</th>
          <th>platforms owned</th>
          <th>genres</th>
          <th>status</th>
        </tr>
      </thead>
      <tbody>
        <% ordered_letters.each do |letter| %>
          <tr class="letter-head" data-letter="<%= letter %>">
            <td colspan="5"><%= letter %></td>
          </tr>
          <% bucketed[letter].sort_by { |g| g.title.to_s.downcase }.each do |game| %>
            <tr class="game-row" data-game-id="<%= game.id %>">
              <td class="cover-cell">
                <% if game.cover_url.present? %>
                  <%= image_tag game.cover_url(size: "t_cover_small"),
                                alt: game.title, loading: "lazy" %>
                <% else %>
                  <span class="text-muted">[no cover]</span>
                <% end %>
              </td>
              <td class="title-cell">
                <%= link_to game.title, game_path(game) %>
                <% if game.release_year.present? %>
                  <span class="text-muted">(<%= game.release_year %>)</span>
                <% end %>
              </td>
              <td class="platforms-cell text-muted">—</td>
              <td class="genres-cell">
                <% genre_names = game.genres.map { |g| genre_short_name(g) }.compact %>
                <% if genre_names.any? %>
                  <%= genre_names.join(", ") %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td class="status-cell">
                <%
                  status = if game.videos.exists?
                             "recorded"
                           elsif game.release_date.present? && game.release_date <= Date.current
                             "released"
                           elsif game.release_date.present?
                             "scheduled"
                           else
                             "unreleased"
                           end
                %>
                <%= status %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no games match this filter.</p>
  <% end %>
</section>
