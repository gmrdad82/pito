<%# Phase 27 §01f — Per-platform ownership editor (revamped 2026-05-12).
    Dedicated page (separate from `/games/:id/edit`). Layout mirrors
    the show / edit pages: narrow cover pane + wide form pane. The
    editor itself is a single row of bracketed checkboxes — one per
    platform — followed by the [save] [cancel] footer. No subtitle,
    no per-row metadata.
%>
<% content_for(:title, t("games.platform_ownerships.edit_title", title: @game.title)) %>
<% breadcrumb([ t("games.breadcrumb_root"), games_path ], [ @game.title, game_path(@game) ], t("games.platform_ownerships.breadcrumb")) %>

<div class="pane-row">
  <div class="pane pane--narrow">
    <%= render "shared/igdb_cover", game: @game, size: "t_cover_big" %>

    <h1 style="margin: 8px 0 4px 0;"><%= @game.title %></h1>
    <p class="text-muted" style="margin: 0 0 8px 0;">
      <% if @game.release_year %><%= @game.release_year %><% else %><%= t("common.em_dash") %><% end %>
    </p>
  </div>

  <div class="pane pane--wide">
    <h2 style="margin-top: 0;"><%= t("games.platform_ownerships.heading") %></h2>

    <% if @form_error.present? %>
      <div class="text-danger" style="margin: 0 0 12px 0;">
        <p style="margin: 0;"><%= @form_error %></p>
      </div>
    <% end %>

    <%= form_with(url: game_platform_ownerships_path(@game),
                  method: :patch,
                  data: { turbo: false }) do %>
      <%= render(Game::PlatformOwnershipEditorComponent.new(
            game: @game,
            platforms: @platforms,
            owned_platform_ids: @owned_platform_ids
          )) %>

      <div class="dot-list" style="margin-top: 12px;">
        <button type="submit" class="bracketed" style="background: none; border: none; padding: 0; cursor: pointer;">[<span class="bl"><%= t("common.actions.save") %></span>]</button>
        <%= render(BracketedLinkComponent.new(label: t("common.actions.cancel"), href: game_path(@game))) %>
      </div>
    <% end %>
  </div>
</div>
