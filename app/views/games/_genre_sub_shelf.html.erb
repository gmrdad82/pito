<%# Phase 27 §01c-v2 — Genre sub-shelf row.
    One sub-shelf per non-empty genre. Renders the heading + count +
    optional `[see all]` link via `::ShelfComponent`, then a
    horizontally scrolling row of bare covers rendered through
    `Game::GenreTileComponent` (a thin wrapper over
    `Game::CoverComponent(variant: :shelf)`).

    Genre and bundle sub-shelves render bare covers at `:shelf` so
    the row stays dense and image-driven; the rich `Game::GameTile
    Component(variant: :shelf)` (title + meta + chips + editions
    badge) is reserved for the LETTER shelves on `/games`.

    Game ordering — alphabetical by `LOWER(games.title)`. Cap — 30
    tiles; beyond that the user is expected to switch to grid / list
    mode for the long tail. The `[see all]` link targets
    `/games?genre=<slug-or-id>` (slug when present, id fallback).

    Phase 27 follow-up (2026-05-11) — primary-genre scoping. The
    sub-shelf now reads `Game.where(primary_genre_id: genre.id)` so
    each game appears in EXACTLY ONE sub-shelf (the row whose
    `primary_genre_id` matches). Multi-genre games no longer duplicate
    across every linked genre — `Game::PrimaryGenrePicker` chose one
    canonical pick at save time.

    Locals:
      genre        Genre — the row whose sub-shelf this represents.
      batch_slice  Optional Hash `{ count: Integer, games: [Game,...] }`
                   pre-computed by `Games::GenreShelfBatch` (P27
                   reviewer follow-up #2). When provided, the partial
                   reads count + tile list from the slice instead of
                   firing a `count` + `limit(30)` pair per render. When
                   absent (isolated view specs), the partial falls
                   back to its in-partial count + fetch so the spec
                   suite keeps its independence.
%>
<%
  genre = local_assigns.fetch(:genre)
  cap = 30
  batch_slice = local_assigns[:batch_slice]
  if batch_slice
    total_count = batch_slice.fetch(:count, 0)
    games = batch_slice.fetch(:games, [])
  else
    base = Game.where(primary_genre_id: genre.id)
    total_count = base.count
    games = base.order(Arel.sql("LOWER(games.title)")).limit(cap).to_a
  end
  href = if genre.slug.present?
           games_path(genre: genre.slug)
         else
           games_path(genre: genre.id)
         end
%>
<%= render(::ShelfComponent.new(
      heading: genre_display_name(genre),
      count: total_count,
      heading_level: :h3,
      extra_classes: "sub-shelf sub-shelf--genre",
      shelf_kind: "genre-sub",
      data: { genre_id: genre.id },
      section_style: "margin-top: 12px;",
      heading_style: "font-size: 13px;",
      heading_margin: "4px",
      row_classes: "sub-shelf-row",
      more_href: (total_count > cap ? href : nil)
    )) do %>
  <% games.each do |game| %>
    <%= render(Game::GenreTileComponent.new(game: game)) %>
  <% end %>
<% end %>
