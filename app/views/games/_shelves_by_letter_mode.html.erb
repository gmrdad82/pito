<%# Phase 27 — 01d. Shelves-by-letter display mode.
    One horizontal shelf per first-letter group. Empty letters are
    NOT rendered (locked decision in the umbrella). Non-alphabetic
    title starts (digits, symbols) bucket into "#".

    Each shelf reuses the existing `games/shelf` partial so the
    skinned horizontal-scroll affordance, the `steam-shelf` Stimulus
    controller, and the bracketed `[see all]` ceremony come for free.
    Tiles use the existing `games/tile` partial.

    Locals:
      games  enumerable of Game records (typically @all_games).
%>
<%
  bucketed = games.group_by do |game|
    first = game.title.to_s.strip[0]
    if first && first.match?(/[A-Za-z]/)
      first.upcase
    else
      "#"
    end
  end

  ordered_letters = bucketed.keys.sort_by do |letter|
    letter == "#" ? "{" : letter
  end
%>
<section class="all-games-shelves-by-letter games-shelves-by-letter-mode"
         data-display-mode="shelves_by_letter"
         style="margin-top: 24px;">
  <h2 style="margin-bottom: 8px;">all</h2>

  <% if games.any? %>
    <% ordered_letters.each do |letter| %>
      <%= render "games/shelf",
                 title: letter,
                 collection: bucketed[letter].sort_by { |g| g.title.to_s.downcase },
                 tile_partial: "games/tile" %>
    <% end %>
  <% else %>
    <p class="text-muted">no games match this filter.</p>
  <% end %>
</section>
