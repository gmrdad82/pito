<%# Single conversation row — used in the sidebar list and for Turbo Stream row-replace.
    Locals:
      conversation — responds to #uuid, #display_name
      current      — boolean, true when this is the active conversation
      timestamp    — pre-formatted timestamp string (may be nil for Turbo replace path)
      ai           — optional boolean: conversation carries :ai messages (list path
                     precomputes it; when absent the row asks the DB itself)

    Structure: a positioning shell (.pito-conversation-row) holds a sliding
    content layer (.pito-conversation-row__content) over a red Delete button
    revealed by the MOBILE swipe-left gesture (pito--resume). The button is
    display:none on desktop (gesture is mobile-only; see application.css). The
    content layer keeps the .pito--rename-display span and all attributes the
    pito--rename / pito--resume controllers depend on. %>
<% if conversation.deleting? %>
  <%# Async delete in flight — same row id (so the cable broadcast targets/removes
      it) but a non-interactive shimmering-dots placeholder (reused ShimmerText).
      The dot run is longer than the row and clipped, filling the width. %>
  <div id="conversation_row_<%= conversation.uuid %>"
       class="pito-conversation-row relative overflow-hidden rounded"
       data-conversation-uuid="<%= conversation.uuid %>">
    <div class="pito-conversation-row__content py-1 px-2 overflow-hidden whitespace-nowrap">
      <%= render(Pito::Shell::ShimmerTextComponent.new(text: ". " * 60)) %>
    </div>
  </div>
<% else %>
<div id="conversation_row_<%= conversation.uuid %>"
     class="pito-conversation-row relative overflow-hidden rounded cursor-pointer <%= "is-current" if current %>"
     data-conversation-uuid="<%= conversation.uuid %>"
     data-controller="pito--rename"
     data-pito--rename-url-value="/chat/<%= conversation.uuid %>">
  <%# Revealed beneath the content layer; only visible once swiped open (mobile). %>
  <button type="button"
          class="pito-conversation-row__delete text-red"
          data-conversation-delete>
    <%= Pito::Copy.render("pito.copy.conversations.delete_button") %>
  </button>
  <%# Sliding content layer — opaque (bg-root on mobile) so it hides the button. %>
  <div class="pito-conversation-row__content flex justify-between items-baseline py-1 px-2 hover:bg-bg-hover">
    <%# The name + optional AI-thread sparkle; min-w-0 keeps truncate working
        inside the nested flex, and the badge never gets clipped by it. List
        renders pass `ai:` precomputed; single-row Turbo replaces fall back
        to one EXISTS. %>
    <span class="flex items-baseline gap-1 min-w-0 mr-2">
      <span class="text-fg truncate pito--rename-display"><%= conversation.display_name %></span>
      <%= render(Pito::Ai::BadgeComponent.new(
            ai: local_assigns.key?(:ai) ? ai : conversation.events.exists?(kind: "ai")
          )) %>
    </span>
    <% if current %>
      <span class="text-cyan shrink-0"><%= Pito::Copy.render("pito.copy.conversations.current_marker") %></span>
    <% else %>
      <span class="text-fg-dim shrink-0"><%= timestamp %></span>
    <% end %>
  </div>
</div>
<% end %>
