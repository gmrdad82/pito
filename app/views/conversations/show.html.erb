<%# Chat shell page for a specific conversation (/chat/:uuid). %>
<%# Identical layout to terminal/show; stream targets the conversation uuid. %>

<%= turbo_stream_from "pito:conversation:#{@conversation.uuid}" %>

<div class="flex flex-col" style="height: 100vh;">
  <div id="pito-scrollback" class="pito-thin-scrollbar" style="flex: 1; overflow-y: auto; padding: 32px 5px 20px;"
       data-controller="pito--scrollback pito--quick-run pito--cable-health pito--lasthashtag">
    <%# Group events by turn so a refresh reproduces the same per-turn containers
        the cable broadcasts build live (echo + its results stay together). %>
    <%# The L2 snapshot: assembled turn containers + L1 fragments + meta fills,
        one cache read on a warm reload (0.9.0 Phases 5–6). Markup identical to
        what the cable broadcasts build live. %>
    <%= @scrollback_html.html_safe %>
  </div>

  <%# Scroll-nav pills — fixed-positioned, no effect on flex layout. %>
  <%= render Pito::Shell::ScrollNavComponent.new %>

  <%# Horizontal padding lives in CSS (17.11): 5px on mobile to match the
      scrollback's 5px, 0 on desktop to match the centered .pito-turn (which has
      none) so the chatbox left border lines up with the messages. %>
  <div class="pito-conversation-col" style="padding-bottom: 32px;">
    <%# CTXF5: meter only inside an authenticated conversation — never for
        unauthenticated visitors, start_screen, or not_found. %>
    <% if @authenticated %>
      <%= render Pito::Shell::ContextMeterComponent.new(
            event_count: @event_count,
            conversation_name: (@conversation.named? ? @conversation.display_name : nil)
          ) %>
    <% end %>
    <%# Restore the conversation's last channel scope (shift+tab) and stats period
        (shift+space) so a reload keeps them; the chat-form controller persists
        each change back via PATCH /chat/:uuid. %>
    <% filter = Current.session.present? ? {
         channel: @channels.any? ? @conversation.scope_channel : "none",
         period: @conversation.stats_period,
         channels: @channels.any? ? ["@all"] + @channels : []
       } : nil %>
    <% form_data = { controller: "pito--chat-form", turbo: true } %>
    <% if filter %>
      <% form_data[:pito__chat_form_channels_value] = filter[:channels].to_json %>
      <% form_data[:pito__chat_form_periods_value] = '["7d","28d","3m","1y","lifetime"]' %>
      <% form_data[:pito__chat_form_uuid_value] = @conversation.uuid %>
    <% end %>
    <%= form_with url: chat_path, method: :post,
                  data: form_data,
                  class: "chatbox-form" do |form| %>
      <%= form.hidden_field :uuid, value: @conversation.uuid %>
      <%= form.hidden_field :input, data: { pito__chat_form_target: "hiddenInput" } %>
      <%# Scrollback width at send time — lets `list` auto-fill table columns to fit. %>
      <%= form.hidden_field :viewport_width, data: { pito__chat_form_target: "viewportWidth" } %>

      <%# SECURITY: only an authenticated session may see the conversation's typed
          history, draft, and title. Unauthenticated visitors get a blank chatbox
          (so they can /login) with none of the conversation's contents. %>
      <%
        sent_history = @authenticated ? @conversation.turns
                         .where(input_kind: [ :slash, :chat, :hashtag ])
                         .reorder(position: :desc)
                         .limit(50)
                         .map(&:display_text) : []

        # Seed the showcase with the last turn's suggestions (or compute the seed
        # set when there are no completed turns yet). Auth-gated: unauthenticated
        # visitors see a blank chatbox and must /login — don't leak entity IDs.
        initial_showcase = if @authenticated
          last_turn_with_suggestions = @conversation.turns
            .where.not(completed_at: nil)
            .order(:position)
            .last
          if last_turn_with_suggestions&.suggestions.present?
            last_turn_with_suggestions.suggestions
          else
            Pito::Showcase::Builder.call(conversation: @conversation)
          end
        else
          []
        end
      %>
      <%= render(Pito::Shell::ChatboxComponent.new(
            state: :default,
            filter: filter,
            input_data: { pito__chat_form_target: "inputField" },
            initial_value: @authenticated ? @conversation.draft.to_s : "",
            draft_uuid: @conversation.uuid,
            conversation_title: @authenticated ? (@conversation.named? ? @conversation.display_name : nil) : nil,
            history: sent_history,
            suggestions: initial_showcase
          )) %>
    <% end %>

    <div class="flex items-center" style="margin-top: 8px;">
      <div style="margin-left: 10px;" data-controller="pito--dots">
        <%= render(Pito::Shell::PostCommandDotsComponent.new) %>
      </div>
      <div id="pito-mini-status" data-pito--home-transition-target="miniStatusSlide" style="margin-left: auto;">
        <%= render(Pito::Shell::MiniStatusComponent.new(
              mode: :connection,
              state: Current.session.present?,
              notifications: Notification.unread.count,
              show_notifications: true
            )) %>
      </div>
    </div>
  </div>
</div>
