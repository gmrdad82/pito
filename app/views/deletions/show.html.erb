<% content_for(:title, "delete #{@type.pluralize}") %>
<% breadcrumb([@type.pluralize, cancel_path_for(@type)], "delete #{number_with_delimiter(@items.length)} #{@type}#{'s' if @items.length != 1}") %>

<div id="delete-content">
  <div style="margin-bottom: 8px;">
    <h1><%= t("deletions.show.heading", count: @items.length, type: @type) %></h1>
    <p class="text-muted" style="margin-top: 2px;"><%= t("deletions.show.body", count: @items.length, type: @type) %></p>
  </div>

  <table>
    <thead>
      <tr>
        <th class="col-action"></th>
        <% case @type %>
        <% when "channel" %>
          <th>URL</th>
          <th class="num">starred</th>
          <th class="num">synced</th>
          <th class="num">videos</th>
        <% when "video" %>
          <th>YouTube id</th>
          <th>channel</th>
          <th class="num">views</th>
          <th class="num">likes</th>
          <th class="num">chats</th>
          <th class="num">watch</th>
          <th class="num">starred</th>
        <% when "project" %>
          <th>name</th>
          <th class="num">footage</th>
          <th class="num">timelines</th>
        <% when "game" %>
          <th><%= t("deletions.show.col.title") %></th>
          <th><%= t("deletions.show.col.publisher") %></th>
          <th><%= t("deletions.show.col.bundles") %></th>
        <% when "timeline" %>
          <th>title</th>
          <th>project</th>
          <th class="num">state</th>
        <% when "bundle" %>
          <th><%= t("deletions.show.col.name") %></th>
          <th class="num"><%= t("deletions.show.col.members") %></th>
        <% when "video_game_link" %>
          <th>video</th>
          <th>kind</th>
          <th>target</th>
          <th class="num">primary</th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @items.each do |item| %>
        <tr>
          <td class="col-action">&nbsp;&nbsp;&nbsp;&nbsp;</td>
          <% case @type %>
          <% when "channel" %>
            <td title="<%= item.channel_url %>" style="max-width: 360px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= item.channel_url %></td>
            <td class="num"><%= item.star? ? "yes" : "no" %></td>
            <td class="num">
              <% if item.last_synced_at.present? %>
                <%= compact_time_ago(item.last_synced_at) %>
              <% else %>
                —
              <% end %>
            </td>
            <td class="num"><%= number_with_delimiter(item.videos.count) %></td>
          <% when "video" %>
            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;"><%= item.youtube_video_id %></td>
            <td><%= item.channel.channel_url %></td>
            <td class="num"><%= number_with_delimiter(item.total_views) %></td>
            <td class="num"><%= number_with_delimiter(item.total_likes) %></td>
            <td class="num"><%= number_with_delimiter(item.total_comments) %></td>
            <td class="num"><%= format_video_watch_time(item.total_watch_time) %></td>
            <td class="num"><%= item.star? ? "yes" : "no" %></td>
          <% when "project" %>
            <td><%= item.name %></td>
            <td class="num"><%= number_with_delimiter(item.footages.count) %></td>
            <td class="num"><%= number_with_delimiter(item.timelines.count) %></td>
          <% when "game" %>
            <td><%= item.title %></td>
            <td><%= item.publisher || t("common.em_dash") %></td>
            <td>
              <% names = item.bundles.order(:name).pluck(:name) %>
              <%= names.any? ? names.join(", ") : t("common.em_dash") %>
            </td>
          <% when "timeline" %>
            <td><%= item.title %></td>
            <td><%= item.project.name %></td>
            <td class="num"><%= item.state %></td>
          <% when "bundle" %>
            <td><%= item.name %></td>
            <td class="num"><%= number_with_delimiter(item.bundle_members.count) %></td>
          <% when "video_game_link" %>
            <td>video #<%= item.video_id %></td>
            <td><%= item.link_type %></td>
            <td>
              <% target = item.target %>
              <% if target.respond_to?(:title) %>
                <%= target.title %>
              <% elsif target.respond_to?(:name) %>
                <%= target.name %>
              <% else %>
                —
              <% end %>
            </td>
            <td class="num"><%= item.is_primary? ? "yes" : "no" %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div id="action-footer">
    <%= render "shared/action_screen",
      submit_label: "[#{t('common.actions.delete_short')}]",
      cancel_path: @cancel_path,
      form_url: "/deletions/#{@type}/#{@items.map(&:id).join(",")}",
      destructive: true %>
  </div>
</div>
