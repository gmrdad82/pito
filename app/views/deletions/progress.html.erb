<% content_for(:title, "deleting #{@type.pluralize}") %>
<% breadcrumb([@type.pluralize, cancel_path_for(@type)], "deleting #{number_with_delimiter(@items.length)} #{@type}#{'s' if @items.length != 1}") %>

<%= turbo_stream_from "bulk_operation_#{@operation.id}" %>

<div style="margin-bottom: 8px;" data-controller="operation-progress" data-operation-progress-url-value="<%= status_bulk_operation_path(@operation, format: :json) %>" data-operation-progress-total-value="<%= @items.length %>">
  <h1>deleting <%= number_with_delimiter(@items.length) %> <%= @type %><%= 's' if @items.length != 1 %></h1>
  <div id="operation_progress" style="margin-top: 2px;">
    <% bar_width = 30 %>
    <span class="text-muted">[<%= "." * bar_width %>] 0/<%= number_with_delimiter(@items.length) %></span>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th class="col-action"></th>
      <% if @type == "channel" %>
        <th>URL</th>
        <th class="num">starred</th>
        <th class="num">videos</th>
      <% else %>
        <th>YouTube id</th>
        <th>channel</th>
        <th class="num">views</th>
        <th class="num">likes</th>
        <th class="num">chats</th>
        <th class="num">watch</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @operation.bulk_operation_items.order(:id).each do |op_item| %>
      <% item = @items.find { |it| it.id == op_item.target_id } %>
      <tr id="item_<%= op_item.id %>">
        <td class="col-action" id="item_status_<%= op_item.id %>"><span class="dot-loader" style="--loader-delay: -<%= rand(0.0..0.75).round(2) %>s"></span></td>
        <% if @type == "channel" && item %>
          <td title="<%= item.channel_url %>" style="max-width: 360px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= item.channel_url %></td>
          <td class="num"><%= item.star? ? "yes" : "no" %></td>
          <td class="num"><%= number_with_delimiter(item.videos.count) %></td>
        <% elsif @type == "video" && item %>
          <td><%= item.youtube_video_id %></td>
          <td><%= item.channel&.channel_url %></td>
          <td class="num"><%= number_with_delimiter(item.total_views) %></td>
          <td class="num"><%= number_with_delimiter(item.total_likes) %></td>
          <td class="num"><%= number_with_delimiter(item.total_comments) %></td>
          <td class="num"><%= format_video_watch_time(item.total_watch_time) %></td>
        <% else %>
          <td colspan="6">(unknown)</td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>

<div style="margin-top: 12px;">
  <%= render(BracketedLinkComponent.new(label: "back", href: @cancel_path)) %>
</div>
