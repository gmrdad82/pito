<% content_for(:title, "footages") %>

<div style="max-width: 1100px;">
  <h1>footages</h1>
  <p class="text-muted" style="margin-bottom: 8px;">footage rows are scoped to projects — open a project to see its footage pane.</p>

  <% if @footages.any? %>
    <table>
      <thead>
        <tr>
          <th>filename</th>
          <th>project</th>
          <th>kind</th>
          <th>resolution</th>
        </tr>
      </thead>
      <tbody>
        <% @footages.each do |footage| %>
          <tr>
            <td><%= link_to footage.filename, edit_footage_path(footage) %></td>
            <td><%= footage.project.name %></td>
            <td><%= footage.kind %></td>
            <td><%= footage.resolution || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no footages yet.</p>
  <% end %>
</div>
