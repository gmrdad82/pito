<%# Phase 11 §01a — End-screen row partial. Used both for persisted
    rows (rendered server-side) and for new rows added by the
    `nested-form` Stimulus controller. Per-row `[remove]` flips
    `_destroy` to `1` and hides the row.

    `kind: none` is the explicit "no end-screen needed" row. The
    controller `collapse_end_screens_if_none!` collapses every other
    submitted row away on save so the model invariant holds.

    Locals:
      `f` — the nested form builder for `video_end_screens`. %>
<div data-nested-form-target="row" style="margin-bottom: 4px;">
  <%= f.hidden_field :_destroy, data: { nested_form_target: "destroyFlag" } %>

  <label style="font-size: 11px; margin-right: 4px;">kind</label>
  <%= f.select :kind,
        VideoEndScreen.kinds.keys.map { |k| [ k.tr("_", " "), k ] },
        { include_blank: false },
        { style: "margin-right: 6px;" } %>

  <label style="font-size: 11px; margin-right: 4px;">target id</label>
  <%= f.text_field :target_id,
        style: "width: 160px; margin-right: 6px;",
        placeholder: "yt id" %>

  <label style="font-size: 11px; margin-right: 4px;">label</label>
  <%= f.text_field :target_label,
        maxlength: 100,
        style: "width: 160px; margin-right: 6px;",
        placeholder: "watch next" %>

  <button type="button"
          class="bracketed"
          data-action="nested-form#remove">
    [remove]
  </button>
</div>
