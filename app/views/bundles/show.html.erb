<%# Phase 14 §2 / Phase 27 follow-up (2026-05-17) — Bundle show.

    Two-pane layout: composite cover + metadata on the left, member
    list + add-member form on the right. The composite cover image
    falls back to `[no cover]` when the build has not landed yet; the
    "regenerating…" caption surfaces when a `BundleCoverBuild` job is
    in flight (best-effort detection in fake-Sidekiq mode).

    2026-05-17 simplification — the `bundle_type` discriminator and
    the IGDB-source metadata strip are gone; the only remaining
    metadata line is the member count. The `[ seed from igdb ]` and
    `last_error` callouts are removed along with the columns that fed
    them. %>
<% content_for(:title, @bundle.name) %>
<% breadcrumb([ "bundles", bundles_path ], @bundle.name) %>

<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "edit", href: edit_bundle_path(@bundle))) %>
    <%= render(BracketedLinkComponent.new(
      label: "-",
      href: deletions_path(type: "bundle", ids: @bundle.id),
      destructive: true)) %>
  </div>
<% end %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. Marker div — invisible, no layout impact. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@bundle, scope: Bundle, path_helper: method(:bundle_path)) %>></div>

<div class="pane-row">
  <%# Left pane — composite cover + bundle metadata. `pane--narrow`
      (280px) snugs the cover column so the right pane's member table +
      add-member form get the breathing room they need. Width revamp
      2026-05-10 — mirrors /games/:id. %>
  <div class="pane pane--narrow">
    <%= render "shared/composite_cover", bundle: @bundle, size: :full %>

    <h1 style="margin: 8px 0 4px 0;"><%= @bundle.name %></h1>
    <p class="text-muted" style="margin: 0 0 8px 0;">
      <%= @members.size %> member<%= 's' if @members.size != 1 %>
    </p>

    <% if @bundle.cover_rebuild_in_flight? %>
      <p class="text-muted" style="margin: 4px 0;">regenerating…</p>
    <% end %>
  </div>

  <%# Right pane — member list + add-member form. `pane--wide` (904px)
      keeps the search input, the picker dropdown, and the add-member
      table visible together without horizontal scroll. %>
  <div class="pane pane--wide">
    <h2 style="margin-top: 0;">members</h2>

    <% if @members.any? %>
      <table>
        <thead>
          <tr>
            <th>game</th>
            <th>release</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @members.each do |member| %>
            <%= render "bundle_members/member_row", member: member, bundle: @bundle %>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">no members yet.</p>
    <% end %>

    <h2 style="margin-top: 16px;">add member</h2>
    <p class="text-muted" style="margin: 0 0 4px 0; font-size: 11px;">
      pick a game from your library.
    </p>
    <%= form_with url: bundle_members_path(@bundle), method: :post, local: true,
                  data: { controller: "bundle-member-picker" } do |f| %>
      <input type="search"
             autocomplete="off"
             data-bundle-member-picker-target="input"
             data-action="input->bundle-member-picker#filter"
             placeholder="search your games…"
             style="width: 280px; padding: 4px 6px;
                    font-family: ui-monospace, monospace; font-size: 13px;" />
      <%= f.select :game_id,
                   options_for_select(member_picker_options(@bundle)),
                   { prompt: "—" },
                   data: { bundle_member_picker_target: "select" } %>
      <button type="submit" class="bracketed">[<span class="bl">add</span>]</button>
      <p data-bundle-member-picker-target="empty" hidden
         class="text-muted" style="margin-top: 4px; font-size: 11px;">
        no games match
      </p>
    <% end %>

    <%# Phase 14 §3 — linked videos. Lists every Video tied to this
        Bundle via `video_game_links`. %>
    <h2 style="margin-top: 16px;">linked videos</h2>
    <% bundle_links = @bundle.video_game_links.includes(:video).order(:id) %>
    <% if bundle_links.any? %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% bundle_links.each do |link| %>
          <% next unless link.video %>
          <li style="padding: 2px 0;">
            <%= link_to link.video.title.presence || link.video.youtube_video_id, video_path(link.video) %>
            <% if link.is_primary? %>
              <span class="bracketed-active">[★]</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted" style="margin: 0;">no linked videos yet.</p>
    <% end %>
  </div>
</div>
