<%# Phase 14 §3 — Steam-shelf revamp of `/bundles`.
    Flat wrapping grid of bundle composite covers. Each tile renders the
    composite + bundle name + member count via `bundles/_tile`. The
    table-shape from §2 is gone.

    Empty-state copy carries through from §2 / master-agent decision #10. %>
<% content_for(:title, "bundles") %>

<div style="max-width: 1100px;">
  <div class="dot-list" style="margin-bottom: 6px;">
    <h1>bundles</h1>
    <%= render(BracketedLinkComponent.new(label: "add bundle", href: new_bundle_path)) %>
  </div>

  <% if @bundles.any? %>
    <div class="bundles-grid"
         style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px; margin-top: 8px;">
      <% @bundles.each do |bundle| %>
        <%= render "bundles/tile", bundle: bundle %>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">no bundles yet. [ add bundle ] to create one.</p>
  <% end %>
</div>
