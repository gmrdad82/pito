<%# 2026-05-18 — `:bundle_add` omnisearch results partial.

    Locals:
      result  — Games::SearchService::Result struct
      query   — sanitized query string
      bundle  — Bundle instance (the modal's host bundle)

    Layout:
      - Local games section (top — fast Meilisearch hits).
      - Hairline.
      - IGDB section (bottom — upstream IGDB hits, may be empty when
        IGDB is unreachable, in which case the section header carries
        the error message).

    Per-row action:
      - Local game: `[add]` POSTs to /bundles/:id/members (member
        creates with that game's id).
      - IGDB row: NO `[add]` inside this mode. Adding from IGDB
        inside the bundle modal is a deliberate two-step (sync IGDB
        into the local library first, then add to the bundle). The
        IGDB section renders informationally so the user can spot
        upstream coverage but is not given a direct add-into-bundle
        affordance. %>
<%= turbo_frame_tag "omnisearch_results_bundle_add" do %>
  <% if query.blank? %>
    <p class="text-muted">type to search.</p>
  <% else %>
    <% if result.local_games.any? %>
      <section class="omnisearch-section">
        <h3 class="omnisearch-section-heading">in your library</h3>
        <ul class="omnisearch-list" style="list-style: none; padding: 0; margin: 0;">
          <% result.local_games.each do |game| %>
            <li class="omnisearch-row">
              <span style="flex: 1;">
                <%= game.title %>
                <% if game.release_year %>
                  <span class="text-muted">(<%= game.release_year %>)</span>
                <% end %>
              </span>
              <%= button_to bundle_members_path(bundle_id: bundle.id),
                            params: { game_id: game.id },
                            method: :post,
                            class: "bracketed",
                            form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl">add</span>]<% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <% if result.igdb.any? || result.igdb_error.present? %>
      <% if result.local_games.any? %>
        <hr class="hairline" style="margin: 12px 0;">
      <% end %>
      <section class="omnisearch-section">
        <h3 class="omnisearch-section-heading">on igdb</h3>
        <% if result.igdb_error.present? %>
          <p class="text-danger">igdb error: <%= result.igdb_error[:message] %></p>
        <% elsif result.igdb.empty? %>
          <p class="text-muted">no igdb results for '<%= query %>'.</p>
        <% else %>
          <ul class="omnisearch-list" style="list-style: none; padding: 0; margin: 0;">
            <% result.igdb.each do |row| %>
              <% release_year = row["first_release_date"].present? ? Time.at(row["first_release_date"]).utc.year : nil %>
              <li class="omnisearch-row">
                <span style="flex: 1;">
                  <%= row["name"] %>
                  <% if release_year %>
                    <span class="text-muted">(<%= release_year %>)</span>
                  <% end %>
                </span>
                <span class="text-muted">in igdb only</span>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>
    <% end %>

    <% if result.local_games.empty? && result.igdb.empty? && result.igdb_error.blank? %>
      <p class="text-muted">no results for '<%= query %>'.</p>
    <% end %>
  <% end %>
<% end %>
