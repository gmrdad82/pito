<%# 2026-05-18 — `:bundle_add` omnisearch results partial.

    Locals:
      result  — Games::SearchService::Result struct
      query   — sanitized query string
      bundle  — Bundle instance (the modal's host bundle)

    Layout:
      - Local games section (top — fast Meilisearch hits).
      - Hairline.
      - IGDB section (bottom — upstream IGDB hits, may be empty when
        IGDB is unreachable, in which case the section header carries
        the error message).

    Per-row action:
      - Local game: `[add]` POSTs to /bundles/:id/members (member
        creates with that game's id).
      - IGDB row: `[add]` POSTs to /bundles/:id/members/from_igdb
        which creates a Game stub with the IGDB id + title pre-seed,
        enqueues `GameIgdbSync` to populate the rest of the metadata
        async, and adds the new game to the bundle in one click.
        2026-05-18 — replaces the prior "in igdb only" muted-text
        affordance which forced the user to round-trip through
        `/games [+]` to add an IGDB game before adding it to the
        bundle. Defensively: if the IGDB id already maps to an
        existing local Game, the action behaves like a regular
        local-add (no duplicate Game row, no new sync). %>
<%= turbo_frame_tag "omnisearch_results_bundle_add" do %>
  <% if query.blank? %>
    <p class="text-muted"><%= t("games.omnisearch.placeholder_default") %></p>
  <% else %>
    <% if result.local_games.any? %>
      <section class="omnisearch-section">
        <h3 class="omnisearch-section-heading"><%= t("bundles.omnisearch.section_local") %></h3>
        <ul class="omnisearch-list" style="list-style: none; padding: 0; margin: 0;">
          <% result.local_games.each do |game| %>
            <li class="omnisearch-row">
              <span style="flex: 1;">
                <%= game.title %>
                <% if game.release_year %>
                  <span class="text-muted">(<%= game.release_year %>)</span>
                <% end %>
              </span>
              <%= button_to bundle_members_path(bundle_id: bundle.id),
                            params: { game_id: game.id },
                            method: :post,
                            class: "bracketed",
                            form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl"><%= t("common.actions.add") %></span>]<% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <% if result.igdb.any? || result.igdb_error.present? %>
      <% if result.local_games.any? %>
        <hr class="hairline" style="margin: 12px 0;">
      <% end %>
      <section class="omnisearch-section">
        <h3 class="omnisearch-section-heading"><%= t("games.omnisearch.section_igdb") %></h3>
        <% if result.igdb_error.present? %>
          <p class="text-danger"><%= t("games.omnisearch.igdb_error", msg: result.igdb_error[:message]) %></p>
        <% elsif result.igdb.empty? %>
          <p class="text-muted"><%= t("games.omnisearch.no_igdb_results", query: query) %></p>
        <% else %>
          <ul class="omnisearch-list" style="list-style: none; padding: 0; margin: 0;">
            <% result.igdb.each do |row| %>
              <% release_year = row["first_release_date"].present? ? Time.at(row["first_release_date"]).utc.year : nil %>
              <li class="omnisearch-row">
                <span style="flex: 1;">
                  <%= row["name"] %>
                  <% if release_year %>
                    <span class="text-muted">(<%= release_year %>)</span>
                  <% end %>
                </span>
                <%# 2026-05-18 — `[add]` posts the IGDB row to the
                    bundle's `from_igdb` endpoint which creates a Game
                    stub + adds it as a member + kicks off async IGDB
                    sync. `data: { turbo: false }` skips Turbo Drive so
                    the post redirects cleanly back to the bundle show
                    page and the modal goes away with the navigation. %>
                <%= button_to from_igdb_bundle_members_path(bundle_id: bundle.id),
                              params: { igdb_id: row["id"], title: row["name"] },
                              method: :post,
                              class: "bracketed",
                              form: { style: "display: inline; margin: 0;", data: { turbo: false } } do %>[<span class="bl"><%= t("common.actions.add") %></span>]<% end %>
              </li>
            <% end %>
          </ul>
        <% end %>
      </section>
    <% end %>

    <% if result.local_games.empty? && result.igdb.empty? && result.igdb_error.blank? %>
      <p class="text-muted"><%= t("games.omnisearch.no_results", query: query) %></p>
    <% end %>
  <% end %>
<% end %>
