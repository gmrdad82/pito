<% content_for(:title, "2FA challenge") %>
<% content_for(:hide_chrome, true) %>

<%# The form posts a single `code` param. The 6-box segmented input
    (TotpCodeInputComponent) writes a 6-digit string into a hidden
    `code` field; the backup-code fallback below writes the same
    `code` field with an 8-char alphanumeric value. Only one of the
    two is filled at a time — the backend tries TOTP first
    (`try_totp`) and falls back to backup-code consumption
    (`try_backup_code`) on the same `params[:code]` string. %>
<div style="max-width: 420px; margin: 24px 0;">
  <h1>2FA</h1>
  <p class="text-muted" style="margin-top: 2px;">
    enter the 6-digit code from your authenticator app.
  </p>

  <%= form_with url: login_totp_path, method: :post, data: { turbo: false } do %>
    <div style="margin-bottom: 12px;">
      <%= render TotpCodeInputComponent.new(field: :code, autofocus: true) %>
    </div>

    <%# Backup-code fallback — same `code` param. A non-empty value
        here overrides the hidden field written by the 6-box grid
        (the field appears later in the form so the browser submits
        the LAST value for repeated names). The bare input is the
        only path for an 8-char alphanumeric backup code; the
        6-digit grid cannot accept it. %>
    <details style="margin-bottom: 12px;">
      <summary class="text-muted" style="cursor: pointer;">
        no access to the authenticator? use a backup code
      </summary>
      <div style="margin-top: 8px;">
        <%= label_tag :code, "backup code" %><br>
        <%= text_field_tag :code, nil,
                           autocomplete: "off",
                           inputmode: "text",
                           maxlength: 8 %>
      </div>
    </details>

    <button type="submit" class="bracketed" style="cursor: pointer;">[<span class="bl">verify</span>]</button>
  <% end %>

  <p class="text-muted" style="margin-top: 16px;">
    not you?
    <%= render BracketedLinkComponent.new(label: "back to log in", href: login_path) %>
  </p>
</div>
