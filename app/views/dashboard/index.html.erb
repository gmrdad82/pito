<% content_for(:title, t("dashboard.index.title", default: "home")) %>
<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<%# Phase 2D (2026-05-23) — home screen layout shell.
    Locked C3 + masonry row 3 grid:
      Row 1 (3 cols, 1fr 1fr 1fr): Channels overview | Latest videos | Games releasing
      Row 2 (40/60, 4fr 6fr):       Notifications feed | Calendar (Calendar still at 60%, just on the right)
      Row 3 (60/40, 6fr 4fr):       Stack | (Notifications settings on top, Security on bottom)
    Hard rule: full-width rows are NEVER allowed. No panel ever spans an
    entire row alone. The right column of row 3 is a vertical flex stack
    with content-driven heights. %>
<div class="pito-workspace home-grid" data-controller="tui-cursor">
  <%# Row 1 — 3 cols even: YouTube content hierarchy %>
  <div class="home-row home-row--3col">
    <%= render Pito::ChannelsOverviewPanelComponent.new %>
    <%= render Pito::LatestVideosPanelComponent.new %>
    <%= render Pito::GamesReleasingPanelComponent.new %>
  </div>

  <%# Row 2 — 40/60: NotifFeed left (4fr), Calendar right (6fr; still 60% of the row).
      Per user 2026-05-23 — Calendar stays at 60% of row width but on the right;
      Notifications feed moves left at 40%. %>
  <div class="home-row home-row--40-60">
    <%= render Pito::NotificationsFeedPanelComponent.new %>
    <%= render Pito::CalendarPanelComponent.new %>
  </div>

  <%# Row 3 — 60/40 with masonry right column.
      Left: Stack (4 service sub-panels).
      Right: vertical stack — Notifications settings on top, Security on bottom. %>
  <div class="home-row home-row--60-40">
    <%= render Pito::StackPanelComponent.new(
          postgres_status:          @postgres_status,
          postgres_table_breakdown: @postgres_table_breakdown,
          search_healthy:           @search_healthy,
          search_stats:             @search_stats,
          search_per_index_stats:   @search_per_index_stats,
          voyage_configured:        @voyage_configured,
          storage_status:           @storage_status,
          assets_breakdown:         @assets_breakdown
        ) %>
    <div class="home-row-3-right-column">
      <%= render Pito::NotificationsPanelComponent.new(
            discord_webhook: @discord_webhook,
            slack_webhook:   @slack_webhook
          ) %>
      <%= render Pito::SecurityPanelComponent.new(
            sessions:       @sessions,
            sessions_sort:  @sessions_sort,
            sessions_dir:   @sessions_dir
          ) %>
    </div>
  </div>
</div>
