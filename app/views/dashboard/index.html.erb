<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<h1>dashboard</h1>

<% if @video_count > 0 %>
  <p class="caption" style="margin-bottom: 8px;"><%= number_with_delimiter(@video_count) %> videos across <%= number_with_delimiter(@channel_count) %> channels.</p>

  <p class="caption">[dashboard reset — charts return with intentional metrics in a later phase.]</p>
<% else %>
  <p class="text-muted">no videos yet. run:</p>
  <div data-controller="clipboard-copy" class="code-block">
    <span class="code-prompt" aria-hidden="true">$</span>
    <code data-clipboard-copy-target="source">bin/rails db:seed</code>
    <a href="#" data-action="click->clipboard-copy#copy" class="bracketed">[<span class="bl">copy</span>]</a>
  </div>
<% end %>
