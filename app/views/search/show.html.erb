<% content_for(:title, "search") %>
<% content_for(:breadcrumbs) do %>
  <span class="text-muted">search</span>
<% end %>

<% if @query.blank? %>
  <p class="caption">enter a search query above.</p>
<% else %>
  <p class="text-muted" style="margin-bottom: 8px;">
    results for "<%= @query %>" &mdash;
    <%= number_with_delimiter(@videos[:total]) %> video<%= @videos[:total] == 1 ? "" : "s" %>
    <span class="caption" style="font-size: 11px;">(<%= number_with_delimiter(@videos[:took_ms]) %>ms)</span>
  </p>

  <% if @videos[:total] > 0 %>
    <h2 style="margin-bottom: 4px;">videos</h2>
    <table class="data-table" style="margin-bottom: 12px; max-width: 1400px;">
      <thead>
        <tr>
          <th>title</th>
          <th>channel</th>
          <th>state</th>
          <th>language</th>
          <th style="text-align: right;">length</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @videos[:hits].each do |hit| %>
          <% video = hit[:record] %>
          <% next unless video %>
          <tr>
            <td><%= hit.dig(:highlights, "title")&.html_safe || video.title %></td>
            <td class="text-muted"><%= video.channel.channel_url %></td>
            <td><%= video.privacy_status.gsub("_", " ") %></td>
            <td><%= video.default_language %></td>
            <td style="text-align: right;"><%= video.duration_seconds ? "#{video.duration_seconds / 60}:#{format('%02d', video.duration_seconds % 60)}" : "—" %></td>
            <td><%= link_to "[o]", video_path(video), class: "bracketed" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <% if @videos[:total] == 0 %>
    <p class="caption">no results found for "<%= @query %>".</p>
  <% end %>
<% end %>
