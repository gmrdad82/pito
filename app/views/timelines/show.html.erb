<% content_for(:title, @timeline.title) %>
<% breadcrumb(["projects", projects_path], [@timeline.project.name, project_path(@timeline.project)], @timeline.title) %>

<h1><%= @timeline.title %></h1>

<table class="detail-table" style="margin-bottom: 8px;">
  <tr><td class="text-muted">state</td><td><%= @timeline.state %></td></tr>
  <tr><td class="text-muted">duration</td><td><%= format_duration(@timeline.duration_seconds) %></td></tr>
  <tr><td class="text-muted">resolution</td><td><%= @timeline.resolution || "—" %></td></tr>
  <tr><td class="text-muted">fps</td><td><%= @timeline.fps || "—" %></td></tr>
</table>

<div style="display: flex; gap: 6px;">
  <% if @timeline.may_export? %>
    <%= button_to timeline_path(@timeline), params: { transition: "export" }, method: :patch, form: { style: "display: inline;", data: { turbo: false } }, class: "bracketed" do %>[<span class="bl">export</span>]<% end %>
  <% end %>
  <% if @timeline.may_upload? %>
    <%= form_with(url: timeline_path(@timeline), method: :patch, html: { style: "display: inline; gap: 6px; align-items: baseline;" }) do |f| %>
      <%= f.hidden_field :transition, value: "upload" %>
      <%= f.url_field :youtube_url, placeholder: "https://youtu.be/...", style: "width: 240px;" %>
      <button type="submit">[<b>upload</b>]</button>
    <% end %>
  <% end %>
</div>
