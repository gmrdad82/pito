<% content_for(:title, "#{@operation.kind.humanize} — #{@operation.status}") %>
<% breadcrumb(@operation.kind.humanize) %>

<%= turbo_stream_from "bulk_operation_#{@operation.id}" %>

<div style="margin-bottom: 12px;">
  <h1><%= @operation.kind.humanize %></h1>
  <%= render "bulk_operations/status", operation: @operation, status: @operation.status %>
</div>

<%= render "bulk_operations/progress",
  current: @operation.succeeded_count + @operation.failed_count,
  total: @operation.target_count,
  status: @operation.status %>

<table style="margin-top: 8px;">
  <thead>
    <tr>
      <th>item</th>
      <th>type</th>
      <th>status</th>
      <th>error</th>
    </tr>
  </thead>
  <tbody>
    <% @items.each do |item| %>
      <tr id="item_<%= item.id %>">
        <%# Phase 7 Path A2 — Video has no title; fall back to
            youtube_video_id, then to channel_url, then to "(deleted)". %>
        <td><%= item.target&.try(:title) || item.target&.try(:youtube_video_id) || item.target&.try(:channel_url) || "(deleted)" %></td>
        <td><%= item.target_type %></td>
        <td>
          <% if item.status_succeeded? %>
            <%= render(StatusIndicatorComponent.new(kind: :up, text: "succeeded")) %>
          <% elsif item.status_failed? %>
            <%= render(StatusIndicatorComponent.new(kind: :down, text: "failed")) %>
          <% elsif item.status_skipped? %>
            <span class="bracketed text-danger">[skip]</span>
          <% else %>
            <span class="text-muted">pending</span>
          <% end %>
        </td>
        <td class="text-muted"><%= item.error_message %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<div style="margin-top: 12px;">
  <%= render(BracketedLinkComponent.new(label: "home", href: root_path)) %>
</div>
