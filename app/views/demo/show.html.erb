<%# /demo — visual inventory of every segment kind.
    Development only. Use this page to review styling before building real flows. %>

<% fake_event = @fake_event %>

<div style="padding: 40px 50px 80px; max-width: 720px;">

  <%#── Section helper ─────────────────────────────────────────────────────%>
  <% section = ->(title) do %>
    <div style="margin: 32px 0 8px; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;"
         class="text-fg-faded">
      <%= title %>
    </div>
  <% end %>

  <%#──────────────────────────────────────────────────────────────────────%>
  <%= section.call("Echo — authenticated") %>
  <%= render Pito::Event::EchoComponent.new(
        payload: { text: "/help", authenticated: true },
        event:   fake_event
      ) %>

  <%= section.call("Echo — unauthenticated (no @all)") %>
  <%= render Pito::Event::EchoComponent.new(
        payload: { text: "/help", authenticated: false },
        event:   fake_event
      ) %>

  <%#──────────────────────────────────────────────────────────────────────%>
  <%= section.call("Assistant text — plain") %>
  <%= render Pito::Event::AssistantTextComponent.new(
        payload: { text: "Here are the commands available to you.", segment_style: "plain" }
      ) %>

  <%= section.call("Assistant text — subsequent (blue accent)") %>
  <%= render Pito::Event::AssistantTextComponent.new(
        payload: { text: "A second result segment in the same turn.", segment_style: "subsequent" }
      ) %>

  <%#──────────────────────────────────────────────────────────────────────%>
  <%= section.call("Error — plain message (red)") %>
  <%= render Pito::Event::ErrorComponent.new(
        payload: { text: "Unknown command: /florp. Type /help for the command list." }
      ) %>

  <%= section.call("Error — with ctrl+o detail (red)") %>
  <%= render Pito::Event::ErrorComponent.new(
        payload: {
          text:   "Something went wrong processing your request.",
          detail: "ActiveRecord::RecordNotFound: Couldn't find Channel with id=42"
        }
      ) %>

  <%= section.call("Error — credential table (red, /connect not configured)") %>
  <%= render Pito::Event::ErrorComponent.new(
        payload: {
          text:        "Google OAuth credentials are not configured.",
          credentials: {
            client_id:     false,
            client_secret: false,
            redirect_uri:  nil,
            api_key:       false
          }
        }
      ) %>

  <%#──────────────────────────────────────────────────────────────────────%>
  <%= section.call("Thinking — unresolved (spinning)") %>
  <%= render Pito::Event::ThinkingComponent.new(
        payload: { dictionary: "slash", word_index: 11 }
      ) %>

  <%= section.call("Thinking — resolved") %>
  <%= render Pito::Event::ThinkingComponent.new(
        payload: { dictionary: "slash", word_index: 11, resolved: true, elapsed_seconds: 0.2 }
      ) %>

  <%#──────────────────────────────────────────────────────────────────────%>
  <%= section.call("Confirmation prompt — PENDING (orange, awaiting #handle confirm/cancel)") %>
  <%= render Pito::Event::ConfirmationPromptComponent.new(
        payload: {
          body: "You're about to disconnect from @gmrdad82.\nThis will remove it from the local database alongside its videos and analytics.\nAre you sure?",
          confirmation_handle: "alpha-1322",
          authenticated: true
        },
        event: fake_event
      ) %>

  <%= section.call("Confirmation prompt — PROCESSING (Braille + verb, job running)") %>
  <%= render Pito::Event::ConfirmationPromptComponent.new(
        payload: {
          body: "You're about to disconnect from @gmrdad82.\nThis will remove it from the local database alongside its videos and analytics.\nAre you sure?",
          confirmation_handle: "alpha-1322",
          processing: true,
          processing_word_index: 2,
          authenticated: true
        },
        event: fake_event
      ) %>

  <%= section.call("Confirmation prompt — RESOLVED: cancelled") %>
  <%= render Pito::Event::ConfirmationPromptComponent.new(
        payload: {
          body: "You're about to disconnect from @gmrdad82.\nThis will remove it from the local database alongside its videos and analytics.\nAre you sure?",
          confirmation_handle: "alpha-1322",
          resolved: true,
          outcome: "cancelled",
          outcome_text: "Alright, I won't disconnect from this channel.",
          authenticated: true
        },
        event: fake_event
      ) %>

  <%= section.call("Confirmation prompt — RESOLVED: confirmed") %>
  <%= render Pito::Event::ConfirmationPromptComponent.new(
        payload: {
          body: "You're about to disconnect from @gmrdad82.\nThis will remove it from the local database alongside its videos and analytics.\nAre you sure?",
          confirmation_handle: "alpha-1322",
          resolved: true,
          outcome: "confirmed",
          outcome_text: "Disconnected from @gmrdad82. Deleted 42 videos.",
          authenticated: true
        },
        event: fake_event
      ) %>

  <%#──────────────────────────────────────────────────────────────────────%>
  <%= section.call("Logout (static — pito--logout controller omitted to avoid navigation)") %>
  <%= render Pito::Segment::Component.new(accent: :purple) do %>
    <span class="text-fg">Session closed. See you on the other side.</span>
  <% end %>

</div>
