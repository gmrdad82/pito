<%# Shared action screen footer — bracketed [confirm] + [cancel]
  Required locals:
    submit_label: String — submit button text. Per Beta 4 — Phase
      F3-DEEP-B (2026-05-20), the partial wraps the label in
      `[<span class="bl">…</span>]` itself, so callers should pass the
      bare label string (e.g. "delete", "sync", "confirm revoke").
      Legacy `[wrapped]` labels continue to render unchanged because the
      partial detects + unwraps a single set of surrounding brackets
      before re-wrapping; mixing styles inside one bracketed label
      stays caller-controlled.
    cancel_path:  String — URL for cancel link
    form_url:     String — form action URL
  Optional locals:
    destructive:  Boolean — submit renders in section-danger pink
                  (default: false)
    form_method:  Symbol — HTTP method (default: :post)

  Beta 4 — Phase F3-DEEP-B (2026-05-20) — TUI confirmation framework.
  The page-level chrome (heading + items table + cancel button hover)
  is owned by the parent view; this partial owns only the actions row
  at the foot of the confirmation. Visually the row now reads as a
  hairline-separated bracketed-link bar — `[confirm]` (pink when
  destructive, link-color otherwise) + `[cancel]` (muted) — replacing
  the previous browser-default `<button>` styling.

  Per the project keyboard contract (CLAUDE.md hard rule + the
  `keyboard-confirmation` Stimulus wiring), `y` triggers the form
  submission and `Esc` triggers the cancel link. The
  `data-keyboard-confirmation` / `data-keyboard-confirmation-cancel`
  attributes preserve that wiring through the visual swap.
%>

<% destructive   = local_assigns.fetch(:destructive, false) %>
<% form_method   = local_assigns.fetch(:form_method, :post) %>
<% raw_label     = submit_label.to_s %>
<% clean_label   = raw_label.sub(/\A\[\s*/, "").sub(/\s*\]\z/, "") %>
<% submit_class  = "bracketed action-screen-submit#{' text-danger' if destructive}" %>

<%= form_with url: form_url, method: form_method, data: { turbo: false, keyboard_confirmation: "true" } do |f| %>
  <% if content_for?(:action_screen_params) %>
    <div style="margin-bottom: 12px;">
      <%= yield :action_screen_params %>
    </div>
  <% end %>

  <div class="action-screen-footer">
    <div class="dot-list">
      <button type="submit" class="<%= submit_class %>">[<span class="bl"><%= clean_label %></span>]</button>
      <%= render(BracketedMutedLinkComponent.new(href: cancel_path, label: t("common.actions.cancel"), data: { keyboard_confirmation_cancel: "true" })) %>
    </div>
  </div>
<% end %>
