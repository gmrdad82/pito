<dialog data-confirm-dialog-target="dialog"
        data-action="click->confirm-dialog#clickOutside keydown->confirm-dialog#keydown">
  <div data-role="title" class="dialog-title"></div>
  <div data-role="message" class="dialog-message"></div>
  <div>
    <button type="button" data-action="confirm-dialog#confirm"
            class="<%= local_assigns[:destructive] ? 'dialog-destructive' : 'dialog-confirm' %>">[confirm]</button>
    <span class="text-muted">&middot;</span>
    <button type="button" data-action="confirm-dialog#cancel">[cancel]</button>
  </div>
</dialog>
