<%# Global search modal — opened by `/` keypress. Submits to
    `/search` (existing `SearchController#show`). The dialog
    autofocuses the input on open and closes on Escape or click
    outside, mirroring the project's `confirm-modal` rhythm.
    No JS confirm/alert/prompt anywhere (CLAUDE.md hard rule). %>
<dialog id="global-search-modal"
        class="confirm-modal pane-dialog"
        data-controller="global-search-modal"
        data-action="click->global-search-modal#clickOutside keydown->global-search-modal#keydown">
  <div class="confirm-modal-inner" style="min-width: 360px;">
    <div class="dialog-title">search</div>
    <%= form_with url: search_path, method: :get, data: { turbo: false }, html: { style: "display: flex; gap: 6px; align-items: center;" } do |f| %>
      <%= f.text_field :q,
                       value: "",
                       placeholder: "search videos…",
                       autocomplete: "off",
                       data: { global_search_modal_target: "input" },
                       style: "flex: 1; height: 24px; padding: 0 6px; font-family: inherit; font-size: 13px; border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text);" %>
      <button type="submit" class="bracketed">[<span class="bl">search</span>]</button>
    <% end %>
    <div class="modal-footer">
      <button type="button" class="bracketed" data-action="global-search-modal#close">[<span class="bl">cancel</span>]</button>
    </div>
  </div>
</dialog>
