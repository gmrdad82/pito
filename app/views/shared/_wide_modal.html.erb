<%# Phase 7.5 §11d — Wide modal partial.
    Reusable wide-variant dialog frame for previews and other
    surfaces that need a 1320px-max canvas (11e watermark preview
    is the next caller).
    Locals:
      id:      DOM id of the <dialog> element (modal-trigger#open
               targets this id).
      title:   short header text rendered above the body.
      top_nav: optional Capybara-renderable string of `[link]`
               affordances rendered next to the title (e.g. the
               desktop/mobile/tv toggles for the preview component).
               Pass `nil` or omit to skip the slot.
    Block:
      The yielded block is rendered inside the modal body.
    Behavior:
      - Esc closes (native <dialog> behavior + confirm-modal
        keydown handler).
      - Click-outside closes (confirm-modal#clickOutside).
      - The `[close]` bracketed link in the footer closes.
    NO JS confirm / alert / prompt — CLAUDE.md hard rule.
%>
<% local_top_nav = local_assigns[:top_nav] %>
<dialog id="<%= id %>"
        class="wide-modal"
        data-controller="confirm-modal"
        data-action="click->confirm-modal#clickOutside keydown->confirm-modal#keydown">
  <div class="wide-modal-inner">
    <div class="wide-modal-header">
      <div class="wide-modal-title-row">
        <h2 class="wide-modal-title"><%= title %></h2>
        <%= render(BracketedLinkComponent.new(label: "close", href: "#",
                                              data: { action: "click->confirm-modal#close" })) %>
      </div>
      <% if local_top_nav.present? %>
        <div class="wide-modal-topnav">
          <%= local_top_nav %>
        </div>
      <% end %>
    </div>
    <div class="wide-modal-body">
      <%= yield %>
    </div>
  </div>
</dialog>
