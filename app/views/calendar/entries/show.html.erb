<% content_for(:title, "calendar ~ #{@entry.title}") %>
<% breadcrumb([ "calendar", calendar_root_path ], @entry.title) %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. Marker div — invisible, no layout impact. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@entry, scope: CalendarEntry, path_helper: method(:calendar_entry_path)) %>></div>

<h1>
  <span class="text-muted"><%= entry_type_label(@entry) %></span>
  <%= @entry.title %>
</h1>

<dl>
  <dt>type</dt><dd><%= @entry.entry_type %></dd>
  <dt>state</dt><dd><%= @entry.state %></dd>
  <dt>source</dt><dd><%= @entry.source %></dd>
  <dt>starts at</dt><dd><%= @entry.starts_at.in_time_zone(@entry.timezone).strftime("%Y-%m-%d %H:%M %Z") %></dd>
  <% if @entry.ends_at %>
    <dt>ends at</dt><dd><%= @entry.ends_at.in_time_zone(@entry.timezone).strftime("%Y-%m-%d %H:%M %Z") %></dd>
  <% end %>
  <% if @entry.description.present? %>
    <dt>description</dt><dd><%= simple_format(@entry.description) %></dd>
  <% end %>
</dl>

<% if @parent_entry %>
  <p>
    <strong>parent:</strong>
    <a href="<%= calendar_entry_path(@parent_entry) %>"><%= @parent_entry.title %></a>
  </p>
<% end %>

<% if @child_entries.any? %>
  <h2>linked entries</h2>
  <ul>
    <% @child_entries.each do |child| %>
      <li><a href="<%= calendar_entry_path(child) %>"><span class="text-muted"><%= entry_type_label(child) %></span> <%= child.title %></a></li>
    <% end %>
  </ul>
<% end %>

<% if @entry.entry_type == "milestone_auto" && @entry.milestone_rule %>
  <p>
    <strong>milestone rule:</strong> <%= @entry.milestone_rule.name %>
    (metric: <%= @entry.metadata["metric_value_at_fire"] %>)
  </p>
<% end %>

<%# Phase 15 reviewer concern 6 — the `[note]` link previously pointed
    at a `modal-trigger` whose target (`note-modal`) is not yet rendered
    on this page. Removed until the modal markup is built; the
    PATCH /calendar/entries/:id/note endpoint stays in place for
    programmatic callers (MCP / Rust client) and a future UI revival. %>
<div class="dot-list" style="margin-top: 16px;">
  <% unless @entry.read_only? %>
    <%= render(BracketedLinkComponent.new(label: "edit",
          href: edit_calendar_entry_path(@entry))) %>
    <%= render(BracketedLinkComponent.new(label: "cancel",
          href: deletions_path(type: "calendar_entry", ids: @entry.id),
          destructive: true)) %>
  <% end %>
  <%= render(BracketedLinkComponent.new(label: "back",
        href: calendar_root_path)) %>
</div>

<%# Phase 15 reviewer concerns 3 + 4 — reminder copy is the canonical
    `[remind: t-7 t-1 t-0]` literal (no inner padding, no derivation
    from `@declarations.map { |d| d[:kind] }`). The schedule view's
    EntryRowComponent already renders the literal; this matches it. %>
<% if @declarations.any? { |d| d[:kind] == "game_release_upcoming" } %>
  <p class="text-muted" style="margin-top: 16px;">
    [remind: t-7 t-1 t-0]
  </p>
<% end %>
