<% content_for(:title, "calendar ~ schedule") %>

<%# Phase 15 calendar UX restructure — breadcrumb segment flip
    (2026-05-10). The breadcrumb keeps the layout
    `[calendar] / [may YYYY] · [schedule] [+]`, but on the schedule
    view the active label is `[schedule]` (plain text) and the
    `[may YYYY]` segment becomes the toggle link back to the month
    grid. The month view inverts these roles (see
    `calendar/month/_navigation`).

    The `[may YYYY]` link targets the canonical month URL directly
    (NOT `/calendar`, which is the view-persistence router). Bouncing
    through the router would let a stale `pito-calendar-view =
    schedule` in localStorage immediately redirect the user back to
    schedule, making the click look broken. The `persistMonth`
    Stimulus action writes the new preference so a subsequent fresh
    `/calendar` visit honors the toggle.

    The breadcrumb is hand-rolled rather than going through the
    `breadcrumb()` helper because the trailing segment is a LINK on
    this page (not the active label) — the helper's
    `BreadcrumbComponent` renders the last crumb as active by
    convention, which is correct for the month view but inverted
    here. %>
<% _now = Time.current %>
<% content_for :breadcrumbs do %>
  <%= render(BracketedLinkComponent.new(label: "calendar",
        href: calendar_root_path)) %><span class="text-muted"> / </span><span data-controller="calendar-view-router"><%= render(BracketedLinkComponent.new(label: calendar_month_heading(_now.year, _now.month),
        href: calendar_month_path(_now.year, format('%02d', _now.month)),
        data: { action: "click->calendar-view-router#persistMonth" })) %></span>
<% end %>

<% content_for :breadcrumb_actions do %>
  <%= render "shared/dot_separator" %>
  <%= render(BracketedLinkComponent.new(label: "schedule", active: true)) %>
  <%# Default-create (Projects pattern): POSTs to `/calendar/entries`
      with no payload. The controller seeds an "Untitled event"
      milestone_manual entry and redirects to /edit. `data-turbo: false`
      forces a full-page navigation so the redirect lands on the edit
      page, matching `/projects` `[+]`. %>
  <%= button_to calendar_entries_path,
        method: :post,
        class: "bracketed",
        form: { style: "display: inline;", data: { turbo: false } } do %>[<span class="bl">+</span>]<% end %>
<% end %>

<div data-controller="calendar-filter"
     data-calendar-filter-view-value="schedule">
  <%# Row 2 — entry kind filter chips. Same synthetic master + 5
      individual chips as the month grid, plus a schedule-specific
      `[ ] include cancelled` checkbox chip. %>
  <div class="dot-list" style="margin-bottom: 8px;">
    <% raw_types = params[:types] %>
    <a href="<%= calendar_all_kinds_chip_href(raw_types, current_params: request.query_parameters) %>"
       class="filter-chip"
       data-keyboard-filter-chip="all"
       data-calendar-filter-target="masterToggle">
      <span class="md-check-static"><%= calendar_all_kinds_checked?(raw_types) ? "[x]" : "[ ]" %></span>
      <span class="md-check-static-label">all</span>
    </a>
    <% CalendarHelper::CALENDAR_KIND_LABELS.each do |label| %>
      <a href="<%= calendar_kind_chip_href(label, raw_types, current_params: request.query_parameters) %>"
         class="filter-chip"
         data-keyboard-filter-chip="<%= label %>"
         data-calendar-filter-target="kindToggle">
        <span class="md-check-static"><%= calendar_kind_checked?(label, raw_types) ? "[x]" : "[ ]" %></span>
        <span class="md-check-static-label"><%= label %></span>
      </a>
    <% end %>
    <a href="<%= url_for(state: @show_cancelled ? nil : "all") %>"
       class="filter-chip"
       data-keyboard-filter-chip="include cancelled">
      <span class="md-check-static"><%= @show_cancelled ? "[x]" : "[ ]" %></span>
      <span class="md-check-static-label">include cancelled</span>
    </a>
  </div>

  <% if @entries.empty? %>
    <p class="text-muted">no entries.</p>
  <% else %>
    <%
      past_entries   = @entries.select { |e| e.starts_at <= @today }
      future_entries = @entries.select { |e| e.starts_at  > @today }
      # Calendar refactor 2026-05-11 — group-by-day. The schedule table
      # no longer fills the viewport; it shrinks to its natural content
      # width. A `width: max-content` plus `max-width: 720px` cap keeps
      # the layout compact on wide screens without truncating long
      # titles on narrow ones. The `last_day_key` accumulator tracks the
      # previously-rendered row's calendar day so repeated dates render
      # an empty date cell.
      last_day_key = nil
    %>
    <table class="calendar-schedule-table" style="width: max-content; max-width: 720px; border-collapse: collapse; font-size: 13px;">
      <tbody>
        <% past_entries.each do |entry| %>
          <%
            key = entry_grouping_day_key(entry)
            show_date = (key != last_day_key)
            last_day_key = key
          %>
          <%= render(EntryRowComponent.new(entry: entry, show_date: show_date)) %>
        <% end %>
        <% if past_entries.any? && future_entries.any? %>
          <tr><td colspan="5" style="border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: 4px 0; text-align: center; opacity: 0.6;" class="schedule-today-divider">[ today ]</td></tr>
          <% # reset grouping after the divider so the first future row stamps its date %>
          <% last_day_key = nil %>
        <% end %>
        <% future_entries.each do |entry| %>
          <%
            key = entry_grouping_day_key(entry)
            show_date = (key != last_day_key)
            last_day_key = key
          %>
          <%= render(EntryRowComponent.new(entry: entry, show_reminder: true, show_date: show_date)) %>
          <% entry.child_entries.where.not(state: %i[cancelled superseded]).each do |child| %>
            <%# Indented child rows always suppress the date cell — they
                visually belong to the parent's day group. %>
            <%= render(EntryRowComponent.new(entry: child, indent: true, show_date: false)) %>
          <% end %>
        <% end %>
      </tbody>
    </table>

    <%= render "pagination" %>
  <% end %>
</div>

<%= render "calendar/entry_modal" %>
