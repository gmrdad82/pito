<%# Calendar refactor 2026-05-11 — calendar entry details modal.
    Mounted at the bottom of the month + schedule views. The
    `calendar-entry-modal` Stimulus controller wraps the <dialog> and
    swaps `/calendar/entries/:id/details_pane` into the inner Turbo
    Frame when a chip / row title is clicked.

    Closing: Escape (native <dialog>), click-outside
    (`clickOutside` action), `[close]` button inside the details pane.

    No JS `confirm()` / `alert()` / `prompt()` (CLAUDE.md hard rule). %>
<span data-controller="calendar-entry-modal">
  <dialog data-calendar-entry-modal-target="dialog"
          data-action="click->calendar-entry-modal#clickOutside"
          class="pane-dialog calendar-entry-modal">
    <div style="padding: 12px 16px; min-width: 480px; max-width: 720px; max-height: 80vh; overflow-y: auto;">
      <%= turbo_frame_tag "calendar_entry_details_frame",
                          data: { calendar_entry_modal_target: "frame" } %>
    </div>
  </dialog>
</span>
