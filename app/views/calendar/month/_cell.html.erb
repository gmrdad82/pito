<%# Phase 15 §2 — single grid cell with chips. %>
<%
  is_today = (date == @today)
  in_month = (date.month == @month)
  cell_entries = @buckets[date] || []
  cell_class = [ "calendar-cell" ]
  cell_class << "today" if is_today
  cell_class << "out-of-month" unless in_month
%>
<%# `data-keyboard-grid-cell` opts this cell into the calendar-aware
    grid navigation declared by the wrapping table. Out-of-month
    cells participate too — the rendered grid is always a multiple
    of 7 (Monday-first) and the controller indexes cells by their
    position in that flat sequence, not by month membership. %>
<%# Calendar polish 2026-05-11 — month cells are forced to a 1:1
    aspect ratio so the grid renders as squares regardless of viewport
    width. `width: 14.2857%` keeps the 7-column split; `aspect-ratio`
    derives the height from that width. `overflow: hidden` clips any
    chip content that doesn't fit (intentional — revisit later). %>
<td class="<%= cell_class.join(' ') %>" data-keyboard-grid-cell style="vertical-align: top; padding: 4px; border: 1px solid var(--color-border); width: 14.2857%; aspect-ratio: 1 / 1; overflow: hidden; <%= 'outline: 1px solid var(--color-border);' if is_today %>">
  <div style="font-size: 11px; opacity: <%= in_month ? '1' : '0.4' %>;">
    <%= date.day %><% if is_today %> <span class="text-muted">today</span><% end %>
  </div>
  <% cell_entries.first(3).each do |entry| %>
    <%= render(EntryChipComponent.new(entry: entry)) %>
  <% end %>
  <% if cell_entries.length > 3 %>
    <%= render(BracketedLinkComponent.new(
      label: "+#{cell_entries.length - 3} more",
      href: calendar_schedule_path)) %>
  <% end %>
</td>
