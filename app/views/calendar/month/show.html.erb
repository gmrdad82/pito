<% content_for(:title, "calendar ~ #{calendar_month_heading(@year, @month)}") %>
<% breadcrumb([ "calendar", calendar_root_path ], calendar_month_heading(@year, @month)) %>

<%# 2026-05-17 — the prev/next/today url values were used by the
    `[`/`]`/`t` global keybinds that drove the month grid; those keys
    were removed in the legacy-keyboard-shortcut sweep. The controller
    now exists only to write `pito-calendar-view = "month"` into
    localStorage (the `/calendar` router signal). Prev/next/today
    affordances live in `_navigation.html.erb` as bracketed links and
    in the leader-menu calendar submenu. %>
<div data-controller="calendar-navigation">
  <%= render "navigation" %>

  <%= render "filter_cluster" %>

  <turbo-frame id="quick_add">
  </turbo-frame>

  <%= render "grid" %>

  <% if @entries.empty? %>
    <p class="text-muted" style="margin-top: 12px;">
      no entries this month.
    </p>
  <% end %>
</div>

<%= render "calendar/entry_modal" %>
