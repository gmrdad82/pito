<%# Phase 13.3 — V8: demographics heatmap. Local: `breakdown`
    (Hash of [age_group, gender] → summed viewer_percentage),
    `caveat:` (optional caveat caption — present on the
    channel-level rollup per Q15).

    Rendered as a stacked bar (column_chart per gender) keyed by
    age_group rather than a true heatmap — Chartkick doesn't ship
    a heatmap helper and a stacked bar conveys the same info with
    less custom JS. %>
<section class="analytics-chart analytics-chart--demographics"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="column">
  <h3>demographics — <%= analytics_window_label(window, long: true) %></h3>
  <% if breakdown.any? %>
    <%
      # Pivot to gender-keyed series with age_group on x-axis.
      genders = breakdown.keys.map { |k| k[1] }.uniq
      series = genders.map do |gender|
        slice = breakdown.select { |key, _| key[1] == gender }
        {
          name: gender.downcase,
          data: slice.transform_keys { |key| key[0] }
        }
      end
    %>
    <div class="h-64">
      <%= column_chart series,
                       stacked: true,
                       library: { animation: false },
                       colors: chart_palette(genders.size),
                       thousands: "," %>
    </div>
    <% if local_assigns[:caveat] && caveat %>
      <p class="caption analytics-caveat">
        summed from per-video data; may differ from Studio's channel report
      </p>
    <% end %>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
