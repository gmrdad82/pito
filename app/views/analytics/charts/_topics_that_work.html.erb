<%# Phase 13.3 — Cross-video local rollup: topics that work.
    Local: `data` (Hash of category_id → median 28d views). %>
<section class="analytics-chart analytics-chart--topics-that-work"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="bar">
  <h3>topics that work</h3>
  <% if data.any? %>
    <div class="h-64">
      <%= bar_chart data,
                    library: { animation: false },
                    colors: chart_palette(1),
                    thousands: "," %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
