<%# Phase 13.3 — V5: traffic source bar. Local: `breakdown` (Hash of
    traffic_source_type → views). %>
<section class="analytics-chart analytics-chart--traffic"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="bar">
  <h3>by traffic source — <%= analytics_window_label(window, long: true) %></h3>
  <% if breakdown.any? %>
    <div class="h-64">
      <%= bar_chart breakdown,
                    library: { animation: false },
                    colors: chart_palette(1),
                    thousands: "," %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
