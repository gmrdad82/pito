<%# Phase 13.3 — V3 / channel-geography: country breakdown. Local:
    `breakdown` (Hash of country_code → views), `caveat:` (optional
    caveat caption — present on the channel-level rollup per Q15). %>
<section class="analytics-chart analytics-chart--country"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="bar">
  <h3>by country — <%= analytics_window_label(window, long: true) %></h3>
  <% if breakdown.any? %>
    <div class="h-64">
      <%= bar_chart breakdown,
                    library: { animation: false },
                    colors: chart_palette(1),
                    thousands: "," %>
    </div>
    <% if local_assigns[:caveat] && caveat %>
      <p class="caption analytics-caveat">
        summed from per-video data; may differ from Studio's channel report
      </p>
    <% end %>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
