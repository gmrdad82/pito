<%# Phase 13.3 — Cross-video local rollup: thumbnail decay.
    Local: `data` (Hash of video label → CTR delta; only declining
    videos are present). %>
<section class="analytics-chart analytics-chart--thumbnail-decay"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="bar">
  <h3>thumbnail decay</h3>
  <% if data.any? %>
    <div class="h-64">
      <%= bar_chart data,
                    library: { animation: false },
                    colors: chart_palette(1),
                    thousands: "," %>
    </div>
    <p class="caption">videos with declining CTR over the last 90 days.</p>
  <% else %>
    <p class="caption analytics-empty-state">
      no thumbnails are decaying right now.
    </p>
  <% end %>
</section>
