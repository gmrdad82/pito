<%# Phase 13.3 — V6: subscribed-status donut. Local: `breakdown`
    (Hash of subscribed_status → views). %>
<section class="analytics-chart analytics-chart--subscribed-status"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="pie">
  <h3>by subscribed status — <%= analytics_window_label(window, long: true) %></h3>
  <% if breakdown.any? %>
    <div class="h-64">
      <%= pie_chart breakdown,
                    donut: true,
                    library: { animation: false },
                    colors: chart_palette(2),
                    thousands: "," %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
