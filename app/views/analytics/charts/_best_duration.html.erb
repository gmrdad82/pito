<%# Phase 13.3 — Cross-video local rollup: best video length.
    Local: `data` (Hash of duration-bucket label → median 28d
    estimated_minutes_watched). %>
<section class="analytics-chart analytics-chart--best-duration"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="bar">
  <h3>best video length</h3>
  <% if data.any? && data.values.any? { |v| v > 0 } %>
    <div class="h-64">
      <%= bar_chart data,
                    library: { animation: false },
                    colors: chart_palette(1),
                    thousands: "," %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
