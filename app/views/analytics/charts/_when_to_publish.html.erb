<%# Phase 13.3 — Cross-video local rollup: when to publish.
    Local: `data` (Hash of "Day HH" → median first-7d views). %>
<section class="analytics-chart analytics-chart--when-to-publish"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="column">
  <h3>when to publish</h3>
  <% if data.any? %>
    <div class="h-64">
      <%= column_chart data,
                       library: { animation: false },
                       colors: chart_palette(1),
                       thousands: "," %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
