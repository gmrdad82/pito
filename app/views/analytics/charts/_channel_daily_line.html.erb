<%# Phase 13.3 — C1: channel daily line chart. Local: `dailies`
    (a relation of `ChannelDaily` rows). Empty-state copy is the
    spec's locked per-channel string. %>
<section class="analytics-chart analytics-chart--channel-daily"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="line"
         data-sync-group="channel-daily">
  <h3>channel daily — <%= analytics_window_label(window, long: true) %></h3>
  <% if dailies.any? %>
    <div class="h-64">
      <%= line_chart(
            { "views" => dailies.pluck(:date, :views).to_h,
              "estimated minutes watched" => dailies.pluck(:date, :estimated_minutes_watched).to_h },
            library: { animation: false },
            colors: chart_palette(2),
            thousands: ","
          ) %>
    </div>
    <%= render "analytics/revision_band_caption" %>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
