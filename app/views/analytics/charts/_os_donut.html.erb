<%# Phase 13.3 — V4-os: operating-system donut. Local: `breakdown`
    (Hash of operating_system → views). %>
<section class="analytics-chart analytics-chart--os"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="pie">
  <h3>by operating system — <%= analytics_window_label(window, long: true) %></h3>
  <% if breakdown.any? %>
    <div class="h-64">
      <%= pie_chart breakdown,
                    donut: true,
                    library: { animation: false },
                    colors: chart_palette(5),
                    thousands: "," %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>
