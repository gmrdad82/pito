<%# Phase 13.3 — V7: retention curve. Local: `buckets` (relation of
    `VideoRetention` rows ordered by elapsed_ratio_bucket).

    Empty-state copy is the dedicated retention string from
    master-agent decision 4: "retention data is refreshed weekly.
    [refresh retention now] to compute it now." The button posts to
    `video_retention_refresh_path`. %>
<section class="analytics-chart analytics-chart--retention"
         data-controller="analytics-chart"
         data-analytics-chart-kind-value="line">
  <h3>retention curve</h3>
  <% if buckets.any? %>
    <div class="h-64">
      <%= line_chart(
            buckets.map { |b| [ (b.elapsed_ratio_bucket.to_f * 100).to_i, b.audience_watch_ratio.to_f ] }.to_h,
            library: { animation: false },
            colors: chart_palette(1),
            thousands: ","
          ) %>
    </div>
  <% else %>
    <p class="caption analytics-empty-state">
      retention data is refreshed weekly.
      <%= button_to "[refresh retention now]",
                    video_retention_refresh_path(video),
                    method: :post,
                    class: "bracketed",
                    form: { style: "display: inline;" } %>
      to compute it now.
    </p>
  <% end %>
</section>
