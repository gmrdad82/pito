<% content_for(:title, "analytics") %>

<header class="analytics-header" style="margin-bottom: 16px;">
  <h1>analytics</h1>
  <%= render "analytics/data_freshness", timestamp: @last_synced_at %>
  <%= render "analytics/window_picker", window: @window %>
</header>

<% if @channels.empty? %>
  <p class="caption analytics-empty-state">
    no analytics yet. add a youtube channel to start syncing.
  </p>
<% end %>

<% if @channels.any? %>
  <% if @show_cross_channel_summary %>
    <section class="analytics-section analytics-cross-channel-summary"
             style="margin: 16px 0;">
      <h2>cross-channel summary — <%= analytics_window_label(@window, long: true) %></h2>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">
        <%= render "analytics/summary_card",
                   label: "views",
                   value: @cross_channel_summary[:views],
                   type: :count %>
        <%= render "analytics/summary_card",
                   label: "estimated minutes watched",
                   value: @cross_channel_summary[:estimated_minutes_watched],
                   type: :count %>
        <%= render "analytics/summary_card",
                   label: "net subscribers",
                   value: @cross_channel_summary[:net_subscribers],
                   type: :integer %>
        <%= render "analytics/summary_card",
                   label: "likes",
                   value: @cross_channel_summary[:likes],
                   type: :count %>
      </div>
    </section>
  <% end %>

  <section class="analytics-section analytics-channel-cards"
           style="margin: 16px 0;">
    <h2>channels</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      <% @channel_decorators.each do |decorator| %>
        <% summary = decorator.window_summary(@window) %>
        <article class="analytics-channel-card"
                 style="border: 1px solid var(--color-border); padding: 8px 10px; min-width: 220px;">
          <h3 style="margin: 0 0 4px 0;">
            <%= link_to decorator.channel_url, channel_analytics_path(decorator.object) %>
          </h3>
          <% if summary %>
            <ul class="caption" style="margin: 0; padding-left: 16px;">
              <li>views: <%= format_metric(summary.views, type: :count) %></li>
              <li>watch time: <%= format_metric(summary.estimated_minutes_watched, type: :count) %> min</li>
              <li>net subs: <%= format_metric(summary.subscribers_gained.to_i - summary.subscribers_lost.to_i, type: :integer) %></li>
            </ul>
          <% else %>
            <p class="caption analytics-empty-state">
              no data for this window. data syncs nightly; refresh to start syncing now.
            </p>
          <% end %>
        </article>
      <% end %>
    </div>
  </section>

<% end %>

<section class="analytics-section analytics-cross-video-locals"
         style="margin: 16px 0;">
  <h2>cross-video insights</h2>
  <%= render "analytics/charts/when_to_publish",
             data: @cross_video_locals.when_to_publish %>
  <%= render "analytics/charts/best_duration",
             data: @cross_video_locals.best_duration %>
  <%= render "analytics/charts/topics_that_work",
             data: @cross_video_locals.topics_that_work %>
  <%= render "analytics/charts/thumbnail_decay",
             data: @cross_video_locals.thumbnail_decay %>
</section>
