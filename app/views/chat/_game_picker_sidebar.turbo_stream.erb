<%# Turbo Stream partial — populates #pito-sidebar with the games picker
    wrapped in the Sidebar shell (fixed overlay panel). %>
<%= render partial: "chat/done_signal" %>
<%= turbo_stream.update "pito-sidebar" do %>
  <%= render(Pito::Sidebar::Component.new(
        title: t("pito.sidebar.games.title")
      )) do |sidebar| %>
    <% sidebar.with_subtitle do %>
      <span><%= t("pito.sidebar.games.hint") %></span>
    <% end %>
    <% sidebar.with_body do %>
      <%= render(Pito::Sidebar::Games::Component.new(
            games: games,
            mode:  mode,
            next_cursor: local_assigns[:next_cursor]
          )) %>
    <% end %>
  <% end %>
<% end %>
