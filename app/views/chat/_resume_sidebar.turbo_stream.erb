<%# Turbo Stream partial — populates #pito-sidebar with the conversation list
    wrapped in the Sidebar shell (fixed overlay panel). %>
<%= render partial: "chat/done_signal" %>
<%= turbo_stream.update "pito-sidebar" do %>
  <%= render(Pito::Sidebar::Component.new(
        title: t("pito.sidebar.conversations.title")
      )) do |sidebar| %>
    <% sidebar.with_subtitle do %>
      <%= render(Pito::Keybinding::HintComponent.new(
            shortcut: "`",
            description: t("pito.sidebar.conversations.rename_hint")
          )) %>
    <% end %>
    <% sidebar.with_body do %>
      <%= render(Pito::Sidebar::Conversations::Component.new(
            groups:       groups,
            current_uuid: current_uuid
          )) %>
    <% end %>
  <% end %>
<% end %>
