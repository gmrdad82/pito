<%# Mounts the /config ai picker overlay into its layout slot. pito--ai-picker
    removes the node on close, leaving the slot empty for the next open. %>
<%= turbo_stream.update "pito-ai-picker-slot" do %>
  <%= render(Pito::Ai::PickerComponent.new(
        provider:     provider,
        label:        label,
        models:       models,
        active_model: active_model,
        key_present:  key_present
      )) %>
<% end %>
