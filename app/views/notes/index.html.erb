<% content_for(:title, "notes") %>

<div style="max-width: 1100px;">
  <h1>notes</h1>
  <p class="text-muted" style="margin-bottom: 8px;">project notes are scoped per project — open a project to see its notes pane.</p>

  <% if @notes.any? %>
    <table>
      <thead>
        <tr>
          <th>title</th>
          <th>project</th>
          <th>last modified</th>
        </tr>
      </thead>
      <tbody>
        <% @notes.each do |note| %>
          <%# `data-keyboard-row` opts each note row into the global
              keyboard controller's list-row navigation (`j`/`k` move
              highlight). Mirrors the channels / videos / projects
              pattern. %>
          <tr data-keyboard-row data-keyboard-row-id="<%= note.id %>">
            <td><%= link_to note.title, note_path(note) %></td>
            <td><%= note.project.name %></td>
            <td class="num"><%= note.last_modified_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no notes yet.</p>
  <% end %>
</div>
