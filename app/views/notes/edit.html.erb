<% content_for(:title, "edit note") %>
<% breadcrumb(["projects", projects_path], [@project.name, project_path(@project)], "edit note") %>

<h1><%= @note.title %></h1>

<%= form_with(model: @note, url: note_path(@note), method: :patch) do |f| %>
  <div style="margin-bottom: 8px;">
    <label>title</label>
    <%= f.text_field :title, value: @note.title, style: "width: 100%; max-width: 480px;" %>
    <p class="text-muted" style="margin-top: 4px; font-size: 11px;">leave blank to auto-derive from the first <code># heading</code>.</p>
  </div>

  <div data-controller="codemirror" style="margin-bottom: 8px;">
    <label for="note_body">body</label>
    <%= text_area_tag "note[body]", @body, id: "note_body", rows: 16, style: "width: 100%; font-family: ui-monospace, monospace;", data: { codemirror_target: "textarea" } %>
  </div>

  <div style="display: flex; gap: 6px;">
    <button type="submit">[<b>save</b>]</button>
    <%= render(BracketedLinkComponent.new(label: "cancel", href: project_path(@project))) %>
    <span class="text-muted">&middot;</span>
    <%= render(BracketedLinkComponent.new(label: "delete", href: "#", destructive: true, data: { controller: "modal-trigger", action: "click->modal-trigger#open", modal_trigger_target_id_value: "confirm-note-#{@note.id}" })) %>
    <%= render(ConfirmModalComponent.new(
      id: "confirm-note-#{@note.id}",
      title: "delete this note?",
      confirm_path: note_path(@note),
      confirm_method: :delete,
      confirm_label: "delete",
      destructive: true
    )) %>
  </div>
<% end %>
