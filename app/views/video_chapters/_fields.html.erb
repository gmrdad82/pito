<%# Phase 11 §01a — Chapter row partial. Used both for persisted
    chapter rows (rendered server-side) and for new rows added by
    the `nested-form` Stimulus controller (template instantiated on
    `[add chapter]` click). Per-row `[remove]` flips `_destroy` to
    `1` and hides the row — no JS confirm.

    Locals:
      `f` — the nested form builder for `video_chapters`. %>
<div data-nested-form-target="row" style="margin-bottom: 4px;">
  <%= f.hidden_field :_destroy, data: { nested_form_target: "destroyFlag" } %>

  <label style="font-size: 11px; margin-right: 4px;">start (sec)</label>
  <%= f.number_field :start_seconds,
        min: 0,
        style: "width: 80px; margin-right: 6px;",
        placeholder: "0" %>

  <label style="font-size: 11px; margin-right: 4px;">label</label>
  <%= f.text_field :label,
        maxlength: 100,
        style: "width: 240px; margin-right: 6px;",
        placeholder: "intro" %>

  <button type="button"
          class="bracketed"
          data-action="nested-form#remove">
    [remove]
  </button>
</div>
