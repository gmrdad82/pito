<%# Public share page — reduced view for a single shared event.
    Privacy: the parent conversation title is NOT shown anywhere. %>
<div id="pito-share" class="flex flex-col" style="height: 100vh; height: 100dvh;">
  <div id="pito-scrollback" class="pito-hide-scrollbar pito-scroll-fade" style="flex: 1; overflow-y: auto; padding: 32px 25px 20px;">
    <%# Intro + the shared event (reply-suppressed) + outro — rendered through
        Pito::Share::PageCache (SolidCache, content-addressed key; 0.9.0
        Phase 7), so repeat public hits cost one cache read. %>
    <%= @scrollback_html.html_safe %>
  </div>

  <div style="padding: 0 25px 32px;">
    <%# Reduced chatbox — a decoy prefilled with "unfold". pito--share-unfold wires
        Enter (and the "Enter" link) → open the full conversation, c → focus, and the
        "c to chat" ⇄ "Enter to unfold" hint swap. No form/submit: the Enter link's
        href navigates (works without JS). Minimal chrome — no mini-status, no comet,
        no scroll-nav, no ctrl+k. %>
    <%= render(Pito::Shell::ChatboxComponent.new(
          state: :default,
          reduced: true,
          initial_value: "unfold",
          unfold_url: conversation_path(@conversation),
          placeholder_key: "pito.copy.share.unfold_hint"
        )) %>
  </div>
</div>
