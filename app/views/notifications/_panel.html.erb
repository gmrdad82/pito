<%# Sidebar panel content — the notifications list wrapped in the Sidebar shell.
    Rendered by both notifications/index.turbo_stream.erb (HTTP path) and
    Pito::Stream::Broadcaster#broadcast_notifications_sidebar (cable / slash path).
    Expects `notifications` (first page) and `next_cursor` (opaque token for the
    next page, or nil on the last page). %>
<%= render(Pito::Sidebar::Component.new(
      title: t("pito.sidebar.notifications.title")
    )) do |sidebar| %>
  <% sidebar.with_subtitle do %>
    <span class="text-fg-dim"><%= t("pito.sidebar.notifications.toggle_hint") %></span>
  <% end %>
  <% sidebar.with_body do %>
    <%= render(Pito::Sidebar::Notifications::Component.new(
          notifications: notifications,
          next_cursor:   next_cursor
        )) %>
  <% end %>
<% end %>
