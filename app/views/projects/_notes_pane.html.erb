<%# Phase 4 §9.1, §6.4 — Notes pane on the project show page.
  Phase B post-commit (2026-05-04):
    - `[e]` now points to `note_path(note)` (the show route IS the
      editor; no /edit segment).
    - Columns include the words count (mirror of the editor's live
      status bar) rendered through `NoteHelper.human_words` so the cell
      reads `6w` / `6,225w` (with the same `Nw` shape used by the
      `/projects` index notes column). Chars was dropped 2026-05-06.
  Phase B polish (2026-05-05) — always-on bulk shape:
    - `[bulk]` toggle and `[cancel]` link removed; checkboxes are
      always rendered.
    - Header `[ ]` / `[x]` select-all checkbox toggles every row.
    - `[delete N]` action self-hides at zero selection via the
      `bulk-select` Stimulus controller.
  Wave 3.5 follow-up (2026-05-06):
    - Title / words / last modified are sortable column headers,
      namespaced to `notes_sort` / `notes_dir` so this table's URL
      state coexists with the footage table's `sort` / `dir` on the
      same show page.
    - `words` and `last modified` use the shared `.num` class on both
      header and cell — right-aligned, tabular-nums (numeric / date-
      like values read better right-aligned).
    - Default sort: `last_modified desc` (most recently modified
      first — matches the legacy ordering).
  Locals:
    project, notes, locked (Boolean — tenant-wide notes-syncing
    lock), sort, dir
%>

<% sort ||= "last_modified" %>
<% dir  ||= "desc" %>

<div data-controller="bulk-select" data-bulk-select-entity-name-value="notes" data-bulk-select-delete-type-value="note">
  <div style="display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px;">
    <h2>notes (<%= number_with_delimiter(notes.size) %>)</h2>
    <% if locked %>
      <span class="text-muted">&middot;</span>
      <span class="bracketed-muted">[+]</span>
    <% else %>
      <span class="text-muted">&middot;</span>
      <%= button_to project_notes_path(project), form: { style: "display: inline;", data: { turbo: false } }, class: "bracketed", method: :post do %>[<span class="bl">+</span>]<% end %>
    <% end %>
    <span class="text-muted">&middot;</span>
    <% if locked %>
      <span class="bracketed-muted">[ scan ]</span>
    <% else %>
      <%= button_to scan_notes_path, form: { style: "display: inline;", data: { turbo: false } }, class: "bracketed", method: :post do %>[<span class="bl">scan</span>]<% end %>
    <% end %>
  </div>

  <% if locked %>
    <div class="flash-warning" style="margin-bottom: 8px;">
      notes are syncing — try again in a moment.
    </div>
  <% end %>

  <% if notes.any? %>
    <%# Phase B polish (2026-05-05) — bulk toolbar always rendered.
        Each `.action` span carries an `.action-sep` `&middot;` that the
        controller hides on whichever action is first-visible. The
        `deleteAction` target self-hides at zero selection. %>
    <div data-bulk-select-target="actions" class="bulk-toolbar" style="margin-bottom: 6px;">
      <span class="action" data-bulk-select-target="count" hidden>
        <span class="action-sep" hidden>&middot;</span>
      </span>
      <span class="action" data-bulk-select-target="deleteAction" hidden>
        <span class="action-sep" hidden>&middot;</span>
      </span>
    </div>

    <table>
      <thead>
        <tr>
          <th class="col-action">
            <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
          </th>
          <th class="sortable"><%= sort_link_to("title", "title", current_sort: sort, current_dir: dir, sort_param: "notes_sort", dir_param: "notes_dir") %></th>
          <th class="sortable num"><%= sort_link_to("words", "words", current_sort: sort, current_dir: dir, sort_param: "notes_sort", dir_param: "notes_dir") %></th>
          <th class="sortable num"><%= sort_link_to("last modified", "last_modified", current_sort: sort, current_dir: dir, sort_param: "notes_sort", dir_param: "notes_dir") %></th>
        </tr>
      </thead>
      <tbody>
        <% notes.each do |note| %>
          <tr>
            <td class="col-action">
              <%= render(CheckboxComponent.new(value: note.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
            </td>
            <td>
              <% if locked %>
                <%= note.title %>
              <% else %>
                <%= link_to note.title, note_path(note) %>
              <% end %>
            </td>
            <td class="num"><%= NoteHelper.human_words(note.words_count) %></td>
            <td class="num"><%= compact_time_ago(note.last_modified_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no notes yet.</p>
  <% end %>
</div>
