<% content_for(:title, "projects") %>

<%#
  Phase B — bulk-select picker on /projects.
  Mirrors app/views/videos/index.html.erb.

  Deviation from videos/index: projects has no multi-pane "open N" flow,
  so we omit `data-bulk-select-max-panes-value` /
  `data-bulk-select-panes-path-value` AND the `openHint` / `openAction`
  targets. The Stimulus controller guards every panes-specific access
  with `has*Target` checks, so the open-related branch is silently
  skipped here. The `count` target stays — it's universal.

  Phase 4 Wave 2 — sortable column headers. Each `<th>` for a sortable
  column is a `link_to` that flips the URL's `sort` / `dir` params,
  mirroring the URL-state pattern `ChannelsController` exposes via
  `ALLOWED_SORTS` + `sort_clause`. Default sort is `created_at DESC`.

  Wave 3.5+ aggregates revamp (2026-05-06):
  - The `footages` column became `footage` (singular header) and now
    renders `human_duration(project.footage_duration_seconds)` —
    summed total of the project's footage durations.
  - The `notes` column keeps the `notes` header (still concept-correct)
    but renders `project.notes_words_total` — summed word count across
    all of the project's notes.
  - Both new values are kept up-to-date by after_save / after_destroy
    callbacks on `Footage` / `Note`. Sort keys map to the new aggregate
    columns (`footage_duration_seconds`, `notes_words_total`).
  - The `timelines` column is unchanged (still the counter cache; no
    timeline-specific aggregate yet).
%>
<%# Sort headers use the shared `sort_link_to` helper so the active
    column's link picks up the `.sort-{asc,desc}` class — the CSS
    `:has()` rule then suppresses the neutral up/down `::after` glyph
    on this column, leaving just the inline `▲` / `▼`. Without the
    helper (or its class), the active header renders both indicators
    at once (the dual-arrow bug). %>
<%
  current_sort = @sort
  current_dir = @dir
%>
<div style="max-width: 1100px;" data-controller="bulk-select" data-bulk-select-entity-name-value="projects" data-bulk-select-delete-type-value="project">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <h1>projects</h1>
    <span class="text-muted">&middot;</span>
    <%= button_to projects_path, form: { style: "display: inline;", data: { turbo: false } }, class: "bracketed", method: :post do %>[<span class="bl">+</span>]<% end %>
    <span data-bulk-select-target="bulkToggle">
      <span class="text-muted">&middot;</span>
      <%= render(BracketedLinkComponent.new(label: "bulk", href: "#", data: { action: "click->bulk-select#enterBulk" })) %>
    </span>
  </div>

  <% if @projects.any? %>
    <%# Phase B — bulk toolbar uses the leading-separator pattern.
        Each `.action` span carries an `.action-sep` `&middot;` that
        the controller hides on whichever action is first-visible.
        See bulk_select_controller.js#_updateSeparators. %>
    <div data-bulk-select-target="actions" hidden class="bulk-toolbar" style="margin-bottom: 6px;">
      <span class="action" data-bulk-select-target="count" hidden>
        <span class="action-sep" hidden>&middot;</span>
      </span>
      <span class="action" data-bulk-select-target="deleteAction" hidden>
        <span class="action-sep" hidden>&middot;</span>
      </span>
      <span class="action">
        <span class="action-sep" hidden>&middot;</span>
        <%= render(BracketedLinkComponent.new(label: "cancel", href: "#", data: { action: "click->bulk-select#exitBulk" })) %>
      </span>
    </div>

    <table>
      <thead>
        <tr>
          <th class="col-action" data-bulk-select-target="bulkCol" hidden>
            <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
          </th>
          <th class="sortable"><%= sort_link_to("name", "name", current_sort: current_sort, current_dir: current_dir) %></th>
          <th class="sortable num"><%= sort_link_to("created", "created_at", current_sort: current_sort, current_dir: current_dir) %></th>
          <th class="sortable num"><%= sort_link_to("footage", "footage_duration_seconds", current_sort: current_sort, current_dir: current_dir) %></th>
          <th class="sortable num"><%= sort_link_to("notes", "notes_words_total", current_sort: current_sort, current_dir: current_dir) %></th>
          <th class="sortable num"><%= sort_link_to("timelines", "timelines_count", current_sort: current_sort, current_dir: current_dir) %></th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr>
            <td class="col-action" data-bulk-select-target="bulkCol" hidden>
              <%= render(CheckboxComponent.new(value: project.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
            </td>
            <td><%= link_to project.name, project_path(project) %></td>
            <td class="num"><%= compact_time_ago(project.created_at) %></td>
            <td class="num"><%= human_duration(project.footage_duration_seconds) %></td>
            <td class="num"><%= NoteHelper.human_words(project.notes_words_total) %></td>
            <td class="num"><%= project.timelines_count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no projects yet.</p>
  <% end %>
</div>
