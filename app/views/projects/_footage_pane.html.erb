<%# Phase 4 §9.1 — Footage pane on the project show page.
  Locals: project, footages
%>

<div style="display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px;">
  <h2>footage (<%= number_with_delimiter(footages.size) %>)</h2>
  <span class="text-muted">&middot;</span>
  <%= render(BracketedLinkComponent.new(label: "download cli", href: footage_importer_download_path)) %>
</div>

<% if footages.any? %>
  <table>
    <thead>
      <tr>
        <th class="col-action"></th>
        <th>filename</th>
        <th>kind</th>
        <th>resolution</th>
        <th>duration</th>
      </tr>
    </thead>
    <tbody>
      <% footages.each do |footage| %>
        <tr>
          <td class="col-action">
            <%= render(BracketedLinkComponent.new(label: "edit", href: edit_footage_path(footage))) %>
          </td>
          <td><%= footage.filename %></td>
          <td><%= footage.kind %></td>
          <td><%= footage.resolution || "—" %></td>
          <td class="num"><%= format_duration(footage.duration_seconds) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">no footage yet. run:</p>
  <div data-controller="clipboard-copy" class="code-block">
    <span class="code-prompt" aria-hidden="true">$</span>
    <code data-clipboard-copy-target="source">pito footage import --project <%= project.id %> --path &lt;dir&gt;</code>
    <a href="#" data-action="click->clipboard-copy#copy" class="bracketed">[<span class="bl">copy</span>]</a>
  </div>
<% end %>
