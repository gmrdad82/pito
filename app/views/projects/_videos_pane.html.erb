<%# Phase 12 realignment (2026-05-10) — videos pane on the project show
    page. Replaces the retired timelines pane. Lists videos linked to
    the project via the direct nullable `Video.project_id` column
    (Phase 12 added `Project has_many :videos, dependent: :nullify`).

    No `[+]` add-button: there is no `videos#new` create flow scoped
    to a project (videos are sourced from YouTube and project_id is
    set via the video edit page).

    Locals: project, videos
%>

<div class="dot-list" style="margin-bottom: 4px;">
  <h2>videos (<%= number_with_delimiter(videos.size) %>)</h2>
</div>

<% if videos.any? %>
  <table>
    <thead>
      <tr>
        <th>title</th>
        <th>privacy</th>
        <th class="num">published</th>
      </tr>
    </thead>
    <tbody>
      <% videos.each do |video| %>
        <tr>
          <td>
            <%= link_to video.title.presence || video.youtube_video_id, video_path(video) %>
          </td>
          <td><%= video.privacy_status %></td>
          <td class="num">
            <% if video.published_at.present? %>
              <%= video.published_at.strftime("%Y-%m-%d") %>
            <% else %>
              &mdash;
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">no videos yet.</p>
<% end %>
