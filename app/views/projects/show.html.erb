<% page_label = @project.name %>
<% content_for(:title, page_label) %>
<% breadcrumb(["projects", projects_path], page_label) %>
<% content_for(:breadcrumb_actions) do %>
  <%= render(BracketedLinkComponent.new(label: "edit", href: edit_project_path(@project))) %>
  <span class="text-muted">&middot;</span>
  <%= render(BracketedLinkComponent.new(label: "delete", href: "/deletions/project/#{@project.id}", destructive: true)) %>
<% end %>

<div style="margin-bottom: 6px;">
  <h1 style="display: inline;"><%= @project.name %></h1>
</div>

<div class="pane-container" style="margin-top: 16px;">
  <div class="pane-wrapper">
    <%= render "projects/footage_pane", project: @project, footages: @footages %>
  </div>
  <div class="pane-wrapper">
    <%= render "projects/notes_pane", project: @project, notes: @notes, locked: @notes_locked %>
  </div>
  <div class="pane-wrapper">
    <%= render "projects/timelines_pane", project: @project, timelines: @timelines %>
  </div>
</div>
