<% page_label = @project.name %>
<% content_for(:title, page_label) %>
<% breadcrumb(["projects", projects_path], page_label) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "e", href: edit_project_path(@project))) %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/project/#{@project.id}", destructive: true)) %>
  </div>
<% end %>

<div style="margin-bottom: 6px;">
  <h1 style="display: inline;"><%= @project.name %></h1>
</div>

<%# Phase B revamp (2026-05-06) — Project show is a `.pane-row` of three
    panes that wrap to a new row when the viewport runs out:
    - timelines (`.pane`, 640px, A)
    - notes (`.pane`, 640px, B)
    - footage (`.pane pane--wide`, 1280px, wide tone)
    Zebra alternation paints the first two; `.pane--wide` keeps the wide
    tone regardless of position. %>
<div class="pane-row" style="margin-top: 16px;">
  <div class="pane">
    <%= render "projects/timelines_pane", project: @project, timelines: @timelines %>
  </div>
  <div class="pane">
    <%= render "projects/notes_pane",
               project: @project,
               notes: @notes,
               locked: @notes_locked,
               sort: @notes_sort,
               dir: @notes_dir %>
  </div>
  <div class="pane pane--wide">
    <%= render "projects/footage_pane",
               project: @project,
               footages: @footages,
               filter_options: @footage_filter_options,
               active_filters: @footage_active_filters,
               sort: @footage_sort,
               dir: @footage_dir %>
  </div>
</div>

<%# Phase 12 — linked videos. Direct nullable Video.project_id replaces
    the dropped Timeline intermediary. Listing is published-first,
    most-recent-first; ordering by published_at desc surfaces the live
    work. %>
<% linked_videos = @project.videos.order(Arel.sql("published_at DESC NULLS LAST")) %>
<div class="pane" style="margin-top: 16px; max-width: 1280px;">
  <h2>linked videos (<%= linked_videos.size %>)</h2>
  <% if linked_videos.any? %>
    <table>
      <thead>
        <tr>
          <th>title</th>
          <th>privacy</th>
          <th>published</th>
        </tr>
      </thead>
      <tbody>
        <% linked_videos.each do |video| %>
          <tr>
            <td>
              <%= link_to video.title.presence || video.youtube_video_id, video_path(video) %>
            </td>
            <td><%= video.privacy_status %></td>
            <td>
              <% if video.published_at.present? %>
                <%= video.published_at.strftime("%Y-%m-%d") %>
              <% else %>
                —
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no videos linked yet.</p>
  <% end %>
</div>
