<% content_for(:title, "authorization code") %>
<% content_for(:hide_chrome, true) %>

<%# Phase 7.5 — Doorkeeper authorization-code page restyled to match
    Pito's design system. This template renders only when the OAuth
    request used the out-of-band redirect (`urn:ietf:wg:oauth:2.0:oob`)
    or no `redirect_uri` — the user must copy the code by hand back to
    the requesting client. `:hide_chrome` strips the header/footer to
    logo + theme toggle (mirrors the sibling `new.html.erb` and
    `error.html.erb`). The code sits inside a `.pane.pane--standalone`
    so it reads with the pane look used everywhere else for data-display
    surfaces — same shape as `settings/oauth_applications/create.html.erb`
    for one-time credentials. %>
<div style="max-width: 480px; margin: 24px 0;">
  <h1>authorization code</h1>
  <p class="text-muted" style="margin-top: 2px;">
    copy this code back into the application that requested authorization.
  </p>

  <div class="pane pane--standalone">
    <table class="detail-table">
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">code</td>
        <td>
          <span data-controller="clipboard-copy" class="code-block">
            <code id="authorization_code" data-clipboard-copy-target="source"><%= params[:code] %></code>
            <a href="#" data-action="click->clipboard-copy#copy" class="bracketed">[<span class="bl">copy</span>]</a>
          </span>
        </td>
      </tr>
    </table>
  </div>

  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "back to home", href: root_path)) %>
  </div>
</div>
