<%# Phase 7.5 §11f — Channel banner upload. Replaces the 11c stub.

    Stimulus controller: `banner-upload`
      - drag-drop zone + hidden `<input type="file">`
      - client-side validation (type, dimensions, aspect, size) with
        clear messages per D22; all rejection reasons render
        simultaneously (no first-fail-only)
      - multi-size preview (web / mobile / TV) before submit
      - blocks the form submit until the async client check passes;
        renders a progress indicator while validating
      - revokes blob URLs after preview generation

    Strict no `alert()` / `confirm()` / `prompt()` per CLAUDE.md.
%>
<fieldset id="channel-banner-section"
          data-controller="banner-upload"
          data-banner-upload-min-width-value="2048"
          data-banner-upload-min-height-value="1152"
          data-banner-upload-aspect-ratio-value="<%= 16.0 / 9.0 %>"
          data-banner-upload-aspect-tolerance-value="0.02"
          data-banner-upload-max-size-bytes-value="6291456"
          style="margin-bottom: 16px; border: 1px solid #ddd; padding: 8px 12px;">
  <legend>banner</legend>
  <p class="form-hint" style="font-size: 11px;">
    Banner: 2048x1152 minimum, 16:9 aspect, JPEG/PNG, max 6MB.
  </p>

  <%= render "channels/banner", channel: channel %>

  <div data-banner-upload-target="dropZone"
       class="banner-upload-drop-zone"
       data-action="dragover->banner-upload#onDragOver dragleave->banner-upload#onDragLeave drop->banner-upload#onDrop"
       style="border: 1px dashed #ddd; padding: 16px; text-align: center; cursor: pointer;">
    <p class="form-hint" style="font-size: 11px; margin: 0 0 8px;">
      drag a JPEG or PNG here, or
    </p>
    <%= link_to "[pick file]", "#",
                class: "bracketed",
                data: {
                  action: "click->banner-upload#openPicker",
                  banner_upload_target: "pickerButton"
                } %>
    <input type="file"
           name="channel[banner_image]"
           accept="image/png,image/jpeg"
           hidden
           data-banner-upload-target="input"
           data-action="change->banner-upload#onFilePicked">
  </div>

  <p class="form-hint banner-upload-progress" hidden
     data-banner-upload-target="progress"
     style="font-size: 11px; margin-top: 8px;">
    validating image...
  </p>

  <div class="banner-upload-errors text-danger" hidden
       data-banner-upload-target="errors"
       style="font-size: 11px; margin-top: 8px;">
  </div>

  <div class="banner-upload-preview" hidden
       data-banner-upload-target="previewContainer"
       style="margin-top: 12px;">
    <p class="form-hint" style="font-size: 11px;">preview:</p>
    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
      <div style="font-size: 11px;">
        <p style="margin: 0 0 4px;">web (2560×423)</p>
        <img data-banner-upload-target="previewWeb"
             alt="banner preview (web)"
             style="display: block; width: 320px; height: 53px; object-fit: cover; border: 1px solid #ddd;">
      </div>
      <div style="font-size: 11px;">
        <p style="margin: 0 0 4px;">mobile (1546×423)</p>
        <img data-banner-upload-target="previewMobile"
             alt="banner preview (mobile)"
             style="display: block; width: 193px; height: 53px; object-fit: cover; border: 1px solid #ddd;">
      </div>
      <div style="font-size: 11px;">
        <p style="margin: 0 0 4px;">tv (2048×1152)</p>
        <img data-banner-upload-target="previewTv"
             alt="banner preview (tv)"
             style="display: block; width: 192px; height: 108px; object-fit: cover; border: 1px solid #ddd;">
      </div>
    </div>
  </div>
</fieldset>
