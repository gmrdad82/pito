<%# Phase 7.5 §11c — Channel edit form. Replaces the URL-paste
    create form (URL-paste entry path was retired). All editable
    fields render here; the controller dispatches the dirty subset
    through Youtube::Client#update_channel + #set_watermark /
    #unset_watermark. Watermark + banner pre-flight validation is
    handled client-side by Stimulus controllers (links repeater +
    file upload). Server-side validation is the authoritative gate
    per D14. %>
<%= form_with(model: channel, multipart: true, html: { data: { controller: "links-repeater file-upload" } }) do |f| %>
  <%= render "channels/form_errors", channel: channel %>

  <%# Locked URL display. URL is immutable post-create (D11a). %>
  <div style="margin-bottom: 12px;">
    <label>youtube channel url</label>
    <input type="text" value="<%= channel.channel_url %>" readonly disabled style="width: 100%; max-width: 480px;">
    <p class="form-hint" style="margin-top: 4px; font-size: 11px;">URL is locked after creation.</p>
  </div>

  <%# ─── Title (14-day gate) ─── %>
  <div style="margin-bottom: 12px;">
    <label for="channel_title">title</label>
    <% if title_gate_open?(channel) %>
      <p class="text-muted" style="margin-top: 4px;">
        title was changed on <%= channel.title_changed_at.to_date.iso8601 %>;
        youtube limits changes to 1 per 14 days.
        <%= link_to "[remind me on #{title_unlock_date(channel)}]",
            "#",
            class: "bracketed",
            data: {
              controller: "reminder-link",
              reminder_link_unlock_date_value: title_unlock_date(channel),
              reminder_link_field_value: "title",
              reminder_link_channel_id_value: channel.id,
              action: "click->reminder-link#create"
            } %>
      </p>
    <% else %>
      <%= f.text_field :title, value: channel.title, maxlength: 100,
                       style: "width: 100%; max-width: 480px;" %>
    <% end %>
  </div>

  <%# ─── Handle (14-day gate) ─── %>
  <div style="margin-bottom: 12px;">
    <label for="channel_handle">handle</label>
    <% if handle_gate_open?(channel) %>
      <p class="text-muted" style="margin-top: 4px;">
        handle was changed on <%= channel.handle_changed_at.to_date.iso8601 %>;
        youtube limits changes to 1 per 14 days.
        <%= link_to "[remind me on #{handle_unlock_date(channel)}]",
            "#",
            class: "bracketed",
            data: {
              controller: "reminder-link",
              reminder_link_unlock_date_value: handle_unlock_date(channel),
              reminder_link_field_value: "handle",
              reminder_link_channel_id_value: channel.id,
              action: "click->reminder-link#create"
            } %>
      </p>
    <% else %>
      <%= f.text_field :handle, value: channel.handle, maxlength: 30,
                       placeholder: "@yourhandle",
                       style: "width: 100%; max-width: 480px;" %>
      <p class="form-hint" style="margin-top: 4px; font-size: 11px;">starts with `@`, 3–30 characters.</p>
    <% end %>
  </div>

  <%# ─── Description ─── %>
  <div style="margin-bottom: 12px;">
    <label for="channel_description">description</label>
    <%= f.text_area :description, value: channel.description, rows: 6,
                    maxlength: 5000,
                    style: "width: 100%; max-width: 560px;" %>
  </div>

  <%# ─── Country / language / keywords ─── %>
  <div style="margin-bottom: 12px;">
    <label for="channel_country">country</label>
    <%= f.text_field :country, value: channel.country, maxlength: 2,
                     placeholder: "US",
                     style: "width: 80px;" %>
    <p class="form-hint" style="margin-top: 4px; font-size: 11px;">ISO 3166-1 alpha-2 (2 uppercase letters).</p>
  </div>

  <div style="margin-bottom: 12px;">
    <label for="channel_default_language">default language</label>
    <%= f.text_field :default_language, value: channel.default_language, maxlength: 10,
                     placeholder: "en",
                     style: "width: 120px;" %>
    <p class="form-hint" style="margin-top: 4px; font-size: 11px;">BCP-47 (e.g., `en`, `en-US`).</p>
  </div>

  <div style="margin-bottom: 12px;">
    <label for="channel_keywords">keywords</label>
    <%= f.text_field :keywords, value: channel.keywords,
                     style: "width: 100%; max-width: 560px;" %>
    <p class="form-hint" style="margin-top: 4px; font-size: 11px;">space-separated.</p>
  </div>

  <%# ─── Links (jsonb repeater) ─── %>
  <div style="margin-bottom: 16px;" data-links-repeater-target="container">
    <label>links</label>
    <p class="form-hint" style="font-size: 11px;">up to 5 entries. each has a label + URL.</p>
    <% existing_links = Array(channel.links) %>
    <% existing_links.each_with_index do |link, idx| %>
      <div class="links-repeater-row" data-links-repeater-target="row" style="display: flex; gap: 6px; margin-bottom: 4px;">
        <input type="text" name="channel[links_attributes][<%= idx %>][title]"
               value="<%= link.is_a?(Hash) ? link["title"] || link[:title] : "" %>"
               maxlength="50" placeholder="label" style="flex: 0 0 160px;">
        <input type="text" name="channel[links_attributes][<%= idx %>][url]"
               value="<%= link.is_a?(Hash) ? link["url"] || link[:url] : "" %>"
               placeholder="https://..." style="flex: 1;">
        <input type="hidden" name="channel[links_attributes][<%= idx %>][_destroy]" value="no"
               data-links-repeater-target="destroyFlag">
        <%= link_to "[remove]", "#", class: "bracketed",
                    data: { action: "click->links-repeater#remove" } %>
      </div>
    <% end %>
    <%# trailing empty row for the first new link, when count < 5 %>
    <% existing_link_count = existing_links.size %>
    <% if existing_link_count < Channel::MAX_LINKS %>
      <% next_link_idx = existing_link_count %>
      <div class="links-repeater-row" data-links-repeater-target="row" style="display: flex; gap: 6px; margin-bottom: 4px;">
        <input type="text" name="channel[links_attributes][<%= next_link_idx %>][title]"
               maxlength="50" placeholder="label" style="flex: 0 0 160px;">
        <input type="text" name="channel[links_attributes][<%= next_link_idx %>][url]"
               placeholder="https://..." style="flex: 1;">
        <input type="hidden" name="channel[links_attributes][<%= next_link_idx %>][_destroy]" value="no"
               data-links-repeater-target="destroyFlag">
        <%= link_to "[remove]", "#", class: "bracketed",
                    data: { action: "click->links-repeater#remove" } %>
      </div>
    <% end %>
    <div data-links-repeater-target="addContainer" <%= "hidden" if existing_link_count >= Channel::MAX_LINKS %>>
      <%= link_to "[+ add link]", "#", class: "bracketed",
                  data: {
                    action: "click->links-repeater#add",
                    links_repeater_max_value: Channel::MAX_LINKS,
                    links_repeater_target: "addButton"
                  } %>
    </div>
  </div>

  <%# ─── Watermark ─── %>
  <fieldset style="margin-bottom: 16px; border: 1px solid #ddd; padding: 8px 12px;">
    <legend>watermark</legend>
    <p class="form-hint" style="font-size: 11px;">
      expected: 800×800 PNG or JPEG; max 1 MB.
    </p>
    <div style="margin-bottom: 8px;">
      <input type="file" name="channel[watermark]" accept="image/png,image/jpeg"
             data-file-upload-target="input"
             data-action="change->file-upload#validate">
      <p class="form-hint file-upload-error text-danger" data-file-upload-target="error"
         style="font-size: 11px;" hidden></p>
    </div>
    <div style="margin-bottom: 8px;">
      <label>timing</label>
      <%= f.select :watermark_timing,
            Channel::WATERMARK_TIMINGS.map { |t| [t.tr("_", " "), t] },
            { include_blank: true, selected: channel.watermark_timing },
            data: { action: "change->file-upload#toggleOffset",
                    file_upload_target: "timing" } %>
    </div>
    <div style="margin-bottom: 8px;" data-file-upload-target="offsetContainer"
         <%= "hidden" unless %w[offset_from_start offset_from_end].include?(channel.watermark_timing) %>>
      <label>offset (ms)</label>
      <%= f.number_field :watermark_offset_ms, value: channel.watermark_offset_ms,
                         min: 0, style: "width: 120px;" %>
    </div>
    <% if channel.watermark_url.present? %>
      <div style="margin-bottom: 8px;">
        <input type="hidden" name="channel[watermark_remove]" value="no"
               data-file-upload-target="removeFlag">
        <%= link_to "[remove watermark]", "/deletions/channel_watermark/#{channel.id}",
                    class: "bracketed text-danger" %>
      </div>
    <% end %>
  </fieldset>

  <%# ─── Banner slot (owned by 11f) ─── %>
  <%= render "channels/banner_upload", channel: channel %>

  <%# ─── Submit ─── %>
  <div style="display: flex; gap: 6px;">
    <button type="submit" class="btn-submit">[<b>update</b>]</button>
    <%= render(BracketedLinkComponent.new(label: "cancel", href: cancel_path)) %>
  </div>
<% end %>
