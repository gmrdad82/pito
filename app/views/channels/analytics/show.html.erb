<%
  channel_label = @channel.channel_url.to_s.split("/").last.presence || "channel #{@channel.id}"
  page_title = "#{channel_label} · analytics"
%>
<% content_for(:title, page_title) %>

<header class="analytics-header" style="margin-bottom: 16px;">
  <h1><%= page_title %></h1>
  <%= render "analytics/data_freshness", timestamp: @last_synced_at %>
  <%= render "analytics/window_picker", window: @window %>
  <% if @channel.youtube_connection.present? %>
    <%= button_to "[refresh now]",
                  channel_analytics_refresh_path(@channel),
                  method: :post,
                  class: "bracketed",
                  form: { style: "display: inline; margin-left: 8px;" } %>
  <% end %>
</header>

<% if @needs_reauth %>
  <%= render "analytics/needs_reauth_banner" %>
<% end %>

<% summary = @decorator.window_summary(@window) %>
<section class="analytics-section analytics-window-summary" style="margin: 16px 0;">
  <h2>summary — <%= analytics_window_label(@window, long: true) %></h2>
  <% if summary %>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      <%= render "analytics/summary_card",
                 label: "views",
                 value: summary.views,
                 type: :count %>
      <%= render "analytics/summary_card",
                 label: "estimated minutes watched",
                 value: summary.estimated_minutes_watched,
                 type: :count %>
      <%= render "analytics/summary_card",
                 label: "average view duration",
                 value: summary.average_view_duration,
                 type: :duration_seconds %>
      <%= render "analytics/summary_card",
                 label: "average view %",
                 value: summary.average_view_percentage,
                 type: :ratio %>
      <%= render "analytics/summary_card",
                 label: "net subscribers",
                 value: (summary.subscribers_gained.to_i - summary.subscribers_lost.to_i),
                 type: :integer %>
      <%= render "analytics/summary_card",
                 label: "thumbnail CTR",
                 value: summary.video_thumbnail_impressions_click_rate,
                 type: :ratio %>
    </div>
    <% if monetization_enabled? %>
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;">
        <%= render "analytics/summary_card",
                   label: "estimated revenue",
                   value: summary.estimated_revenue,
                   type: :money %>
        <%= render "analytics/summary_card",
                   label: "cpm",
                   value: summary.cpm,
                   type: :money %>
      </div>
    <% else %>
      <%= render "analytics/monetization_disabled" %>
    <% end %>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>

<section class="analytics-section analytics-daily" style="margin: 16px 0;">
  <%= render "analytics/charts/channel_daily_line",
             dailies: @decorator.daily_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-top-videos-section" style="margin: 16px 0;">
  <%= render "analytics/charts/top_videos_table",
             rows: @decorator.top_videos(@window),
             window: @window %>
</section>

<section class="analytics-section analytics-geography-section" style="margin: 16px 0;">
  <%= render "analytics/charts/country_bar",
             breakdown: @decorator.geography_summed(@window_start, @window_end),
             window: @window,
             caveat: true %>
</section>

<section class="analytics-section analytics-demographics-section" style="margin: 16px 0;">
  <%= render "analytics/charts/demographics_heatmap",
             breakdown: @decorator.demographics_summed(@window_start, @window_end),
             window: @window,
             caveat: true %>
</section>

<%# Phase 26 §01g — viewer-time heatmap (channel aggregate). %>
<%= render "channels/viewer_time_tab", channel: @channel %>
