<% content_for(:title, "channels") %>
<% pane_label = ->(c) { c ? "##{c.id}" : "?" } %>
<% pane_breadcrumb = @panes.compact.map { |c| pane_label.call(c) }.join(" + ") %>
<% breadcrumb(["channels", channels_path], pane_breadcrumb) %>
<% content_for(:breadcrumb_actions) do %>
  <% if @saved_view %>
    <% saved_view_modal_id = "confirm-saved-view-#{@saved_view.id}" %>
    <%= render(BracketedLinkComponent.new(
      label: "delete",
      href: "#",
      destructive: true,
      data: {
        controller: "modal-trigger",
        action: "click->modal-trigger#open",
        modal_trigger_target_id_value: saved_view_modal_id
      }
    )) %>
    <%= render(ConfirmModalComponent.new(
      id: saved_view_modal_id,
      title: "delete this saved view?",
      confirm_path: saved_view_path(@saved_view),
      confirm_method: :delete,
      confirm_label: "delete",
      destructive: true
    )) %>
  <% else %>
    <%= button_to saved_views_path, params: { saved_view: { kind: "channels", url: request.fullpath, name: pane_breadcrumb } }, form: { style: "display: inline;", data: { turbo: false } } do %>[<span class="bl">save</span>]<% end %>
  <% end %>
<% end %>

<% pane_ids = @panes.compact.map(&:id) %>
<% current_ids = pane_ids.join(",") %>

<div data-controller="add-pane">
  <div style="margin-bottom: 6px;">
    <h1 style="display: inline;">channels (<%= number_with_delimiter(@panes.compact.size) %>)</h1>
    <% if @available_channels&.any? %>
      <span style="position: relative; top: -2px;">
        <span class="text-muted">&middot;</span>
        <%= render(BracketedLinkComponent.new(label: "+", href: "#", data: { action: "click->add-pane#open" })) %>
      </span>
    <% end %>
  </div>

  <div class="pane-container">
    <% @panes.each_with_index do |channel, i| %>
      <% if channel %>
        <div class="pane-wrapper" style="position: relative;">
          <% if i > 0 %>
            <% swapped = pane_ids.dup; swapped[i], swapped[i-1] = swapped[i-1], swapped[i] %>
            <%= link_to "◀", "#{panes_channels_path}?ids=#{swapped.join(',')}", class: "pane-arrow pane-arrow-left", title: "move left" %>
            <%= link_to "▲", "#{panes_channels_path}?ids=#{swapped.join(',')}", class: "pane-arrow pane-arrow-up", title: "move up" %>
          <% end %>
          <% if i < @panes.compact.size - 1 %>
            <% swapped = pane_ids.dup; swapped[i], swapped[i+1] = swapped[i+1], swapped[i] %>
            <%= link_to "▶", "#{panes_channels_path}?ids=#{swapped.join(',')}", class: "pane-arrow pane-arrow-right", title: "move right" %>
            <%= link_to "▼", "#{panes_channels_path}?ids=#{swapped.join(',')}", class: "pane-arrow pane-arrow-down", title: "move down" %>
          <% end %>
          <div style="display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px;">
            <h2>channel #<%= channel.id %></h2>
            <span style="position: relative; top: -1px;"><span class="text-muted">&middot;</span>
            <%= render(BracketedLinkComponent.new(label: "focus", href: channel_path(channel))) %>
            <% remaining_ids = pane_ids.reject { |id| id == channel.id } %>
            <% if remaining_ids.size > 1 %>
              <span class="text-muted">&middot;</span>
              <%= render(BracketedLinkComponent.new(label: "−", href: "#{panes_channels_path}?ids=#{remaining_ids.join(',')}")) %>
            <% elsif remaining_ids.size == 1 %>
              <span class="text-muted">&middot;</span>
              <%= render(BracketedLinkComponent.new(label: "−", href: channel_path(remaining_ids.first))) %>
            <% end %></span>
          </div>
          <%= render "channels/pane", channel: channel %>
        </div>
      <% else %>
        <div class="pane-wrapper">
          <p class="text-muted" style="padding: 8px;">channel not found.</p>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @available_channels&.any? %>
    <%= render "channels/add_pane_dialog", available_channels: @available_channels, current_ids: current_ids %>
  <% end %>
</div>
