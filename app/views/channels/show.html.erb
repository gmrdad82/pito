<% content_for(:title, @channel.title) %>
<% breadcrumb(["channels", channels_path], @channel.title) %>
<% content_for(:breadcrumb_actions) do %>
  <%= render(BracketedLinkComponent.new(label: "edit", href: edit_channel_path(@channel))) %>
  <span class="text-muted">&middot;</span>
  <%= render(BracketedLinkComponent.new(label: "delete", href: "/deletions/channel/#{@channel.id}", destructive: true)) %>
<% end %>

<div data-controller="add-pane">
  <div style="margin-bottom: 6px;">
    <h1 style="display: inline;"><%= @channel.title %></h1><% if @available_channels.any? %> <span style="position: relative; top: -2px;"><span class="text-muted">&middot;</span> <%= render(BracketedLinkComponent.new(label: "+", href: "#", data: { action: "click->add-pane#open" })) %></span><% end %>
  </div>

  <%= render "channels/pane", channel: @channel %>

  <% if @available_channels.any? %>
    <%= render "channels/add_pane_dialog", available_channels: @available_channels, current_ids: @channel.id.to_s %>
  <% end %>
</div>
