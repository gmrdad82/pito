<% page_label = "channel ##{@channel.id}" %>
<% content_for(:title, page_label) %>
<% breadcrumb(["channels", channels_path], page_label) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "e", href: edit_channel_path(@channel))) %>
    <%= render(BracketedLinkComponent.new(label: "sync", href: "/syncs/channel/#{@channel.id}", data: { keyboard_page_action: "sync" })) %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/channel/#{@channel.id}", destructive: true, data: { keyboard_page_action: "delete" })) %>
  </div>
<% end %>

<%# `data-keyboard-external-url` lets the global keyboard controller
    open the channel's underlying URL in a new tab when the user
    presses `v` on the detail page (mirrors the CLI binding). %>
<div data-controller="add-pane" data-keyboard-external-url="<%= @channel.channel_url %>">
  <div class="dot-list" style="margin-bottom: 6px;">
    <h1 style="display: inline;">channel #<%= @channel.id %></h1>
    <% if @available_channels.any? %>
      <%= render(BracketedLinkComponent.new(label: "+", href: "#", data: { action: "click->add-pane#open" })) %>
    <% end %>
  </div>

  <%# Phase 22 — in-flight import badge. Visible whenever an ImportJob
      for this channel is `queued` or `running`. Links to the modal's
      show view so the user can resume the keep/reject flow without
      reopening from `/videos`. %>
  <% if (in_flight_job = @channel.in_flight_import_job) %>
    <div class="pane pane--standalone" style="margin-bottom: 8px; padding: 6px 10px;">
      <%= render(Imports::ProgressIndicatorComponent.new(import_job: in_flight_job)) %>
      <%= render(BracketedLinkComponent.new(
        label: "view progress",
        href: imports_channel_path(in_flight_job)
      )) %>
    </div>
  <% end %>

  <%# Two-pane layout (2026-05-10): the show page now splits channel detail
      and the videos list into separate side-by-side panes inside a
      `.pane-row`. Detail lives in the first pane (zebra index A); videos
      live in the second (zebra index B). The detail pane lets the URL row
      wrap with `word-break: break-all` so the full canonical URL stays
      visible without an ellipsis. %>
  <div class="pane-row">
    <div class="pane">
      <%# URL row. The URL is itself an external link; `word-break: break-all`
          lets it wrap inside the 452px pane instead of truncating. %>
      <div style="display: flex; align-items: baseline; gap: 6px; min-width: 0; max-width: 100%; margin-bottom: 4px;">
        <span class="text-muted" style="flex-shrink: 0;">URL</span>
        <a href="<%= @channel.channel_url %>" target="_blank" rel="noopener noreferrer" style="flex: 1; min-width: 0; word-break: break-all;"><%= @channel.channel_url %></a>
      </div>
      <table class="detail-table" style="margin-bottom: 8px;">
        <tr>
          <td class="text-muted" style="padding-right: 12px;">starred</td>
          <td>
            <%= @channel.star? ? "yes" : "no" %>
            <%= form_with(model: @channel, html: { style: "display: inline; margin-left: 8px;" }) do |f| %>
              <%= f.hidden_field :star, value: @channel.star? ? "no" : "yes" %>
              <button type="submit" class="bracketed" style="background: none; border: none; cursor: pointer; padding: 0; color: inherit; font: inherit;">
                [<%= @channel.star? ? "unstar" : "star" %>]
              </button>
            <% end %>
          </td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">last sync</td>
          <td><%= compact_time_ago(@channel.last_synced_at) %></td>
        </tr>
      </table>
    </div>

    <div class="pane">
      <% videos = @channel.videos
          .left_joins(:video_stats)
          .select(
            "videos.*",
            "COALESCE(SUM(video_stats.views), 0) AS total_views",
            "COALESCE(SUM(video_stats.likes), 0) AS total_likes"
          )
          .group("videos.id")
          .order(created_at: :desc) %>

      <h2>videos (<%= number_with_delimiter(@channel.videos.count) %>)</h2>
      <%# Phase 21 — quick jump to the videos picker pre-filtered by this
          channel. The `?channel=<slug>` param is read by
          `VideosController#index` (Channel.friendly.find resolves slug-
          or-id) and renders a clear-filter chip on the picker page. %>
      <p style="margin: 0 0 8px 0;">
        <%= render(BracketedLinkComponent.new(label: "see all videos for this channel", href: videos_path(channel: @channel.to_param))) %>
      </p>

      <% if videos.any? %>
        <div data-controller="sortable-table" data-sortable-table-id-value="<%= @channel.id %>">
          <table data-sortable-table-target="table">
            <thead>
              <tr>
                <%= render(SortableHeaderComponent.new(label: "id", sort_type: "number", numeric: true)) %>
                <%= render(SortableHeaderComponent.new(label: "YouTube id", sort_type: "string")) %>
                <%= render(SortableHeaderComponent.new(label: "views", sort_type: "number", numeric: true)) %>
                <%= render(SortableHeaderComponent.new(label: "likes", sort_type: "number", numeric: true)) %>
              </tr>
            </thead>
            <tbody>
              <% videos.each do |video| %>
                <tr>
                  <td class="num"><%= link_to video.id, video_path(video), data: { turbo_frame: "_top" } %></td>
                  <td><%= video.youtube_video_id %></td>
                  <td class="num"><%= number_with_delimiter(video.total_views) %></td>
                  <td class="num"><%= number_with_delimiter(video.total_likes) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="caption">no videos yet.</p>
      <% end %>
    </div>
  </div>

  <% if @available_channels.any? %>
    <%= render "channels/add_pane_dialog", available_channels: @available_channels, current_ids: @channel.id.to_s %>
  <% end %>
</div>
