<%# Phase 7.5 §11b — channel show page revamp.
    Three pane rows stacked vertically (detail → analytics → videos),
    replacing the prior two-pane URL+videos placeholder. Every
    nullable column has a muted empty-state per the locked matrix;
    the page never 500s on a bare-bones pre-sync channel.

    The empty `channel_diff_banner` Turbo frame under the H1 is the
    drop target for 11i's diff banner stream — 11b ships the slot
    empty so 11i can populate it without re-editing this view.
%>
<% display_title = channel_display_title(@channel) %>
<%# 2026-05-11 — drop the redundant "channel " prefix from the page title
    and breadcrumb. The `[channels]` breadcrumb segment already communicates
    the section; doubling "channel" in the leaf label is noise. %>
<% content_for(:title, display_title) %>
<% breadcrumb(["channels", channels_path], display_title) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "e", href: edit_channel_path(@channel))) %>
    <%= render(BracketedLinkComponent.new(label: "changes", href: channel_change_logs_path(@channel))) %>
    <%# Phase 11i Q7 follow-up — single-channel `[sync]` is a diff-check
        intent (compare YouTube, surface divergence) NOT a cache overwrite.
        The Phase 11i banner Turbo Frame consumes the result. %>
    <%= render(BracketedLinkComponent.new(label: "sync", href: "/syncs/channel/#{@channel.id}?intent=diff_check", data: { keyboard_page_action: "sync" })) %>
    <%# Phase 24 — per-channel `[revoke]` cascade. Inline with the rest
        of the heading-actions row. Destructive (red) — opens the
        wide-modal confirmation page. NO keyboard shortcut by design
        (locked decision #6, matches absence of shortcut for `[-]`). %>
    <%= render(BracketedLinkComponent.new(label: "revoke", href: revoke_channel_path(@channel), destructive: true)) %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/channel/#{@channel.id}", destructive: true, data: { keyboard_page_action: "delete" })) %>
  </div>
<% end %>

<%# `data-keyboard-external-url` keeps the `v` shortcut wired to the
    underlying YouTube URL (mirrors the CLI binding). The
    `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    pair (when present) carries the `h` / `l` sibling navigation URLs
    for the global keyboard controller. %>
<div data-controller="add-pane" data-keyboard-external-url="<%= @channel.channel_url %>" <%= keyboard_detail_nav_data_attributes(@channel, scope: Channel, path_helper: method(:channel_path)) %>>
  <%# 2026-05-11 — title row is `<display_title> [+] · [youtube channel]
      [youtube studio]`. The "channel" prefix was dropped from the H1
      (the [channels] breadcrumb segment already names the section).
      The outbound YouTube links moved up from the detail pane into
      the H1 row so the high-value navigation sits at the top edge of
      the page. A `nav-sep` middle-dot separates the in-app `[+]`
      action from the outbound `[youtube …]` cluster — same separator
      pattern used in the top navbar. %>
  <div class="dot-list" style="margin-bottom: 6px;">
    <h1 style="display: inline;"><%= display_title %></h1>
    <% if @available_channels.any? %>
      <%= render(BracketedLinkComponent.new(label: "+", href: "#", data: { action: "click->add-pane#open" })) %>
    <% end %>
    <% yt_channel = youtube_channel_url(@channel) %>
    <% yt_studio = youtube_studio_url(@channel) %>
    <% if yt_channel || yt_studio %>
      <span class="nav-sep" aria-hidden="true">·</span>
      <% if yt_channel %>
        <%= render(BracketedLinkComponent.new(
              label: "youtube channel",
              href: yt_channel,
              target: "_blank",
              rel: "noopener noreferrer"
            )) %>
      <% end %>
      <% if yt_studio %>
        <%= render(BracketedLinkComponent.new(
              label: "youtube studio",
              href: yt_studio,
              target: "_blank",
              rel: "noopener noreferrer"
            )) %>
      <% end %>
    <% end %>
  </div>

  <%# 11i diff banner slot — empty in 11b. 11i streams a Turbo
      Stream replacing this frame's contents when a diff exists. %>
  <%= turbo_frame_tag "channel_diff_banner" %>

  <%# Phase 22 — in-flight import badge. Visible whenever an ImportJob
      for this channel is `queued` or `running`. Links to the modal's
      show view so the user can resume the keep/reject flow without
      reopening from `/videos`. %>
  <% if (in_flight_job = @channel.in_flight_import_job) %>
    <div class="pane pane--standalone" style="margin-bottom: 8px; padding: 6px 10px;">
      <%= render(Imports::ProgressIndicatorComponent.new(import_job: in_flight_job)) %>
      <%= render(BracketedLinkComponent.new(
        label: "view progress",
        href: imports_channel_path(in_flight_job)
      )) %>
    </div>
  <% end %>

  <%# Row 1 — detail pane. Banner → avatar+title → handle → outbound
      links → description → links cluster. Banner row is hidden when
      `banner_url` is nil (locked decision: no colored placeholder).
      Avatar sits in its own row beside the title, NOT overlapping the
      banner (locked decision — cleaner, matches game show layout). %>
  <div class="pane-row">
    <div class="pane pane--standalone">
      <%= render "channels/banner", channel: @channel %>

      <div class="channel-identity" style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
        <% if @channel.avatar_url.present? %>
          <%= image_tag @channel.avatar_url,
                        alt: "channel avatar",
                        style: "display: block; width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 1px solid #ddd;" %>
        <% else %>
          <div class="channel-avatar-placeholder text-muted"
               style="width: 64px; height: 64px; border-radius: 50%; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 10px;"
               aria-label="no avatar">no avatar</div>
        <% end %>
        <div style="min-width: 0; flex: 1;">
          <div style="font-size: 14px; font-weight: 600;"><%= display_title %></div>
          <div class="text-muted" style="margin-top: 2px;">
            <% if @channel.handle.present? %>
              <%= @channel.handle %>
            <% else %>
              <span aria-label="no handle">@—</span>
            <% end %>
          </div>
        </div>
      </div>

      <%# 2026-05-11 — the `[youtube channel]` / `[youtube studio]`
          outbound links moved into the H1 row at the top of the page.
          The detail pane is now identity → description → links cluster. %>

      <%# Description — plain-text + auto-linked URLs. The helper runs
          input through `simple_format(sanitize: true)` which strips
          `<script>` and `<img onerror>` payloads before any URL
          rewriting happens. XSS-safe by construction. %>
      <div class="channel-description" style="margin-bottom: 8px;">
        <% description_html = channel_description_html(@channel) %>
        <% if description_html.present? %>
          <%= description_html %>
        <% else %>
          <p class="caption">no description yet.</p>
        <% end %>
      </div>

      <%= render "channels/links", channel: @channel %>
    </div>
  </div>

  <%# Row 2 — analytics summary. 2026-05-11 restructure — analytics
      moved above the Google connection panel so the high-signal
      numbers sit near the page top. The `videos` row was dropped
      from this table (the dedicated videos table further down
      surfaces that count next to the `[see all videos]` link). NO
      inline sparkline (locked decision — avoid chartkick coupling on
      the show page). %>
  <div class="pane-row">
    <div class="pane pane--standalone">
      <h2 style="margin: 0 0 8px 0;">analytics</h2>
      <table class="detail-table" style="margin-bottom: 8px;">
        <tr>
          <td class="text-muted" style="padding-right: 12px;">subscribers</td>
          <td><%= formatted_subscriber_count(@channel) %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px;">views</td>
          <td><%= formatted_view_count(@channel) %></td>
        </tr>
      </table>
      <%= render(BracketedLinkComponent.new(
            label: "full analytics",
            href: channel_analytics_path(@channel)
          )) %>
    </div>
  </div>

  <%# Row 3 — per-channel Google management panel. Renders the
      YoutubeConnection that owns this channel (last-authorized,
      reauth state) or a "no connection" empty state with a
      `[connect this channel]` entry point. Placement moved (2026-05-11)
      to sit after analytics — OAuth status is plumbing, analytics is
      the headline. %>
  <div class="pane-row">
    <%= render "channels/google_panel", channel: @channel, youtube_connection: @youtube_connection %>
  </div>

  <%# Videos table (NOT a pane). Mirrors /videos column shape, scoped
      to this channel. Starred-first, then latest by
      COALESCE(published_at, created_at) DESC, capped at 30. The
      `[see all videos]` link is rendered only when the channel has
      more than 30 videos — at <=30 the table already shows everything.
  %>
  <%= render "channels/videos_table",
             channel: @channel,
             videos: @channel_videos,
             total: @channel_videos_total %>

  <% if @available_channels.any? %>
    <%= render "channels/add_pane_dialog", available_channels: @available_channels, current_ids: @channel.id.to_s %>
  <% end %>
</div>
