<%# Phase 24 — bulk `[revoke N]` confirmation page. Server-rendered
    wide-modal. Renders the shared `channels/_revoke_modal` partial in
    bulk-channel mode (channels list + aggregated counts + orphan
    connection enumeration). %>
<% total = @channels.length %>
<% content_for(:title, "revoke #{total} channel#{'s' if total != 1}") %>
<% breadcrumb(["channels", channels_path],
              "revoke #{total} channel#{'s' if total != 1}") %>

<%= render "channels/revoke_modal",
           channels: @preview_channels,
           overflow_count: @overflow_count,
           counts: @counts,
           orphan_connections: @orphan_connections,
           form_url: channels_bulk_revoke_path(ids: @channels.map(&:id).join(",")),
           cancel_url: channels_path %>
