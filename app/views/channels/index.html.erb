<% content_for(:title, "channels") %>

<div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px;">
  <h1>channels</h1>
  <a href="#" class="bracketed">[ <span class="bl">add channel</span> ]</a>
</div>

<% if @channels.any? %>
  <div data-controller="sortable-table">
    <table data-sortable-table-target="table">
      <thead>
        <tr>
          <th class="sortable" data-action="click->sortable-table#sort" data-column="0" data-sort-type="string">title</th>
          <th class="sortable num" data-action="click->sortable-table#sort" data-column="1" data-sort-type="string">connected</th>
          <th class="sortable num" data-action="click->sortable-table#sort" data-column="2" data-sort-type="number">subscribers</th>
          <th class="sortable num" data-action="click->sortable-table#sort" data-column="3" data-sort-type="number">videos</th>
          <th class="sortable num" data-action="click->sortable-table#sort" data-column="4" data-sort-type="number">views</th>
          <th class="col-action"></th>
        </tr>
      </thead>
      <tbody>
        <% @channels.each do |channel| %>
          <tr>
            <td><%= channel.title %></td>
            <td class="num"><%= channel.connected? ? "yes" : "no" %></td>
            <td class="num"><%= number_with_delimiter(channel.subscriber_count || 0) %></td>
            <td class="num"><%= number_with_delimiter(channel.videos_count) %></td>
            <td class="num"><%= number_with_delimiter(channel.view_count || 0) %></td>
            <td class="col-action"><a href="#" class="bracketed">[ <span class="bl">open</span> ]</a></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">no channels yet.</p>
<% end %>
