<% content_for(:title, "channels") %>

<div style="max-width: 1100px;" data-controller="bulk-select" data-bulk-select-max-panes-value="<%= max_panes %>" data-bulk-select-entity-name-value="channels" data-bulk-select-panes-path-value="<%= panes_channels_path %>" data-bulk-select-delete-type-value="channel" data-bulk-select-sync-type-value="channel">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <div class="dot-list">
      <h1>channels</h1>
      <%= render(BracketedLinkComponent.new(label: "+", href: new_channel_path)) %>
    </div>
    <span style="margin-left: auto;"><%= render(SavedViewsSectionComponent.new(saved_views: @saved_views || SavedView.none, kind: "channels")) %></span>
  </div>

  <% filters = @filters || [] %>
  <div class="dot-list" style="margin-bottom: 6px; gap: 10px;">
    <span class="text-muted">filter:</span>
    <%= render(FilterChipComponent.new(label: "starred", param: "star", current_params: request.query_parameters, frame: "channels-index-table")) %>
    <%= render(FilterChipComponent.new(label: "connected", param: "connected", current_params: request.query_parameters, frame: "channels-index-table")) %>
    <%= render(FilterChipComponent.new(label: "syncing", param: "syncing", current_params: request.query_parameters, frame: "channels-index-table")) %>
    <% if filters.any? %>
      <%= render(BracketedLinkComponent.new(label: "clear", href: channels_path, data: { turbo_frame: "channels-index-table", turbo_action: "advance" })) %>
    <% end %>
  </div>

  <%# Turbo-frame wrapper (polish-3, 2026-05-06): the bulk toolbar +
      channels table sit inside `<turbo-frame id="channels-index-table">`
      so a sort-header click or filter-chip toggle only re-renders the
      frame's content. The frame element exists on every render
      (including the empty state) so Turbo can match it in the response
      and skip the fall-back to a full-page navigation. %>
  <%= turbo_frame_tag "channels-index-table" do %>
  <% if channels.any? %>
    <div>
      <%# Phase B polish (2026-05-05) — bulk toolbar is always rendered.
          Each `.action` span carries an `.action-sep` `&middot;` that
          the controller hides on whichever action is first-visible.
          Action targets (open / count / sync / delete) self-hide when
          selection count is zero; see bulk_select_controller.js. %>
      <div data-bulk-select-target="actions" style="margin-bottom: 2px;">
        <div class="bulk-toolbar">
          <span class="action" data-bulk-select-target="openHint">
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="openAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="count" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="syncAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="deleteAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
        </div>
        <div data-bulk-select-target="overMaxHint" hidden class="form-hint" style="font-size: 12px; margin-top: 2px;">max <%= max_panes %> channels at a time can be opened in split view.</div>
      </div>

      <%# Sortable column headers — server-side sort via `?sort=<key>&dir=<asc|desc>`.
          `sort_link_to` builds a link that merges the new sort params into
          `request.query_parameters`, so active filter chips (`?starred=yes`,
          `?connected=yes`, etc.) are preserved across header clicks.
          Mirrors the `/projects` index pattern; replaces the prior
          client-side `sortable-table` Stimulus controller, which still
          serves the per-pane video tables. %>
      <%# Table sizing — the URL column is server-side middle-truncated to
          a fixed head…tail form (~17 chars), so the table no longer needs
          to stretch to viewport width. Explicit colgroup widths plus
          `table-layout: fixed; width: 480px;` size the table to its
          content (40 + 60 + 200 + 80 + 100 = 480 px). `width: auto` is
          NOT enough under `table-layout: fixed`: per CSS spec the table
          stretches to fill its containing block and dumps the slack on
          the last column, so an explicit width is required. The header
          text "starred" was shortened to "star" in a 2026-05-06 polish
          to mirror the [star] / [unstar] action vocabulary used
          elsewhere; the underlying sort key stays `starred`. %>
      <table style="table-layout: fixed; width: 480px;">
        <colgroup>
          <col style="width: 40px;">  <%# selection checkbox %>
          <col style="width: 60px;">  <%# Name (id) %>
          <col style="width: 200px;"> <%# URL (truncated) %>
          <col style="width: 80px;">  <%# star %>
          <col style="width: 100px;"> <%# last sync %>
        </colgroup>
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <%# Name column — placeholder for the YouTube channel title once
                sync lands. For now the cell renders `channel.id` linked to
                the show page so the column has stable content. The legacy
                `[o]` action column was dropped (2026-05-05 polish): the
                Name cell IS the show-page link, so a separate open-action
                cell was redundant. The header text reads `name`
                (lowercase) — Pito's design uses lowercase column labels
                throughout (mirrors `last sync`, `star`, `URL` is the
                acronym exception). %>
            <th class="sortable"><%= sort_link_to("name", "id", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
            <th>URL</th>
            <th class="sortable num"><%= sort_link_to("star", "starred", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
            <th class="sortable num"><%= sort_link_to("last sync", "last_synced_at", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
          </tr>
        </thead>
        <tbody>
          <% channels.each do |channel| %>
            <tr>
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: channel.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <td><%= link_to channel.id, channel_path(channel), data: { turbo_frame: "_top" } %></td>
              <%# URL cell — server-side middle-truncated to a fixed
                  `<head>…<tail>` string (e.g. `https://…jF7eS8r1`) so
                  the unique channel ID at the end of the YouTube URL
                  stays visible without overflowing the column. Same
                  shape as the footage filename column — both delegate
                  to `ApplicationHelper#middle_truncate`. The `<td>`
                  carries the full URL via `title=` for hover-reveal. %>
              <td title="<%= channel.channel_url %>">
                <%= link_to middle_truncate(channel.channel_url, head: 8, tail: 8), channel.channel_url, target: "_blank", rel: "noopener noreferrer" %>
              </td>
              <td class="num"><%= channel.star? ? "yes" : "no" %></td>
              <td class="num">
                <% if channel.syncing? %>
                  <strong>syncing</strong>
                <% elsif channel.last_synced_at.present? %>
                  <%= compact_time_ago(channel.last_synced_at) %>
                <% else %>
                  —
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">no channels yet.</p>
  <% end %>
  <% end %>
</div>
