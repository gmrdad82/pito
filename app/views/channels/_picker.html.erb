<% content_for(:title, "channels") %>

<div style="max-width: 1100px;" data-controller="bulk-select" data-bulk-select-max-panes-value="<%= max_panes %>" data-bulk-select-entity-name-value="channels" data-bulk-select-panes-path-value="<%= panes_channels_path %>" data-bulk-select-delete-type-value="channel" data-bulk-select-sync-type-value="channel">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <h1>channels</h1>
    <span class="text-muted">&middot;</span>
    <%= render(BracketedLinkComponent.new(label: "+", href: new_channel_path)) %>
    <span style="margin-left: auto;"><%= render(SavedViewsSectionComponent.new(saved_views: @saved_views || SavedView.none, kind: "channels")) %></span>
  </div>

  <% filters = @filters || [] %>
  <div style="margin-bottom: 6px; display: flex; gap: 10px; align-items: baseline;">
    <span class="text-muted">filter:</span>
    <%= render(FilterChipComponent.new(label: "starred", param: "star", current_params: request.query_parameters)) %>
    <%= render(FilterChipComponent.new(label: "connected", param: "connected", current_params: request.query_parameters)) %>
    <%= render(FilterChipComponent.new(label: "syncing", param: "syncing", current_params: request.query_parameters)) %>
    <% if filters.any? %>
      <span class="text-muted">&middot;</span>
      <%= render(BracketedLinkComponent.new(label: "clear", href: channels_path)) %>
    <% end %>
  </div>

  <% if channels.any? %>
    <div data-controller="sortable-table">
      <%# Phase B polish (2026-05-05) — bulk toolbar is always rendered.
          Each `.action` span carries an `.action-sep` `&middot;` that
          the controller hides on whichever action is first-visible.
          Action targets (open / count / sync / delete) self-hide when
          selection count is zero; see bulk_select_controller.js. %>
      <div data-bulk-select-target="actions" style="margin-bottom: 2px;">
        <div class="bulk-toolbar">
          <span class="action" data-bulk-select-target="openHint">
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="openAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="count" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="syncAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="deleteAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
        </div>
        <div data-bulk-select-target="overMaxHint" hidden class="form-hint" style="font-size: 12px; margin-top: 2px;">max <%= max_panes %> channels at a time can be opened in split view.</div>
      </div>

      <table data-sortable-table-target="table">
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <th class="col-action"></th>
            <th>URL</th>
            <%= render(SortableHeaderComponent.new(label: "starred", sort_type: "string", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "last sync", sort_type: "date", numeric: true)) %>
          </tr>
        </thead>
        <tbody>
          <% channels.each do |channel| %>
            <tr>
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: channel.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <td class="col-action">
                <%= render(BracketedLinkComponent.new(label: "o", href: channel_path(channel))) %>
              </td>
              <td style="max-width: 480px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <a href="<%= channel.channel_url %>" target="_blank" rel="noopener noreferrer"><%= channel.channel_url %></a>
              </td>
              <td class="num"><%= channel.star? ? "yes" : "no" %></td>
              <td class="num">
                <% if channel.syncing? %>
                  <strong>syncing</strong>
                <% elsif channel.last_synced_at.present? %>
                  <%= compact_time_ago(channel.last_synced_at) %>
                <% else %>
                  —
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">no channels yet.</p>
  <% end %>
</div>
