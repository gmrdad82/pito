<% content_for(:title, "channels") %>

<div data-controller="bulk-select" data-bulk-select-max-panes-value="<%= max_panes %>" data-bulk-select-entity-name-value="channels" data-bulk-select-panes-path-value="<%= panes_channels_path %>" data-bulk-select-delete-type-value="channel" data-bulk-select-sync-type-value="channel" data-bulk-select-revoke-path-value="/channels/revokes">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <div class="dot-list">
      <h1>channels</h1>
      <%# `[+]` opens the Google OAuth dance via the
          `/channels/connect_google` request-phase entry point.
          `account=new` triggers `prompt=select_account consent` on
          the Google side so the user can pick which Google account
          / channel context to authorize (otherwise Google silently
          reuses the most-recently-used account). The OAuth callback
          enumerates `mine: true` channels under the just-authorized
          connection and auto-adds non-duplicates. %>
      <%= form_with url: connect_google_channels_path, method: :post,
                    data: { turbo: false }, html: { style: "display: inline;" } do %>
        <input type="hidden" name="account" value="new">
        <button type="submit" class="bracketed">[<span class="bl">+</span>]</button>
      <% end %>
    </div>
    <span style="margin-left: auto;"><%= render(SavedViewsSectionComponent.new(saved_views: @saved_views || SavedView.none, kind: "channels")) %></span>
  </div>

  <%# Density polish (2026-05-10) — the filter chip cluster and the
      bulk toolbar are both pre-table rows. Tightening the chip cluster's
      `margin-bottom` to 2px (was 6px) brings the table closer to the
      filter row and matches the videos index where there is no chip
      cluster between the h1 row and the bulk toolbar.

      2026-05-11 fix — the chip lives OUTSIDE the `channels-index-table`
      turbo frame (the frame opens below the filter row). Previously it
      carried `frame: "channels-index-table"` / `data-turbo-frame=...`,
      which made Turbo swap the frame body but left the chip stranded
      in the surrounding DOM — clicking `[ ]` never flipped to `[x]`
      because the chip itself never re-rendered. Mirrors the `/videos`
      and `/notifications` chips, which use full-page navigation for
      the same structural reason.

      2026-05-11 — the redundant `[clear]` link was dropped (clicking
      the chip itself toggles the filter off). %>
  <div class="dot-list" style="margin-bottom: 2px; gap: 10px;">
    <span class="text-muted">filter:</span>
    <%= render(FilterChipComponent.new(label: "starred", param: "star", current_params: request.query_parameters)) %>
  </div>

  <%# Turbo-frame wrapper (polish-3, 2026-05-06): the bulk toolbar +
      channels table sit inside `<turbo-frame id="channels-index-table">`
      so a sort-header click or filter-chip toggle only re-renders the
      frame's content. The frame element exists on every render
      (including the empty state) so Turbo can match it in the response
      and skip the fall-back to a full-page navigation. %>
  <%= turbo_frame_tag "channels-index-table" do %>
  <% if channels.any? %>
    <div>
      <%# Phase B polish (2026-05-05) — bulk toolbar is always rendered.
          Each `.action` span carries an `.action-sep` `&middot;` that
          the controller hides on whichever action is first-visible.
          Action targets (open / count / sync / delete) self-hide when
          selection count is zero; see bulk_select_controller.js. %>
      <%# `data-turbo-frame="_top"` cascades to the controller-injected
          `[open N]` / `[sync N]` / `[delete N]` links so their clicks
          navigate full-page to `/channels/panes`, `/syncs/channel/:ids`,
          and `/deletions/channel/:ids` instead of being scoped to the
          enclosing `channels-index-table` Turbo Frame. Each of those
          targets is a full-page surface (panes workspace,
          `shared/_action_screen.html.erb`) and has no matching frame
          in its response — without `_top` Turbo shows "Content
          missing". %>
      <div data-bulk-select-target="actions" style="margin-bottom: 0;" data-turbo-frame="_top">
        <div class="bulk-toolbar">
          <span class="action" data-bulk-select-target="openHint">
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="openAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="count" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="syncAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="deleteAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <%# Phase 24 — `[revoke N]` bulk action. Same data-bulk-select-target
              pattern as `[delete N]`; the controller wires the URL to
              `/channels/revokes/<comma-separated-ids>`. Cascade is
              broader than plain delete — see DeleteChannelDataJob. %>
          <span class="action" data-bulk-select-target="revokeAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
        </div>
        <div data-bulk-select-target="overMaxHint" hidden class="form-hint" style="font-size: 12px; margin-top: 2px;">max <%= max_panes %> channels at a time can be opened in split view.</div>
      </div>

      <%# Sortable column headers — server-side sort via `?sort=<key>&dir=<asc|desc>`.
          `sort_link_to` builds a link that merges the new sort params into
          `request.query_parameters`, so active filter chips (`?star=yes`,
          etc.) are preserved across header clicks.
          Mirrors the `/projects` index pattern; replaces the prior
          client-side `sortable-table` Stimulus controller, which still
          serves the per-pane video tables.

          Phase 24+ density pass (2026-05-10) — the table was widened from
          the prior 5-column placeholder (checkbox / name(id) / URL truncated
          / star / last sync) into an 8-column rich row that surfaces the
          sync-populated metadata: avatar, title + `@handle`, full
          `/@handle` URL, subscriber count (with "Hidden" treatment),
          video count, star, last sync. Header text stays lowercase to
          match Pito's design system (`URL` is the acronym exception).
          The URL column is no longer truncated — it renders the full
          `/@handle` (or UC-id fallback) string. Layout is `auto` so the
          URL column can absorb its natural width.

          Sortable columns: `name` (by `channels.id`), `subscribers`
          (by `channels.subscriber_count`), `videos` (by
          `channels.video_count`), `star`, `last sync`. Subscriber and
          video counts are nullable until ChannelSync populates them;
          Postgres default NULL ordering matches the rest of the index
          (NULLS LAST on asc, NULLS FIRST on desc). %>
      <table style="table-layout: auto;">
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <%# Avatar column — narrow, no header label. Rendered as a
                32px rounded thumbnail via `.avatar-thumb`; the empty
                state is a single em-dash to keep the column stable. %>
            <th></th>
            <%# Name column — title (with `@handle` as muted sub-text).
                The cell is a link to the channel show page; falls back
                to the UC-id text when title is nil (pre-sync rows).
                Underlying sort key stays `id` since `name` /`title` is
                not yet in `ALLOWED_SORTS`. %>
            <th class="sortable"><%= sort_link_to("name", "id", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
            <th>URL</th>
            <th class="sortable num"><%= sort_link_to("subs", "subscriber_count", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
            <th class="sortable num"><%= sort_link_to("videos", "video_count", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
            <th class="sortable num"><%= sort_link_to("star", "starred", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
            <th class="sortable num"><%= sort_link_to("synced", "last_synced_at", current_sort: @sort, current_dir: @dir, frame: "channels-index-table") %></th>
          </tr>
        </thead>
        <tbody>
          <% channels.each do |channel| %>
            <% display_url = channel_display_url(channel) %>
            <%# `data-keyboard-row` opts each channel row into the global
                keyboard controller's list-row navigation (`j`/`k` move
                highlight, `space` toggles the row's checkbox, `D`/`Y`
                drive bulk delete/sync against the highlighted row's id).
                Mirrors the hook on notifications and schedule rows. %>
            <tr data-keyboard-row data-keyboard-row-id="<%= channel.id %>">
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: channel.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <%# Avatar cell — narrow, vertically centered. Falls back to
                  a muted em-dash when `avatar_url` is nil (pre-sync). The
                  explicit `width`/`height` HTML attributes are defensive:
                  they reserve the intrinsic 32×32 box before the network
                  image loads so the table cell never collapses the image
                  into a narrow/stretched silhouette during paint. The
                  `.avatar-thumb` CSS enforces the same dimensions plus
                  `object-fit: cover` for non-square sources. %>
              <td class="avatar-cell">
                <% if channel.avatar_url.present? %>
                  <%= image_tag channel.avatar_url,
                                alt: "",
                                class: "avatar-thumb",
                                width: 32,
                                height: 32,
                                loading: "lazy" %>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <%# Name cell — display title links to the show page. The
                  `@handle` sub-line moved to the URL column (2026-05-11)
                  per user direction so the name column carries only the
                  title. When `title` is nil, the helper renders
                  "untitled channel"; we still want a stable, scannable
                  identifier in that case, so we fall back to the channel
                  id as the link text. %>
              <td>
                <%
                  title = channel.title.to_s.strip
                  link_label = title.empty? ? channel.id.to_s : title
                %>
                <%= link_to link_label, channel_path(channel), data: { turbo_frame: "_top" } %>
              </td>
              <%# URL cell — visible text is the @handle when present,
                  otherwise a middle-truncated UCxxxxxx…xyz slug. The
                  href stays the full YouTube URL (the /@handle URL or
                  the /channel/UC-id fallback) so the link still
                  resolves to a real YouTube page. 2026-05-11 — title
                  moved out of this column into the name cell; the
                  column now surfaces only the short identifier.
                  white-space: nowrap keeps the label on a single line. %>
              <td style="white-space: nowrap;">
                <%= link_to channel_url_label(channel), display_url, target: "_blank", rel: "noopener noreferrer" %>
              </td>
              <td class="num"><%= formatted_subscriber_count(channel) %></td>
              <td class="num"><%= formatted_video_count(channel) %></td>
              <td class="num"><%= channel.star? ? "yes" : "no" %></td>
              <td class="num">
                <% if channel.last_synced_at.present? %>
                  <%= compact_time_ago(channel.last_synced_at) %>
                <% else %>
                  —
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
  <% end %>
</div>
