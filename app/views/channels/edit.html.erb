<% page_label = "channel ##{@channel.id}" %>
<% content_for(:title, "edit #{page_label}") %>
<% breadcrumb(["channels", channels_path], [page_label, channel_path(@channel)], "edit") %>

<h1>edit channel</h1>

<p class="text-muted">
  edit the cached metadata for this channel.<br>
  changes push to youtube and refresh pito's local cache on success.<br>
  the channel url is locked after create — only the editable subset is shown below.
</p>

<%# Phase 7.5 §11h — toasts emitted by `reminder_link_controller`
    render into the global `.toast-container` (see
    `app/views/shared/_flash_toasts.html.erb`), so no per-page slot
    is needed. The previous in-page placeholder was retired because
    Stimulus targets must live inside the controller element scope,
    and the controller binds to the link element itself. %>

<% unless @channel.youtube_connection_id %>
  <div class="pane pane--standalone" style="margin-bottom: 12px; padding: 10px 14px;">
    <p class="text-muted">
      this channel is not connected to a google identity.<br>
      edits save locally only until you connect a Google account from /channels.
    </p>
  </div>
<% end %>

<%# Phase 7.5 §11d — preview controller wraps the form AND the modal
    so the `input->channel-preview#updatePreview` debounced listener
    on the form fields can locate the `frame` target inside the
    modal. The `[preview]` bracketed link below opens the modal via
    `modal-trigger#open`. %>
<div data-controller="channel-preview"
     data-channel-preview-url-value="<%= channel_preview_path(@channel) %>"
     data-channel-preview-debounce-ms-value="300">
  <div class="pane pane--standalone" style="padding: 12px 16px;">
    <div style="margin-bottom: 8px;">
      <%= render(BracketedLinkComponent.new(
            label: "preview",
            href: "#",
            data: {
              controller: "modal-trigger",
              action: "click->modal-trigger#open",
              modal_trigger_target_id_value: "channel-preview-modal-#{@channel.id}"
            }
          )) %>
    </div>
    <%= render "channels/form", channel: @channel, cancel_path: channel_path(@channel) %>
  </div>

  <% modal_id = "channel-preview-modal-#{@channel.id}" %>
  <% top_nav = capture do %>
    <span data-channel-preview-target="navLink"
          data-layout="desktop"
          class="bracketed preview-nav-active"
          data-action="click->channel-preview#selectLayout"
          role="button"
          tabindex="0">[desktop]</span>
    <span data-channel-preview-target="navLink"
          data-layout="mobile"
          class="bracketed"
          data-action="click->channel-preview#selectLayout"
          role="button"
          tabindex="0">[mobile]</span>
    <span data-channel-preview-target="navLink"
          data-layout="tv"
          class="bracketed"
          data-action="click->channel-preview#selectLayout"
          role="button"
          tabindex="0">[tv]</span>
  <% end %>
  <%= render "shared/wide_modal",
             id: modal_id,
             title: "channel preview",
             top_nav: top_nav do %>
    <%= render(ChannelPreviewComponent.new(channel: @channel)) %>
  <% end %>
</div>
