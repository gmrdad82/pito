<%# Phase 7.5 §11c — Channel edit form errors partial. Renders the
    flash.now[:alert] (set by the controller's YouTube error rescues)
    plus any per-attribute errors collected from validation. The
    form re-renders on every failure with the user's in-flight edits
    intact, so the messages here are the user's signal that
    something went wrong. %>
<% if flash.now[:alert].present? %>
  <div class="flash-error" style="margin-bottom: 8px; padding: 6px 10px;">
    <%= flash.now[:alert] %>
  </div>
<% end %>
<% if channel.errors.any? %>
  <div class="flash-error" style="margin-bottom: 8px; padding: 6px 10px;">
    couldn't save — check the fields below.
    <ul style="margin: 4px 0 0 16px;">
      <% channel.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
