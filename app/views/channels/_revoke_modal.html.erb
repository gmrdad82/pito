<%# Phase 24 — shared wide-modal partial for channel revoke.
    Renders a server-page wide-modal (NOT a JS <dialog> overlay — the
    user's autonomous lock notes that wide-modal here is a styled
    action-screen, not the `<dialog>` overlay shape that ships
    elsewhere). The pattern: pane--standalone background, structured
    cascade-count block, `[cancel]` / `[confirm revoke]` button row at
    the bottom.

    Two call modes:

      Single-channel (sub-spec 24c) — caller passes:
        channel:                       the Channel record
        counts:                        ChannelRevokeCounts::Counts struct
        is_last_channel_on_connection: Boolean
        form_url:                      String — POST target (channel_revoke_path)
        cancel_url:                    String — GET target for [cancel]

      Bulk-channel (sub-spec 24e) — caller passes:
        channels:           Array<Channel> (cap-trimmed previews)
        overflow_count:     Integer — number beyond the preview cap
        counts:             ChannelRevokeCounts::Counts (aggregated)
        orphan_connections: Array<YoutubeConnection> (will lose their grants)
        form_url:           String — POST target (channels_bulk_revoke_path)
        cancel_url:         String — GET target for [cancel]

    Both modes pluralize copy and yield a uniform footer. No
    data-turbo-confirm. No JS confirm / alert / prompt. %>

<% mode = local_assigns[:channel] ? :single : :bulk %>
<% counts = local_assigns.fetch(:counts) %>

<div class="pane pane--standalone wide-modal-page"
     style="max-width: 720px; padding: 16px;">
  <% if mode == :single %>
    <% channel = local_assigns[:channel] %>
    <% display_title = channel.title.presence ||
                       channel.channel_url.to_s.sub(%r{\Ahttps?://(www\.)?youtube\.com/channel/}, "") %>
    <h1 style="margin: 0 0 12px 0;">revoke channel "<%= display_title %>"?</h1>
  <% else %>
    <% channels = Array(local_assigns[:channels]) %>
    <% overflow_count = local_assigns.fetch(:overflow_count, 0).to_i %>
    <% total_n = channels.length + overflow_count %>
    <h1 style="margin: 0 0 12px 0;">revoke <%= total_n %> channel<%= "s" if total_n != 1 %>?</h1>

    <p class="text-muted" style="margin: 0 0 8px 0;">channels:</p>
    <ul style="list-style: none; padding-left: 12px; margin: 0 0 12px 0;">
      <% channels.each do |c| %>
        <% label = c.title.presence || c.channel_url.to_s.sub(%r{\Ahttps?://(www\.)?youtube\.com/channel/}, "") %>
        <li><%= label %></li>
      <% end %>
      <% if overflow_count.positive? %>
        <li class="text-muted">…and <%= overflow_count %> more</li>
      <% end %>
    </ul>
  <% end %>

  <p class="text-muted" style="margin: 0 0 12px 0;">
    this will permanently delete:<br>
    <%= counts.videos %> video<%= "s" if counts.videos != 1 %><br>
    <%= counts.analytics %> analytics record<%= "s" if counts.analytics != 1 %><br>
    <%= counts.diffs %> diff record<%= "s" if counts.diffs != 1 %><br>
    <%= counts.change_logs %> change-log record<%= "s" if counts.change_logs != 1 %><br>
    <%= counts.links %> link record<%= "s" if counts.links != 1 %><br>
    <%= counts.rejected_imports %> rejected-import record<%= "s" if counts.rejected_imports != 1 %><br>
    <%= counts.calendar_entries %> calendar entry<%= counts.calendar_entries == 1 ? "" : " (entries)" %>.
  </p>

  <% if mode == :single %>
    <% if local_assigns[:is_last_channel_on_connection] %>
      <p class="text-muted" style="margin: 0 0 12px 0;">
        <% conn = local_assigns[:channel]&.youtube_connection %>
        <% if conn&.email.present? %>
          the Google OAuth grant for <strong><%= format_connection_email(conn.email) %></strong> will be revoked — this is the last channel on the connection.
        <% else %>
          the Google OAuth grant will be revoked — this is the last channel on the connection.
        <% end %>
      </p>
    <% end %>
  <% else %>
    <% orphans = Array(local_assigns[:orphan_connections]) %>
    <% if orphans.any? %>
      <p class="text-muted" style="margin: 0 0 12px 0;">
        the Google OAuth grant<%= "s" if orphans.length != 1 %> for
        <% orphans.each_with_index do |conn, i| %>
          <strong><%= format_connection_email(conn.email) %></strong><%= i < orphans.length - 1 ? ", " : "" %>
        <% end %>
        will be revoked — every channel on
        <%= orphans.length == 1 ? "the connection is" : "those connections are" %>
        in this revoke.
      </p>
    <% end %>
  <% end %>

  <p class="text-muted" style="margin: 0 0 16px 0;">this action cannot be undone.</p>

  <div class="modal-footer">
    <%= form_with url: local_assigns.fetch(:form_url), method: :post,
                  data: { turbo: false, keyboard_confirmation: "true" },
                  html: { style: "display: inline;" } do %>
      <input type="hidden" name="confirm" value="yes">
      <%= render(BracketedLinkComponent.new(label: "cancel",
                                            href: local_assigns.fetch(:cancel_url),
                                            data: { keyboard_confirmation_cancel: "true" })) %>
      <button type="submit" class="bracketed text-danger">[<span class="bl">confirm revoke</span>]</button>
    <% end %>
  </div>
</div>
