<dialog data-add-pane-target="dialog" data-action="click->add-pane#clickOutside" class="pane-dialog">
  <%# Phase B polish (2026-05-05) — capped at 80vh with a scrollable body
      and a .modal-footer hairline so [close] sits at the bottom (matches
      the saved-views and confirm modals). %>
  <div style="padding: 12px; min-width: 480px; max-width: 720px; max-height: 80vh; display: flex; flex-direction: column;">
    <h2 style="margin-bottom: 8px;">add a channel</h2>
    <div style="overflow-y: auto; flex: 1; min-height: 0;">
      <% if available_channels.any? %>
        <table>
          <thead>
            <tr>
              <th class="col-action"></th>
              <th>URL</th>
              <th class="num">starred</th>
            </tr>
          </thead>
          <tbody>
            <% available_channels.each do |channel| %>
              <tr>
                <td class="col-action">
                  <% new_ids = [current_ids, channel.id].reject(&:blank?).join(",") %>
                  <%= render(BracketedLinkComponent.new(label: "+", href: "#{panes_channels_path}?ids=#{new_ids}")) %>
                </td>
                <td style="max-width: 480px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= channel.channel_url %></td>
                <td class="num"><%= channel.star? ? "yes" : "no" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="caption">no more channels to add.</p>
      <% end %>
    </div>
    <div class="modal-footer">
      <%= render(BracketedLinkComponent.new(label: "close", href: "#", data: { action: "click->add-pane#close" })) %>
    </div>
  </div>
</dialog>
