<% content_for(:title, "sync #{@type.pluralize}") %>
<% breadcrumb([@type.pluralize, cancel_path_for(@type)], "sync #{number_with_delimiter(@items.length)} #{@type}#{'s' if @items.length != 1}") %>

<%# Phase 7 Path A2 (literal full retract). The legacy `syncing`
    column is gone; the partition into already-syncing skipped rows
    goes away. The action button is always enabled when there is at
    least one item.

    Phase 11i Q7 follow-up: the `intent` param flips copy + dispatch.
    `intent=overwrite` (default, legacy) renders the existing "kicking
    off the sync" lead and POSTs to the BulkSyncJob path. `intent=
    diff_check` (used by `[sync]` on /channels/:slug and /videos/:slug)
    renders the diff-check copy and POSTs to the per-record diff-check
    job. The `form_url` preserves the `intent` query param so the POST
    branch reads the same value the GET saw. %>

<% intent = @intent || "overwrite" %>
<% form_url = "/syncs/#{@type}/#{@items.map(&:id).join(",")}" %>
<% form_url += "?intent=#{intent}" if intent == "diff_check" %>

<div id="sync-content">
  <div style="margin-bottom: 8px;">
    <h1><%= t("syncs.show.heading", count: @items.length, type: @type) %></h1>
    <% if intent == "diff_check" %>
      <p class="text-muted" style="margin-top: 2px;">
        sync from youtube? pito will compare and present any differences for review.
      </p>
    <% else %>
      <p class="text-muted" style="margin-top: 2px;"><%= t("syncs.show.body_overwrite") %></p>
    <% end %>
  </div>

  <%# 2026-05-11 polish (Fix 1) — narrow column widths via `<colgroup>`
      mirroring the `/projects` and `/games` list-mode pattern; the
      table sheds its `width: 100%` and uses `max-content` so it
      naturally shrinks to the cell widths without stretching across
      the viewport. `starred` header renamed to `star` (shorter). %>
  <table style="width: max-content; max-width: 100%;">
    <colgroup>
      <col style="width: 1%;"> <%# action gutter %>
      <% case @type %>
      <% when "channel" %>
        <col style="width: 360px;"> <%# URL %>
        <col style="width: 60px;">  <%# star %>
        <col style="width: 90px;">  <%# synced %>
      <% when "video" %>
        <col style="width: 180px;"> <%# YouTube id %>
        <col style="width: 360px;"> <%# channel %>
      <% when "project", "collection" %>
        <col style="width: 360px;"> <%# name %>
      <% when "game", "timeline" %>
        <col style="width: 360px;"> <%# title %>
      <% end %>
    </colgroup>
    <thead>
      <tr>
        <th class="col-action"></th>
        <% case @type %>
        <% when "channel" %>
          <th>URL</th>
          <th class="num">star</th>
          <th class="num">synced</th>
        <% when "video" %>
          <th>YouTube id</th>
          <th>channel</th>
        <% when "project", "collection" %>
          <th>name</th>
        <% when "game", "timeline" %>
          <th><%= t("syncs.show.col.title") %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @items.each do |item| %>
        <tr>
          <td class="col-action">&nbsp;&nbsp;&nbsp;&nbsp;</td>
          <% case @type %>
          <% when "channel" %>
            <td title="<%= item.channel_url %>" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <%= item.channel_url %>
            </td>
            <td class="num"><%= item.star? ? "yes" : "no" %></td>
            <td class="num">
              <% if item.last_synced_at.present? %>
                <%= compact_time_ago(item.last_synced_at) %>
              <% else %>
                —
              <% end %>
            </td>
          <% when "video" %>
            <td><%= item.youtube_video_id %></td>
            <td><%= item.channel&.channel_url %></td>
          <% when "project", "collection" %>
            <td><%= item.name %></td>
          <% when "game", "timeline" %>
            <td><%= item.title %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div id="action-footer">
    <%= render "shared/action_screen",
      submit_label: "[#{t('common.actions.sync')}]",
      cancel_path: @cancel_path,
      form_url: form_url,
      destructive: false %>
  </div>
</div>
