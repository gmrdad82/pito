<% content_for(:title, "syncing #{@type.pluralize}") %>
<% breadcrumb([@type.pluralize, cancel_path_for(@type)], "syncing #{number_with_delimiter(@items.length)} #{@type}#{'s' if @items.length != 1}") %>

<%= turbo_stream_from "bulk_operation_#{@operation.id}" %>

<div style="margin-bottom: 8px;" data-controller="operation-progress" data-operation-progress-url-value="<%= status_bulk_operation_path(@operation, format: :json) %>" data-operation-progress-total-value="<%= @items.length %>">
  <h1>syncing <%= number_with_delimiter(@items.length) %> <%= @type %><%= 's' if @items.length != 1 %></h1>
  <div id="operation_progress" style="margin-top: 2px;">
    <% bar_width = 30 %>
    <span class="text-muted">[<%= "." * bar_width %>] 0/<%= number_with_delimiter(@items.length) %></span>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th class="col-action"></th>
      <% if @type == "channel" %>
        <th>url</th>
        <th class="num">starred</th>
        <th class="num">connected</th>
        <th class="num">last sync</th>
      <% else %>
        <th>title</th>
        <th>channel</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @operation.bulk_operation_items.order(:id).each do |op_item| %>
      <% item = @items.find { |it| it.id == op_item.target_id } %>
      <tr id="item_<%= op_item.id %>">
        <td class="col-action" id="item_status_<%= op_item.id %>">
          <% if op_item.status_skipped? %>
            <span class="bracketed text-danger">[ skip ]</span>
          <% else %>
            <span class="dot-loader" style="--loader-delay: -<%= rand(0.0..0.75).round(2) %>s"></span>
          <% end %>
        </td>
        <% if @type == "channel" && item %>
          <td title="<%= item.channel_url %>" style="max-width: 360px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= item.channel_url %></td>
          <td class="num"><%= item.star? ? "yes" : "no" %></td>
          <td class="num"><%= item.connected? ? "yes" : "no" %></td>
          <td class="num">
            <% if item.syncing? %>
              <strong>syncing</strong>
            <% elsif item.last_synced_at.present? %>
              <%= compact_time_ago(item.last_synced_at) %>
            <% else %>
              —
            <% end %>
          </td>
        <% elsif @type == "video" && item %>
          <td style="max-width: 280px; overflow: hidden; text-overflow: ellipsis;"><%= item.title %></td>
          <td><%= item.channel&.channel_url %></td>
        <% else %>
          <td colspan="4">(unknown)</td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>

<div style="margin-top: 12px;">
  <%= render(BracketedLinkComponent.new(label: "back", href: @cancel_path)) %>
</div>
