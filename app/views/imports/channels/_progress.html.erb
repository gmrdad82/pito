<%# Phase 22 §7.3 — per-channel progress row. Wrapped in a stable
    dom_id so the Sidekiq worker can broadcast_replace_to a single
    row as the import advances. %>
<div id="<%= dom_id(import_job, :progress) %>">
  <strong><%= import_job.channel.title.presence || import_job.channel.url_slug || "channel ##{import_job.channel_id}" %></strong>
  <%= render(Imports::ProgressIndicatorComponent.new(import_job: import_job)) %>
  <% if import_job.completed? %>
    <%= render(BracketedLinkComponent.new(label: "review", href: imports_channel_path(import_job))) %>
  <% end %>
</div>
