<% content_for(:title, "import videos — running") %>

<%# Phase 22 §7.3 — Modal step 2: progress.
    The frame is replaced once after enqueue; the per-row `_progress`
    partials live inside individual stream targets so the Sidekiq
    worker can swap them in place as the job progresses. %>
<%= turbo_frame_tag "imports_modal_frame" do %>
  <%= turbo_stream_from "import_jobs" %>
  <div class="pane pane--standalone" style="max-width: 600px;">
    <h1>importing videos</h1>
    <p class="text-muted">
      pito is pulling new uploads in the background.<br>
      progress updates live for every channel.
    </p>

    <% if @errors.present? %>
      <ul class="text-danger" style="margin-bottom: 8px;">
        <% @errors.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>

    <ul style="list-style: none; padding: 0;">
      <% @enqueued.each do |import_job| %>
        <li style="margin-bottom: 6px;">
          <%= render "imports/channels/progress", import_job: import_job %>
        </li>
      <% end %>
    </ul>

    <div class="modal-footer" style="margin-top: 12px;">
      <%= render(BracketedLinkComponent.new(label: "back to videos", href: videos_path)) %>
    </div>
  </div>
<% end %>
