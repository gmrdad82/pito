<%# Phase 22 §7.4 — keep/reject table. All checkboxes ticked by
    default; submitting the form keeps every still-ticked id and
    permanently rejects (destroy + tombstone) the rest. %>
<h2 style="margin-top: 12px;">keep what to import</h2>
<p class="text-muted">
  all rows are kept by default.<br>
  uncheck a row to permanently reject that video.<br>
  rejected videos are not re-imported by future syncs.
</p>

<% if candidate_videos.any? %>
  <%= form_with url: imports_channel_path(import_job),
                method: :patch,
                local: true do |f| %>
    <table style="margin-top: 8px;">
      <thead>
        <tr>
          <th class="col-action"></th>
          <th>title</th>
          <th class="num">length</th>
          <th>category</th>
        </tr>
      </thead>
      <tbody>
        <% candidate_videos.each do |video| %>
          <tr>
            <td class="col-action">
              <input type="checkbox"
                     name="keep_video_ids[]"
                     value="<%= video.id %>"
                     checked>
            </td>
            <td><%= video.title.presence || video.youtube_video_id %></td>
            <td class="num"><%= video.duration_seconds || "—" %></td>
            <td><%= video.category_id || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="modal-footer" style="margin-top: 12px;">
      <button type="submit" class="bracketed">[<span class="bl">keep</span>]</button>
      <%= render(BracketedLinkComponent.new(label: "cancel", href: videos_path)) %>
    </div>
  <% end %>
<% else %>
  <p class="text-muted">no new videos to review.</p>
  <div class="modal-footer">
    <%= render(BracketedLinkComponent.new(label: "back to videos", href: videos_path)) %>
  </div>
<% end %>
