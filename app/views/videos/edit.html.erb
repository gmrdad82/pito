<% page_label = "video ##{@video.id}" %>
<% content_for(:title, "edit #{page_label}") %>
<% breadcrumb(["videos", videos_path], [page_label, video_path(@video)], "edit") %>

<h1>edit video</h1>

<%# Phase 11 §01a — Video edit page polish. Every edit sub-section
    stacks inside one .pane.pane--standalone per locked decision §1.
    Order: writable subset form → thumbnail → chapters → end-screens
    → links. The form's [save changes] CTA is the single submit that
    persists thumbnail / chapters / end-screens nested attributes. %>
<div class="pane pane--standalone" style="max-width: 560px;">
  <%= render "videos/form", video: @video %>

  <%# Phase 14 §3 — linked games / bundles fieldset. Sits below the
      main edit form so the [save changes] CTA above isn't crowded.
      The link create / remove flow uses its own POST + action-screen
      DELETE — independent of the edit form's submit. %>
  <%= render "videos/links_section",
             video: @video,
             links: @video_links,
             pickable_games: @link_pickable_games,
             pickable_bundles: @link_pickable_bundles %>
</div>
