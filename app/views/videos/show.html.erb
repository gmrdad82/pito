<% page_label = "video ##{@video.id}" %>
<% content_for(:title, page_label) %>
<% breadcrumb(["videos", videos_path], page_label) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/video/#{@video.id}", destructive: true, data: { keyboard_page_action: "delete" })) %>
  </div>
<% end %>

<%# `data-keyboard-external-url` lets the global keyboard controller
    open the video's YouTube URL in a new tab when the user presses
    `v` on the detail page (mirrors the CLI binding). %>
<div data-controller="add-pane" data-keyboard-external-url="https://www.youtube.com/watch?v=<%= @video.youtube_video_id %>">
  <div class="dot-list" style="margin-bottom: 6px;">
    <h1 style="display: inline;">video #<%= @video.id %></h1>
    <% if @available_videos.any? %>
      <%= render(BracketedLinkComponent.new(label: "|", href: "#", data: { action: "click->add-pane#open" })) %>
    <% end %>
  </div>

  <%# Phase B revamp (2026-05-06) — single pane on the show page sits
      in a `.pane-strip` (no wrap). The pane is fixed 640px wide. %>
  <div class="pane-strip">
    <%= render "videos/pane", video: @video %>
  </div>

  <% if @available_videos.any? %>
    <%= render "videos/add_pane_dialog", available_videos: @available_videos, current_ids: @video.id.to_s %>
  <% end %>
</div>
