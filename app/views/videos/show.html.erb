<% page_label = "video ##{@video.id}" %>
<% content_for(:title, page_label) %>
<% breadcrumb(["videos", videos_path], page_label) %>
<% content_for(:breadcrumb_actions) do %>
  <div class="dot-list">
    <%= render(BracketedLinkComponent.new(label: "e", href: edit_video_path(@video))) %>
    <%= render(BracketedLinkComponent.new(label: "-", href: "/deletions/video/#{@video.id}", destructive: true, data: { keyboard_page_action: "delete" })) %>
  </div>
<% end %>

<%# `data-keyboard-external-url` lets the global keyboard controller
    open the video's YouTube URL in a new tab when the user presses
    `v` on the detail page (mirrors the CLI binding). The
    `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    pair (when present) carries the `h` / `l` sibling navigation URLs. %>
<div data-controller="add-pane" data-keyboard-external-url="https://www.youtube.com/watch?v=<%= @video.youtube_video_id %>" <%= keyboard_detail_nav_data_attributes(@video, scope: Video, path_helper: method(:video_path)) %>>
  <div class="dot-list" style="margin-bottom: 6px;">
    <h1 style="display: inline;">video #<%= @video.id %></h1>
    <% if @available_videos.any? %>
      <%= render(BracketedLinkComponent.new(label: "|", href: "#", data: { action: "click->add-pane#open" })) %>
    <% end %>
  </div>

  <% if @video.title.present? %>
    <p style="margin-bottom: 4px;"><strong><%= @video.title %></strong></p>
  <% end %>
  <% if @video.imported? %>
    <p class="text-muted" style="margin-bottom: 4px;">imported</p>
  <% end %>
  <% if @video.last_sync_error.present? %>
    <p class="flash-error" style="margin-bottom: 8px; padding: 4px 8px;">
      youtube sync failed: <%= @video.last_sync_error %>
    </p>
  <% end %>

  <%# Phase 23 §23b — open-diff banner. When the latest VideoDiffCheckJob
      run detected a YouTube divergence, surface it here with a [view diff]
      bracketed link so the user can resolve before doing anything else. %>
  <% if (open_diff = @video.open_diff) %>
    <p class="flash-warn" style="margin-bottom: 8px; padding: 4px 8px;">
      youtube diverged on <%= number_with_delimiter(open_diff.fields.size) %>
      field<%= 's' if open_diff.fields.size != 1 %>.
      <%= link_to "[view diff]", diff_video_path(@video), class: "bracketed" %>
    </p>
  <% end %>

  <%# Phase 23 §23c — user-triggered sync. Routes through the syncs
      confirmation page per the bulk-as-foundation rule and the hard
      ban on JS confirms. One-element ids list.
      Phase 11i Q7 follow-up — `intent=diff_check` makes the POST enqueue
      `VideoDiffCheckJob` directly instead of fanning through `BulkSyncJob
      → VideoSync` (which already delegated to the diff-check job). The
      diff result lands on this page's open-diff banner above. %>
  <p style="margin-bottom: 8px;">
    <%= link_to "[sync]", syncs_path(type: "video", ids: @video.id, intent: "diff_check"), class: "bracketed" %>
  </p>

  <%# Layout pass (2026-05-10) — stats section moved to its own row
      below the detail pane (mirrors the `/games/:id` row pattern). Row 1
      holds the detail pane on its own; row 2 holds a full-width
      `.pane.pane--wide` carrying the recent-stats table. The stats
      table can be wider than the pane on narrower viewports, so its
      wrapper carries `overflow-x: auto` to scroll internally without
      forcing the whole page to scroll horizontally. The detail pane
      lets the channel URL wrap on `word-break: break-all` instead of
      truncating with an ellipsis. %>
  <div class="pane-row">
    <div class="pane">
      <h2>detail</h2>
      <table class="detail-table" style="margin-bottom: 8px;">
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">YouTube ID</td>
          <td><%= @video.youtube_video_id %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">channel</td>
          <%# 2026-05-16 polish — bracketed convention for every callable
              link. BracketedLinkComponent auto-detects the external href
              and applies `target="_blank" rel="noopener noreferrer"`. %>
          <td style="word-break: break-all; white-space: normal;">
            <%= render(BracketedLinkComponent.new(
                  label: @video.channel.channel_url,
                  href: @video.channel.channel_url
                )) %>
          </td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">starred</td>
          <td><%= @video.star? ? "yes" : "no" %></td>
        </tr>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">synced</td>
          <td><%= compact_time_ago(@video.last_synced_at) %></td>
        </tr>
      </table>
    </div>
  </div>

  <div class="pane-row">
    <div class="pane pane--wide">
      <% stats = @video.video_stats.order(date: :desc).limit(30) %>
      <% if stats.any? %>
        <h2>recent stats (<%= number_with_delimiter(stats.size) %> days)</h2>
        <div data-controller="sortable-table" data-sortable-table-id-value="<%= @video.id %>" style="overflow-x: auto;">
          <table data-sortable-table-target="table">
            <thead>
              <tr>
                <%= render(SortableHeaderComponent.new(label: "date", sort_type: "date")) %>
                <%= render(SortableHeaderComponent.new(label: "views", sort_type: "number", numeric: true)) %>
                <%= render(SortableHeaderComponent.new(label: "likes", sort_type: "number", numeric: true)) %>
                <%= render(SortableHeaderComponent.new(label: "chats", sort_type: "number", numeric: true)) %>
                <%= render(SortableHeaderComponent.new(label: "watch", sort_type: "number", numeric: true)) %>
              </tr>
            </thead>
            <tbody>
              <% stats.each do |stat| %>
                <tr>
                  <td><%= stat.date.strftime("%Y-%m-%d") %></td>
                  <td class="num"><%= number_with_delimiter(stat.views) %></td>
                  <td class="num"><%= number_with_delimiter(stat.likes) %></td>
                  <td class="num"><%= number_with_delimiter(stat.comments) %></td>
                  <td class="num"><span data-sort-value="<%= stat.watch_time_minutes.to_f.round %>"><%= format_video_watch_time(stat.watch_time_minutes) %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <h2>recent stats</h2>
        <p class="text-muted">no stats yet.</p>
      <% end %>
    </div>
  </div>

  <% if @available_videos.any? %>
    <%= render "videos/add_pane_dialog", available_videos: @available_videos, current_ids: @video.id.to_s %>
  <% end %>
</div>
