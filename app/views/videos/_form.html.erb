<%# Phase 12 — video edit form fragment. Surfaces the writable
      subset (title, description, tags, category_id,
      self_declared_made_for_kids, contains_synthetic_media,
      project_id). Privacy and publish_at are read-only here — the
      [publish] / [schedule] / [unpublish] CTAs above the form
      are the only paths that change them. %>
<%= form_with model: video, url: video_path(video), method: :patch, local: true do |f| %>
  <% if video.errors.any? %>
    <div class="flash-error" style="margin-bottom: 8px; padding: 4px 8px;">
      couldn't update — check the fields below.
      <ul style="margin: 4px 0 0 16px; padding: 0;">
        <% video.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset style="margin-bottom: 12px;">
    <legend>basics</legend>

    <div style="margin-bottom: 6px;">
      <label for="video_title">title</label>
      <%= f.text_field :title,
            maxlength: 100,
            style: "width: 100%; max-width: 480px;" %>
    </div>

    <div style="margin-bottom: 6px;">
      <label for="video_description">description</label>
      <%= f.text_area :description,
            rows: 6,
            style: "width: 100%; max-width: 480px;" %>
      <p class="form-hint" style="margin-top: 4px; font-size: 11px;">max 5000 bytes UTF-8.</p>
    </div>

    <div style="margin-bottom: 6px;">
      <label for="video_tags">tags (comma separated)</label>
      <input type="text"
             name="video[tags_csv]"
             id="video_tags"
             value="<%= Array(video.tags).join(", ") %>"
             style="width: 100%; max-width: 480px;"
             data-controller="tag-input">
      <%# tags arrive as a CSV string; the controller parses on submit
          (server side) into an array. The hidden array sentinel below
          lets Rails' params parser see `tags[]` even when the input
          stays empty. %>
      <input type="hidden" name="video[tags][]" value="">
    </div>

    <div style="margin-bottom: 6px;">
      <label for="video_category_id">category id</label>
      <%= f.text_field :category_id, style: "width: 80px;" %>
      <span class="form-hint" style="font-size: 11px;">numeric (YouTube category id; 20 = Gaming).</span>
    </div>
  </fieldset>

  <fieldset style="margin-bottom: 12px;">
    <legend>visibility</legend>
    <p>privacy: <strong><%= video.privacy_status %></strong></p>
    <% if video.publish_at.present? %>
      <%# Phase 26 — 01h. Display in the user's stored zone. UTC is the
          storage rule; render-time conversion is the only surface for
          tz mapping. %>
      <p>scheduled for: <strong><%= l_user_tz(video.publish_at) %></strong></p>
    <% end %>
    <% if video.privacy_private? %>
      <%= link_to "[publish]", pre_publish_checklist_video_path(video, target_action: "publish"),
                  class: "bracketed",
                  data: { turbo_frame: "pre-publish-modal-frame" } %>
      <%= link_to "[schedule]", pre_publish_checklist_video_path(video, target_action: "schedule"),
                  class: "bracketed",
                  data: { turbo_frame: "pre-publish-modal-frame" } %>
    <% else %>
      <%# Routed to a dedicated `unpublish` action (PATCH
          /videos/:id/unpublish) rather than `update` so the
          privacy_status flip stays outside the smuggle guard's
          blocklist. Rendered as `link_to` (not `button_to`) so the
          trigger is NOT a nested `<form>` inside the surrounding
          `form_with` — invalid HTML otherwise. `turbo_method: :patch`
          turns the click into a PATCH via Turbo. %>
      <%= link_to "[unpublish]", unpublish_video_path(video),
                  class: "bracketed",
                  data: { turbo_method: :patch } %>
    <% end %>
  </fieldset>

  <fieldset style="margin-bottom: 12px;">
    <legend>audience</legend>
    <div style="margin-bottom: 6px;">
      <%= f.label :self_declared_made_for_kids, "made for kids" %>
      <%= f.check_box :self_declared_made_for_kids %>
    </div>
    <% if video.made_for_kids_effective != video.self_declared_made_for_kids %>
      <p class="form-hint" style="font-size: 11px;">
        youtube reports made_for_kids_effective = <%= video.made_for_kids_effective %>
        (read-only).
      </p>
    <% end %>
  </fieldset>

  <fieldset style="margin-bottom: 12px;">
    <legend>disclosures</legend>
    <div style="margin-bottom: 6px;">
      <%= f.label :contains_synthetic_media, "contains synthetic / generative media" %>
      <%= f.check_box :contains_synthetic_media %>
    </div>
  </fieldset>

  <fieldset style="margin-bottom: 12px;">
    <legend>studio-only</legend>
    <p class="form-hint" style="font-size: 11px;">
      these fields live in YouTube Studio. pito does not edit them; the
      pre-publish checklist surfaces them as a manual reminder.
    </p>
    <ul style="list-style: none; padding: 0;">
      <li>game tag &mdash; <%= render(BracketedLinkComponent.new(label: "open in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %></li>
      <li>age restriction (18+) &mdash; <%= render(BracketedLinkComponent.new(label: "open in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %></li>
      <li>paid promotion &mdash; <%= render(BracketedLinkComponent.new(label: "open in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %></li>
      <li>end screen &mdash; <%= render(BracketedLinkComponent.new(label: "open in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %></li>
    </ul>
  </fieldset>

  <fieldset style="margin-bottom: 12px;">
    <legend>project</legend>
    <%= f.select :project_id,
                 [ [ "(none)", nil ] ] + @projects.map { |p| [ p.name, p.id ] },
                 { include_blank: false },
                 { style: "max-width: 320px;" } %>
  </fieldset>

  <% if video.last_sync_error.present? %>
    <p class="flash-error" style="margin-bottom: 8px; padding: 4px 8px;">
      youtube sync failed: <%= video.last_sync_error %>
    </p>
  <% end %>

  <div style="display: flex; gap: 6px;">
    <button type="submit" class="btn-submit">[<b>save changes</b>]</button>
    <%= link_to "[cancel]", video_path(video), class: "bracketed" %>
  </div>
<% end %>

<%# Turbo Frame target for the pre-publish modal. The frame is empty
    until the [publish] / [schedule] CTA loads its content. %>
<%= turbo_frame_tag "pre-publish-modal-frame" %>
