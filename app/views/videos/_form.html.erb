<%= form_with(model: video) do |f| %>
  <% if video.errors.any? %>
    <div class="flash-error" style="margin-bottom: 8px; padding: 4px 8px;">couldn't <%= video.new_record? ? "create" : "update" %> — check the fields below.</div>
  <% end %>

  <%= render(FormFieldComponent.new(form: f, field: :title)) %>
  <% if video.new_record? %>
    <%= render(FormFieldComponent.new(form: f, field: :channel_id, label: "channel", type: :collection_select, collection: Channel.order(:title), prompt: "select a channel...")) %>
  <% end %>
  <%= render(FormFieldComponent.new(form: f, field: :description, type: :text_area)) %>
  <%= render(FormFieldComponent.new(form: f, field: :privacy_status, type: :select, options: Video.privacy_statuses.keys.map { |k| [k.sub("_video", ""), k] })) %>
  <%= render(FormFieldComponent.new(form: f, field: :tags)) %>

  <div style="display: flex; gap: 6px;">
    <button type="submit" class="btn-submit">[<b>save</b>]</button>
    <%= render(BracketedLinkComponent.new(label: "cancel", href: cancel_path)) %>
  </div>
<% end %>
