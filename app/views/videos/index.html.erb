<% content_for(:title, "videos") %>

<div style="max-width: 1400px;" data-controller="bulk-select" data-bulk-select-max-panes-value="<%= @max_panes %>" data-bulk-select-entity-name-value="videos" data-bulk-select-panes-path-value="/videos/panes" data-bulk-select-delete-type-value="video">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <h1>videos</h1>
    <span class="text-muted">&middot;</span>
    <%= render(BracketedLinkComponent.new(label: "+", href: new_video_path)) %>
    <span style="margin-left: auto;"><%= render(SavedViewsSectionComponent.new(saved_views: @saved_views || SavedView.none, kind: "videos")) %></span>
  </div>

  <% if @videos.any? %>
    <div>
      <%# Phase B polish (2026-05-05) — bulk toolbar is always rendered.
          Each `.action` span carries an `.action-sep` `&middot;` that
          the controller hides on whichever action is first-visible.
          Action targets (open / count / delete) self-hide when
          selection count is zero; see bulk_select_controller.js. %>
      <div data-bulk-select-target="actions" class="bulk-toolbar" style="margin-bottom: 6px;">
        <span class="action" data-bulk-select-target="openHint">
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="openAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="count" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="deleteAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
      </div>

      <%# Sortable column headers — server-side sort via `?sort=<key>&dir=<asc|desc>`.
          Only columns whose key lives in `VideosController::ALLOWED_SORTS`
          render as sort links (Name / title / date). Aggregate columns
          (views / trend / likes / chats / watch) and computed cells
          (channel / state / length) stay as plain `<th>` text — adding
          them to the allowlist is a forward-looking item and would need
          ORDER BY on the SUM expression for the aggregates. %>
      <%# Table sizing — explicit colgroup widths plus
          `table-layout: fixed; width: 1220px;` so the table sizes to its
          content (40 + 60 + 280 + 200 + 80 + 60 + 80 + 80 + 80 + 80 +
          100 + 80 = 1220 px) rather than stretching to viewport width.
          Mirrors the /channels polish (2026-05-06): the channel-URL
          column is server-side middle-truncated, so it fits comfortably
          in 200 px. `width: auto` is NOT enough under
          `table-layout: fixed` — see /channels picker partial for the
          longer note. There is no `starred` column on videos. %>
      <table style="table-layout: fixed; width: 1220px;">
        <colgroup>
          <col style="width: 40px;">  <%# selection checkbox %>
          <col style="width: 60px;">  <%# Name (id) %>
          <col style="width: 280px;"> <%# title %>
          <col style="width: 200px;"> <%# channel URL (truncated) %>
          <col style="width: 80px;">  <%# views %>
          <col style="width: 60px;">  <%# trend %>
          <col style="width: 80px;">  <%# likes %>
          <col style="width: 80px;">  <%# chats %>
          <col style="width: 80px;">  <%# watch %>
          <col style="width: 80px;">  <%# state %>
          <col style="width: 100px;"> <%# date %>
          <col style="width: 80px;">  <%# length %>
        </colgroup>
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <%# Name column — placeholder for the YouTube video title once
                sync lands. For now the cell renders `video.id` linked to
                the show page so the column has stable content. The legacy
                `[o]` action column was dropped (2026-05-05 polish): the
                Name cell IS the show-page link, so a separate open-action
                cell was redundant. %>
            <th class="sortable"><%= sort_link_to("Name", "id", current_sort: @sort, current_dir: @dir) %></th>
            <th class="sortable"><%= sort_link_to("title", "title", current_sort: @sort, current_dir: @dir) %></th>
            <th>channel</th>
            <th class="num">views</th>
            <th class="num">trend</th>
            <th class="num">likes</th>
            <th class="num">chats</th>
            <th class="num">watch</th>
            <th class="num">state</th>
            <th class="sortable num"><%= sort_link_to("date", "published_at", current_sort: @sort, current_dir: @dir) %></th>
            <th class="num">length</th>
          </tr>
        </thead>
        <tbody>
          <% @videos.each do |video| %>
            <tr>
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: video.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <td><%= link_to video.id, video_path(video) %></td>
              <td style="overflow: hidden; text-overflow: ellipsis;"><%= video.title %></td>
              <%# Channel column — server-side middle-truncated to a
                  fixed `<head>…<tail>` string (e.g. `https://…jF7eS8r1`).
                  Same shape as the `/channels` URL column. Full URL is
                  preserved on the `<td>`'s `title` attribute. %>
              <td title="<%= video.channel.channel_url %>">
                <%= link_to middle_truncate(video.channel.channel_url, head: 8, tail: 8), video.channel.channel_url, target: "_blank", rel: "noopener noreferrer" %>
              </td>
              <td class="num"><%= number_with_delimiter(video.total_views) %></td>
              <td class="num"><%= view_trend_indicator(video) %></td>
              <td class="num"><%= number_with_delimiter(video.total_likes) %></td>
              <td class="num"><%= number_with_delimiter(video.total_comments) %></td>
              <td class="num"><span data-sort-value="<%= video.total_watch_time.to_i %>"><%= format_video_watch_time(video.total_watch_time) %></span></td>
              <td class="num"><%= video.privacy_status&.sub("_video", "") || "—" %></td>
              <td class="num"><%= video.published_at&.strftime("%Y-%m-%d") %></td>
              <td class="num"><%= format_duration(video.duration_seconds) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">no videos yet.</p>
  <% end %>
</div>
