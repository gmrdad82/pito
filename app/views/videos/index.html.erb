<% content_for(:title, "videos") %>

<div style="max-width: 1400px;" data-controller="bulk-select" data-bulk-select-max-panes-value="<%= @max_panes %>" data-bulk-select-entity-name-value="videos" data-bulk-select-panes-path-value="/videos/panes" data-bulk-select-delete-type-value="video">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <h1>videos</h1>
    <span class="text-muted">&middot;</span>
    <%= render(BracketedLinkComponent.new(label: "+", href: new_video_path)) %>
    <span style="margin-left: auto;"><%= render(SavedViewsSectionComponent.new(saved_views: @saved_views || SavedView.none, kind: "videos")) %></span>
  </div>

  <% if @videos.any? %>
    <div data-controller="sortable-table">
      <%# Phase B polish (2026-05-05) — bulk toolbar is always rendered.
          Each `.action` span carries an `.action-sep` `&middot;` that
          the controller hides on whichever action is first-visible.
          Action targets (open / count / delete) self-hide when
          selection count is zero; see bulk_select_controller.js. %>
      <div data-bulk-select-target="actions" class="bulk-toolbar" style="margin-bottom: 6px;">
        <span class="action" data-bulk-select-target="openHint">
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="openAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="count" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="deleteAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
      </div>

      <table data-sortable-table-target="table">
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <th class="col-action"></th>
            <%= render(SortableHeaderComponent.new(label: "title", sort_type: "string")) %>
            <th>channel</th>
            <%= render(SortableHeaderComponent.new(label: "views", sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "trend", sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "likes", sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "chats", sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "watch", sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "state", sort_type: "string", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "date", sort_type: "date", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: "length", sort_type: "number", numeric: true)) %>
          </tr>
        </thead>
        <tbody>
          <% @videos.each do |video| %>
            <tr>
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: video.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <td class="col-action"><%= render(BracketedLinkComponent.new(label: "o", href: video_path(video))) %></td>
              <td style="max-width: 280px; overflow: hidden; text-overflow: ellipsis;"><%= video.title %></td>
              <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">
                <a href="<%= video.channel.channel_url %>" target="_blank" rel="noopener noreferrer"><%= truncate(video.channel.channel_url, length: 30, omission: "…") %></a>
              </td>
              <td class="num"><%= number_with_delimiter(video.total_views) %></td>
              <td class="num"><%= view_trend_indicator(video) %></td>
              <td class="num"><%= number_with_delimiter(video.total_likes) %></td>
              <td class="num"><%= number_with_delimiter(video.total_comments) %></td>
              <td class="num"><span data-sort-value="<%= video.total_watch_time.to_i %>"><%= format_video_watch_time(video.total_watch_time) %></span></td>
              <td class="num"><%= video.privacy_status&.sub("_video", "") || "—" %></td>
              <td class="num"><%= video.published_at&.strftime("%Y-%m-%d") %></td>
              <td class="num"><%= format_duration(video.duration_seconds) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-muted">no videos yet.</p>
  <% end %>
</div>
