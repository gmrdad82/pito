<% content_for(:title, "videos") %>

<%# Phase 7 Path A2 (literal full retract). Video is a thin
    YouTube-reference record. The index renders id, youtube ID, channel
    URL, aggregate stats (views/likes/comments/watch), star, and last
    sync. The legacy [+] add button is gone — Videos are created via
    the Phase 7C connect-channel flow, not via an in-app form. %>
<div style="max-width: 1100px;" data-controller="bulk-select" data-bulk-select-max-panes-value="<%= @max_panes %>" data-bulk-select-entity-name-value="videos" data-bulk-select-panes-path-value="/videos/panes" data-bulk-select-delete-type-value="video">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <div class="dot-list">
      <h1>videos</h1>
      <%# Phase 22 — `[import]` opens the import modal in place. Frame
          target is `imports_modal_frame` so the response replaces this
          link's enclosing turbo-frame on the modal step views. %>
      <%= render(BracketedLinkComponent.new(
        label: "import",
        href: imports_channels_path,
        data: { turbo_frame: "imports_modal_frame" }
      )) %>
    </div>
    <span style="margin-left: auto;"><%= render(SavedViewsSectionComponent.new(saved_views: @saved_views || SavedView.none, kind: "videos")) %></span>
  </div>

  <%# Phase 22 — modal frame. The `[import]` link above fills this
      frame with `imports/channels/index`. When no import is open the
      frame stays empty (no DOM impact). %>
  <%= turbo_frame_tag "imports_modal_frame" %>

  <%# Phase 21 — `?channel=<slug-or-id>` filter chip. The chip renders
      only when the URL carries the param; clicking it clears `?channel`
      while preserving any other filter / sort params. The label uses
      the channel's title when populated and falls back to the URL
      slug (UC-id) so the chip is meaningful even on freshly synced
      channels with blank titles. The chip uses full-page navigation
      (no `frame:`) because the chip element itself lives OUTSIDE the
      `videos-index-table` turbo frame — a frame swap would update
      the table but leave the chip stranded in the DOM. %>
  <% if @filter_channel %>
    <div class="dot-list" style="margin-bottom: 2px; gap: 10px;">
      <span class="text-muted">filter:</span>
      <%= render(FilterChipComponent.new(
        label: "channel: #{@filter_channel.title.presence || @filter_channel.to_param}",
        param: "channel",
        value: @filter_channel.to_param,
        current_params: request.query_parameters
      )) %>
    </div>
  <% end %>

  <%= turbo_frame_tag "videos-index-table" do %>
  <% if @videos.any? %>
    <div>
      <%# `data-turbo-frame="_top"` cascades to the controller-injected
          `[open N]` / `[delete N]` links so their clicks navigate
          full-page to `/videos/panes` and `/deletions/video/:ids`
          instead of being scoped to the enclosing
          `videos-index-table` Turbo Frame. Both targets are full-page
          surfaces (panes workspace, `shared/_action_screen.html.erb`)
          and have no matching frame in their responses — without
          `_top` Turbo shows "Content missing". %>
      <div data-bulk-select-target="actions" class="bulk-toolbar" style="margin-bottom: 6px;" data-turbo-frame="_top">
        <span class="action" data-bulk-select-target="openHint">
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="openAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="count" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
        <span class="action" data-bulk-select-target="deleteAction" hidden>
          <span class="action-sep" hidden>&middot;</span>
        </span>
      </div>

      <div class="themed-scroll-x" style="overflow-x: auto; max-width: 100%;">
      <table style="table-layout: fixed; width: 1080px;">
        <colgroup>
          <col style="width: 40px;">  <%# selection checkbox %>
          <col style="width: 60px;">  <%# id %>
          <col style="width: 160px;"> <%# youtube id %>
          <col style="width: 180px;"> <%# channel URL %>
          <col style="width: 80px;">  <%# privacy %>
          <col style="width: 80px;">  <%# views %>
          <col style="width: 80px;">  <%# likes %>
          <col style="width: 80px;">  <%# chats %>
          <col style="width: 80px;">  <%# watch %>
          <col style="width: 60px;">  <%# star %>
          <col style="width: 100px;"> <%# last sync %>
          <col style="width: 60px;">  <%# edit %>
        </colgroup>
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <th class="sortable"><%= sort_link_to("name", "id", current_sort: @sort, current_dir: @dir, frame: "videos-index-table") %></th>
            <th>YouTube id</th>
            <th>channel</th>
            <th class="sortable"><%= sort_link_to("privacy", "privacy_status", current_sort: @sort, current_dir: @dir, frame: "videos-index-table") %></th>
            <th class="num">views</th>
            <th class="num">likes</th>
            <th class="num">chats</th>
            <th class="num">watch</th>
            <th class="sortable num"><%= sort_link_to("star", "starred", current_sort: @sort, current_dir: @dir, frame: "videos-index-table") %></th>
            <th class="sortable num"><%= sort_link_to("last sync", "last_synced_at", current_sort: @sort, current_dir: @dir, frame: "videos-index-table") %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @videos.each do |video| %>
            <%# `data-keyboard-row` opts each video row into the global
                keyboard controller's list-row navigation (`j`/`k` move
                highlight, `space` toggles the row's checkbox, `D` drives
                bulk delete against the highlighted row's id). Mirrors
                the channels / notifications / schedule pattern. %>
            <tr data-keyboard-row data-keyboard-row-id="<%= video.id %>">
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: video.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <td><%= link_to video.id, video_path(video), data: { turbo_frame: "_top" } %></td>
              <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= video.youtube_video_id %>"><%= video.youtube_video_id %></td>
              <td title="<%= video.channel.channel_url %>">
                <%= link_to middle_truncate(video.channel.channel_url, head: 8, tail: 8), video.channel.channel_url, target: "_blank", rel: "noopener noreferrer" %>
              </td>
              <td>
                <%= video.privacy_status %>
                <% if video.imported? %>
                  <span class="text-muted" style="font-size: 11px;">imported</span>
                <% end %>
              </td>
              <td class="num"><%= number_with_delimiter(video.total_views) %></td>
              <td class="num"><%= number_with_delimiter(video.total_likes) %></td>
              <td class="num"><%= number_with_delimiter(video.total_comments) %></td>
              <td class="num"><span data-sort-value="<%= video.total_watch_time.to_i %>"><%= format_video_watch_time(video.total_watch_time) %></span></td>
              <td class="num"><%= video.star? ? "yes" : "no" %></td>
              <td class="num">
                <% if video.last_synced_at.present? %>
                  <%= compact_time_ago(video.last_synced_at) %>
                <% else %>
                  —
                <% end %>
              </td>
              <td><%= render(BracketedLinkComponent.new(label: "edit", href: edit_video_path(video))) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    </div>
  <% else %>
    <p class="text-muted">no videos yet.</p>
  <% end %>
  <% end %>
</div>
