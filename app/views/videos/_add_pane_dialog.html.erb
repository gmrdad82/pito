<dialog data-add-pane-target="dialog" data-action="click->add-pane#clickOutside" class="pane-dialog">
  <%# Phase B polish (2026-05-05) — capped at 80vh with a scrollable body
      and a .modal-footer hairline so [close] sits at the bottom (matches
      the saved-views and confirm modals). %>
  <div style="padding: 12px; min-width: 400px; max-width: 600px; max-height: 80vh; display: flex; flex-direction: column;">
    <h2 style="margin-bottom: 8px;">add a video</h2>
    <div style="overflow-y: auto; flex: 1; min-height: 0;">
      <% if available_videos.any? %>
        <table>
          <thead>
            <tr>
              <th class="col-action"></th>
              <th>title</th>
              <th>channel</th>
            </tr>
          </thead>
          <tbody>
            <% available_videos.each do |video| %>
              <tr>
                <td class="col-action">
                  <% new_ids = [current_ids, video.id].reject(&:blank?).join(",") %>
                  <%= render(BracketedLinkComponent.new(label: "+", href: "#{panes_videos_path}?ids=#{new_ids}")) %>
                </td>
                <td><%= truncate(video.title, length: 40, omission: "…") %></td>
                <td><%= truncate(video.channel.channel_url, length: 40, omission: "…") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted">no more videos to add.</p>
      <% end %>
    </div>
    <div class="modal-footer">
      <%= render(BracketedLinkComponent.new(label: "close", href: "#", data: { action: "click->add-pane#close" })) %>
    </div>
  </div>
</dialog>
