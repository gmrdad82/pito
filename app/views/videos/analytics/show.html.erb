<%
  video_label = @video.title.presence || @video.youtube_video_id.presence || "video #{@video.id}"
  page_title = "#{video_label} · analytics"
%>
<% content_for(:title, page_title) %>

<header class="analytics-header" style="margin-bottom: 16px;">
  <h1><%= page_title %></h1>
  <%= render "analytics/data_freshness", timestamp: @last_synced_at %>
  <%= render "analytics/window_picker", window: @window %>
  <% if @video.channel&.youtube_connection.present? %>
    <%= button_to "[refresh now]",
                  video_analytics_refresh_path(@video),
                  method: :post,
                  class: "bracketed",
                  form: { style: "display: inline; margin-left: 8px;" } %>
    <%= button_to "[refresh retention]",
                  video_retention_refresh_path(@video),
                  method: :post,
                  class: "bracketed",
                  form: { style: "display: inline; margin-left: 4px;" } %>
  <% end %>
</header>

<% if @needs_reauth %>
  <%= render "analytics/needs_reauth_banner" %>
<% end %>

<% summary = @decorator.window_summary(@window) %>
<section class="analytics-section analytics-window-summary" style="margin: 16px 0;">
  <h2>summary — <%= analytics_window_label(@window, long: true) %></h2>
  <% if summary %>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      <%= render "analytics/summary_card",
                 label: "views",
                 value: summary.views,
                 type: :count %>
      <%= render "analytics/summary_card",
                 label: "estimated minutes watched",
                 value: summary.estimated_minutes_watched,
                 type: :count %>
      <%= render "analytics/summary_card",
                 label: "average view duration",
                 value: summary.average_view_duration,
                 type: :duration_seconds %>
      <%= render "analytics/summary_card",
                 label: "average view %",
                 value: summary.average_view_percentage,
                 type: :ratio %>
      <%= render "analytics/summary_card",
                 label: "thumbnail CTR",
                 value: summary.video_thumbnail_impressions_click_rate,
                 type: :ratio %>
    </div>
    <% if monetization_enabled? %>
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px;">
        <%= render "analytics/summary_card",
                   label: "estimated revenue",
                   value: summary.estimated_revenue,
                   type: :money %>
        <%= render "analytics/summary_card",
                   label: "cpm",
                   value: summary.cpm,
                   type: :money %>
      </div>
    <% else %>
      <%= render "analytics/monetization_disabled" %>
    <% end %>
  <% else %>
    <p class="caption analytics-empty-state">
      no data for this window. data syncs nightly; refresh to start syncing now.
    </p>
  <% end %>
</section>

<section class="analytics-section analytics-daily" style="margin: 16px 0;">
  <%= render "analytics/charts/video_daily_line",
             dailies: @decorator.daily_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-retention" style="margin: 16px 0;">
  <%= render "analytics/charts/video_retention_line",
             buckets: @decorator.retention,
             video: @video %>
</section>

<section class="analytics-section analytics-country" style="margin: 16px 0;">
  <%= render "analytics/charts/country_bar",
             breakdown: @decorator.country_breakdown_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-device" style="margin: 16px 0;">
  <%= render "analytics/charts/device_donut",
             breakdown: @decorator.device_breakdown_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-os" style="margin: 16px 0;">
  <%= render "analytics/charts/os_donut",
             breakdown: @decorator.os_breakdown_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-traffic" style="margin: 16px 0;">
  <%= render "analytics/charts/traffic_source_bar",
             breakdown: @decorator.traffic_source_breakdown_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-subscribed" style="margin: 16px 0;">
  <%= render "analytics/charts/subscribed_status_donut",
             breakdown: @decorator.subscribed_status_breakdown_for_window(@window_start, @window_end),
             window: @window %>
</section>

<section class="analytics-section analytics-demographics" style="margin: 16px 0;">
  <%= render "analytics/charts/demographics_heatmap",
             breakdown: @decorator.demographics_for_window(@window_start, @window_end),
             window: @window %>
</section>

<%# Phase 26 §01g — viewer-time heatmap. %>
<%= render "videos/viewer_time_tab", video: @video %>
