<%# Phase 12 — pre-publish checklist modal partial.

      Rendered into the Turbo Frame `pre-publish-modal-frame`. Submit
      target is either `publish` (publish flow, the trigger sets
      target_privacy_status hidden field) or `schedule` (adds a
      publish_at date/time input).

      The `pre-publish-checklist` Stimulus controller disables the
      submit button until all four checkboxes are checked.

      NO JS confirm() / alert() / data-turbo-confirm — the modal IS
      the confirmation surface (CLAUDE.md hard rule).
%>
<%
  target_action ||= "publish"
  error ||= local_assigns[:error]
  form_path = if target_action == "schedule"
                schedule_video_path(video)
              else
                publish_video_path(video)
              end
%>
<%= turbo_frame_tag "pre-publish-modal-frame" do %>
  <div class="pre-publish-modal" data-controller="pre-publish-checklist" role="dialog" aria-labelledby="pre-publish-heading">
    <div class="pre-publish-modal__panel">
      <h2 id="pre-publish-heading">pre-publish checklist</h2>

      <p style="margin-bottom: 8px;">
        these four fields live in youtube studio. check each one in
        studio, then tick the box here to confirm. pito does not
        enforce them &mdash; this is a manual reminder.
      </p>

      <% if error.present? %>
        <p class="flash-error" style="margin-bottom: 8px;"><%= error %></p>
      <% end %>

      <%= form_with url: form_path, method: :patch, local: true, data: { pre_publish_checklist_target: "form" } do |f| %>
        <% if target_action == "publish" %>
          <%= hidden_field_tag "video[target_privacy_status]", "public", id: "video_target_privacy_status" %>
        <% end %>

        <div style="margin-bottom: 6px;">
          <%= hidden_field_tag "video[pre_publish_game_ok]", "no", id: "video_pre_publish_game_ok_hidden" %>
          <input type="checkbox"
                 name="video[pre_publish_game_ok]"
                 value="yes"
                 id="video_pre_publish_game_ok"
                 data-pre-publish-checklist-target="checkbox"
                 data-action="change->pre-publish-checklist#refresh"
                 <%= "checked" if video.pre_publish_game_ok? %>>
          <label for="video_pre_publish_game_ok">Game set correctly (if category = Gaming)</label>
          <%= render(BracketedLinkComponent.new(label: "check in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %>
        </div>

        <div style="margin-bottom: 6px;">
          <%= hidden_field_tag "video[pre_publish_age_ok]", "no", id: "video_pre_publish_age_ok_hidden" %>
          <input type="checkbox"
                 name="video[pre_publish_age_ok]"
                 value="yes"
                 id="video_pre_publish_age_ok"
                 data-pre-publish-checklist-target="checkbox"
                 data-action="change->pre-publish-checklist#refresh"
                 <%= "checked" if video.pre_publish_age_ok? %>>
          <label for="video_pre_publish_age_ok">Age restriction (18+) reviewed</label>
          <%= render(BracketedLinkComponent.new(label: "check in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %>
        </div>

        <div style="margin-bottom: 6px;">
          <%= hidden_field_tag "video[pre_publish_paid_promotion_ok]", "no", id: "video_pre_publish_paid_promotion_ok_hidden" %>
          <input type="checkbox"
                 name="video[pre_publish_paid_promotion_ok]"
                 value="yes"
                 id="video_pre_publish_paid_promotion_ok"
                 data-pre-publish-checklist-target="checkbox"
                 data-action="change->pre-publish-checklist#refresh"
                 <%= "checked" if video.pre_publish_paid_promotion_ok? %>>
          <label for="video_pre_publish_paid_promotion_ok">Paid promotion declared if applicable</label>
          <%= render(BracketedLinkComponent.new(label: "check in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %>
        </div>

        <div style="margin-bottom: 12px;">
          <%= hidden_field_tag "video[pre_publish_end_screen_ok]", "no", id: "video_pre_publish_end_screen_ok_hidden" %>
          <input type="checkbox"
                 name="video[pre_publish_end_screen_ok]"
                 value="yes"
                 id="video_pre_publish_end_screen_ok"
                 data-pre-publish-checklist-target="checkbox"
                 data-action="change->pre-publish-checklist#refresh"
                 <%= "checked" if video.pre_publish_end_screen_ok? %>>
          <label for="video_pre_publish_end_screen_ok">End screen reviewed</label>
          <%= render(BracketedLinkComponent.new(label: "check in studio", href: video.studio_url, target: "_blank", rel: "noopener noreferrer")) %>
        </div>

        <% if target_action == "schedule" %>
          <div style="margin-bottom: 12px;">
            <label for="video_publish_at">publish at (future ISO 8601 timestamp)</label>
            <input type="datetime-local"
                   name="video[publish_at]"
                   id="video_publish_at"
                   value="<%= video.publish_at&.iso8601(0) %>"
                   required>
          </div>
        <% end %>

        <div style="display: flex; gap: 6px;">
          <button type="submit"
                  class="btn-submit"
                  data-pre-publish-checklist-target="submit"
                  disabled>
            [<b>confirm <%= target_action %></b>]
          </button>
          <%= link_to "[cancel]", edit_video_path(video),
                      class: "bracketed",
                      data: { turbo_frame: "pre-publish-modal-frame" } %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
