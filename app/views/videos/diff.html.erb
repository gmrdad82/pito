<% page_label = "video ##{@video.id} diff" %>
<% content_for(:title, page_label) %>
<% breadcrumb(["videos", videos_path], ["video ##{@video.id}", video_path(@video)], "diff") %>

<% if @diff.nil? %>
  <%# Defensive — the controller already redirects on no-diff, but if a
      validation failure re-renders this template, surface a clear notice. %>
  <div class="pane pane--standalone">
    <h1>diff</h1>
    <p class="text-muted">no open diff for this video.</p>
    <p><%= link_to "[ back to video ]", video_path(@video), class: "bracketed" %></p>
  </div>
<% else %>
  <div class="pane pane--standalone">
    <h1>diff for video #<%= @video.id %></h1>
    <p class="text-muted">
      detected <%= compact_time_ago(@diff.detected_at) %> ·
      <%= number_with_delimiter(@diff.fields.size) %> field<%= 's' if @diff.fields.size != 1 %> differ
    </p>
    <p>
      <strong>title:</strong>
      <%= @video.title.presence || content_tag(:span, "(empty)", class: "text-muted") %>
    </p>
    <p class="text-muted" style="margin-bottom: 12px;">
      youtube id: <code><%= @video.youtube_video_id %></code>
    </p>

    <%= render "shared/diff_table",
               subject: @video,
               fields: @diff.fields,
               diff: @diff,
               decision_form_url: apply_diff_video_path(@video),
               decision_name: "decisions" %>

    <p style="margin-top: 16px;">
      <%= link_to "[ cancel ]", video_path(@video), class: "bracketed" %>
    </p>
  </div>
<% end %>
