<% content_for(:title, "settings") %>
<h1>settings</h1>
<script>
  // Sync localStorage + theme with server setting after form save
  (function() {
    var theme = "<%= (AppSetting.get('theme') || 'auto').gsub('"', '') %>";
    if (theme === "auto") {
      localStorage.removeItem("pito-theme");
    } else {
      localStorage.setItem("pito-theme", theme);
    }
    var effective = theme;
    if (theme === "auto") {
      effective = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    document.documentElement.setAttribute("data-theme", effective);
    document.documentElement.dataset.themePreference = theme;
    var label = document.querySelector('[data-theme-target="label"]');
    if (label) label.textContent = effective === "dark" ? "light" : "dark";
    if (window.recolorCharts) setTimeout(window.recolorCharts, 100);
  })();
</script>

<%# 2026-05-10 user-locked restructure — three titled sections, each a
    2-column grid:

      ## customize
      [ ui / ux ]              [ workspaces ]
      [ user ]                 [ time zone ]

      ## integrations
      [ YouTube ]              [ Voyage.ai ]
      [ OAuth applications ]   [ sessions ]

      ## stack
      [ sql ]                  [ search ]
      [ storage ]              (empty right cell)

    Section headings use the standard h2 styling. Each section holds
    its own group of `.pane-row` flex containers. Slack + Discord
    panes are deliberately NOT on this page — their controllers /
    routes / partials remain so the partial-level view specs and the
    request specs for the webhook controllers keep passing, but they
    no longer surface on the settings index per the user-locked
    layout.

    Pane h2 brand-casing rule survives the restructure: `YouTube`,
    `Voyage.ai`, `OAuth applications` keep their casing; everything
    else stays lowercase.

    YouTube credentials status — the row labels read
    `public API key` / `OAuth client ID` / `OAuth client secret` /
    `OAuth redirect URI`. The controller looks them up under the
    `:google_oauth` credentials block (NOT `:youtube` — that block
    does not exist in this install).
%>

<%# ============================================================
    customize
============================================================ %>
<h2>customize</h2>

<%# customize row 1 — ui / ux | workspaces. The section identifier on
    the wire stays `appearance` for backward compatibility with any
    scripted PATCH callers; only the visible H2 + the row label changed
    when keyboard navigation joined the pane. %>
<div class="pane-row">
  <%# ui / ux %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="appearance">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>ui / ux</h2></legend>

        <div style="margin-bottom: 6px;">
          <label class="form-label">theme</label>
          <div style="display: flex; gap: 12px;">
            <% %w[light dark auto].each do |opt| %>
              <label class="md-radio">
                <input type="radio" name="settings[theme]" value="<%= opt %>" <%= "checked" if @theme == opt %>>
                <span class="md-radio-indicator"></span>
                <span class="md-radio-label"><%= opt %><%= " (system)" if opt == "auto" %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%# Keyboard-navigation toggle. Renders as on / off radios so
            the row mirrors the theme picker visually. Wire format is
            yes / no per the project's external-boolean rule
            (CLAUDE.md hard rules); the controller flips it back to
            Boolean before storage. The setting is surfaced to the
            keyboard Stimulus controller via the body-level
            `data-keyboard-navigation-enabled` attribute (see
            application.html.erb). %>
        <div style="margin-bottom: 6px;">
          <label class="form-label">keyboard navigation</label>
          <div style="display: flex; gap: 12px;">
            <% %w[yes no].each do |opt| %>
              <label class="md-radio">
                <input type="radio" name="settings[keyboard_navigation_enabled]" value="<%= opt %>" <%= "checked" if (@keyboard_navigation_enabled ? "yes" : "no") == opt %>>
                <span class="md-radio-indicator"></span>
                <span class="md-radio-label"><%= opt == "yes" ? "on" : "off" %></span>
              </label>
            <% end %>
          </div>
        </div>

        <button type="submit">[update]</button>
      </fieldset>
    <% end %>
  </div>

  <%# workspaces %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="workspaces">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>workspaces</h2></legend>

        <div style="margin-bottom: 6px;">
          <label for="settings_pane_title_length" class="form-label">pane title truncation</label>
          <input type="number" name="settings[pane_title_length]" id="settings_pane_title_length"
                 value="<%= @settings['pane_title_length'] %>" min="6" max="50"
                 placeholder="<%= @pane_title_length_default %>" autocomplete="off"
                 style="width: 80px; text-align: right;">
          <span class="form-hint" style="display: block;">default: <%= @pane_title_length_default %> chars.</span>
        </div>

        <div style="margin-bottom: 6px;">
          <label for="settings_max_panes" class="form-label">max panes</label>
          <input type="number" name="settings[max_panes]" id="settings_max_panes"
                 value="<%= @settings['max_panes'] %>" min="1" max="10"
                 placeholder="<%= @max_panes_default %>" autocomplete="off"
                 style="width: 80px; text-align: right;">
          <span class="form-hint" style="display: block;">default: <%= @max_panes_default %>.</span>
        </div>

        <button type="submit">[update]</button>
      </fieldset>
    <% end %>
  </div>
</div>

<%# customize row 2 — user | time zone. %>
<div class="pane-row">
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>user</h2></legend>

      <p><%= Current.user&.email %></p>
      <p class="text-muted">
        change your email or password.<br>
        current password is required.
      </p>

      <%# 2026-05-11 — user direction. The `[edit]` link drops the
          redundant `account` token (bracketed-link convention:
          single-word labels avoid restating context), and the
          `[security]` sibling wires the previously-orphaned
          `/settings/security` dashboard into the user pane so 2FA,
          blocked locations, and the attempts log are one click
          from the main settings page. %>
      <%= render(BracketedLinkComponent.new(label: "edit", href: settings_user_path)) %>
      <span class="nav-sep" aria-hidden="true">·</span>
      <%= render(BracketedLinkComponent.new(label: "security", href: settings_security_path)) %>
    </fieldset>
  </div>

  <%# Phase 26 — 01a. Timezone foundation pane. %>
  <%= render "time_zone_pane" %>
</div>

<%# ============================================================
    integrations
============================================================ %>
<h2>integrations</h2>

<%# integrations row 1 — YouTube | Voyage.ai. 2026-05-11 — YouTube
    moved from a read-only credentials-status card to a Voyage-style
    edit form. Source of truth: AppSetting singleton columns
    (sensitive ones encrypted via Active Record Encryption). The
    `:google_oauth` credentials block stays on-disk as a manual
    revert path but is no longer the runtime read source. %>
<div class="pane-row">
  <%# YouTube — editable credentials. %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="youtube">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>YouTube</h2></legend>

        <%# Voyage pattern: each field renders an input with a
            placeholder. Sensitive fields (api_key, client_secret)
            never echo their value — the placeholder reads
            `key configured (•••••••)` when set, plain "no key
            configured" otherwise. Non-sensitive fields (client_id,
            redirect_uri) DO surface their stored value as the
            placeholder so the operator can verify it at a glance.

            A `clear stored <field>` checkbox renders next to each
            configured field so the operator can wipe one value
            without retyping the others (form-level, no JS confirm
            per CLAUDE.md hard rules). %>
        <% @youtube_credentials[:fields].each do |field, meta| %>
          <% configured = meta[:configured] %>
          <% input_id = "settings_#{field}" %>
          <div style="margin-bottom: 8px;">
            <label for="<%= input_id %>" class="form-label"><%= meta[:label] %></label>
            <% if meta[:sensitive] %>
              <input type="password"
                     name="settings[<%= field %>]"
                     id="<%= input_id %>"
                     value="" autocomplete="off"
                     placeholder="<%= configured ? 'key configured (•••••••)' : 'no key configured' %>"
                     style="max-width: 420px; width: 100%;">
            <% else %>
              <% placeholder =
                if field == "youtube_redirect_uri"
                  meta[:effective_redirect_uri].to_s + (meta[:redirect_uri_default] ? " (default)" : "")
                else
                  configured ? meta[:value].to_s : "not configured"
                end
              %>
              <input type="text"
                     name="settings[<%= field %>]"
                     id="<%= input_id %>"
                     value="" autocomplete="off"
                     placeholder="<%= placeholder %>"
                     style="max-width: 420px; width: 100%;">
            <% end %>
            <% if configured %>
              <label class="md-check" style="margin-top: 4px;">
                <input type="checkbox" name="settings[clear_<%= field %>]" value="yes">
                <span class="md-check-indicator"></span>
                <span class="md-check-label">clear stored <%= meta[:label] %></span>
              </label>
            <% end %>
          </div>
        <% end %>

        <%# Voyage's hint placement: one muted line under the input
            stack explaining the blank-keeps-current convention.
            Hidden on a fully-blank pane so the empty install isn't
            cluttered. %>
        <% if @youtube_credentials[:fields].any? { |_, m| m[:configured] } %>
          <span class="form-hint" style="display: block; margin-bottom: 6px;">
            leave blank to keep current; submit to replace.
          </span>
        <% end %>

        <%# 2026-05-11 — fresh TOTP gate. When 2FA is on, the
            controller rejects updates that don't carry a valid
            `totp_code`. Read-only views are not gated. %>
        <% if Current.user&.totp_enabled? %>
          <div style="margin-bottom: 8px;">
            <label for="settings_youtube_totp_code" class="form-label">2FA code</label>
            <input type="text" name="totp_code" id="settings_youtube_totp_code"
                   value="" autocomplete="one-time-code" inputmode="numeric"
                   pattern="\d{6}" maxlength="6"
                   style="max-width: 420px; width: 100%;">
            <span class="form-hint" style="display: block;">required to authorize the change.</span>
          </div>
        <% end %>

        <button type="submit">[update]</button>

        <p class="text-muted" style="margin-top: 8px; margin-bottom: 0;">
          credentials stored encrypted in the database; never echoed.
        </p>
      </fieldset>
    <% end %>
  </div>

  <%# Voyage.ai — API key + per-target indexing flags. %>
  <div class="pane">
    <%= form_with url: settings_path, method: :patch do |f| %>
      <input type="hidden" name="section" value="voyage">
      <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
        <legend><h2>Voyage.ai</h2></legend>

        <div style="margin-bottom: 6px;">
          <label for="settings_voyage_api_key" class="form-label">API key</label>
          <input type="password" name="settings[voyage_api_key]" id="settings_voyage_api_key"
                 value="" autocomplete="off"
                 placeholder="<%= @voyage_configured ? 'key configured (•••••••)' : 'no key configured' %>"
                 style="max-width: 420px; width: 100%;">
          <% if @voyage_configured %>
            <span class="form-hint" style="display: block;">leave blank to keep current; submit to replace.</span>
          <% else %>
            <span class="form-hint" style="display: block;">paste your Voyage.ai API key.</span>
          <% end %>
        </div>

        <% if @voyage_configured %>
          <div style="margin-bottom: 6px;">
            <label class="md-check">
              <input type="checkbox" name="settings[clear_voyage_api_key]" value="yes">
              <span class="md-check-indicator"></span>
              <span class="md-check-label">clear stored key</span>
            </label>
            <div class="form-hint">disables Voyage.ai indexing if any flag is on.</div>
          </div>
        <% end %>

        <% if AppSetting.voyage_configured? %>
          <div style="margin-bottom: 6px;">
            <label class="form-label">indexes</label>
            <div style="display: flex; align-items: baseline; gap: 12px;">
              <span class="text-muted">project notes</span>
              <% %w[yes no].each do |opt| %>
                <label class="md-radio">
                  <input type="radio" name="settings[voyage_index_project_notes]" value="<%= opt %>" <%= "checked" if (@voyage_indexing_project_notes ? "yes" : "no") == opt %>>
                  <span class="md-radio-indicator"></span>
                  <span class="md-radio-label"><%= opt %></span>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# 2026-05-11 — fresh TOTP gate. When 2FA is on, the
            controller rejects updates that don't carry a valid
            `totp_code`. Read-only views are not gated. %>
        <% if Current.user&.totp_enabled? %>
          <div style="margin-bottom: 8px;">
            <label for="settings_voyage_totp_code" class="form-label">2FA code</label>
            <input type="text" name="totp_code" id="settings_voyage_totp_code"
                   value="" autocomplete="one-time-code" inputmode="numeric"
                   pattern="\d{6}" maxlength="6"
                   style="max-width: 420px; width: 100%;">
            <span class="form-hint" style="display: block;">required to authorize the change.</span>
          </div>
        <% end %>

        <button type="submit">[update]</button>

        <p class="text-muted" style="margin-top: 8px; margin-bottom: 0;">
          credentials stored encrypted in the database; never echoed.
        </p>
      </fieldset>
    <% end %>
  </div>
</div>

<%# integrations row 2 — Discord | Slack. 2026-05-11 — the Slack +
    Discord webhook panes were built in Phase 26 (01b/01c) but were
    never wired into the settings index. The user-locked integrations
    section now surfaces them on row 2 (Discord left, Slack right),
    with OAuth applications + sessions moving to row 3. Each pane is
    a self-contained partial; the ivars (`@discord_webhook`,
    `@slack_webhook`) are populated in `SettingsController#index`. %>
<div class="pane-row">
  <%= render "discord_pane" %>
  <%= render "slack_pane" %>
</div>

<%# integrations row 3 — OAuth applications (+ tokens via hairline) |
    sessions. The OAuth pane keeps the combined OAuth-applications +
    tokens sub-sections fenced by a `<hr class="hairline">` so the
    two related token-issuance surfaces stay near each other in one
    cell. %>
<div class="pane-row">
  <%# Combined OAuth applications + tokens. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>OAuth applications</h2></legend>

      <p>
        <% if @oauth_applications_count.zero? %>
          no OAuth applications
        <% elsif @oauth_applications_count == 1 %>
          1 OAuth application
        <% else %>
          <%= number_with_delimiter(@oauth_applications_count) %> OAuth applications
        <% end %>
      </p>
      <p class="text-muted">
        applications that issue access tokens via authorization code + PKCE.
      </p>

      <%= render(BracketedLinkComponent.new(label: "manage applications", href: settings_oauth_applications_path)) %>
    </fieldset>

    <hr class="hairline">

    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>tokens</h2></legend>

      <p>
        <% if @active_tokens_count.zero? && @revoked_tokens_count.zero? %>
          no active tokens
        <% else %>
          <%
            active_label = @active_tokens_count == 1 ? "1 active token" :
              "#{number_with_delimiter(@active_tokens_count)} active tokens"
            active_label = "no active tokens" if @active_tokens_count.zero?
          %>
          <% if @revoked_tokens_count.positive? %>
            <%= @active_tokens_count.zero? ? "0 active" : "#{number_with_delimiter(@active_tokens_count)} active" %>
            ·
            <%= number_with_delimiter(@revoked_tokens_count) %> revoked
          <% else %>
            <%= active_label %>
          <% end %>
        <% end %>
      </p>
      <p class="text-muted">
        bearer tokens for the JSON API and MCP HTTP transport.
      </p>

      <%= render(BracketedLinkComponent.new(label: "manage tokens", href: settings_tokens_path)) %>
    </fieldset>
  </div>

  <%# sessions — active browser logins. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>sessions</h2></legend>

      <p>
        <% if @active_sessions_count.zero? %>
          no active sessions
        <% elsif @active_sessions_count == 1 %>
          1 active session
        <% else %>
          <%= number_with_delimiter(@active_sessions_count) %> active sessions
        <% end %>
      </p>
      <p class="text-muted">
        one row per active browser login.<br>
        revoke remotely from anywhere.
      </p>

      <%= render(BracketedLinkComponent.new(label: "manage sessions", href: settings_sessions_path)) %>
    </fieldset>
  </div>
</div>

<%# ============================================================
    stack
============================================================ %>
<h2>stack</h2>

<%# 2026-05-11 (later) — user direction reshuffles the stack section:
    `sql` → `db`, Redis demoted from its own pane into a hairline-
    fenced row inside the `db` pane, and per-model + per-state
    breakdown tables surfaced on each side. The storage pane goes
    from a 1-column "pito-assets + notes" stack to a 2-column
    `assets` (left) + `notes` (right) inner layout with detailed
    sub-category tables. Layout:
      stack row 1 — db | search
      stack row 2 — storage | (empty right cell)
    The `db` pane mirrors the `search` pane's internal pattern
    (Meilisearch + hairline + Voyage embeddings → Postgres +
    hairline + Redis).
%>
<div class="pane-row">
  <%# db — Postgres + Redis status with hairline fence. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>db</h2></legend>

      <div style="margin-bottom: 6px;">
        <span>Postgres</span>
        <% if @postgres_status[:connected] %>
          <span style="color: var(--color-success);">▲ connected</span>
        <% else %>
          <span class="text-danger">▽ disconnected</span>
        <% end %>
      </div>

      <%# 2026-05-11 (later 2) — per user direction: the Postgres
          half drops version / database name / total rows / total
          size on disk; the per-model breakdown table is the only
          surface besides the status badge above. Count + size
          columns right-align via `class="num"` (design.md numbers
          convention). %>
      <% if @postgres_status[:connected] && @postgres_table_breakdown.any? %>
        <table class="detail-table" style="margin-bottom: 8px;">
          <thead>
            <tr>
              <th style="font-weight: normal; padding-right: 12px;">model</th>
              <th class="num" style="font-weight: normal; padding-right: 12px;">rows</th>
              <th class="num" style="font-weight: normal;">size</th>
            </tr>
          </thead>
          <tbody>
            <% @postgres_table_breakdown.each do |row| %>
              <tr>
                <td class="text-muted" style="padding-right: 12px;"><%= row[:label] %></td>
                <td class="text-muted num" style="padding-right: 12px;">
                  <%= row[:count] ? number_with_delimiter(row[:count]) : "—" %>
                </td>
                <td class="text-muted num">
                  <%= row[:size_bytes] ? number_to_human_size(row[:size_bytes]) : "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <hr class="hairline">

      <%# Redis sub-section — connectivity badge + Sidekiq
          job-state breakdown. Version / memory / keys /
          persistence lines dropped per 2026-05-11 (later 2)
          user direction. %>
      <div style="margin-bottom: 6px;">
        <span>Redis</span>
        <% if @redis_status[:connected] %>
          <span style="color: var(--color-success);">▲ connected</span>
        <% else %>
          <span class="text-danger">▽ disconnected</span>
        <% end %>
      </div>

      <%# 2026-05-11 (later 2) — per user direction: Redis half
          drops version / memory / keys / persistence; only the
          status badge above remains, alongside the Sidekiq
          breakdown table below.

          The Sidekiq table is a 3-row grouped-header layout:
            row 1 (thead) — `successful` (colspan 3) | `failed` (colspan 2)
            row 2 (thead) — totals under each header
            row 3 (thead) — five state columns: busy | scheduled | enqueued | retry | dead
            row 4 (tbody) — five live counts
          All numeric cells right-align via `class="num"`.

          Empty list = sidekiq/api couldn't load (e.g. Redis just
          went down between the connectivity probe and this read);
          render nothing. %>
      <% if @redis_status[:connected] && @sidekiq_breakdown.any? %>
        <%
          sidekiq_counts = @sidekiq_breakdown.each_with_object({}) do |row, acc|
            acc[row[:label]] = row[:count]
          end
        %>
        <table class="detail-table" style="margin-bottom: 8px;">
          <thead>
            <tr>
              <th class="num" colspan="3" style="font-weight: normal; padding-right: 12px;">successful</th>
              <th class="num" colspan="2" style="font-weight: normal;">failed</th>
            </tr>
            <tr>
              <td class="text-muted num" colspan="3" style="padding-right: 12px;">
                <%= sidekiq_counts["processed"] ? number_with_delimiter(sidekiq_counts["processed"]) : "—" %>
              </td>
              <td class="text-muted num" colspan="2">
                <%= sidekiq_counts["failed"] ? number_with_delimiter(sidekiq_counts["failed"]) : "—" %>
              </td>
            </tr>
            <tr>
              <th class="num" style="font-weight: normal; padding-right: 12px;">busy</th>
              <th class="num" style="font-weight: normal; padding-right: 12px;">scheduled</th>
              <th class="num" style="font-weight: normal; padding-right: 12px;">enqueued</th>
              <th class="num" style="font-weight: normal; padding-right: 12px;">retry</th>
              <th class="num" style="font-weight: normal;">dead</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <% %w[busy scheduled enqueued retry].each do |state| %>
                <td class="text-muted num" style="padding-right: 12px;">
                  <%= sidekiq_counts[state] ? number_with_delimiter(sidekiq_counts[state]) : "—" %>
                </td>
              <% end %>
              <td class="text-muted num">
                <%= sidekiq_counts["dead"] ? number_with_delimiter(sidekiq_counts["dead"]) : "—" %>
              </td>
            </tr>
          </tbody>
        </table>
      <% end %>
    </fieldset>
  </div>

  <%# search — Meilisearch + Voyage embeddings status. %>
  <div class="pane">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>search</h2></legend>

      <div style="margin-bottom: 6px;">
        <span>Meilisearch</span>
        <% if @search_healthy %>
          <span style="color: var(--color-success);">▲ connected</span>
        <% else %>
          <span class="text-danger">▽ disconnected</span>
        <% end %>
      </div>

      <%# 2026-05-11 (later 2) — per user direction: drop the
          `indexed documents` flat list and the `total index size`
          aggregate. The Meilisearch surface is now a 3-column
          table (index | documents | size). Source: engine's
          `per_index_stats`. Empty list = engine doesn't expose
          per-index stats / probe failed; render nothing besides
          the status badge above. %>
      <% if @search_per_index_stats.any? %>
        <table class="detail-table" style="margin-bottom: 8px;">
          <thead>
            <tr>
              <th style="font-weight: normal; padding-right: 12px;">index</th>
              <th class="num" style="font-weight: normal; padding-right: 12px;">documents</th>
              <th class="num" style="font-weight: normal;">size</th>
            </tr>
          </thead>
          <tbody>
            <% @search_per_index_stats.each do |row| %>
              <tr>
                <td class="text-muted" style="padding-right: 12px;"><%= row[:label] %></td>
                <td class="text-muted num" style="padding-right: 12px;">
                  <%= number_with_delimiter(row[:documents].to_i) %>
                </td>
                <td class="text-muted num">
                  <%= row[:size_bytes] ? number_to_human_size(row[:size_bytes]) : "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <hr class="hairline">

      <%# Voyage embeddings status — read out of AppSetting so the
          search pane shows the full hybrid-search picture (keyword
          via Meilisearch + semantic via Voyage). The API key
          itself stays in the Voyage.ai pane (integrations); this
          row is pure status. %>
      <div style="margin-bottom: 6px;">
        <span>Voyage embeddings</span>
        <% if @voyage_configured %>
          <span style="color: var(--color-success);">▲ configured</span>
        <% else %>
          <span class="text-danger">▽ not configured</span>
        <% end %>
        <% if @voyage_configured %>
          <br>
          <span class="text-muted">project notes: <%= @voyage_indexing_project_notes ? "indexing" : "off" %></span>
        <% end %>
      </div>

      <%= render(BracketedLinkComponent.new(
        label: "reindex",
        href: "#",
        data: {
          controller: "modal-trigger",
          action: "click->modal-trigger#open",
          modal_trigger_target_id_value: "reindex_meilisearch_modal"
        }
      )) %>
      <%= render(ConfirmModalComponent.new(
        id: "reindex_meilisearch_modal",
        title: "reindex Meilisearch?",
        body: "this re-indexes all configured targets. it can take a while on large corpora and adds load to the search service.",
        confirm_path: settings_reindex_path,
        confirm_method: :post,
        confirm_label: "reindex",
        cancel_label: "cancel",
        destructive: false
      )) %>
    </fieldset>
  </div>
</div>

<%# stack row 2 — storage | (empty right cell). The storage pane
    is now a 2-column inner layout: `assets` (left) + `notes`
    (right) separated by a vertical hairline gutter. Both columns
    surface availability + size + file count + a per-subcategory
    breakdown table. User direction (2026-05-11): rename the
    `pito-assets` heading to `assets` (display label only; the
    on-disk volume name + env var stay `pito-assets`). Notes still
    cover the `Note` ActiveRecord population plus the Mobile MCP
    drop-zone under `docs/notes/`. The extension hook for future
    note populations (video notes, channel notes) is
    `NOTES_NAMESPACE_SOURCES` in the controller; new namespaces
    slot into the same `@notes_breakdown` rows without view
    changes. %>
<div class="pane-row">
  <%# storage — 2-column inner layout (assets | notes). The pane
      uses `.pane--wide` so the inner grid has enough room for both
      detail tables side-by-side without the columns squashing. %>
  <div class="pane pane--wide">
    <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
      <legend><h2>storage</h2></legend>

      <%# Two equal-width columns with a vertical hairline gutter.
          `align-items: stretch` lets the hairline span the taller
          column. %>
      <div style="display: grid; grid-template-columns: 1fr 1px 1fr; gap: 12px; align-items: stretch;">
        <%# assets column (renamed from pito-assets per user direction).
            2026-05-11 — per user direction the size + files summary
            lines under the title are dropped; only the title + writable
            badge remain. The per-subcategory table below carries the
            file count + size per category. %>
        <div>
          <div style="margin-bottom: 6px;">
            <span>assets</span>
            <% if @storage_status[:present] %>
              <% if @storage_status[:writable] %>
                <span style="color: var(--color-success);">▲ writable</span>
              <% else %>
                <span class="text-danger">▽ read-only</span>
              <% end %>
            <% else %>
              <span class="text-muted">▽ not present</span>
            <% end %>
          </div>

          <%# Per-subcategory breakdown — fixed allowlist.
              Rows: cover arts (composites/), thumbnails
              (footage_thumbs/), banners (banners/), other
              (everything else, including Active Storage shard
              directories). All four rows always render so the
              operator sees the asset taxonomy even on a
              greenfield install. Order matches the allowlist
              declared in the controller. %>
          <% if @assets_breakdown.any? %>
            <table class="detail-table" style="margin-bottom: 8px;">
              <thead>
                <tr>
                  <th style="font-weight: normal; padding-right: 12px;">category</th>
                  <th class="num" style="font-weight: normal; padding-right: 12px;">files</th>
                  <th class="num" style="font-weight: normal;">size</th>
                </tr>
              </thead>
              <tbody>
                <% @assets_breakdown.each do |row| %>
                  <tr>
                    <td class="text-muted" style="padding-right: 12px;"><%= row[:label] %></td>
                    <td class="text-muted num" style="padding-right: 12px;">
                      <%= row[:file_count] ? number_with_delimiter(row[:file_count]) : "—" %>
                    </td>
                    <td class="text-muted num">
                      <%= row[:size_bytes] ? number_to_human_size(row[:size_bytes]) : "—" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% end %>
        </div>

        <%# Vertical hairline gutter — matches `hr.hairline`'s
            single-pixel border-color contract, just turned 90°.
            Reaches the full height of the taller column thanks
            to `align-items: stretch` on the grid container. %>
        <div style="background: var(--color-border); width: 1px;"></div>

        <%# notes column — Note rows. The mobile MCP `save_note`
            drop-zone is a dev-only artifact (doesn't ship in production
            builds) and was dropped from this surface per user
            direction 2026-05-11. The size + files summary lines under
            the title were also dropped — only the title + writable
            badge remain; the per-namespace table below carries count
            + size per namespace. %>
        <div>
          <div style="margin-bottom: 6px;">
            <span>notes</span>
            <% if @notes_volume_status[:present] %>
              <% if @notes_volume_status[:writable] %>
                <span style="color: var(--color-success);">▲ writable</span>
              <% else %>
                <span class="text-danger">▽ read-only</span>
              <% end %>
            <% else %>
              <span class="text-muted">▽ not present</span>
            <% end %>
          </div>

          <%# Per-namespace breakdown. `count` column shows the
              row count for namespaces backed by a DB table (project
              notes today); namespaces without a backing table
              (Mobile drop-zone) render `—` for the count. Future
              video notes / channel notes slot into the same table
              via `NOTES_NAMESPACE_SOURCES` in the controller. %>
          <% if @notes_breakdown.any? %>
            <table class="detail-table" style="margin-bottom: 8px;">
              <thead>
                <tr>
                  <th style="font-weight: normal; padding-right: 12px;">namespace</th>
                  <th class="num" style="font-weight: normal; padding-right: 12px;">count</th>
                  <th class="num" style="font-weight: normal;">size</th>
                </tr>
              </thead>
              <tbody>
                <% @notes_breakdown.each do |row| %>
                  <tr>
                    <td class="text-muted" style="padding-right: 12px;"><%= row[:label] %></td>
                    <td class="text-muted num" style="padding-right: 12px;">
                      <%= row[:count] ? number_with_delimiter(row[:count]) : "—" %>
                    </td>
                    <td class="text-muted num">
                      <%= row[:size_bytes] ? number_to_human_size(row[:size_bytes]) : "—" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% end %>
        </div>
      </div>
    </fieldset>
  </div>

  <%# Right cell intentionally absent — the user-locked stack
      layout drops Redis as a standalone pane; Redis now lives
      inside the `db` pane on the row above. The `.pane-row` flex
      container with a single `.pane` child renders the storage
      pane at its natural width without a placeholder sibling. %>
</div>
