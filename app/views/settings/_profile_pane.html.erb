<%# Phase 29 (settings refactor) — profile pane (row 1 left).

    Inline username + password update form. PATCHes the existing
    `/settings/user` endpoint owned by `Settings::UserController#update`
    — current_password gate and 2FA gate stay in place.

    The form re-uses the `totp-modal` Stimulus controller so the
    layout-level TOTP verification modal opens on submit when 2FA is
    on (same pattern the standalone /settings/user page already
    uses). %>
<div class="pane">
  <fieldset style="padding: 8px; margin-bottom: 8px; border: none;">
    <legend><h2><%= t("settings.profile.heading") %></h2></legend>

    <%= form_with url: settings_user_path, method: :patch, scope: :user, local: true,
                  data: {
                    controller: "totp-modal",
                    action: "submit->totp-modal#maybeIntercept",
                    totp_modal_required_value: Current.user&.totp_enabled? ? "yes" : "no",
                    turbo: false
                  } do |f| %>
      <% if @user&.errors&.any? %>
        <div class="flash-error" style="margin-bottom: 8px;">
          <% @user.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <div style="margin-bottom: 8px;">
        <label for="user_username" class="form-label"><%= t("settings.profile.username_label") %></label>
        <input type="text" name="user[username]" id="user_username"
               value="<%= @user&.username %>" required autocomplete="username"
               style="max-width: 360px; width: 100%;">
      </div>

      <hr class="hairline">

      <div style="margin-bottom: 8px;">
        <label for="user_current_password" class="form-label"><%= t("settings.profile.current_password_label") %></label>
        <input type="password" name="user[current_password]" id="user_current_password"
               value="" required autocomplete="current-password"
               style="max-width: 360px; width: 100%;">
        <span class="form-hint" style="display: block;"><%= t("settings.profile.current_password_hint") %></span>
      </div>

      <div style="margin-bottom: 8px;">
        <label for="user_password" class="form-label"><%= t("settings.profile.new_password_label") %></label>
        <input type="password" name="user[password]" id="user_password"
               value="" autocomplete="new-password"
               style="max-width: 360px; width: 100%;">
        <span class="form-hint" style="display: block;"><%= t("settings.profile.new_password_hint") %></span>
      </div>

      <div style="margin-bottom: 8px;">
        <label for="user_password_confirmation" class="form-label"><%= t("settings.profile.confirm_password_label") %></label>
        <input type="password" name="user[password_confirmation]" id="user_password_confirmation"
               value="" autocomplete="new-password"
               style="max-width: 360px; width: 100%;">
      </div>

      <button type="submit">[<%= t("common.actions.update") %>]</button>
    <% end %>
  </fieldset>
</div>
