<% content_for(:title, "revoke session") %>
<% breadcrumb(["settings", settings_path], ["sessions", settings_sessions_path], "revoke") %>

<div style="margin-bottom: 8px;">
  <h1>revoke session</h1>
  <p class="text-muted" style="margin-top: 2px;">
    this sets <code>revoked_at</code> on the row. the browser holding this
    session is signed out on its next request. the row stays in the database
    for the audit trail.
  </p>
</div>

<%# Phase 12 UX sweep — pane-wrapped detail-table mirrors the canonical
    label/value layout from `channels/_pane.html.erb` and
    `videos/_pane.html.erb`. The `.pane.pane--standalone` modifier gives
    this full-width single-column surface the pane look (elevated bg)
    without the workspace-grid fixed-width / zebra rules. Label cells
    carry `padding-right: 12px;` so labels don't kiss the values. %>
<div class="pane pane--standalone" style="margin-bottom: 12px;">
  <table class="detail-table">
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">user-agent</td>
      <td><code><%= @session.user_agent.presence || "—" %></code></td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">ip</td>
      <td><%= @session.ip || "—" %></td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">last activity</td>
      <td>
        <% if @session.last_activity_at %>
          <%= @session.last_activity_at.strftime("%Y-%m-%d %H:%M") %>
        <% else %>
          never
        <% end %>
      </td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">remember</td>
      <td><%= @session.remember? ? "yes" : "no" %></td>
    </tr>
    <% if @session.current? %>
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">note</td>
        <td><strong>this is your current session.</strong> revoking it signs you out.</td>
      </tr>
    <% end %>
  </table>
</div>

<%= render "shared/action_screen",
  submit_label: "[revoke]",
  cancel_path: settings_sessions_path,
  form_url: settings_session_path(@session),
  form_method: :delete,
  destructive: true %>
