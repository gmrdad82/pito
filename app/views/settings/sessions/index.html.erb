<% content_for(:title, "sessions") %>
<% breadcrumb(["settings", settings_path], "sessions") %>

<div style="margin-bottom: 8px;">
  <h1>sessions</h1>
  <p class="text-muted" style="margin-top: 2px;">
    every active login is a row here.<br>
    revoking a row clears its server-side state; the next request from that
    browser bounces to <code>/login</code>.<br>
    rows stay in the database after revoke for the audit trail.
  </p>
</div>

<% if @sessions.any? %>
  <table>
    <thead>
      <tr>
        <th>user-agent</th>
        <th>ip</th>
        <th class="num">last activity</th>
        <th>remember</th>
        <th class="num">status</th>
        <th class="col-action"></th>
      </tr>
    </thead>
    <tbody>
      <% @sessions.each do |s| %>
        <tr<%= s.revoked? ? ' class="text-muted" style="opacity: 0.6;"'.html_safe : "".html_safe %>>
          <td style="max-width: 360px; white-space: normal;">
            <code><%= s.user_agent.presence || "—" %></code>
            <% if s.current? %>
              <span class="text-muted">(this session)</span>
            <% end %>
          </td>
          <td><%= s.ip || "—" %></td>
          <td class="num">
            <% if s.last_activity_at %>
              <%= time_ago_in_words(s.last_activity_at) %> ago
            <% else %>
              never
            <% end %>
          </td>
          <td><%= s.remember? ? "yes" : "no" %></td>
          <td class="num">
            <% if s.revoked? %>
              revoked <%= s.revoked_at.strftime("%Y-%m-%d") %>
            <% else %>
              active
            <% end %>
          </td>
          <td class="col-action">
            <% unless s.revoked? %>
              <%= render(BracketedLinkComponent.new(label: "revoke", href: revoke_settings_session_path(s), destructive: true)) %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">no sessions yet. log in to mint one.</p>
<% end %>
