<% content_for(:title, "disable 2FA") %>
<% breadcrumb(["settings", settings_path], ["security", settings_security_path], ["2FA", settings_security_totp_path], "disable") %>

<div style="margin-bottom: 8px;">
  <h1>disable 2FA</h1>
  <p class="text-muted" style="margin-top: 2px;">
    this removes the seed and every backup code.<br>
    you will need to re-enroll to turn 2FA back on.<br>
    enter your password and a fresh 6-digit code to confirm.
  </p>
</div>

<%= form_with url: settings_security_totp_disable_path, method: :post, data: { turbo: false } do %>
  <div style="margin-bottom: 12px;">
    <%= label_tag :password, "password", class: "form-label" %>
    <%= password_field_tag :password, nil, autocomplete: "current-password", autofocus: true %>
  </div>

  <div style="margin-bottom: 12px;">
    <%= label_tag :code, "6-digit code from your authenticator app", class: "form-label" %>
    <%= text_field_tag :code, nil, autocomplete: "one-time-code", inputmode: "numeric", pattern: "\\d{6}", maxlength: 6 %>
  </div>

  <%= hidden_field_tag :confirm, "yes" %>

  <div class="action-screen-footer">
    <div class="dot-list">
      <button type="submit" class="btn-danger">[<span class="bl">disable 2FA</span>]</button>
      <%= render BracketedLinkComponent.new(label: "cancel", href: settings_security_totp_path) %>
    </div>
  </div>
<% end %>
