<% content_for(:title, t("settings.security.totp.title")) %>
<%
  # Phase 32 follow-up (2026-05-16). 2FA / TOTP cleanup.
  #
  # This is the ONLY 2FA surface on the web side now — the "manage"
  # page, the disable flow, and the backup-codes management page are
  # gone (operator-only via rake tasks: `pito:user:reset_totp` and
  # `pito:user:regenerate_backup_codes`).
  #
  # The view is mounted as a focused enrollment dialog — no
  # breadcrumb, no nav chrome, no "cancel" button. The only exits are
  # complete enrollment or log out via the global top-right [logout]
  # link (allowlisted by the mandatory-2FA gate).
  #
  # Non-resumable: every fresh GET regenerates the seed + the 10
  # backup codes (see TotpsController#new). A wrong-code 422 re-renders
  # the SAME draft so the user can retry with the QR they already
  # scanned; the cache draft is only dropped on successful confirm.
  #
  # Layout — single `.pane-row` with two `.pane` cells side-by-side
  # inside a widened mandatory-2FA modal (960px max-width, see
  # `application.css` non-dismissible rules):
  #
  #   Left  `.pane` : scan heading + QR + seed text + hairline +
  #                   enter-code heading + 6-digit input + submit
  #   Right `.pane` : backup codes heading + 10 codes + "save them"
%>
<% content_for(:hide_chrome, true) %>

<%# Wrap in `settings_modal_frame` so a click from the auto-open
    modal on `/settings` swaps this view into the dialog. Direct hits
    (JS-off, deep links) still render the full page through the
    layout. %>
<%
  # 2026-05-16 polish — the outer body wrapper used a vertical margin
  # (`margin: 24px auto`) to provide breathing room above/below the
  # body when this view renders standalone inside the layout's `<main>`
  # (JS-off fallback / deep link). Inside the mandatory-2FA modal the
  # dialog's own padding + the empty-title header row already provide
  # the top inset, so the extra 24px stacks on top and produces a
  # visible gap above the "two-factor setup required" <h1> (the bottom
  # 24px is masked by the dialog's scroll container, so only the top
  # gap reads). Drop the vertical margin when rendered into the modal
  # turbo-frame; preserve `0 auto` for horizontal centering in the
  # standalone path. The 928px max-width still bounds the body in
  # both contexts.
  body_wrapper_margin = turbo_frame_request? ? "0 auto" : "24px auto"
%>
<%= turbo_frame_tag "settings_modal_frame" do %>
  <div style="max-width: 928px; margin: <%= body_wrapper_margin %>; overflow-wrap: break-word;">
    <%# Beta 4 F3-DEEP-A — TUI revamp.
        Lowercase H1 (rendered at 13px bold via the single-font-size
        heading rule), one-sentence-per-line lead paragraph, framed
        panels for the scan + backup-codes blocks. %>
    <div style="margin-bottom: 12px;">
      <h1>enroll two-factor authentication</h1>
      <p class="text-danger" style="margin-top: 4px;">
        <%= t("settings.security.totp.requires_line1") %><br>
        <%= t("settings.security.totp.requires_line2") %>
      </p>
      <p class="text-muted" style="margin-top: 6px;">
        scan the QR with Google Authenticator, 1Password, Authy, or any other authenticator app.
      </p>
    </div>

    <%# Single row — scan + enter-code (left) and backup codes (right). %>
    <div class="pane-row">
      <div class="pane">
        <%= render Pito::TotpEnrollmentPanelComponent.new(totp_uri: @totp_uri, seed: @seed) %>
      </div>

      <div class="pane">
        <%= render Tui::FramedPanelComponent.new(title: "backup codes") do %>
          <pre style="font-family: inherit; font-size: 13px; padding: 6px 8px; margin: 4px 0; white-space: pre; background: var(--color-bg-alt); border: 1px solid var(--color-border); font-variant-numeric: tabular-nums;"><% @codes.each do |code| %><%= code %>
<% end %></pre>
          <p class="text-muted" style="margin: 8px 0 0;">
            <%= t("settings.security.totp.backup_codes_hint_line1") %><br>
            <%= t("settings.security.totp.backup_codes_hint_line2_html").html_safe %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
