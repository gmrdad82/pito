<% content_for(:title, t("settings.security.title")) %>
<% breadcrumb([t("settings.breadcrumb_root"), settings_path], t("settings.security.breadcrumb")) %>

<div style="margin-bottom: 8px;">
  <h1><%= t("settings.security.heading") %></h1>
</div>

<div class="pane pane--standalone" style="margin-bottom: 12px;">
  <h2 style="margin-top: 0;"><%= t("settings.security.twofa_label") %></h2>
  <%# Phase 32 follow-up (2026-05-16) — 2FA / TOTP cleanup.
      The web-side manage surface (disable + backup-code rotation) is
      gone; both moved to operator-only rake tasks
      (`pito:user:reset_totp`, `pito:user:regenerate_backup_codes`).
      The status line stays here as read-only context. %>
  <p class="text-muted" style="margin-top: 2px;">
    <%= t("settings.security.status_prefix") %>
    <% if @twofa_enabled %>
      <strong><%= t("settings.security.status_on") %></strong>
    <% else %>
      <strong><%= t("settings.security.status_off") %></strong>
    <% end %>
  </p>
</div>
