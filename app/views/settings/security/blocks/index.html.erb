<% content_for(:title, "blocks") %>
<% breadcrumb(["settings", settings_path], ["security", settings_security_path], "blocks") %>

<div style="margin-bottom: 8px;">
  <h1>auto-block list</h1>
  <p class="text-muted" style="margin-top: 2px;">
    one row per blocked <code>(fingerprint, ip prefix)</code> pair.<br>
    blocks persist forever — manual unblock or
    <%= render BracketedLinkComponent.new(label: "purge", href: settings_security_blocks_purge_path) %>
    is the only way out.
  </p>
</div>

<%# Filters — plain GET form. Yes/no `active` is the LD-15 boundary. %>
<div class="pane pane--standalone" style="margin-bottom: 12px;">
  <%= form_with url: settings_security_blocks_path, method: :get,
                scope: nil, data: { turbo: false } do %>
    <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: end;">
      <div>
        <label for="source_surface" class="form-label">source</label>
        <select name="source_surface" id="source_surface">
          <option value="">(any)</option>
          <% %w[web tui mcp].each do |s| %>
            <option value="<%= s %>" <%= "selected" if @applied_filters[:source_surface] == s %>><%= s %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label for="active" class="form-label">active</label>
        <select name="active" id="active">
          <option value="">(both)</option>
          <option value="yes" <%= "selected" if @applied_filters[:active] == "yes" %>>yes</option>
          <option value="no"  <%= "selected" if @applied_filters[:active] == "no" %>>no (unblocked)</option>
        </select>
      </div>
      <div>
        <label for="since" class="form-label">since (iso8601)</label>
        <input type="text" name="since" id="since"
               value="<%= @applied_filters[:since] %>"
               placeholder="2026-05-01T00:00:00Z">
      </div>
      <div>
        <label for="until_ts" class="form-label">until (iso8601)</label>
        <input type="text" name="until_ts" id="until_ts"
               value="<%= @applied_filters[:until_ts] %>"
               placeholder="2026-05-31T00:00:00Z">
      </div>
      <div>
        <label for="fingerprint" class="form-label">fingerprint</label>
        <input type="text" name="fingerprint" id="fingerprint"
               value="<%= @applied_filters[:fingerprint] %>"
               style="width: 280px;">
      </div>
      <div>
        <label for="ip_prefix" class="form-label">ip prefix</label>
        <input type="text" name="ip_prefix" id="ip_prefix"
               value="<%= @applied_filters[:ip_prefix] %>"
               placeholder="1.2.3.0/24">
      </div>
      <div>
        <button type="submit">[filter]</button>
      </div>
    </div>
  <% end %>
</div>

<% if @rows.any? %>
  <table>
    <thead>
      <tr>
        <th class="num">blocked</th>
        <th>source</th>
        <th>fingerprint</th>
        <th>ip prefix</th>
        <th class="num">attempts</th>
        <th class="num">last attempt</th>
        <th>state</th>
        <th class="col-action"></th>
      </tr>
    </thead>
    <tbody>
      <% @rows.each do |row| %>
        <%= render BlockedLocationRowComponent.new(row: row) %>
      <% end %>
    </tbody>
  </table>

  <% pages = (@total.to_f / @per_page).ceil %>
  <% if pages > 1 %>
    <p style="margin-top: 8px;">
      page <strong><%= @page %></strong> of <strong><%= pages %></strong>
      (<%= @total %> rows)
      <% if @page > 1 %>
        &nbsp;
        <%= render BracketedLinkComponent.new(label: "prev", href: settings_security_blocks_path(request.query_parameters.merge(page: @page - 1))) %>
      <% end %>
      <% if @page < pages %>
        &nbsp;
        <%= render BracketedLinkComponent.new(label: "next", href: settings_security_blocks_path(request.query_parameters.merge(page: @page + 1))) %>
      <% end %>
    </p>
  <% end %>
<% else %>
  <p class="text-muted">no blocks match those filters.</p>
<% end %>

<p style="margin-top: 12px;">
  <%= render BracketedLinkComponent.new(label: "purge by filter", href: settings_security_blocks_purge_path(request.query_parameters)) %>
</p>
