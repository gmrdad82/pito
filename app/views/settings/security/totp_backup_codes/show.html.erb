<% content_for(:title, "backup codes") %>
<% breadcrumb(["settings", settings_path], ["security", settings_security_path], ["2FA", settings_security_totp_path], "backup codes") %>

<div style="margin-bottom: 8px;">
  <h1>backup codes</h1>
  <p class="text-muted" style="margin-top: 2px;">
    use these when you can't reach your authenticator app.<br>
    each code works exactly once.
  </p>
</div>

<div class="pane pane--standalone" style="margin-bottom: 12px;">
  <h2 style="margin-top: 0;">status</h2>
  <p class="text-muted" style="margin-top: 2px;">
    unused: <strong><%= @unused_count %></strong>,
    used: <strong><%= @used_count %></strong>.
  </p>

  <% if @last_used_at %>
    <p class="text-muted" style="margin-top: 2px;">
      last used: <%= l(@last_used_at, format: :long) %>.
    </p>
  <% end %>

  <p class="text-muted" style="margin-top: 8px;">
    plaintext codes are never re-displayed. regenerate to get a fresh set (the old set is invalidated).
  </p>

  <div class="dot-list" style="margin-top: 8px;">
    <%= render BracketedLinkComponent.new(label: "regenerate", href: settings_security_new_totp_backup_codes_path, destructive: true) %>
    <%= render BracketedLinkComponent.new(label: "back", href: settings_security_totp_path) %>
  </div>
</div>

<% if @one_shot_codes.present? %>
  <div class="pane pane--standalone" style="margin-bottom: 12px;">
    <h2 style="margin-top: 0;">new codes</h2>
    <p class="text-muted" style="margin-top: 2px;">
      <strong>store these now</strong> — they will not be shown again.
    </p>
    <pre style="font-size: 14px; padding: 8px;">
<% @one_shot_codes.each do |code| %><%= code %>
<% end %></pre>
  </div>
<% end %>
