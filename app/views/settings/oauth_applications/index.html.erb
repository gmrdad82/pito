<% content_for(:title, "OAuth applications") %>
<% breadcrumb(["settings", settings_path], "OAuth applications") %>

<div style="margin-bottom: 8px;">
  <h1>OAuth applications</h1>
  <p class="text-muted" style="margin-top: 2px;">
    third-party clients (e.g. the pito CLI) authenticate via authorization
    code + PKCE.<br>
    <code>client_id</code> and <code>client_secret</code> are shown exactly
    once at creation.<br>
    revoking an application also revokes every access and refresh token it
    has issued.
  </p>
</div>

<div class="dot-list" style="margin-bottom: 12px;">
  <%= render(BracketedLinkComponent.new(label: "new", href: new_settings_oauth_application_path)) %>
</div>

<% if @applications.any? %>
  <table>
    <thead>
      <tr>
        <th>name</th>
        <th>client_id</th>
        <th>redirect_uri</th>
        <th>scopes</th>
        <th>confidential</th>
        <th class="num">created</th>
        <th class="col-action"></th>
      </tr>
    </thead>
    <tbody>
      <% @applications.each do |app| %>
        <tr>
          <td><%= link_to app.name, settings_oauth_application_path(app) %></td>
          <%# Phase 7.5 — middle-truncate long values so the table fits
              within typical laptop viewports. The 43-char Doorkeeper
              `uid` is the worst offender; redirect URIs are next. Both
              cells expose the full value via `title=` for hover-reveal;
              the show page renders the untruncated values. Same shape
              as the channel-picker URL column — all delegate to
              `ApplicationHelper#middle_truncate`. Tighter params
              (head/tail 8 / 12) trigger truncation more reliably for
              typical OAuth callback URLs and Doorkeeper-issued ids. %>
          <td title="<%= app.uid %>"><code><%= middle_truncate(app.uid, head: 8, tail: 8) %></code></td>
          <td title="<%= app.redirect_uri %>">
            <% app.redirect_uri.to_s.split("\n").each do |uri| %>
              <code><%= middle_truncate(uri, head: 12, tail: 12) %></code><br>
            <% end %>
          </td>
          <td style="max-width: 240px; white-space: normal;"><code><%= app.scopes %></code></td>
          <td><%= app.confidential? ? "yes" : "no" %></td>
          <td class="num"><%= app.created_at.strftime("%Y-%m-%d") %></td>
          <td class="col-action">
            <%= render(BracketedLinkComponent.new(label: "revoke", href: revoke_settings_oauth_application_path(app), destructive: true)) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">no applications yet. click <code>[ new ]</code> to register one.</p>
<% end %>
