<% content_for(:title, "revoke OAuth application") %>
<% breadcrumb(["settings", settings_path], ["OAuth applications", settings_oauth_applications_path], "revoke") %>

<div style="margin-bottom: 8px;">
  <h1>revoke <%= @application.name %></h1>
  <p class="text-muted" style="margin-top: 2px;">
    this destroys the application row and revokes every active access and
    refresh token issued through it. clients will need to re-register and
    re-consent to issue new tokens.
  </p>
</div>

<%# Phase 7.5 — metadata block uses the pane look
    (`.pane.pane--standalone`) so this full-width detail surface reads
    visually consistent with the show + create pages and the rest of
    the app's data-display panes. %>
<div class="pane pane--standalone">
  <%# Label cells carry `padding-right: 12px;` to match the post-create
      and show pages so labels don't kiss the values. %>
  <table class="detail-table">
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">name</td>
      <td><strong><%= @application.name %></strong></td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">client_id</td>
      <td><code><%= @application.uid %></code></td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">scopes</td>
      <td><code><%= @application.scopes %></code></td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">created</td>
      <td><%= @application.created_at.strftime("%Y-%m-%d %H:%M") %></td>
    </tr>
  </table>
</div>

<%= render "shared/action_screen",
  submit_label: "[revoke]",
  cancel_path: settings_oauth_applications_path,
  form_url: settings_oauth_application_path(@application),
  form_method: :delete,
  destructive: true %>
