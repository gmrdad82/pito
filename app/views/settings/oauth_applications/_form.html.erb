<%# Form partial for /settings/oauth_applications/new.
    Phase 10 — the catalog is flat (`dev` + `app`); the per-namespace
    fieldset grouping from the 9-scope era is gone. %>
<%
  selected_scopes = @application.scopes.to_s.split(/\s+/).reject(&:blank?)
%>
<%= form_with url: settings_oauth_applications_path, method: :post, scope: :oauth_application, data: { turbo: false } do |f| %>
  <% if @application.errors.any? %>
    <div class="flash-error" style="margin-bottom: 8px;">
      <% @application.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div style="margin-bottom: 12px;">
    <label for="oauth_application_name" class="form-label">name</label>
    <input type="text" name="oauth_application[name]" id="oauth_application_name"
           value="<%= @application.name %>" required autocomplete="off"
           style="max-width: 420px; width: 100%;">
    <span class="form-hint" style="display: block;">a human-readable label (e.g. <code>pito-cli</code>, <code>mobile-app</code>).</span>
  </div>

  <div style="margin-bottom: 12px;">
    <label for="oauth_application_redirect_uri" class="form-label">redirect URIs</label>
    <textarea name="oauth_application[redirect_uri]" id="oauth_application_redirect_uri"
              rows="3" required autocomplete="off"
              style="max-width: 420px; width: 100%; font-family: inherit; font-size: 13px;"
    ><%= @application.redirect_uri %></textarea>
    <span class="form-hint" style="display: block;">
      one URI per line. examples:<br>
      &nbsp;&nbsp;<code>https://claude.ai/api/mcp/auth_callback</code> &mdash; claude.ai web connector<br>
      &nbsp;&nbsp;<code>http://127.0.0.1:8000/oauth/callback</code> &mdash; native cli / mobile via loopback<br>
      PKCE is enforced for non-confidential clients.
    </span>
  </div>

  <div style="margin-bottom: 12px;">
    <label class="form-label">scopes</label>
    <% Scopes::DESCRIPTIONS.each do |scope, desc| %>
      <div style="margin-left: 4px; padding: 2px 0;">
        <label class="md-check">
          <input type="checkbox" name="oauth_application[scopes][]" value="<%= scope %>" <%= "checked" if selected_scopes.include?(scope) %>>
          <span class="md-check-indicator"></span>
          <span class="md-check-label"><code><%= scope %></code> &mdash; <%= desc %></span>
        </label>
      </div>
    <% end %>
  </div>

  <div style="margin-bottom: 12px;">
    <label class="form-label">confidential</label>
    <div style="display: flex; gap: 12px;">
      <% %w[no yes].each do |opt| %>
        <label class="md-radio">
          <input type="radio" name="oauth_application[confidential]" value="<%= opt %>" <%= "checked" if (@application.confidential? ? "yes" : "no") == opt %>>
          <span class="md-radio-indicator"></span>
          <span class="md-radio-label"><%= opt %></span>
        </label>
      <% end %>
    </div>
    <span class="form-hint" style="display: block;">public clients (cli, mobile) pick <code>no</code>; PKCE is enforced. confidential clients (server-to-server) skip PKCE.</span>
  </div>

  <div class="dot-list">
    <button type="submit">[create]</button>
    <%= render(BracketedLinkComponent.new(label: "cancel", href: settings_oauth_applications_path)) %>
  </div>
<% end %>
