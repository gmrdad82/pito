<% content_for(:title, "application created") %>
<% breadcrumb(["settings", settings_path], ["OAuth applications", settings_oauth_applications_path], "created") %>

<div style="margin-bottom: 8px;">
  <h1>application created</h1>
  <p class="text-muted" style="margin-top: 2px;">
    save these credentials now. <code>client_secret</code> cannot be shown again
    &mdash; if you lose it, revoke this application and register a new one.
  </p>
</div>

<%# Phase 7.5 — credentials block uses the pane look (elevated
    `--color-pane-bg-a` background) via `.pane.pane--standalone` so this
    full-width single-column "save these credentials now" surface reads
    visually consistent with every other data-display pane in the app
    (workspace columns, settings index, OAuth show/revoke). The
    `--standalone` modifier drops the fixed 452px width + zebra rule so
    the pane fills its parent. %>
<div class="pane pane--standalone">
  <%# Label cells carry `padding-right: 12px;` so labels don't kiss the
      values — the same shape used by `channels/_pane.html.erb` and other
      detail-table surfaces. The base `.detail-table td` rule has
      `padding: 1px 0;` (no horizontal padding) which is fine for narrow
      key/value columns but leaves long values like `client_secret` and
      multi-line redirect URIs visually flush with their label. %>
  <table class="detail-table">
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">name</td>
      <td><strong><%= @application.name %></strong></td>
    </tr>
    <%# Phase 7.5 — `[copy]` affordance on the credentials. Same Stimulus
        `clipboard-copy` controller used by the project footage-import
        snippet (`projects/_footage_pane.html.erb`) and the dashboard
        empty-state (`dashboard/index.html.erb`). The table cell wraps
        the `<code>` element so the copy link rides next to the value
        without disturbing the two-column detail-table layout. %>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">client_id</td>
      <td>
        <span data-controller="clipboard-copy" class="code-block">
          <code data-clipboard-copy-target="source"><%= @plaintext_uid %></code>
          <a href="#" data-action="click->clipboard-copy#copy" class="bracketed">[<span class="bl">copy</span>]</a>
        </span>
      </td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">client_secret</td>
      <td>
        <span data-controller="clipboard-copy" class="code-block">
          <code data-clipboard-copy-target="source"><%= @plaintext_secret %></code>
          <a href="#" data-action="click->clipboard-copy#copy" class="bracketed">[<span class="bl">copy</span>]</a>
        </span>
      </td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">redirect URIs</td>
      <td>
        <% @application.redirect_uri.to_s.split("\n").each do |uri| %>
          <code><%= uri %></code><br>
        <% end %>
      </td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">scopes</td>
      <td><code><%= @application.scopes %></code></td>
    </tr>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">confidential</td>
      <td><%= @application.confidential? ? "yes" : "no" %></td>
    </tr>
    <%# Phase 7.5 — MCP server URL row. The value clients paste into
        Claude.ai / Claude Desktop / any MCP-aware client to reach the
        Pito MCP Puma. Sourced from `Pito::PublicHosts.mcp_base` so a
        future host change propagates from one constant rather than
        scattered string literals across views and metadata documents. %>
    <tr>
      <td class="text-muted" style="padding-right: 12px; vertical-align: top;">mcp server URL</td>
      <td>
        <span data-controller="clipboard-copy" class="code-block">
          <code data-clipboard-copy-target="source"><%= "#{Pito::PublicHosts.mcp_base}/mcp" %></code>
          <a href="#" data-action="click->clipboard-copy#copy" class="bracketed">[<span class="bl">copy</span>]</a>
        </span>
      </td>
    </tr>
  </table>
</div>

<div class="dot-list">
  <%= render(BracketedLinkComponent.new(label: "i got this!", href: settings_oauth_applications_path)) %>
</div>
