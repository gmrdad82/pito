<% content_for(:title, "user") %>
<% breadcrumb(["settings", settings_path], "user") %>

<div style="margin-bottom: 8px;">
  <h1>user</h1>
  <p class="text-muted" style="margin-top: 2px;">
    change your email or password.<br>
    current password is required to authorize the change.
  </p>
</div>

<%# 2026-05-11 polish (Fix 4) — `totp-modal` Stimulus controller
    intercepts the submit when 2FA is on; the layout-level TOTP
    verification modal (`shared/_totp_verification_modal`) collects the
    6-digit code and re-submits the form with `totp_code` attached.
    The inline `2FA code` text input that used to render above
    `[update]` is gone — the modal IS the surface. When 2FA is off,
    `required` is "no" and the submit passes through untouched.
    Mirrors the YouTube / Voyage / Slack / Discord pane adoption that
    landed earlier in the session. %>
<div class="pane pane--standalone">
  <%= form_with url: settings_user_path, method: :patch, scope: :user,
                data: {
                  controller: "totp-modal",
                  action: "submit->totp-modal#maybeIntercept",
                  totp_modal_required_value: Current.user&.totp_enabled? ? "yes" : "no",
                  turbo: false
                } do |f| %>
    <% if @user.errors.any? %>
      <div class="flash-error" style="margin-bottom: 8px;">
        <% @user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div style="margin-bottom: 12px;">
      <label for="user_email" class="form-label">email</label>
      <input type="email" name="user[email]" id="user_email"
             value="<%= @user.email %>" required autocomplete="off"
             style="max-width: 420px; width: 100%;">
    </div>

    <div style="margin-bottom: 12px;">
      <label for="user_current_password" class="form-label">current password</label>
      <input type="password" name="user[current_password]" id="user_current_password"
             value="" required autocomplete="current-password"
             style="max-width: 420px; width: 100%;">
      <span class="form-hint" style="display: block;">required to authorize the change.</span>
    </div>

    <div style="margin-bottom: 12px;">
      <label for="user_password" class="form-label">new password</label>
      <input type="password" name="user[password]" id="user_password"
             value="" autocomplete="new-password"
             style="max-width: 420px; width: 100%;">
      <span class="form-hint" style="display: block;">leave blank to keep current password.</span>
    </div>

    <div style="margin-bottom: 12px;">
      <label for="user_password_confirmation" class="form-label">confirm new password</label>
      <input type="password" name="user[password_confirmation]" id="user_password_confirmation"
             value="" autocomplete="new-password"
             style="max-width: 420px; width: 100%;">
    </div>

    <%# 2026-05-11 polish (Fix 4) — inline `2FA code` text input
        retired. When 2FA is on, the form-level `totp-modal` Stimulus
        controller intercepts `[update]` and opens the layout-level
        TOTP verification modal; the modal injects a hidden
        `totp_code` field and re-submits. The controller-side
        `RecentTotpVerification` concern still reads
        `params[:totp_code]` and rejects with a generic
        `credentials don't match.` flash on a bad / missing code. %>

    <div class="dot-list">
      <button type="submit">[update]</button>
      <%= render(BracketedLinkComponent.new(label: "cancel", href: settings_path)) %>
    </div>
  <% end %>
</div>
