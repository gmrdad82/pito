<%# Settings → Google manage page — one row per fetched YouTube
    channel in the multi-select "select channels to add" form.

    Locals:
      channel:      Hash from Youtube::Client (snake_case keys).
      pito_channel: Channel record (or nil) matching the same URL.

    Already-linked channels render with a disabled checkbox and an
    "already added" cell so the user sees the row but cannot
    re-submit it. Unlinked rows render an enabled checkbox keyed by
    the YouTube channel ID; ticked rows roll up into the form's
    `youtube_channel_ids[]` array on submit. %>

<% youtube_channel_id = channel[:id].to_s %>
<% snippet = (channel[:snippet].is_a?(Hash) ? channel[:snippet] : {}) %>
<% statistics = (channel[:statistics].is_a?(Hash) ? channel[:statistics] : {}) %>
<% title = snippet[:title].to_s %>
<% thumbnails = snippet[:thumbnails].is_a?(Hash) ? snippet[:thumbnails] : {} %>
<% default_thumb = thumbnails[:default].is_a?(Hash) ? thumbnails[:default] : {} %>
<% thumbnail_url = default_thumb[:url].to_s %>
<% subscriber_count = statistics[:subscriber_count] || statistics["subscriberCount"] %>
<% already_added = pito_channel.present? && pito_channel.youtube_connection_id.present? %>

<tr>
  <td class="col-action" style="vertical-align: middle;">
    <label class="md-check" style="margin: 0;">
      <input type="checkbox"
             name="youtube_channel_ids[]"
             value="<%= youtube_channel_id %>"
             <%= "disabled" if already_added %>>
      <span class="md-check-indicator"></span>
    </label>
  </td>
  <td class="avatar-cell">
    <% if thumbnail_url.present? %>
      <img src="<%= thumbnail_url %>" alt="" class="avatar-thumb"
           loading="lazy" referrerpolicy="no-referrer">
    <% end %>
  </td>
  <td style="vertical-align: middle;"><%= title.presence || "(untitled)" %></td>
  <td class="num" style="vertical-align: middle;">
    <% if subscriber_count.present? %>
      <%= number_with_delimiter(subscriber_count.to_i) %>
    <% else %>
      —
    <% end %>
  </td>
  <td style="vertical-align: middle;">
    <% if already_added %>
      <span class="text-muted">already added</span>
    <% end %>
  </td>
</tr>
