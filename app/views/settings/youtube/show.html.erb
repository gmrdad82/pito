<% content_for(:title, "Google connection") %>
<% breadcrumb(["settings", settings_path], "Google") %>

<div style="margin-bottom: 8px;">
  <% if @youtube_connections.length > 1 %>
    <h1>Google connections</h1>
  <% else %>
    <h1>Google connection</h1>
  <% end %>
</div>

<%# Phase 10 polish — single consolidated top-of-page reconnect banner.
    The pane-internal `[reconnect]` button and the picker-section red
    banner are gone (the top banner is the primary CTA). Two copy
    variants live in the partial (revoked grant vs. missing scopes).

    Multi-connection note: the top banner reflects the FIRST
    connection only (the back-compat `@youtube_connection`). The
    unified table below absorbs per-channel detail; any per-connection
    nuance the banner can't cover (e.g. one connection healthy, one
    needing re-auth across many channels) is still legible from the
    connected-as email on each channel row. %>
<% if @youtube_connection.present? && @youtube_connection.needs_reauth? %>
  <%= render "settings/youtube/needs_reauth_banner" %>
<% end %>

<% if @youtube_connections.empty? %>
  <%# Empty state — no Google account connected. %>
  <div class="pane pane--standalone" style="margin-top: 12px; padding: 16px; max-width: 60ch;">
    <p>no Google account connected.</p>

    <%= form_with url: settings_youtube_connect_path, method: :post,
                  data: { turbo: false } do %>
      <button type="submit">[connect]</button>
    <% end %>

    <p class="text-muted" style="margin-top: 8px;">
      pito requests <code>youtube.readonly</code> and
      <code>yt-analytics.readonly</code>.<br>
      read-only — pito cannot upload, edit, or delete your videos with
      these scopes.
    </p>
  </div>
<% else %>
  <%# Unified table — every Channel across every YoutubeConnection
      lives in a single table. Each channel renders as ONE flat `<tr>`
      row:

        checkbox | channel | connected as | linked at

      Drops the per-connection metadata pane and the per-connection
      `[add]` button. A single `[+ add another Google account]` button
      below the table is the new entry point; it kicks OmniAuth with
      `prompt=select_account` so Google renders the account picker /
      Brand-Account switcher rather than silently reusing the most
      recently used Google account. The callback (see
      `YoutubeConnections::OauthCallbacksController#create`) enumerates
      `mine: true` channels under the granted access and adds non-
      duplicates as Channel rows under the matching YoutubeConnection
      (creating a new one if the user picked a different Google account
      on the consent screen). %>

  <%# Every Channel owned by any of this user's connections, ordered
      by connection then by channel slug so rows under the same Google
      account cluster together visually. %>
  <% connection_by_id = @youtube_connections.index_by(&:id) %>
  <% all_channels = Channel
                     .where(youtube_connection_id: @youtube_connections.map(&:id))
                     .order(:youtube_connection_id, :channel_url)
                     .to_a %>

  <% if all_channels.any? %>
    <%# Bulk-select wrapper — same shape as /channels /videos /projects.
        Checkboxes are always on (no [bulk] toggle); the bulk toolbar
        renders the dynamic `[disconnect N]` action once at least one
        row is selected, pointing at the existing
        `/deletions/youtube_connection/:ids` action-screen
        confirmation page. The `delete-type-value="youtube_connection"`
        plus the `action-label-value="disconnect"` keep the verb
        correct — the action clears `youtube_connection_id` on the
        Channel rows and revokes the orphaned Google grant. %>
    <div data-controller="bulk-select"
         data-bulk-select-entity-name-value="channels"
         data-bulk-select-delete-type-value="youtube_connection"
         data-bulk-select-action-label-value="disconnect">

      <div data-bulk-select-target="actions" style="margin-bottom: 0;" data-turbo-frame="_top">
        <div class="bulk-toolbar">
          <span class="action" data-bulk-select-target="count" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
          <span class="action" data-bulk-select-target="deleteAction" hidden>
            <span class="action-sep" hidden>&middot;</span>
          </span>
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th class="col-action">
              <%= render(CheckboxComponent.new(data: { bulk_select_target: "headerCheckbox", action: "change->bulk-select#toggleAll" })) %>
            </th>
            <th>channel</th>
            <th>connected as</th>
            <th>linked at</th>
          </tr>
        </thead>
        <tbody>
          <% all_channels.each do |c| %>
            <% connection = connection_by_id[c.youtube_connection_id] %>
            <%# One flat data row per channel. The dropped scopes row
                (period-separated short labels) was redundant detail;
                connected-as email is enough to identify which Google
                account owns the channel. %>
            <tr>
              <td class="col-action">
                <%= render(CheckboxComponent.new(value: c.id, data: { bulk_select_target: "checkbox", action: "change->bulk-select#toggle" })) %>
              </td>
              <td style="font-family: monospace;">
                <%# Display label — `title` once populated by sync,
                    falling back to the slug-style UC id derived from
                    `channel_url` until then. %>
                <%= link_to (c.title.presence ||
                              c.channel_url.sub(%r{\Ahttps?://(www\.)?youtube\.com/channel/}, "")),
                            channel_path(c) %>
              </td>
              <td><%= format_connection_email(connection&.email) %></td>
              <td>
                <%# `linked at` — uses `created_at` per the spec note
                    (no new column; `created_at` is reliable as the
                    moment the row first appeared in pito). The
                    compact-time helper renders the same `~5h ago`
                    shape used elsewhere. %>
                <%= compact_time_ago(c.created_at) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <%# Connections exist but no Channel rows yet (the user just
        connected an account but `mine: true` discovery returned an
        empty list, or every discovered channel was already linked
        elsewhere and silently skipped). Surface the connected emails
        so the page isn't a bare "no channels" message that hides the
        fact that an account is connected. %>
    <p class="text-muted">no channels linked yet.</p>
    <ul class="text-muted" style="list-style: none; padding: 0; margin: 4px 0 0;">
      <% @youtube_connections.each do |connection| %>
        <li>connected as <strong><%= format_connection_email(connection.email) %></strong></li>
      <% end %>
    </ul>
  <% end %>

  <%# Single entry to add another Google account. Same OAuth dance as
      before — `account=new` flips the request URL to include
      `prompt=select_account` so Google shows the account picker /
      Brand-Account switcher instead of silently reusing the most
      recently used grant. %>
  <div style="margin-top: 24px;">
    <%= form_with url: settings_youtube_connect_path, method: :post,
                  data: { turbo: false }, html: { style: "display: inline;" } do %>
      <input type="hidden" name="account" value="new">
      <button type="submit">[+ add another Google account]</button>
    <% end %>
  </div>
<% end %>
