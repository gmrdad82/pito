<% content_for(:title, "YouTube") %>
<% breadcrumb(["settings", settings_path], "YouTube") %>

<div style="margin-bottom: 8px;">
  <h1>YouTube</h1>
</div>

<% if @youtube_connection.present? && @youtube_connection.needs_reauth? %>
  <%= render "settings/youtube/needs_reauth_banner" %>
<% end %>

<% if @youtube_connection.nil? %>
  <%# Empty state — no Google account connected. %>
  <div class="pane" style="margin-top: 12px; padding: 16px;">
    <p>no google account connected.</p>

    <%= form_with url: settings_youtube_connect_path, method: :post,
                  data: { turbo: false } do %>
      <button type="submit">[ connect ]</button>
    <% end %>

    <p class="text-muted" style="margin-top: 8px;">
      pito requests <code>youtube.readonly</code> and
      <code>yt-analytics.readonly</code>.<br>
      read-only — pito cannot upload, edit, or delete your videos with
      these scopes.
    </p>
  </div>
<% else %>
  <%# Connected state. Phase 12 UX sweep — label/value metadata rendered
      as a `detail-table` inside the pane so the value column aligns with
      the rest of pito's settings surfaces (mirrors `channels/_pane.html.erb`
      and `videos/_pane.html.erb`). Label cells carry `padding-right: 12px;`
      so labels don't kiss the values — the base `.detail-table td` rule
      has `padding: 1px 0;` (no horizontal padding). %>
  <div class="pane" style="margin-top: 12px; padding: 16px;">
    <table class="detail-table" style="margin-bottom: 8px;">
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">connected as</td>
        <td><strong><%= @youtube_connection.email %></strong></td>
      </tr>
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">last authorized</td>
        <td><%= @youtube_connection.last_authorized_at.strftime("%Y-%m-%d %H:%M %Z") %></td>
      </tr>
      <% if @youtube_connection.last_refreshed_at.present? %>
        <tr>
          <td class="text-muted" style="padding-right: 12px; vertical-align: top;">last refreshed</td>
          <td><%= @youtube_connection.last_refreshed_at.strftime("%Y-%m-%d %H:%M %Z") %></td>
        </tr>
      <% end %>
      <tr>
        <td class="text-muted" style="padding-right: 12px; vertical-align: top;">scopes</td>
        <td><%= Array(@youtube_connection.scopes).join(", ") %></td>
      </tr>
    </table>

    <div class="dot-list" style="margin-top: 8px;">
      <%= form_with url: settings_youtube_connect_path, method: :post,
                    data: { turbo: false }, html: { style: "display: inline;" } do %>
        <button type="submit">[ reconnect ]</button>
      <% end %>
    </div>
  </div>

  <% if @youtube_error.present? %>
    <div class="flash-error" style="margin: 12px 0; padding: 10px 12px; border: 1px solid #cc0000; color: #cc0000;">
      YouTube api unavailable right now: <%= @youtube_error %>.
      showing already-connected channels only.
    </div>
  <% end %>

  <h2 style="margin-top: 16px;">your YouTube channels</h2>

  <% pito_channels_by_url = Channel.where(channel_url: @youtube_channels.map { |c| "https://www.youtube.com/channel/#{c[:id]}" }).index_by(&:channel_url) %>

  <% if @youtube_channels.any? %>
    <table>
      <thead>
        <tr>
          <th>channel id</th>
          <th>title</th>
          <th class="num">subscribers</th>
          <th>state</th>
        </tr>
      </thead>
      <tbody>
        <% @youtube_channels.each do |channel| %>
          <% url = "https://www.youtube.com/channel/#{channel[:id]}" %>
          <%= render "settings/youtube/channel_row",
                     channel: channel,
                     pito_channel: pito_channels_by_url[url] %>
        <% end %>
      </tbody>
    </table>
  <% elsif @youtube_error.present? %>
    <%# Fallback to listing already-connected channels in pito. %>
    <% fallback = Channel.where(youtube_connection_id: @youtube_connection.id).order(channel_url: :asc) %>
    <% if fallback.any? %>
      <table>
        <thead>
          <tr>
            <th>channel url</th>
            <th class="num">connected</th>
          </tr>
        </thead>
        <tbody>
          <% fallback.each do |c| %>
            <tr>
              <td style="font-family: monospace;"><%= c.channel_url %></td>
              <td class="num">yes</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">no channels available right now.</p>
    <% end %>
  <% else %>
    <p class="text-muted">no channels found under this google account.</p>
  <% end %>
<% end %>
