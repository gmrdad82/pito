<% content_for(:title, @collection.name) %>
<% breadcrumb(["collections", collections_path], @collection.name) %>

<%# `data-keyboard-detail-prev-url` / `data-keyboard-detail-next-url`
    carry the `h` / `l` sibling navigation URLs for the global
    keyboard controller. Marker div — invisible, no layout impact. %>
<div style="display: contents;" <%= keyboard_detail_nav_data_attributes(@collection, scope: Collection, path_helper: method(:collection_path)) %>></div>

<h1><%= @collection.name %></h1>

<%= form_with(model: @collection, url: collection_path(@collection), method: :patch) do |f| %>
  <div style="margin-bottom: 8px;">
    <label>name</label>
    <%= f.text_field :name, style: "width: 320px;" %>
  </div>
  <button type="submit">[<b>update</b>]</button>
<% end %>

<h2 style="margin-top: 16px;">games (<%= number_with_delimiter(@games.size) %>)</h2>
<% if @games.any? %>
  <ul>
    <% @games.each do |game| %>
      <li><%= link_to game.title, game_path(game) %></li>
    <% end %>
  </ul>
<% else %>
  <p class="text-muted">no games in this collection yet.</p>
<% end %>
