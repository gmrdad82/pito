<% content_for(:title, "collections") %>

<div style="max-width: 1100px;">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <h1>collections</h1>
    <span class="text-muted">&middot;</span>
    <%= button_to collections_path, form: { style: "display: inline;", data: { turbo: false } }, class: "bracketed", method: :post do %>[<span class="bl">+</span>]<% end %>
  </div>

  <% if @collections.any? %>
    <table>
      <thead>
        <tr>
          <th class="col-action"></th>
          <th>name</th>
          <th>games</th>
        </tr>
      </thead>
      <tbody>
        <% @collections.each do |collection| %>
          <tr>
            <td class="col-action">
              <%= render(BracketedLinkComponent.new(label: "o", href: collection_path(collection))) %>
            </td>
            <td><%= collection.name %></td>
            <td class="num"><%= number_with_delimiter(collection.games.count) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">no collections yet.</p>
  <% end %>
</div>
