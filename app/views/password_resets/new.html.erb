<% content_for(:title, "reset password") %>
<% content_for(:hide_chrome, true) %>

<div style="max-width: 420px; margin: 24px 0;">
  <h1>reset password</h1>
  <p class="text-muted" style="margin-top: 2px;">
    enter your username and a current code from your authenticator app.<br>
    a backup code works too if you have lost your device.<br>
    a successful reset signs out every active session.
  </p>

  <%= form_with url: password_reset_path, method: :post, scope: nil,
                data: { turbo: false } do %>
    <div style="margin-bottom: 12px;">
      <label for="reset_username" class="form-label">username</label>
      <input type="text" name="username" id="reset_username"
             value="<%= params[:username] %>" required autocomplete="username"
             style="width: 100%;">
    </div>

    <div style="margin-bottom: 12px;">
      <label for="reset_code" class="form-label">authenticator or backup code</label>
      <input type="text" name="code" id="reset_code"
             required autocomplete="one-time-code" inputmode="text"
             style="width: 100%;">
    </div>

    <div class="dot-list">
      <button type="submit">[reset password]</button>
      <%= render(BracketedLinkComponent.new(label: "back to login", href: login_path)) %>
    </div>
  <% end %>
</div>
