<% if sessions.any? %>
  <%# Idle bulk-revoke toolbar — `[revoke]` muted/non-clickable
      until at least one checkbox is ticked. The
      `sessions-bulk-revoke` Stimulus controller mutates the
      anchor's text + classes in place as the selection changes.
      Clicking the live `[revoke N]` link opens the in-page
      `<dialog>` confirm modal mounted at the bottom of this
      pane (no navigation — the old action-screen page is gone). %>
  <div class="bulk-toolbar" style="margin-bottom: 6px;">
    <span class="action">
      <a data-sessions-bulk-revoke-target="link" class="bracketed-muted">[revoke]</a>
    </span>
  </div>

  <%# Beta 4 — Phase F3-DEEP-B (2026-05-20):
      Migrated to the canonical `.tui-table` styling family that ships
      with `Tui::TableComponent` (F2 primitive). Approach B — class
      swap on the existing markup, no component refactor — keeps the
      bulk-revoke + checkbox + chip + sortable-header logic intact
      while inheriting the TUI table grammar (hairline rows, muted
      lowercase headers, no zebra, no hover).

      Columns: checkbox / user-agent / pinged.

      Beta 4 — Phase F3-C (2026-05-20):
        * Row + header checkboxes now use `Tui::CheckboxComponent`
          form-mode. The stimulus targets + `data-current` host element
          move to the enclosing `<span class="sessions-table__checkbox">`
          wrapper. The JS controller dereferences the wrapper to the
          inner `<input type=checkbox>` for state.
        * The current-session marker uses `Tui::ChipComponent
          variant: :current` per ADR 0016.

      Sortable headers drive `?sessions_sort=<key>&sessions_dir=
      <asc|desc>` on `/settings` itself. %>
  <table class="tui-table sessions-table" style="table-layout: auto;">
    <thead>
      <tr>
        <th class="tui-table__th tui-table__th--left col-action">
          <span class="sessions-table__checkbox sessions-table__checkbox--header"
                data-sessions-bulk-revoke-target="headerCheckbox"
                data-action="change->sessions-bulk-revoke#toggleAll">
            <%= render(Tui::CheckboxComponent.new(name: "__select_all", value: "yes", checked: false)) %>
          </span>
        </th>
        <th class="tui-table__th tui-table__th--left sortable"><%= helpers.sort_link_to("user-agent", "user_agent", current_sort: sessions_sort, current_dir: sessions_dir, sort_param: "sessions_sort", dir_param: "sessions_dir") %></th>
        <th class="tui-table__th tui-table__th--right sortable num"><%= helpers.sort_link_to("pinged", "last_activity", current_sort: sessions_sort, current_dir: sessions_dir, sort_param: "sessions_sort", dir_param: "sessions_dir") %></th>
      </tr>
    </thead>
    <tbody>
      <% sessions.each do |s| %>
        <tr class="tui-table__row">
          <td class="tui-table__td tui-table__td--left col-action">
            <span class="sessions-table__checkbox"
                  data-sessions-bulk-revoke-target="checkbox"
                  data-action="change->sessions-bulk-revoke#toggle"
                  data-current="<%= current_flag(s) %>"
                  data-value="<%= s.id %>">
              <%= render(Tui::CheckboxComponent.new(name: "ids[]", value: s.id, checked: false)) %>
            </span>
          </td>
          <td class="tui-table__td tui-table__td--left" style="max-width: 360px; white-space: normal;">
            <code><%= s.user_agent.presence || "—" %></code><%= render(TooltipBadgeComponent.new(label: "ip", tooltip: s.ip || "—", variant: :code)) %><% if current?(s) %><%= render(Tui::ChipComponent.new(label: "this", variant: :current)) %><% end %>
          </td>
          <td class="tui-table__td tui-table__td--right num"><%= helpers.compact_time_ago(s.last_activity_at) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted" style="margin: 0;">no active sessions.</p>
<% end %>
