<%# Phase 37 Wave A (window-summaries A-slice, 2026-05-19) — V2 grid.
    All five windows visible at once. Inert this slice.

    Layout:
      Recent activity
      ┌────────┬────────┬────────┬────────┬─────────┐
      │  7d    │  28d   │  3m    │  365d  │ alltime │
      │ subs   │ subs   │ subs   │ subs   │ subs    │
      │ +9.2K  │ +28K   │ +78K   │ +296K  │ 1.4M    │
      │ views  │ views  │ views  │ views  │ views   │
      │ +1.4M  │ +5.4M  │ +18M   │ +71M   │ 49M     │
      │ hours  │ hours  │ hours  │ hours  │ hours   │
      │ 6.030h │ 23.953h│ 78.180h│ 297.730│ 383.171 │
      └────────┴────────┴────────┴────────┴─────────┘
%>
<section class="channels-window-summaries channels-window-summaries--grid">
  <h3 style="font-size: 13px; font-weight: 700; margin: 0 0 6px 0;"><%= heading %></h3>

  <div class="channels-window-summaries__cards"
       style="display: flex; gap: 0; align-items: stretch;
              border: 1px solid var(--color-border); border-radius: 0;">
    <% cards.each_with_index do |card, index| %>
      <% if index.positive? %>
        <div style="border-left: 1px solid var(--color-border);"></div>
      <% end %>
      <div class="channels-window-summaries__card"
           style="flex: 1; padding: 8px 10px; display: flex; flex-direction: column; gap: 6px; min-width: 0;">
        <div class="channels-window-summaries__card-window"
             style="font-weight: 700; font-size: 13px;">
          <%= card[:window] %>
        </div>
        <div class="channels-window-summaries__card-row"
             style="display: flex; justify-content: space-between; align-items: baseline; gap: 6px;">
          <span style="color: var(--color-muted);">subs</span>
          <span style="font-variant-numeric: tabular-nums;"><%= card[:subs] %></span>
        </div>
        <div class="channels-window-summaries__card-row"
             style="display: flex; justify-content: space-between; align-items: baseline; gap: 6px;">
          <span style="color: var(--color-muted);">views</span>
          <span style="font-variant-numeric: tabular-nums;"><%= card[:views] %></span>
        </div>
        <div class="channels-window-summaries__card-row"
             style="display: flex; justify-content: space-between; align-items: baseline; gap: 6px;">
          <span style="color: var(--color-muted);">hours</span>
          <span style="font-variant-numeric: tabular-nums;"><%= card[:hours] %></span>
        </div>
      </div>
    <% end %>
  </div>
</section>
