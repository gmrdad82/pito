<%# Variant 2 — bordered card grid.

    Four equal-width cells reusing the same border + radius + bg tone as
    `Channels::IdCardComponent` so the row visually rhymes with the ID-card
    shelf above. Value 22px bold centered above the muted label. %>
<section class="channels-basics channels-basics--card"
         style="margin: 12px 0 0;">
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;">
    <% stats.each do |stat| %>
      <div class="channels-basics__cell"
           style="display: flex; flex-direction: column; align-items: center; gap: 4px;
                  padding: 12px 8px;
                  border: 1px solid var(--color-cover-border);
                  border-radius: 0;">
        <span class="channels-basics__value"
              style="font-size: 22px; font-weight: 700; line-height: 1.2;
                     font-variant-numeric: tabular-nums; color: var(--color-text);">
          <%= stat[:formatter].call(stat[:value]) %>
        </span>
        <span class="channels-basics__label"
              style="font-size: 11px; color: var(--color-muted);">
          <%= stat[:label] %>
        </span>
      </div>
    <% end %>
  </div>
</section>
<hr class="hairline">
