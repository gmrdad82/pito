<%# Variant 2 — split / side-by-side. Two columns: LEFT traffic-source
    breakdown, RIGHT top YouTube search terms. Equal-width flex
    children, 32 px inter-column gap. Wraps to single column when
    container is narrow.

    Tokens used:
      * 13 px body (CLAUDE.md visual style § Font)
      * `var(--color-text)`, `var(--color-text)`, `var(--color-muted)`,
        `var(--color-border)` per design.md.
      * Bar fill uses `var(--color-trend-up)` (non-red accent, same
        choice as Variant 1). %>
<section class="channels-traffic-sources channels-traffic-sources--split"
         style="display: flex; flex-direction: column; gap: 12px;">
  <div class="channels-traffic-sources__header"
       style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px;">
    <h2 style="font-size: 13px; font-weight: 700; color: var(--color-text); margin: 0;">
      traffic sources
    </h2>
    <span style="font-size: 12px; color: var(--color-muted);">
      variant 2 / side-by-side
    </span>
  </div>

  <div class="channels-traffic-sources__cols"
       style="display: flex; flex-wrap: wrap; gap: 32px; align-items: flex-start;">
    <%# LEFT half — ranked source list with horizontal bars. %>
    <div class="channels-traffic-sources__col channels-traffic-sources__col--sources"
         style="flex: 1 1 320px; min-width: 280px; display: flex; flex-direction: column; gap: 8px;">
      <h3 style="font-size: 12px; font-weight: 700; color: var(--color-text); margin: 0 0 2px; text-transform: lowercase; letter-spacing: 0.02em;">
        where the views come from
      </h3>
      <ol style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px;">
        <% aggregated_sources.each do |label, pct, _views| %>
          <li style="display: grid; grid-template-columns: 130px 1fr 40px; column-gap: 8px; align-items: center; font-size: 13px; color: var(--color-text);">
            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= label %>
            </span>
            <span aria-hidden="true"
                  style="position: relative; height: 8px; background: var(--color-border); border-radius: 0; overflow: hidden;">
              <span style="position: absolute; inset: 0 auto 0 0; width: <%= [pct, 1].max %>%; background: var(--color-trend-up);"></span>
            </span>
            <span style="text-align: right; font-variant-numeric: tabular-nums; color: var(--color-muted);">
              <%= pct_label(pct) %>
            </span>
          </li>
        <% end %>
      </ol>
    </div>

    <%# RIGHT half — top YouTube search terms list. %>
    <div class="channels-traffic-sources__col channels-traffic-sources__col--terms"
         style="flex: 1 1 320px; min-width: 280px; display: flex; flex-direction: column; gap: 8px;">
      <h3 style="font-size: 12px; font-weight: 700; color: var(--color-text); margin: 0 0 2px; text-transform: lowercase; letter-spacing: 0.02em;">
        top YouTube search terms
      </h3>
      <ol style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px;">
        <% aggregated_search_terms.each_with_index do |(term, views), idx| %>
          <li style="display: grid; grid-template-columns: 20px 1fr auto; column-gap: 10px; align-items: baseline; font-size: 13px; color: var(--color-text);">
            <span style="text-align: right; font-variant-numeric: tabular-nums; color: var(--color-muted);">
              <%= idx + 1 %>.
            </span>
            <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= term %>
            </span>
            <span style="text-align: right; font-variant-numeric: tabular-nums; color: var(--color-muted);">
              <%= views_label(views) %>
            </span>
          </li>
        <% end %>
      </ol>
    </div>
  </div>
</section>
