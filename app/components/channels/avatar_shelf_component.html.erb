<%# Phase 37 Wave A1 — right-side avatar shelf.

    Thin wrapper around `Channels::AvatarChipComponent` instances.
    Inline-flex container with `flex-wrap: wrap` so the shelf reflows
    on narrow viewports. The 6px gap matches the chip horizontal gap
    convention from `Games::FilterRowComponent` (filter_row_component
    .html.erb L23). %>
<div class="channels-avatar-shelf"
     style="display: inline-flex; flex-wrap: wrap; gap: 6px; align-items: flex-start;">
  <% channels.each do |channel| %>
    <%= render(Channels::AvatarChipComponent.new(channel: channel, current_params: current_params)) %>
  <% end %>
</div>
