<%# Phase 37 Top Content — Variant 1 (vertical ranked list).
    Each row: rank | thumbnail placeholder | title | views | channel
    badge. Rows use a CSS grid so all rows align column-by-column. %>
<div class="channels-top-content-list"
     style="display: flex; flex-direction: column; gap: 6px;">
  <% videos.each_with_index do |video, idx| %>
    <div class="channels-top-content-list__row"
         style="display: grid; grid-template-columns: 28px 80px 1fr auto auto; gap: 12px; align-items: center; padding: 6px 4px; border-bottom: 1px solid var(--color-border);">
      <span class="channels-top-content-list__rank"
            style="font-variant-numeric: tabular-nums; color: var(--color-muted); text-align: right;">
        <%= idx + 1 %>
      </span>
      <span class="channels-top-content-list__thumb"
            style="<%= thumbnail_box_style %>"></span>
      <span class="channels-top-content-list__title"
            style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        <%= video[:title] %>
      </span>
      <span class="channels-top-content-list__views"
            style="font-variant-numeric: tabular-nums; color: var(--color-muted);">
        <%= views_formatted(video) %>
      </span>
      <span class="channels-top-content-list__channel bracketed-muted">
        [ <%= channel_name_for(video) %> ]
      </span>
    </div>
  <% end %>
</div>
