<%# Phase 37 Wave A1 (landscape redesign, 2026-05-19) — channel ID card.
    2026-05-19 spec correction — layout refactor:
      * Body is a single flex row (avatar left, stats right). The
        previous vertical hairline between the left and right body
        columns is REMOVED.
      * The `[@handle]` link previously stacked under the avatar in the
        left column moves to the FOOTER (bottom-left of the card).
      * The footer is now FULL-WIDTH (was right-column-only). It has a
        full-width horizontal hairline above it, and its contents are
        split into `[@handle]` (left) + a vertical `|` divider via
        `border-left` on the Studio wrapper + `[ Studio ]` (right).
      * Footer copy: `[ YouTube Studio ]` → `[ Studio ]` per spec.
    Avatar stays at 80 px (kept proportionate — the freed-up left column
    vertical space is absorbed by `justify-content: center`). %>
<article class="channels-id-card"
         data-channel-id="<%= channel[:id] %>"
         style="position: relative;
                display: flex; flex-direction: column;
                width: <%= card_width_px %>; height: <%= card_height_px %>;
                flex: 0 0 <%= card_width_px %>;
                border: 1px solid var(--color-cover-border);
                border-radius: 2px;
                background: var(--color-channel-id-card-bg);">

  <%# Optional score badge overlay — top-right corner. Only rendered
      when `@score` is provided (recommended-channels-on-/games/:id
      usage). Absolute-positioned against the card's relative origin
      so the badge sits over the name row's right edge without
      disrupting the locked flex layout. Plain `[NN]` bracketed
      surface, bold + tabular-nums for digit alignment. %>
  <% if score %>
    <div class="channels-id-card__score-badge"
         aria-label="Recommendation score <%= score %>">[<%= score %>]</div>
  <% end %>

  <%# Row 1 — name, full width across the top. Bold weight at body 13 px. 6 px vertical / 8 px horizontal padding gives the title visible breathing room from the hairlines and card borders. %>
  <div class="channels-id-card__name"
       style="padding: 6px 8px;
              font-weight: 700;
              max-width: 100%;
              white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
    <%= channel[:display_name] %>
  </div>

  <%# Horizontal hairline between name and body — full card width. %>
  <div class="channels-id-card__hairline"
       style="border-top: 1px solid var(--color-border); width: 100%;"></div>

  <%# Row 2 — body. Single flex row: avatar left, stats right. No
      vertical hairline between the two (removed per the 2026-05-19
      spec correction). Body fills the remaining vertical space via
      `flex: 1`. %>
  <div class="channels-id-card__body"
       style="display: flex; flex: 1; min-height: 0;">

    <%# Left column — avatar only (handle moved to footer).
        `align-items: center` + `justify-content: center` centers the
        avatar both axes inside the column. %>
    <div class="channels-id-card__left"
         style="display: flex; flex-direction: column;
                padding: 6px;
                align-items: center;
                justify-content: center;
                width: 125px; flex-shrink: 0;
                box-sizing: border-box;">
      <%# Avatar — circular per design.md §"Channel avatars". 80 px square. %>
      <% if channel[:avatar_url].present? %>
        <img src="<%= channel[:avatar_url] %>"
             alt="<%= channel[:display_name] %>"
             class="channels-id-card__avatar"
             style="width: <%= avatar_dimension_px %>; height: <%= avatar_dimension_px %>;
                    flex-shrink: 0;
                    aspect-ratio: 1 / 1;
                    object-fit: cover;
                    border: 1px solid var(--color-cover-border);
                    border-radius: 50%;
                    display: block;">
      <% else %>
        <span class="channels-id-card__avatar"
              aria-label="<%= channel[:display_name] %>"
              style="width: <%= avatar_dimension_px %>; height: <%= avatar_dimension_px %>;
                     flex-shrink: 0;
                     aspect-ratio: 1 / 1;
                     border: 1px solid var(--color-cover-border);
                     border-radius: 50%;
                     display: block;"></span>
      <% end %>
    </div>

    <%# Right column — stat grid only (the in-column hairline + footer
        are gone; the footer is now a full-width sibling below the
        body). No `border-left` — the body has no vertical divider per
        the 2026-05-19 spec correction. %>
    <div class="channels-id-card__right"
         style="display: flex; flex-direction: column;
                flex: 1; min-width: 0;">

      <%# Stat grid — three rows × three columns: number / unit / arrow.
          The number cell uses `justify-self: end` so the three number
          right edges align at the same x against the unit label. The
          unit cell uses `justify-self: start` so the three unit left
          edges align. The arrow cell uses `justify-self: end` so the
          three arrows align at the right edge. `padding-right: 6px`
          keeps the arrows ~6 px clear of the card border. %>
      <div class="channels-id-card__stats"
           style="flex: 1;
                  display: grid;
                  grid-template-columns: 1fr auto auto;
                  column-gap: 6px;
                  row-gap: 4px;
                  align-content: center;
                  padding: 4px 6px 4px 4px;
                  min-width: 0;">

        <% glyph, css_var = trend(channel[:subscriber_count_trend]) %>
        <span class="channels-id-card__value"
              style="font-size: <%= stat_value_font_size %>; justify-self: end; align-self: center; font-variant-numeric: tabular-nums;"><%= subscriber_count_formatted %></span>
        <span class="channels-id-card__label"
              style="color: var(--color-muted); justify-self: start; align-self: center;">subs</span>
        <span class="channels-id-card__trend"
              style="display: inline-block; width: 1em; justify-self: end; align-self: center; color: var(<%= css_var %>);"><%= glyph %></span>

        <% glyph, css_var = trend(channel[:view_count_trend]) %>
        <span class="channels-id-card__value"
              style="font-size: <%= stat_value_font_size %>; justify-self: end; align-self: center; font-variant-numeric: tabular-nums;"><%= view_count_formatted %></span>
        <span class="channels-id-card__label"
              style="color: var(--color-muted); justify-self: start; align-self: center;">views</span>
        <span class="channels-id-card__trend"
              style="display: inline-block; width: 1em; justify-self: end; align-self: center; color: var(<%= css_var %>);"><%= glyph %></span>

        <% glyph, css_var = trend(channel[:watch_hours_trend]) %>
        <span class="channels-id-card__value"
              style="font-size: <%= stat_value_font_size %>; justify-self: end; align-self: center; font-variant-numeric: tabular-nums;"><%= watch_hours_formatted %></span>
        <span class="channels-id-card__label"
              style="color: var(--color-muted); justify-self: start; align-self: center;">hours</span>
        <span class="channels-id-card__trend"
              style="display: inline-block; width: 1em; justify-self: end; align-self: center; color: var(<%= css_var %>);"><%= glyph %></span>
      </div>
    </div>
  </div>

  <%# Row 3 — full-width footer. Sibling of the body inside the card
      root (not nested in the right column anymore). The horizontal
      hairline above the footer spans the full card width via
      `border-top` on this element. `display: flex` with
      `justify-content: space-between` places `[@handle]` at the left
      and `[ Studio ]` at the right; the Studio wrapper carries a
      `border-left` to render the vertical `|` divider between the two
      sides. %>
  <div class="channels-id-card__footer"
       style="border-top: 1px solid var(--color-border);
              display: flex; justify-content: space-between; align-items: stretch;
              width: 100%;">
    <div class="channels-id-card__handle"
         style="padding: 2px 6px;
                min-width: 0;
                white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
      <%= render(BracketedLinkComponent.new(label: channel[:handle], href: handle_url)) %>
    </div>
    <div class="channels-id-card__studio"
         style="padding: 2px 6px;
                border-left: 1px solid var(--color-border);">
      <%= render(BracketedLinkComponent.new(label: "Studio", href: studio_url)) %>
    </div>
  </div>
</article>
