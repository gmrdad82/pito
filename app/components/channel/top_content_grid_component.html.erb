<%# Phase 37 Top Content — Variant 2 (4-column tile grid).
    Compact tiles. Thumbnail (16:9 placeholder) + 2-line title + views
    + channel badge. %>
<div class="channels-top-content-grid"
     style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px;">
  <% videos.each do |video| %>
    <div class="channels-top-content-grid__tile"
         style="display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--color-border); border-radius: 0; padding: 6px; background: transparent;">
      <div class="channels-top-content-grid__thumb"
           style="aspect-ratio: 16 / 9; width: 100%; border: 1px solid var(--color-border); border-radius: 0;"></div>
      <div class="channels-top-content-grid__title"
           style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3; min-height: calc(1.3em * 2);">
        <%= video[:title] %>
      </div>
      <div class="channels-top-content-grid__meta"
           style="display: flex; justify-content: space-between; align-items: baseline; gap: 8px;">
        <span class="channels-top-content-grid__views"
              style="font-variant-numeric: tabular-nums; color: var(--color-muted);">
          <%= views_formatted(video) %>
        </span>
        <span class="channels-top-content-grid__channel bracketed-muted"
              style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
          [ <%= channel_name_for(video) %> ]
        </span>
      </div>
    </div>
  <% end %>
</div>
