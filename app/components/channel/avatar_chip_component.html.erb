<%# Phase 37 Wave A1 — channel avatar chip.

    Structurally identical to `FilterChipComponent`'s template
    (`app/components/filter_chip_component.html.erb` L1) — same
    `.filter-chip` anchor + `.md-check-static` glyph — except the
    label slot is an avatar tile instead of a text label. The
    `.channels-avatar-chip` modifier flags the divergence for any
    future styling pass without forking the base class.

    2026-05-19 chip-row consolidation — avatar tile now sized at
    1.4em + 4px overflow (2px up + 2px down) with margin-top -3px so
    [ ] aligns with avatar disc center (1px nudge upward per user
    request 2026-05-19 follow-up) — chip line-height from
    application.css:278. %>
<a href="<%= href %>"
   class="filter-chip channels-avatar-chip"
   data-keyboard-filter-chip="<%= channel[:display_name] %>"
   data-channel-id="<%= channel[:id] %>"
   style="align-items: flex-start;">
  <span class="md-check-static" style="line-height: 1.4;"><%= checked? ? "[x]" : "[ ]" %></span>
  <%# Circular per design.md §"Channel avatars" — 2026-05-19 user lock. %>
  <% if channel[:avatar_url].present? %>
    <img src="<%= channel[:avatar_url] %>"
         alt="<%= channel[:display_name] %>"
         class="channels-avatar-chip__tile"
         style="width: <%= avatar_dimension_css %>; height: <%= avatar_dimension_css %>; margin-top: -3px; object-fit: cover; border: 1px solid var(--color-border); border-radius: 50%; display: block;">
  <% else %>
    <span class="channels-avatar-chip__tile"
          aria-label="<%= channel[:display_name] %>"
          style="width: <%= avatar_dimension_css %>; height: <%= avatar_dimension_css %>; margin-top: -3px; border: 1px solid var(--color-border); border-radius: 50%; display: block;"></span>
  <% end %>
</a>
