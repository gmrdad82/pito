<%# Variant 2 — horizontal bar chart (top-8 countries).

    Each row: [ country name (120px) ][ scaled bar (1fr) ][ value (72px) ].

    Bar width tracks the country's view count relative to the max
    (largest bar always reaches 100%). Track background is transparent
    so the bar floats on the page bg; the bar fill uses `var(--color-link)`.

    Bars are taller (18px) than the list-variant's 10px so this variant
    reads as "chart-first" rather than "list with bars". %>
<section class="channels-geography channels-geography--bar"
         style="margin: 12px 0 0;">
  <h3 style="font-size: 13px; font-weight: 700; margin: 0 0 8px;">
    Audience geography
    <span style="font-size: 11px; color: var(--color-muted); font-weight: 400;">
      &mdash; variant 2 (bar chart)
    </span>
  </h3>

  <% if has_data? %>
    <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; max-width: 520px;">
      <% aggregated.each do |row| %>
        <li style="display: grid; grid-template-columns: 120px 1fr 72px; align-items: center; gap: 12px; font-size: 13px;">
          <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            <%= row[:country_name] %>
          </span>
          <span style="position: relative; height: 18px; display: block;">
            <span aria-hidden="true"
                  style="position: absolute; inset: 0 auto 0 0; width: <%= row[:width_pct] %>%; background: var(--color-link); display: block;"></span>
          </span>
          <span style="text-align: right; font-variant-numeric: tabular-nums;">
            <%= compact(row[:views]) %>
          </span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div style="font-size: 13px; color: var(--color-muted);">&mdash;</div>
  <% end %>
</section>
<hr class="hairline">
