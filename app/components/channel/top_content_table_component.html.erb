<%# Phase 37 Top Content — Variant 3 (compact 3-column table).
    Tight, data-dense, single line per row. %>
<table class="channels-top-content-table"
       style="width: 100%; border-collapse: collapse; table-layout: fixed;">
  <thead>
    <tr style="border-bottom: 1px solid var(--color-border);">
      <th style="text-align: left; padding: 4px 6px; font-weight: 700; color: var(--color-muted);">title</th>
      <th style="text-align: right; padding: 4px 6px; font-weight: 700; color: var(--color-muted); width: 80px;">views</th>
      <th style="text-align: right; padding: 4px 6px; font-weight: 700; color: var(--color-muted); width: 160px;">channel</th>
    </tr>
  </thead>
  <tbody>
    <% videos.each do |video| %>
      <tr style="border-bottom: 1px solid var(--color-border);">
        <td style="padding: 4px 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
          <%= video[:title] %>
        </td>
        <td style="padding: 4px 6px; text-align: right; font-variant-numeric: tabular-nums; color: var(--color-muted);">
          <%= views_formatted(video) %>
        </td>
        <td style="padding: 4px 6px; text-align: right;">
          <span class="bracketed-muted">[ <%= channel_name_for(video) %> ]</span>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
