<%# Variant 3 — squarified treemap.

    Outer canvas is 560×280 px. Each tile is absolutely positioned
    using percentages computed by the `squarify` algorithm in
    `Channel::GeographyTreemapComponent`. The largest country sits in
    the bottom-left (highest opacity); the smallest sits in the top-
    right (lightest opacity).

    Tile label rendering — code on top, percentage below. Both render
    only when the tile is wide enough to fit them legibly; CSS
    `overflow: hidden` clips smaller tiles. White text on the blue
    fill keeps contrast strong across the opacity ramp. %>
<section class="channels-geography channels-geography--treemap"
         style="margin: 12px 0 0;">
  <h3 style="font-size: 13px; font-weight: 700; margin: 0 0 8px;">
    Audience geography
    <span style="font-size: 11px; color: var(--color-muted); font-weight: 400;">
      &mdash; variant 3 (treemap)
    </span>
  </h3>

  <% if has_data? %>
    <div role="img"
         aria-label="Country viewership treemap"
         style="position: relative; width: <%= canvas_width_px %>px; height: <%= canvas_height_px %>px; background: var(--color-border); border: 1px solid var(--color-border); overflow: hidden;">
      <% tiles.each do |tile| %>
        <div style="position: absolute; left: <%= tile[:x] %>%; top: <%= tile[:y] %>%; width: <%= tile[:w] %>%; height: <%= tile[:h] %>%; background: var(--color-link); opacity: <%= tile[:opacity] %>; outline: 1px solid #ffffff; outline-offset: -1px; overflow: hidden; color: #ffffff; display: flex; flex-direction: column; justify-content: center; align-items: center; font-size: 12px; line-height: 1.2; padding: 4px; box-sizing: border-box; text-align: center;">
          <span style="font-weight: 700; letter-spacing: 0.5px;"><%= tile[:country_code] %></span>
          <span style="font-variant-numeric: tabular-nums; font-size: 11px; opacity: 0.85;"><%= tile[:percent] %>%</span>
        </div>
      <% end %>
    </div>
    <%# Legend row below the canvas — full country names + codes + %, 3-column wrap. %>
    <ul style="list-style: none; margin: 8px 0 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px 16px; max-width: <%= canvas_width_px %>px; font-size: 11px; color: var(--color-muted);">
      <% tiles.each do |tile| %>
        <li style="display: flex; gap: 6px; align-items: baseline;">
          <span style="display: inline-block; width: 24px; color: var(--color-text); font-variant-numeric: tabular-nums;"><%= tile[:country_code] %></span>
          <span style="flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= tile[:country_name] %></span>
          <span style="font-variant-numeric: tabular-nums;"><%= tile[:percent] %>%</span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div style="font-size: 13px; color: var(--color-muted);">&mdash;</div>
  <% end %>
</section>
<hr class="hairline">
