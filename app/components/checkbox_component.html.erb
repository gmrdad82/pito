<label class="md-check"><input type="checkbox"<% if @checked %> checked<% end %><% if @value %> value="<%= @value %>"<% end %><% if @name %> name="<%= @name %>"<% end %><% @data.each do |k, v| %> data-<%= k.to_s.dasherize %>="<%= v %>"<% end %>><span class="md-check-indicator"></span><% if @label %><span class="md-check-label"><%= @label %></span><% end %></label>