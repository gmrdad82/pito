<section class="viewer-time-heatmap" data-component="viewer-time-heatmap" aria-label="viewer-time heatmap">
  <% if empty? %>
    <p class="caption analytics-empty-state viewer-time-heatmap__empty">
      no viewer-time data yet — sync runs daily at 03:00 server time.
    </p>
  <% else %>
    <header class="viewer-time-heatmap__header">
      <span class="viewer-time-heatmap__title">viewer-time heatmap</span>
      <% if tz_label %>
        <span class="caption viewer-time-heatmap__tz">tz: <%= tz_label %></span>
      <% end %>
      <span class="caption viewer-time-heatmap__intensity">intensity: <%= intensity_by %></span>
    </header>

    <div class="viewer-time-heatmap__grid" role="table">
      <div class="viewer-time-heatmap__corner" role="columnheader" aria-label=""></div>
      <% HOURS.each do |hod| %>
        <div class="viewer-time-heatmap__col-header" role="columnheader"><%= hod.to_s.rjust(2, "0") %></div>
      <% end %>

      <% DAYS.each do |dow| %>
        <div class="viewer-time-heatmap__row-header" role="rowheader"><%= DAY_LABELS[dow] %></div>
        <% HOURS.each do |hod| %>
          <div
            class="viewer-time-heatmap__cell"
            role="cell"
            tabindex="0"
            style="background-color: <%= background_for(dow, hod) %>;"
            aria-label="<%= tooltip_at(dow, hod) %>"
            data-tooltip="<%= tooltip_at(dow, hod) %>"
            data-dow="<%= dow %>"
            data-hod="<%= hod %>"
            data-intensity="<%= intensity_at(dow, hod).round(4) %>"
          ></div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
