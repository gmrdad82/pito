<%# About modal — reuses `.confirm-modal` sizing + `.modal-footer` hairline
    pattern so width (max 420px) and padding (12px 16px) match the
    smallest existing dialog (ConfirmModalComponent). The
    `confirm-modal` Stimulus controller handles click-outside + Escape
    + the close action — no new controller needed. %>
<dialog id="<%= AboutModalComponent::MODAL_ID %>" class="confirm-modal"
        data-controller="confirm-modal"
        data-action="click->confirm-modal#clickOutside keydown->confirm-modal#keydown">
  <div class="confirm-modal-inner">
    <div class="dialog-title"><%= t("about.modal.title") %></div>

    <%# Logo above the project name. 64px display size sourced from
        `/favicon-128x128.png` for ~2x retina density on this small modal
        surface (max 420px wide). `border-radius: 2px` matches the project's
        standard square-asset radius (favicon is a logo asset, not a
        circular avatar). 2026-05-19 — added when `/Pito.png` was retired
        in favor of the multi-size favicon set. %>
    <%# 2026-05-19 — `?v=2` cache-bust matches the rest of the favicon set. %>
    <img src="/favicon-128x128.png?v=2" alt="pito" style="width: 64px; height: 64px; border-radius: 2px; display: block; margin: 12px auto 0;">

    <%# Project identity block — name + muted subtitle. %>
    <div style="margin-top: 10px; text-align: center;">
      <div><%= t("about.modal.project_name") %></div>
      <div class="text-muted"><%= t("about.modal.subtitle") %></div>
    </div>

    <%# Version + revision K-V block — 2-column CSS Grid wrapped in a flex
        container so the dl's intrinsic width (label-col + gap + value-col)
        is centered in the dialog. Labels right-aligned + values
        left-aligned puts the visual gap at the dl's horizontal middle,
        which aligns with the centered "pito" word above. `auto auto`
        keeps both columns sized to content, no expansion to the dialog
        edges. No colons — the grid itself communicates K-V. The revision
        value is a bracketed link to GitHub opening in a new tab; falls
        back to em-dash when no SHA is available. %>
    <div style="display: flex; justify-content: center; margin: 10px 0 0;">
      <dl style="display: grid; grid-template-columns: auto auto; column-gap: 8px; row-gap: 4px; margin: 0;">
        <dt class="text-muted" style="text-align: right;"><%= t("about.modal.version_label") %></dt>
        <dd style="margin: 0; text-align: left;"><%= version_string %></dd>
        <dt class="text-muted" style="text-align: right;"><%= t("about.modal.revision_label") %></dt>
        <dd style="margin: 0; text-align: left;">
          <% if commit_url %>
            <%= render BracketedLinkComponent.new(label: sha, href: commit_url) %>
          <% else %>
            <span class="text-muted"><%= t("common.em_dash") %></span>
          <% end %>
        </dd>
        <dt class="text-muted" style="text-align: right;"><%= t("about.modal.env_label") %></dt>
        <dd style="margin: 0; text-align: left;"><%= env %></dd>
      </dl>
    </div>

    <%# Copyright line — mirrors the footer string in
        `layouts/application.html.erb`. Centered horizontally to match
        the logo / project name / subtitle block above. %>
    <div class="text-muted" style="margin-top: 10px; text-align: center;">
      <%= copyright_text %>
    </div>

    <%# Footer action row — single `[ close ]` link, LEFT-aligned per the
        design.md "Modal footer alignment" rule. `.modal-footer` /
        `.confirm-modal-actions` use `display: flex` with no
        `justify-content` override, so the button sits at the start of the
        row by default. No `margin-left: auto`. %>
    <div class="confirm-modal-actions modal-footer">
      <button type="button" class="bracketed text-muted" data-action="confirm-modal#close">[<span class="bl"><%= t("common.actions.close") %></span>]</button>
    </div>
  </div>
</dialog>
