<%# Single canonical visualization — the fuel gauge. The bar spans the
    full pane width and represents hours (not percentages) along its
    x-axis. See `time_to_beat_component.rb` for the layout sketch and
    the 4-zone color rationale.

    BZ+ restructure (2026-05-17):

      Row 1 — footage value text   (top, positioned over footage tick)
      Row 2 — TTB bar              (3 colored pillar ticks + 1 footage tick)
      Row 3 — pillar hour values   (positioned BELOW each pillar tick)
      Row 4 — legend               (4 swatches + names)

    Pillar names migrated FROM below-the-bar TO the legend row. The
    "recorded" caption migrated FROM below-the-bar TO the legend row.
    Pillar tick fills moved from theme-text grey to vivid literal
    hex (yellow / white / pink) so the legend swatch ⇔ bar tick
    color identity reads at a glance against the cool-spectrum
    gradient.
%>
<%
  h_main          = hours[:main].to_i
  h_extras        = hours[:extras].to_i
  h_completionist = hours[:completionist].to_i
  footage         = footage_hours

  main_pos        = position(h_main)
  extras_pos      = position(h_extras)
  compl_pos       = position(h_completionist)
  footage_pos     = position(footage)
%>

<div class="ttb-fuel-gauge" data-component="time-to-beat" data-variant="fuel_gauge">
  <%# Row 1 — Footage value text, positioned over the footage tick.
      Only one item lives in this row now; pillar hour values have
      moved BELOW the bar. The footage hours use --color-text so the
      focal "you are here" number reads brighter than the gradient. %>
  <div class="ttb-fuel-gauge__values ttb-fuel-gauge__values--top">
    <% if render_footage_tick? %>
      <span class="ttb-fuel-gauge__value ttb-fuel-gauge__value--footage <%= footage_label_alignment_class %>"
            style="left: <%= footage_pos %>%;">
        <%= footage_value_label %>
      </span>
    <% end %>
  </div>

  <%# Row 2 — the bar itself. The 4-zone effort ramp is a smooth
      multi-stop linear gradient computed per-game by `gradient_stops`
      (heat thresholds projected onto `max_x`), inlined as
      `background-image` here so the visible color spread reflects the
      game's actual effort scale — Pragmata stays mostly green/lime,
      Crimson Desert is mostly pink. Zone semantic thresholds (10 / 40
      / 100 hours) are implicit; no visible vertical guides. %>
  <div class="ttb-fuel-gauge__bar"
       style="background-image: linear-gradient(to right, <%= gradient_stops %>);">
    <%# Inline "TTB" watermark, vertically centered inside the bar,
        left-aligned with a few px of padding. Carries the section
        identifier so no standalone heading sits above. %>
    <span class="ttb-fuel-gauge__title">TTB</span>

    <%# Pillar ticks — thin (2px), no border, FILLED with the per-
        pillar literal hex from `PILLAR_COLOR`. Color identity is
        what now ties each tick back to its legend swatch + bottom-
        row hour value. Overshoots the bar by 3px top + bottom so
        each tick reads as a marker, not a fill stripe. %>
    <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--pillar ttb-fuel-gauge__tick--main"
         style="left: <%= main_pos %>%;"
         data-pillar="main"></div>
    <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--pillar ttb-fuel-gauge__tick--extras"
         style="left: <%= extras_pos %>%;"
         data-pillar="extras"></div>
    <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--pillar ttb-fuel-gauge__tick--completionist"
         style="left: <%= compl_pos %>%;"
         data-pillar="completionist"></div>

    <%# Footage tick — UNCHANGED visual styling from BB/BV: 4px wide,
        theme-aware page-bg fill + text-color border. Always overlaid
        on top of the pillar ticks via stacking order. %>
    <% if render_footage_tick? %>
      <div class="ttb-fuel-gauge__tick ttb-fuel-gauge__tick--footage"
           style="left: <%= footage_pos %>%;"
           data-footage-hours="<%= footage %>"></div>
    <% end %>
  </div>

  <%# Row 3 — pillar hour values, BELOW the bar. Each label sits at
      its tick's x-position, ALWAYS centered (no edge-clamping — the
      "Nh" strings are short enough that overflow at the bar bounds
      is negligible, per 2026-05-17 user direction). Uses --color-muted
      so the bar + legend stay visually dominant. Plain `"<N>h"`
      strings only — the previous emoji escalation was removed
      (2026-05-17 user direction).

      Collision handling: when two adjacent pillar labels sit within
      `BOTTOM_LABEL_COLLISION_THRESHOLD_PCT` (10 %) of each other on
      the bar, the earlier label gets `--nudge-left` and the later
      label gets `--nudge-right` — both stay on the same row,
      shifted ~12 px apart around their tick midpoints. This resolves
      the Crimson Desert case where main (31h, ~4 %) and extras (71h,
      ~9 %) crowd each other against a 775h max_x. %>
  <div class="ttb-fuel-gauge__values ttb-fuel-gauge__values--bottom">
    <% pillar_label_data.each do |label_data| %>
      <% nudge_class = case label_data[:nudge]
         when :left  then " ttb-fuel-gauge__value--nudge-left"
         when :right then " ttb-fuel-gauge__value--nudge-right"
         else             ""
         end %>
      <span class="ttb-fuel-gauge__value ttb-fuel-gauge__value--pillar <%= pillar_bottom_label_alignment_class %><%= nudge_class %>"
            style="left: <%= label_data[:position] %>%;"
            data-pillar="<%= label_data[:key] %>">
        <%= label_data[:label] %>
      </span>
    <% end %>
  </div>

  <%# Row 4 — legend. Four items: three pillar swatches + names plus
      the "recorded" swatch + name. Each swatch fills with the same
      color as its corresponding tick on the bar (footage swatch
      mirrors the footage tick's bg-fill + text-color border). %>
  <div class="ttb-fuel-gauge__legend">
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--main"></span>
      <%= PILLAR_LABEL[:main] %>
    </span>
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--extras"></span>
      <%= PILLAR_LABEL[:extras] %>
    </span>
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--completionist"></span>
      <%= PILLAR_LABEL[:completionist] %>
    </span>
    <% if render_footage_tick? %>
      <span class="ttb-fuel-gauge__legend-item">
        <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--footage"></span>
        <%= footage_caption %>
      </span>
    <% end %>
  </div>
</div>
