<%# 2026-05-19 v4 — RHM-V5-shaped text bar:
    `[ ──────────────── ]` flexbox track with `[` and `]` anchored to
    the parent's left/right edges, a stretching `__fill` carrying the
    continuous Dracula Green→Cyan→Yellow→Pink gradient, and 4
    absolutely-positioned `|` ticks (main / extras / completionist /
    footage) each painted in their category color token.

    The 4-row structure (top bubble / bar / bottom labels / legend) is
    retained from v3 with tighter inter-row gaps. %>

<div class="ttb-fuel-gauge" data-component="time-to-beat" data-variant="text_bar">
  <%# Row 1 — Footage value bubble, positioned over the footage tick.
      2026-05-20 — RHM-style column bubble: number on top, ▼ arrow
      below, both centered on the footage tick at `footage_position%`. %>
  <div class="ttb-fuel-gauge__values ttb-fuel-gauge__values--top">
    <% if render_footage_tick? %>
      <div class="ttb-fuel-gauge__footage-bubble" style="left: <%= footage_position %>%;">
        <span class="ttb-fuel-gauge__footage-bubble-num"><%= footage_value_label %></span>
        <span class="ttb-fuel-gauge__footage-bubble-arrow">&#9660;</span>
      </div>
    <% end %>
  </div>

  <%# Row 2 — the bar itself. Flexbox track mirrors RHM-V5: `[` + `]`
      snap to the container edges via `flex: 0 0 auto`; the `__fill`
      grows via `flex: 1 1 auto + overflow: hidden`. Ticks are
      absolutely positioned overlays at `left: <position>%`. %>
  <div class="ttb-fuel-gauge__bar-row">
    <span class="ttb-fuel-gauge__bar"
          data-resyncing="<%= resyncing? ? "yes" : "no" %>">
      <% gradient_breaks = gradient_break_positions %>
      <span class="ttb-fuel-gauge__track"><span class="ttb-fuel-gauge__bracket">[</span><span class="ttb-fuel-gauge__fill"<% if gradient_breaks %> style="--ttb-p1: <%= gradient_breaks[:p1] %>; --ttb-p2: <%= gradient_breaks[:p2] %>; --ttb-p3: <%= gradient_breaks[:p3] %>; --ttb-p4: <%= gradient_breaks[:p4] %>; --ttb-p5: <%= gradient_breaks[:p5] %>; --ttb-p6: <%= gradient_breaks[:p6] %>;"<% end %>>===============================================================================</span><span class="ttb-fuel-gauge__bracket">]</span></span>
      <% tick_overlays.each do |tick| %>
        <span class="ttb-fuel-gauge__tick <%= tick[:token_class] %>"
              style="left: <%= tick[:position] %>%;"
              data-tick="<%= tick[:key] %>">|</span>
      <% end %>
    </span>
  </div>

  <%# Row 3 — pillar hour values, BELOW the bar. %>
  <div class="ttb-fuel-gauge__values ttb-fuel-gauge__values--bottom">
    <% pillar_label_data.each do |label_data| %>
      <span class="ttb-fuel-gauge__value ttb-fuel-gauge__value--pillar <%= pillar_bottom_label_alignment_class %>"
            style="left: <%= label_data[:effective_position] %>%;"
            data-pillar="<%= label_data[:key] %>">
        <%= label_data[:label] %>
      </span>
    <% end %>
  </div>

  <%# Row 4 — legend. Each item pairs a `|` tick glyph in its category
      color token with the category label. Replaces the previous CSS
      rectangle swatches. %>
  <div class="ttb-fuel-gauge__legend">
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-tick" style="color: var(--color-ttb-main);">|</span>
      <span class="ttb-fuel-gauge__legend-label"><%= self.class.pillar_label[:main] %></span>
    </span>
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-tick" style="color: var(--color-ttb-extras);">|</span>
      <span class="ttb-fuel-gauge__legend-label"><%= self.class.pillar_label[:extras] %></span>
    </span>
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-tick" style="color: var(--color-ttb-completionist);">|</span>
      <span class="ttb-fuel-gauge__legend-label"><%= self.class.pillar_label[:completionist] %></span>
    </span>
    <% if render_footage_tick? %>
      <span class="ttb-fuel-gauge__legend-item">
        <span class="ttb-fuel-gauge__legend-tick" style="color: var(--color-ttb-footage);">|</span>
        <span class="ttb-fuel-gauge__legend-label"><%= footage_caption %></span>
      </span>
    <% end %>
  </div>
</div>
