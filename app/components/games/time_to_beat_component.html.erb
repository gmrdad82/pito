<%# 2026-05-19 v3 — full-width gradient bar with four `|` ticks.
    The bar shape is ALWAYS `[===…===]` (N=40 cells between the
    brackets). All `=` cells share the cool-spectrum gradient via
    background-clip:text on the `__fill` spans. Four `|` ticks
    (footage + main + extras + completionist) replace individual
    `=` cells at their projected positions; each tick lives in its
    own `__tick-char` span so it renders in theme-text color
    regardless of gradient stop.

    Surrounding rows (footage value above, pillar hour labels below,
    legend) are retained from v1 / v2 — only the bar itself changed
    shape between revisions.
%>

<div class="ttb-fuel-gauge" data-component="time-to-beat" data-variant="text_bar">
  <%# Row 1 — Footage value text, positioned over the footage tick. %>
  <div class="ttb-fuel-gauge__values ttb-fuel-gauge__values--top">
    <% if render_footage_tick? %>
      <span class="ttb-fuel-gauge__value ttb-fuel-gauge__value--footage <%= footage_label_alignment_class %>"
            style="left: <%= footage_position %>%;">
        <%= footage_value_label %>
      </span>
    <% end %>
  </div>

  <%# Row 2 — the bar itself, rendered as one monospace text line. %>
  <div class="ttb-fuel-gauge__bar-row">
    <span class="ttb-fuel-gauge__bar"
          data-resyncing="<%= resyncing? ? "yes" : "no" %>">
      <span class="ttb-fuel-gauge__bracket">[</span><% cell_groups.each do |group| %><% if group[:kind] == :fill %><span class="ttb-fuel-gauge__fill"><%= group[:text] %></span><% else %><span class="ttb-fuel-gauge__tick-char"><%= group[:text] %></span><% end %><% end %><span class="ttb-fuel-gauge__bracket">]</span>
    </span>
  </div>

  <%# Row 3 — pillar hour values, BELOW the bar. %>
  <div class="ttb-fuel-gauge__values ttb-fuel-gauge__values--bottom">
    <% pillar_label_data.each do |label_data| %>
      <span class="ttb-fuel-gauge__value ttb-fuel-gauge__value--pillar <%= pillar_bottom_label_alignment_class %>"
            style="left: <%= label_data[:effective_position] %>%;"
            data-pillar="<%= label_data[:key] %>">
        <%= label_data[:label] %>
      </span>
    <% end %>
  </div>

  <%# Row 4 — legend. Three pillar swatches (uniform tick color)
      + the recorded swatch (white-fill / bordered). %>
  <div class="ttb-fuel-gauge__legend">
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--pillar"></span>
      <%= self.class.pillar_label[:main] %>
    </span>
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--pillar"></span>
      <%= self.class.pillar_label[:extras] %>
    </span>
    <span class="ttb-fuel-gauge__legend-item">
      <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--pillar"></span>
      <%= self.class.pillar_label[:completionist] %>
    </span>
    <% if render_footage_tick? %>
      <span class="ttb-fuel-gauge__legend-item">
        <span class="ttb-fuel-gauge__legend-swatch ttb-fuel-gauge__legend-swatch--footage"></span>
        <%= footage_caption %>
      </span>
    <% end %>
  </div>
</div>
