<%# Phase 27 §01f — Per-platform ownership editor (revamped 2026-05-12).
    One bracketed-checkbox row per platform — `[ ] <Platform Name>` —
    using the project's canonical `.md-check` pattern. Real
    `<input type="checkbox">` is rendered (visually hidden via CSS) and
    the bracketed indicator is drawn by `.md-check-indicator::before`.
    The form posts `platform_owned_ids[]` as a flat array. No JS confirm.
%>
<% if any_platforms? %>
  <div class="platform-ownership-row-list" style="display: flex; flex-wrap: wrap; gap: 12px 18px;">
    <% platforms.each do |platform| %>
      <label class="md-check"
             data-platform-slug="<%= platform.slug %>">
        <input type="checkbox"
               name="platform_owned_ids[]"
               value="<%= platform.id %>"
               <%= "checked" if owned?(platform) %>
               data-platform-slug="<%= platform.slug %>">
        <span class="md-check-indicator"></span>
        <span class="md-check-label"><%= platform.name %></span>
      </label>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">(no platforms available)</p>
<% end %>
