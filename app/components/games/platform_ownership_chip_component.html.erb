<%# Wave C4 stub — per-platform ownership toggle. The form submits the
    full `platform_owned_ids[]` set with this platform added or
    removed (see component class for the TODO note on a dedicated
    per-platform endpoint). The submit button is styled to match the
    `Platforms::ChipComponent` brand chip — bracketed label, brand
    color when owned, muted gray when not. %>
<%= form_with url: game_platform_ownerships_path(game),
              method: :patch,
              data: { turbo: false },
              class: "ownership-chip-form",
              style: "display: inline;" do |f| %>
  <% toggled_ids.each do |pid| %>
    <%= hidden_field_tag "platform_owned_ids[]", pid %>
  <% end %>
  <%# Empty hidden field ensures the array param survives even when
      the toggle would deselect the last owned platform. %>
  <% if toggled_ids.empty? %>
    <%= hidden_field_tag "platform_owned_ids[]", "" %>
  <% end %>
  <button type="submit"
          class="platform-chip platform-chip--md ownership-chip-button"
          style="color: <%= chip_color %>;"
          title="<%= owned? ? t("games.platform_ownership_chip.owned_title", label: label) : t("games.platform_ownership_chip.not_owned_title", label: label) %>">[<%= label %>]</button>
<% end %>
