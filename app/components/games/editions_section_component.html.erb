<%# Phase 28 §01a — Editions sub-section. Listed in title order.
    Each row carries: cover thumb (small IGDB variant), title (link to
    the edition show page), version_title (muted), and the per-edition
    owned-platforms chip strip. %>
<section id="editions" class="editions-section" style="margin-top: 16px;">
  <h2 style="margin-top: 0;"><%= heading %></h2>
  <ul style="list-style: none; padding: 0; margin: 0;">
    <% editions.each do |edition| %>
      <li class="edition-row" style="padding: 6px 0; border-bottom: 1px solid var(--color-border); display: flex; align-items: center; gap: 8px;">
        <span class="edition-cover" style="flex: 0 0 36px;">
          <% if edition.cover_url.present? %>
            <%= image_tag edition.cover_url(size: "t_cover_small"),
                          alt: edition.title,
                          loading: "lazy",
                          style: "width: 36px; height: 48px; object-fit: cover; display: block;" %>
          <% else %>
            <span class="text-muted" style="display: inline-block; width: 36px; height: 48px;">—</span>
          <% end %>
        </span>
        <span class="edition-title" style="flex: 1 1 auto; min-width: 0;">
          <%= link_to edition.title, game_path(edition) %>
          <% if edition.version_title.present? %>
            <span class="text-muted edition-version-title" style="font-size: 11px;">
              (<%= edition.version_title %>)
            </span>
          <% end %>
        </span>
        <span class="edition-ownership" style="flex: 0 0 auto;">
          <%= render(Games::OwnedPlatformsChipListComponent.new(game: edition)) %>
        </span>
      </li>
    <% end %>
  </ul>
</section>
