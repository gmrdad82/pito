<%# Phase 27 §01b — multi-select filter row.

    Two-row layout (2026-05-11 polish):
      Row 1 (status + platforms): released, scheduled, ps5, switch2,
        steam, gog, epic, xbox. `[clear all]` rides the right side of
        row 1 when at least one chip is active.
      Row 2 (ownership/recorded): owned, not_owned, recorded.
        The display-mode switcher rides row 2's optional right slot.

    No JS. Pure GET-link navigation; URL-state-driven. %>
<section class="games-filter-row" data-controller="">
  <%# Row 1 — status + platforms.

      `flex-wrap: wrap` keeps the chips graceful at narrow widths.
      `[clear all]` lives inline at the end of row 1 (not row 2) so
      it stays visually attached to the chip cluster when the second
      row carries only ownership+recorded. %>
  <div class="games-filter-row__row games-filter-row__row--1"
       style="display: flex; flex-wrap: wrap; gap: 6px; align-items: baseline;">
    <div class="games-filter-row__chips games-filter-row__chips--1"
         style="display: flex; flex-wrap: wrap; gap: 6px; align-items: baseline;">
      <% row_1_tokens.each do |t| %>
        <%= render chip_for(t) %>
      <% end %>

      <% if any_active? %>
        <%# `feedback_bracketed_links` convention — multi-word labels
            carry inner spaces (`[ clear all ]`). Single-token chip
            labels stay flush (`[ps5]`). %>
        <span class="games-filter-row__clear-all" style="margin-left: 8px;">
          <%= link_to clear_all_href, class: "bracketed games-filter-row__clear-all-link" do %>[ <span class="bl">clear all</span> ]<% end %>
        </span>
      <% end %>
    </div>
  </div>

  <%# Row 2 — ownership/recorded chips + optional right slot (display
      switcher). Same wrap rules as row 1; `margin-left: auto` pins
      the right slot flush-right even when chips wrap. %>
  <div class="games-filter-row__row games-filter-row__row--2"
       style="display: flex; flex-wrap: wrap; gap: 6px; align-items: baseline; margin-top: 4px;">
    <div class="games-filter-row__chips games-filter-row__chips--2"
         style="display: flex; flex-wrap: wrap; gap: 6px; align-items: baseline;">
      <% row_2_tokens.each do |t| %>
        <%= render chip_for(t) %>
      <% end %>
    </div>

    <% if right_slot? %>
      <div class="games-filter-row__right" style="margin-left: auto; display: inline-flex; align-items: baseline;">
        <%= right_slot %>
      </div>
    <% end %>
  </div>

  <% if contradiction? %>
    <p class="text-muted games-filter-row__contradiction" style="margin-top: 4px;">
      (owned and not owned together — no matches)
    </p>
  <% end %>

  <% if dev_warning? %>
    <p class="text-muted games-filter-row__dropped" style="margin-top: 4px;">
      (dev) dropped non-canonical filter tokens: <%= dropped_tokens.join(", ") %>
    </p>
  <% end %>
</section>
