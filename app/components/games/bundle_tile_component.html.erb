<%# Phase 27 Wave F (2026-05-17) — Verbatim port of
    `app/views/games/_bundle_for_shelf_tile.html.erb`. Keep the two
    in sync until VC5 swaps the partial's render for this component;
    the partial is still the live wiring at this dispatch.

    2026-05-18 — extended for `size: :shelf` (98 × 130 bare cover,
    no caption) and `mode: :suggest` (button_to POST → add target_game
    to this bundle). Both default to the original grid + modal-trigger
    behavior so existing callers (`_bundles_for_shelf`, the create
    Turbo Stream) render unchanged. %>
<% if suggest_mode? %>
  <%# `mode: :suggest` — RIGHT half of the /games/:id bundles section.
      Click POSTs `/bundles/:slug/members` with the target game id
      (BundleMembersController#create). `source=games_show` instructs
      the controller to redirect back to /games/:id (instead of the
      bundle show page) with "added to <bundle name>." in the flash. %>
  <%= button_to add_member_url,
                method: :post,
                params: { game_id: target_game.id, source: "games_show" },
                form: { class: "bundle-tile bundle-tile--suggest",
                        style: "margin: 0; flex: 0 0 auto; display: inline-flex; flex-direction: column; align-items: flex-start; gap: 4px; width: #{width}px;",
                        data: { bundle_id: bundle.id } },
                class: "bundle-tile-suggest-button",
                aria: { label: aria_label },
                title: aria_label do %>
    <div class="bundle-cover-wrap" style="position: relative; display: block; width: <%= width %>px; height: <%= height %>px;">
      <% if composite_url.present? %>
        <img src="<%= composite_url %>"
             width="<%= width %>"
             height="<%= height %>"
             loading="lazy"
             alt="<%= bundle.name %>"
             class="bundle-cover-composite"
             style="display: block; object-fit: cover;">
      <% else %>
        <%# 2026-05-18 (Bug 4) — netflix-3 placeholder for empty
            bundles. Replaces the generic game-cover fallback SVG
            (which read as "a single missing game") with a 3-cell
            grid that visually previews the netflix-style composite
            layout a 3-member bundle would render. The single large
            left cell + two stacked right cells mirror
            `Composite::CellMap.for(3)` so the empty bundle looks
            like a bundle, not a generic game.

            2026-05-18 (follow-up) — each cell embeds the shared
            game-cover fallback SVG (the stylised controller icon)
            so the placeholder reads as "bundle of missing games"
            instead of three empty boxes. The main left cell uses
            the `--large` size; the two right cells use `--small`
            because their 40% × 50% slot is much tighter. Light +
            dark variants stack and are toggled via the same
            `[data-theme]` rules as `.game-cover-fallback`. %>
        <div class="bundle-tile__nocover-netflix3"
             aria-label="<%= bundle.name %>"
             title="<%= bundle.name %>">
          <div class="cell cell--main">
            <%= image_tag image_path("controller_icon_light.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "light" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--large game-cover-fallback--light" %>
            <%= image_tag image_path("controller_icon_dark.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "dark" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--large game-cover-fallback--dark" %>
          </div>
          <div class="cell">
            <%= image_tag image_path("controller_icon_light.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "light" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--light" %>
            <%= image_tag image_path("controller_icon_dark.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "dark" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--dark" %>
          </div>
          <div class="cell">
            <%= image_tag image_path("controller_icon_light.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "light" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--light" %>
            <%= image_tag image_path("controller_icon_dark.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "dark" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--dark" %>
          </div>
        </div>
      <% end %>
      <% if has_overflow? %>
        <div class="bundle-cover-overflow-overlay">
          <%= render(StatusBadgeComponent.new(label: "+#{overflow_n}", kind: :neutral)) %>
        </div>
      <% end %>
    </div>
    <% if show_caption? %>
      <span class="tile-caption-title bundle-tile-name"
            style="font-size: 11px; max-width: <%= width %>px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-align: left;">
        <%= bundle.name %>
      </span>
    <% end %>
  <% end %>
<% else %>
  <a id="bundle-tile-<%= bundle.id %>"
     href="<%= fallback_href %>"
     class="bundle-tile"
     data-bundle-id="<%= bundle.id %>"
     data-controller="bundles-modal-trigger"
     data-action="click->bundles-modal-trigger#open"
     data-bundles-modal-trigger-url-value="<%= pane_url %>"
     data-bundles-modal-trigger-title-value="<%= bundle.name %>"
     data-bundles-modal-trigger-update-url-value="<%= update_url %>"
     data-bundles-modal-trigger-delete-confirm-id-value="<%= delete_confirm_id %>"
     title="<%= bundle.name %>"
     style="flex: 0 0 auto; display: inline-flex; flex-direction: column; align-items: flex-start; gap: 4px; text-decoration: none; color: inherit; cursor: pointer; width: <%= width %>px;">
    <%# 2026-05-17 — wrap the cover (composite img OR fallback SVGs) in
        a `position: relative` container so the `+N` overflow overlay
        below can anchor flush to the bottom-right corner. Mirrors the
        `.tile-cover` wrapper in `_tile.html.erb`. %>
    <div class="bundle-cover-wrap" style="position: relative; display: block; width: <%= width %>px; height: <%= height %>px;">
      <% if composite_url.present? %>
        <img src="<%= composite_url %>"
             width="<%= width %>"
             height="<%= height %>"
             loading="lazy"
             alt="<%= bundle.name %>"
             class="bundle-cover-composite"
             style="display: block; object-fit: cover;">
      <% else %>
        <%# 2026-05-18 (Bug 4) — netflix-3 placeholder. See the
            matching block in the `suggest_mode?` branch above for
            the design rationale: a 3-cell grid that previews the
            netflix-style composite layout so an empty bundle reads
            as a bundle (not a missing single game). The earlier
            theme-aware single-cover fallback SVG is reserved for
            actual game tiles; bundles now own a distinct
            placeholder. The `.cell` border + background pick up
            theme tokens from `.bundle-tile__nocover-netflix3` in
            `application.css`.

            2026-05-18 (follow-up) — controller icon embedded in each
            cell at two sizes: `--large` for the main left cell,
            `--small` for the two cramped right cells. Light + dark
            variants stack and toggle via the shared `[data-theme]`
            rules. %>
        <div class="bundle-tile__nocover-netflix3"
             aria-label="<%= bundle.name %>"
             title="<%= bundle.name %>">
          <div class="cell cell--main">
            <%= image_tag image_path("controller_icon_light.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "light" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--large game-cover-fallback--light" %>
            <%= image_tag image_path("controller_icon_dark.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "dark" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--large game-cover-fallback--dark" %>
          </div>
          <div class="cell">
            <%= image_tag image_path("controller_icon_light.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "light" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--light" %>
            <%= image_tag image_path("controller_icon_dark.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "dark" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--dark" %>
          </div>
          <div class="cell">
            <%= image_tag image_path("controller_icon_light.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "light" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--light" %>
            <%= image_tag image_path("controller_icon_dark.svg"),
                          alt: "", loading: "lazy",
                          data: { theme: "dark" },
                          class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small game-cover-fallback--dark" %>
          </div>
        </div>
      <% end %>
      <%# 2026-05-17 — HTML `+N` overflow overlay. Mirrors the
          `.tile-cover-chip-overlay` pattern from `_tile.html.erb`, but
          tuned for parity with the `:sm` platform chips: the inner
          StatusBadge is scoped-stripped of its bordered-pill chrome and
          renormalised to the `--sm` chip's 11px / `padding: 0 5px`
          dimensions, and the overlay container itself is offset
          `-1px` on right + bottom so its edge OVERLAPS the cover's
          1px border instead of stacking alongside it (the double-line
          artifact on dark theme). All styling lives in
          `.bundle-cover-overflow-overlay` in `application.css`. %>
      <% if has_overflow? %>
        <div class="bundle-cover-overflow-overlay">
          <%= render(StatusBadgeComponent.new(label: "+#{overflow_n}", kind: :neutral)) %>
        </div>
      <% end %>
    </div>
    <% if show_caption? %>
      <%# 2026-05-17 — title styling aligned with the letter shelf rich tile
          (`_tile.html.erb` `.tile-caption-title`): inherits the default
          text color (NOT `text-muted`), 11px font-size matching the grid
          caption, left-aligned, single-line ellipsis-truncated to the
          150px cover width. Anchor's `align-items: flex-start` (above)
          keeps the title flush left under the cover. %>
      <span class="tile-caption-title bundle-tile-name"
            style="font-size: 11px; max-width: <%= width %>px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-align: left;">
        <%= bundle.name %>
      </span>
    <% end %>
  </a>
<% end %>
