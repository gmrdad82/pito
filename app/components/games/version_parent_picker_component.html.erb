<%# Phase 28 §01a — version-parent typeahead picker.
    Two inputs:
      - visible search input (typeahead, populated via the Stimulus
        controller fetching from `version_parent_search_games_path`)
      - hidden `game[version_parent_id]` carrying the resolved id
    Plus a `[detach]` bracketed link that clears the hidden value via
    the Stimulus controller. Disabled when the current row has
    editions of its own (cannot become an edition itself). %>
<div class="version-parent-picker"
     data-controller="version-parent-picker"
     data-version-parent-picker-search-url-value="<%= search_url %>"
     data-version-parent-picker-self-id-value="<%= game.id || '' %>">
  <%= form.hidden_field :version_parent_id,
                        value: current_parent_id,
                        data: { version_parent_picker_target: "hiddenId" } %>
  <input type="text"
         class="version-parent-picker-input"
         placeholder="<%= disabled? ? 'cannot attach — this row has editions' : 'type to search primaries…' %>"
         value="<%= current_parent_title %>"
         <%= 'disabled' if disabled? %>
         autocomplete="off"
         data-version-parent-picker-target="input"
         data-action="input->version-parent-picker#search keydown->version-parent-picker#keydown" />
  <ul class="version-parent-picker-results"
      data-version-parent-picker-target="results"
      style="list-style: none; padding: 0; margin: 4px 0 0 0; border: 1px solid var(--color-border); max-height: 240px; overflow-y: auto; display: none; background: var(--color-bg);"></ul>
  <% if current_parent_id.present? %>
    <span class="version-parent-picker-detach" style="margin-left: 8px;">
      <a href="#"
         class="bracketed"
         data-action="click->version-parent-picker#detach"
         data-version-parent-picker-target="detachLink">[<span class="bl">detach</span>]</a>
    </span>
  <% end %>
</div>
