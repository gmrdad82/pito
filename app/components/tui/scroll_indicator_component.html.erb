<% if horizontal? %>
<span class="tui-scroll-indicator tui-scroll-indicator--horizontal tui-scroll-indicator--left"
      data-tui-scroll-indicator-target="left"
      aria-hidden="true">◀</span>
<span class="tui-scroll-indicator tui-scroll-indicator--horizontal tui-scroll-indicator--handle"
      data-tui-scroll-indicator-target="handle"
      aria-hidden="true">▬</span>
<span class="tui-scroll-indicator tui-scroll-indicator--horizontal tui-scroll-indicator--right"
      data-tui-scroll-indicator-target="right"
      aria-hidden="true">▶</span>
<% else %>
<span class="tui-scroll-indicator tui-scroll-indicator--top"
      data-tui-scroll-indicator-target="top"
      aria-hidden="true">▲</span>
<span class="tui-scroll-indicator tui-scroll-indicator--handle"
      data-tui-scroll-indicator-target="handle"
      aria-hidden="true">█</span>
<span class="tui-scroll-indicator tui-scroll-indicator--bottom"
      data-tui-scroll-indicator-target="bottom"
      aria-hidden="true">▼</span>
<% end %>
