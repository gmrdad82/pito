<%# Tui::TotpCodeComponent — segmented code input.
    Mode :digits renders 6 numeric boxes; mode :backup renders 8 alphanumeric boxes.
    The tui-totp-code Stimulus controller wires per-box handlers and syncs the
    hidden aggregation field on every change so the parent form submits the
    expected params[field] value. %>
<div class="totp-modal-boxes"
     <%= hidden? ? "hidden" : "" %>
     data-controller="<%= stimulus_controller %>"
     data-tui-totp-code-mode-value="<%= @mode %>"
     data-tui-totp-code-field-value="<%= field %>">
  <% box_count.times do |i| %>
    <input type="text"
           maxlength="1"
           inputmode="<%= inputmode %>"
           <% if pattern %> pattern="<%= pattern %>"<% end %>
           autocomplete="<%= i.zero? ? "one-time-code" : "off" %>"
           <% if i.zero? && autofocus? %>autofocus<% end %>
           aria-label="<% if mode_digits? %>digit <%= i + 1 %><% else %>backup code character <%= i + 1 %><% end %>"
           class="totp-modal-box"
           data-tui-totp-code-target="<%= controller_target %>"
           data-action="input->tui-totp-code#onInput change->tui-totp-code#onInput keydown->tui-totp-code#onKeydown paste->tui-totp-code#onPaste blur->tui-totp-code#onCellBlur">
  <% end %>
  <input type="hidden"
         name="<%= field %>"
         value=""
         data-tui-totp-code-target="hidden">
</div>
