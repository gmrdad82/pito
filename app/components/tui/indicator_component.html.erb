<% case mode
when :idle %><span class="<%= css_class %>" data-controller="tui-indicator" data-tui-indicator-variant-value="<%= variant %>" data-tui-indicator-start-offset-value="<%= start_offset %>"></span><% when :indeterminate %><span class="<%= css_class %>" data-controller="tui-indicator" data-tui-indicator-variant-value="<%= variant %>" data-tui-indicator-start-offset-value="<%= start_offset %>"><%= initial_frame %></span><% when :progress %><span class="<%= css_class %>"><% if progress_bar %><span class="tui-indicator__bar"><%= progress_bar %></span><% end %><% if progress_label %><span class="tui-indicator__counter"><%= progress_label %></span><% end %></span><% when :error %><span class="<%= css_class %>">✗</span><% end -%>