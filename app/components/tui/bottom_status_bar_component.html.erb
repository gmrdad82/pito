<%#
  Beta 4 — Phase F1. Bottom status bar template. Sticky-bottom counterpart
  to `Tui::TopStatusBarComponent`. Renders the mode lozenge, the 8-section
  nav row, and the `?` / `:` hint markers. A separate dispatch will wire
  the `tui-bottom-status-bar` Stimulus controller; the data-controller
  attribute is mounted here so the JS dispatch only needs to drop the
  controller file in.
%>
<footer class="bsb-bar" data-controller="tui-bottom-status-bar">
  <span class="bsb-mode bsb-mode--<%= mode %>"><%= mode %></span>
  <span class="bsb-pipe">|</span>
  <span class="bsb-sections">
    <% SECTIONS.each do |section| %>
      <a href="<%= section_path(section) %>" class="<%= section_classes(section) %>"><%= section_label(section) %></a>
    <% end %>
  </span>
  <span class="bsb-pipe">|</span>
  <span class="bsb-hints">
    <span class="bsb-hint-key">?</span><span class="bsb-hint-label"> help</span>
    <span class="bsb-hint-spacer"></span>
    <span class="bsb-hint-key">:</span><span class="bsb-hint-label"> command</span>
  </span>
</footer>
