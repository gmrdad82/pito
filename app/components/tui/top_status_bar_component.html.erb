<%#
  R10b (2026-05-25). Top status bar template. Simplified to 3 slots:
  [app version] .... [empty center] .... [ [ ] sync | DateTime ]

  Left:   AppVersionComponent
  Center: empty (was TstNoticeComponent; moved to ephemeral-notice territory;
          center is visually blank to keep the TST uncluttered)
  Right:  SyncIndicatorComponent + pipe + DateTimeComponent

  The parent `tui-status-bar` controller (Lane C) dispatches custom DOM
  events (`tui:sync-changed`) on every `pito:status_bar` cable payload;
  child VCs' Stimulus controllers listen for their event and patch in place.

  Removed from TST (R10b):
  - BreadcrumbComponent   → moved to BST left zone
  - TstNoticeComponent    → center slot now empty
  - ScreensListComponent  → was already removed in R2
  - SidekiqStatsComponent → was already moved to BST in Phase 2 (2026-05-22)
  - HelpHintComponent     → moved to BST right zone
  - CommandHintComponent  → moved to BST right zone
%>
<div class="sb-bar"
     data-controller="tui-status-bar"
     data-cable-channel="pito:status_bar"
     data-tui-status-bar-target="root">
  <div class="sb-left">
    <%= render Tui::AppVersionComponent.new %>
  </div>
  <div class="sb-center">
  </div>
  <div class="sb-right">
    <% if progress_visible? %>
      <span class="sb-progress-bar" data-tui-status-bar-target="progressBar">
        <% filled, empty = progress_bar_cells %>
        <span class="sb-progress-bar-filled"><%= filled %></span><span class="sb-progress-bar-empty"><%= empty %></span>
      </span>
      <span class="sb-progress-counter" data-tui-status-bar-target="progressCounter"><%= progress_counter %></span>
    <% end %>
    <%= render Tui::SyncIndicatorComponent.new(state: sync_state) %>
    <span class="sb-pipe">|</span>
    <%= render Tui::DateTimeComponent.new %>
  </div>
</div>
