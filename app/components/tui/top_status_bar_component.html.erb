<%#
  Beta 4 — Phase F1 Lane B. Top status bar template. Mirrors V3 of
  `tmp/demo-status-bar-final.html` (which exercises every state slot:
  section + page tail + progress + sync target + colored Sidekiq).
  Lane C's `tui-status-bar` Stimulus controller subscribes to
  `pito:status_bar` via the `data-cable-channel` root attribute and
  updates the marked `data-tui-status-bar-target` cells in place.

  FB-161 (2026-05-21): three sub-elements extracted to their own
  ViewComponents per "ViewComponents are kings":
  - Tui::SyncIndicatorComponent  — ●/✗ + word + optional target
  - Tui::SidekiqStatsComponent   — b/e/r cells
  - Tui::DateTimeComponent       — wall clock (SSR placeholder, hydrated by Stimulus)
  Stimulus target attributes are preserved on the extracted roots so
  the cable update contract stays intact.
%>
<div class="sb-bar"
     data-controller="tui-status-bar"
     data-cable-channel="pito:status_bar"
     data-tui-status-bar-target="root">
  <div class="sb-left">
    <span class="sb-version"><%= version %></span>
    <span class="<%= section_class %>" data-tui-status-bar-target="section"><%= section %><% if page %><span class="sb-page-tail">:(<span class="sb-page-name"><%= page %></span>)</span><% end %></span>
  </div>
  <div class="sb-right">
    <% if progress_visible? %>
      <span class="sb-progress-bar" data-tui-status-bar-target="progressBar">
        <% filled, empty = progress_bar_cells %>
        <span class="sb-progress-bar-filled"><%= filled %></span><span class="sb-progress-bar-empty"><%= empty %></span>
      </span>
      <span class="sb-progress-counter" data-tui-status-bar-target="progressCounter"><%= progress_counter %></span>
    <% end %>
    <%= render Tui::SyncIndicatorComponent.new(state: sync_state, target: sync_target) %>
    <span class="sb-pipe">|</span>
    <%= render Tui::SidekiqStatsComponent.new(
      busy: sidekiq_stats[:busy],
      enqueued: sidekiq_stats[:enqueued],
      retry: sidekiq_stats[:retry]
    ) %>
    <span class="sb-pipe">|</span>
    <%= render Tui::DateTimeComponent.new %>
  </div>
</div>
