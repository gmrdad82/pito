<%= render Tui::DialogComponent.new(
      id: id,
      title: dialog_title,
      screen_accent: :home
    ) do |dialog| %>
  <% dialog.with_body do %>
    <div class="cal-day-dialog__body">
      <% if empty? %>
        <p class="cal-day-dialog__empty"><%= I18n.t("tui.home.panels.calendar.day_dialog.empty") %></p>
      <% else %>
        <table class="cal-day-dialog__table">
          <tbody>
            <% entries.each do |entry| %>
              <tr class="cal-day-dialog__row">
                <td class="cal-day-dialog__kind-cell">
                  <span class="tui-chip <%= entry_kind_class(entry) %>"><%= entry_category(entry) %></span>
                </td>
                <td class="cal-day-dialog__title-cell"><%= entry.title %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  <% end %>
<% end %>
