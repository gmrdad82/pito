<%# Tui::CodeComponent — bordered monospace command display with optional [ copy ] action.
    Uses .code-block + .code-block code CSS rules (application.css § Item 1 — Code-block).
    When copyable: true, the clipboard-copy Stimulus controller wires the action to
    navigator.clipboard.writeText. %>
<div class="code-block"
     <% if copyable? %>
     data-controller="clipboard-copy"
     data-clipboard-copy-toast-message-value="<%= copied_message %>"
     <% end %>>
  <code <% if copyable? %>data-clipboard-copy-target="source"<% end %>><%= text %></code>
  <% if copyable? %>
    <%= render Tui::ActionComponent.new(
          label: copy_label,
          as: :button,
          data: { action: "click->clipboard-copy#copy" }) %>
  <% end %>
</div>
