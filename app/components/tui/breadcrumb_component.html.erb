<%
  base_data = transitionable_data[:data]
  data_attrs = base_data.merge(
    controller: "tui-breadcrumb #{base_data[:controller]}",
    tui_status_bar_target: "section",
    tui_breadcrumb_screen_value: screen,
    tui_breadcrumb_tui_transition_outlet: ".sb-section"
  )
%>
<%= content_tag :span, current_value, class: "sb-section", data: data_attrs %>
