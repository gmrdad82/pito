<%= content_tag :span, class: "tui-view-toggle", data: root_data do %><% renderables.each do |v| %><button type="button" class="<%= v[:classes] %>" aria-pressed="<%= v[:active] ? "true" : "false" %>" data-action="click->tui-view-toggle#switch" data-tui-view-toggle-view-param="<%= v[:name] %>" data-tui-focusable="view_<%= v[:name] %>" data-tui-focusable-key="<%= v[:name] %>"><%= v[:visible_text] %></button><% end %><% end %>
