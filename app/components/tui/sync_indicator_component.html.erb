<span class="sb-sync" data-tui-status-bar-target="sync">
  <span class="<%= dot_class %>" data-tui-status-bar-target="syncDot"><%= dot_glyph %></span><span class="<%= word_class %>" data-tui-status-bar-target="syncWord"><%= word %></span><% if target_visible? %>
    <span class="sb-sync-target" data-tui-status-bar-target="syncTarget"><%= target %></span>
  <% end %>
</span>
