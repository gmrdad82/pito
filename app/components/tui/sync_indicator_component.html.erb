<%# Tui::SyncIndicatorComponent — 3-state sync indicator for TST.
    States: synced (muted [ ] sync) / syncing (accent [x] sync + shimmer) /
    disconnected (danger [ ] sync, color-only). JS controller drives state
    transitions via pito:cable-activity + pito:cable:disconnected + pito:cable:connected. %>
<span class="tui-sync-indicator"
      data-controller="tui-sync-indicator"
      data-tui-sync-indicator-state-value="<%= initial_state %>">
  <span class="tui-sync-indicator__box" aria-hidden="true">[<%= glyph_for(initial_state) %>]</span>
  <span class="tui-sync-indicator__label">sync</span>
</span>
