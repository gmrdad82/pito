<div class="diff-decision">
  <label for="<%= input_id(DiffDecisionRadioComponent::PITO) %>" class="diff-decision-label<%= " is-disabled" if pito_disabled? %>">
    <input type="radio"
           id="<%= input_id(DiffDecisionRadioComponent::PITO) %>"
           name="<%= input_name %>"
           value="<%= DiffDecisionRadioComponent::PITO %>"
           <%= "checked" if pito_checked? %>
           <%= "disabled" if pito_disabled? %>>
    [ <span class="bl">accept pito</span> ]
  </label>
  <label for="<%= input_id(DiffDecisionRadioComponent::YOUTUBE) %>" class="diff-decision-label">
    <input type="radio"
           id="<%= input_id(DiffDecisionRadioComponent::YOUTUBE) %>"
           name="<%= input_name %>"
           value="<%= DiffDecisionRadioComponent::YOUTUBE %>"
           <%= "checked" if youtube_checked? %>
           <%= "disabled" if youtube_disabled? %>>
    [ <span class="bl">accept youtube</span> ]
  </label>
  <% if disabled %>
    <span class="text-muted" style="margin-left: 6px;">(display-only)</span>
  <% end %>
</div>
