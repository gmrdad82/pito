<%# Verbatim transplant of the netflix-3 placeholder previously
    inline in `app/views/bundles/games_pane.html.erb`. Three cells
    (one `--main` + two regular) each rendering the single-dark
    controller-icon SVG. The `--modal` modifier on the wrapper
    lifts the icon max-width caps for the larger modal cover;
    absent modifier renders shelf-tile sizing. Single-dark since
    the THEME-REMOVE-COMPONENTS phase 1 sweep. %>
<div class="<%= wrapper_classes %>"
     aria-label="<%= label %>"
     title="<%= label %>">
  <div class="cell cell--main">
    <%= image_tag image_path("controller_icon_dark.svg"),
                  alt: "", loading: "lazy",
                  class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--large" %>
  </div>
  <div class="cell">
    <%= image_tag image_path("controller_icon_dark.svg"),
                  alt: "", loading: "lazy",
                  class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small" %>
  </div>
  <div class="cell">
    <%= image_tag image_path("controller_icon_dark.svg"),
                  alt: "", loading: "lazy",
                  class: "bundle-tile__nocover-icon bundle-tile__nocover-icon--small" %>
  </div>
</div>
