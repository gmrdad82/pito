<%# Calendar refactor 2026-05-11 — month-grid chip.
    Lowercase monospace per docs/design.md. Click opens the entry
    details modal (handled by the `calendar-entry-modal` Stimulus
    controller mounted on the layout-level <dialog>). The `href` is a
    JS-off fallback pointing at the canonical entry show page. %>
<a href="<%= fallback_href %>"
   class="<%= state_class %> calendar-entry-chip"
   data-action="click->calendar-entry-modal#open"
   data-calendar-entry-modal-url-param="<%= details_pane_url %>"
   style="display: block; text-decoration: none; color: inherit; cursor: pointer; font-size: 12px; line-height: 1.2; padding: 1px 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
  <span class="calendar-entry__type" style="opacity: 0.7;"><%= type_label %></span>
  <% if time_label.present? %>
    <span class="calendar-entry__time" style="opacity: 0.6;"><%= time_label %></span>
  <% end %>
  <span class="calendar-entry__title"><%= title %></span>
</a>
