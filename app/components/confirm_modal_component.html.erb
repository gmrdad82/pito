<%# `data-modal-actions-key` is rendered conditionally — only when the
    invoker opts into the leader-menu modal-context flow by passing
    `modal_actions_key:`. Per-invocation; revoke + reindex both pass
    their own key (`revoke_confirm` / `reindex_confirm`). Bare confirm
    modals (per-game / per-bundle delete, etc.) omit the kwarg and
    render without the attribute, falling back to the page's regular
    leader-menu surface. %>
<dialog id="<%= @id %>" class="confirm-modal"
        data-controller="confirm-modal"
        data-action="click->confirm-modal#clickOutside keydown->confirm-modal#keydown"
        <% if @modal_actions_key.present? %>data-modal-actions-key="<%= @modal_actions_key %>"<% end %>>
  <div class="confirm-modal-inner">
    <div class="dialog-title"><%= @title %></div>
    <% if @body.present? %>
      <div class="dialog-message"><%= @body %></div>
    <% end %>
    <div class="confirm-modal-actions modal-footer">
      <%= form_with url: @confirm_path, method: @confirm_method, authenticity_token: true, data: { turbo: @turbo }, html: { style: "display: inline;" } do %>
        <button type="submit" class="<%= confirm_button_classes %>">[<span class="bl"><%= @confirm_label %></span>]</button>
      <% end %>
      <button type="button" class="bracketed text-muted" data-action="confirm-modal#close">[<span class="bl"><%= @cancel_label %></span>]</button>
    </div>
  </div>
</dialog>
