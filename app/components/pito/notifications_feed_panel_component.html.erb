<%# Pito::NotificationsFeedPanelComponent — in-app notifications feed (clean slate).
    Border actions: [read] [unread] — mark all read / mark all unread.
    Body: placeholder pending rebuild.
    Cable: pito:home:notifications_feed. %>
<%= content_tag :section,
      class: "pane pito-pane pito-panel pito-panel--notifications-feed",
      **panel_data do %>
  <span class="pito-pane__title"><%= title %></span>
  <span class="pito-pane__title-actions">
    <%= form_with url: mark_read_notifications_feed_index_path,
          method: :post,
          data: { "turbo-frame": Pito::NotificationsFeedPanelComponent::FRAME_ID } do |f| %>
      <%= f.button "[read]", type: "submit", class: "bracketed-action" %>
    <% end %>
    <%= form_with url: mark_unread_notifications_feed_index_path,
          method: :post,
          data: { "turbo-frame": Pito::NotificationsFeedPanelComponent::FRAME_ID } do |f| %>
      <%= f.button "[unread]", type: "submit", class: "bracketed-action" %>
    <% end %>
  </span>
  <turbo-frame id="<%= Pito::NotificationsFeedPanelComponent::FRAME_ID %>">
    <%= render Tui::PanelFieldsetComponent.new do %>
      <span class="color-muted">notifications feed body removed — pending rebuild</span>
    <% end %>
  </turbo-frame>
<% end %>
