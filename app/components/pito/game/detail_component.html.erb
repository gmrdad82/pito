<%# Pito::Game::DetailComponent — game detail card for chat messages %>
<div class="pito-game-detail flex flex-col gap-3">

  <%# Cover art or placeholder %>
  <div class="pito-game-detail__cover">
    <% if cover_art_attached? %>
      <% url = cover_art_url %>
      <% if url %>
        <%= image_tag url, alt: @game.title, class: "block max-w-full" %>
      <% else %>
        <div class="text-fg-dim"><%=t "pito.game.detail.no_cover" %></div>
      <% end %>
    <% else %>
      <div class="text-fg-dim"><%=t "pito.game.detail.no_cover" %></div>
    <% end %>
  </div>

  <%# Title %>
  <div class="text-fg font-bold"><%= @game.title %></div>

  <%# Developer %>
  <% if developer_names.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.developer" %>:</span><span class="text-fg"><%= developer_names %></span>
    </div>
  <% end %>

  <%# Publisher %>
  <% if publisher_names.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.publisher" %>:</span><span class="text-fg"><%= publisher_names %></span>
    </div>
  <% end %>

  <%# Release %>
  <% if release_label.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.release" %>:</span><span class="text-fg"><%= release_label %></span>
    </div>
  <% end %>

  <%# Available platforms %>
  <% if platforms_label.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.platforms" %>:</span><span class="text-fg"><%= platforms_label %></span>
    </div>
  <% end %>

  <%# Owned platforms %>
  <% if owned_platforms_label.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.owned" %>:</span><span class="text-fg"><%= owned_platforms_label %></span>
    </div>
  <% end %>

  <%# Description %>
  <% if summary.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.description" %>:</span><span class="text-fg"><%= summary %></span>
    </div>
  <% end %>

  <%# Genres %>
  <% if genres_label.present? %>
    <div class="flex gap-2">
      <span class="text-fg-dim"><%=t "pito.game.detail.genres" %>:</span><span class="text-fg"><%= genres_label %></span>
    </div>
  <% end %>

  <%# Time-to-beat %>
  <div class="pito-game-detail__ttb">
    <%= render(Pito::TimeToBeatComponent.new(game: @game, footage_hours: footage_hours)) %>
  </div>

  <%# Score bar %>
  <div class="pito-game-detail__score">
    <%= render(Pito::ScoreBarComponent.new(game: @game)) %>
  </div>

</div>
