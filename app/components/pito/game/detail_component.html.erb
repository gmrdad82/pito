<%# Pito::Game::DetailComponent — game detail card, two columns.
    LEFT = 480px cover + hairline + V/L/C stats + legend + optional Shinies.
    RIGHT = kv-table (Title first, then ID … Price), hairline, Score+TTB bars,
    hairline, Description at the bottom. %>
<div class="pito-game-detail flex gap-4 items-start">

  <%# ── Left column: intro (with timestamp slot), cover, stats, legend, Shinies ── %>
  <div class="pito-game-detail__left flex flex-col gap-3">

    <% if @intro.present? %>
      <div class="pito-game-detail__intro text-fg flex flex-wrap items-baseline"><span data-pito-ts-slot></span><%= @intro %></div>
    <% end %>

    <%# Cover art or placeholder %>
    <div class="pito-game-detail__cover">
      <% if cover_art_attached? && (url = detail_cover_url) %>
        <%= image_tag url, alt: @game.title, class: "block" %>
      <% else %>
        <div class="text-fg-dim"><%=t "pito.game.detail.no_cover" %></div>
      <% end %>
    </div>

    <%# Hairline separating the cover from the stats %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded)) %>

    <%# Stats — bold heading (Pito::Copy) + one-line counters (V/L/C), left. %>
    <div class="pito-game-detail__stats flex flex-col gap-1">
      <div class="pito-game-detail__stats-heading text-fg-dim font-bold"><%= Pito::Copy.render("pito.copy.stats.heading") %></div>
      <%= render(Pito::Stats::CountersComponent.new(metrics: stat_counter_metrics, align: :left)) %>
    </div>

    <%# Shinies — only when the game has at least one achievement. Badges align
        left (inner text stays centered); the legend below is left-aligned too. %>
    <% if @game.achievements.any? %>
      <div class="flex flex-col gap-1">
        <div class="pito-game-detail__shinies-heading text-fg-dim font-bold"><%= Pito::Copy.render("pito.copy.shinies.heading") %></div>
        <div class="pito-game-detail__shinies flex flex-wrap gap-2">
          <% top_shinies_per_metric.each do |a| %>
            <%= render(Pito::Achievement::BadgeComponent.new(threshold: a.threshold, metric: a.metric, unlocked_on: a.unlocked_at.to_date)) %>
          <% end %>
        </div>
        <p class="pito-game-detail__shinies-legend text-fg-dim italic text-left"><%= Pito::Copy.render("pito.copy.shinies.legend") %></p>
      </div>
    <% end %>
  </div>

  <%# ── Right column: kv-table (Title first), hairline, Score+TTB, hairline, Description ── %>
  <div class="pito-game-detail__right flex flex-col gap-2 flex-1 min-w-0">

    <%# Details — Title is the first row, then ID, platforms … price %>
    <div class="grid grid-cols-[max-content_1fr] gap-x-2 gap-y-1">
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.title"),
            value_text:  @game.title,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.id"),
            value_text:  "##{@game.id}",
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <% if platforms_icons.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.platforms"),
              value_text:  platforms_icons,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if genres_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.genres"),
              value_text:  genres_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if themes_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.themes"),
              value_text:  themes_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if perspectives_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.perspective"),
              value_text:  perspectives_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if developer_names.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.developer"),
              value_text:  developer_names,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if publisher_names.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.publisher"),
              value_text:  publisher_names,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if release_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.game.detail.release"),
              value_text:  release_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.footage"),
            value_text:  footage_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg tabular-nums"
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.price"),
            value_text:  price_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg tabular-nums"
          )) %>
    </div>

    <%# Hairline before the bars (carries its own spacing via my:) %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-hairline")) %>

    <%# Score + TTB bars %>
    <div class="pito-game-detail__score">
      <%= render(Pito::ScoreBarComponent.new(game: @game, label: score_bar_label)) %>
    </div>
    <div class="pito-game-detail__ttb">
      <%= render(Pito::TimeToBeatComponent.new(game: @game, footage_hours: footage_hours, label: ttb_bar_label)) %>
    </div>

    <%# Divider hairline between the bars and the description %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-hairline")) %>

    <%# Description — label on its own row, body beneath %>
    <% if summary.present? %>
      <div class="text-fg-dim mt-1"><%= t("pito.game.detail.description") %></div>
      <div class="pito-game-detail__description text-fg"><%= summary %></div>
    <% end %>
  </div>

</div>
