<%# Pito::Game::EnhancedComponent — rich recommendations message after Voyage indexing %>
<%# Intro leads inline (outside the flex wrapper) so the event timestamp
    ("HH:MM ·", rendered before the body) sits on the SAME row as it; the rest of
    the enhanced message follows as a block below. %>
<span class="pito-game-enhanced-message__intro text-fg"><%= intro %></span>
<div class="pito-game-enhanced-message">

  <% if channels? %>
    <%# 2. Spacer + channel section header %>
    <p class="pito-game-enhanced-message__section-header text-fg-dim"><%= channels_header %></p>

    <%# Channel grid: one column per channel, using shared ItemComponent %>
    <div class="pito-game-enhanced-message__channel-grid">
      <% channel_results.each do |result| %>
        <div class="pito-game-enhanced-message__channel-col">
          <%= render(Pito::Channel::ItemComponent.new(
                channel:     result.channel,
                show_visit:  false,
                show_avatar: true,
                score:       result.score
              )) %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if similar_games? %>
    <%# Spacer between sections (only shown when we have something above) %>
    <% if channels? %>
      <div class="pito-game-enhanced-message__spacer" aria-hidden="true"></div>
    <% end %>

    <%# 3. Similar games section header %>
    <p class="pito-game-enhanced-message__section-header text-fg-dim"><%= similar_games_header %></p>

    <%# Similar games strip: inline wrapping small cover cards %>
    <div class="pito-game-enhanced-message__similar-games-strip">
      <% similar_game_results.each do |result| %>
        <div class="pito-game-enhanced-message__similar-game-card"
             data-game-id="<%= result.game.id %>">
          <% url = cover_art_url_for(result.game) %>
          <% if url %>
            <%= image_tag url,
                          alt: result.game.title,
                          class: "pito-game-enhanced-message__similar-game-cover block" %>
          <% else %>
            <div class="pito-game-enhanced-message__similar-game-cover pito-game-enhanced-message__similar-game-cover--placeholder text-fg-faded">
              ?
            </div>
          <% end %>
          <%# id and title on one line: "#12 · Elden Ring". Flex keeps the id and
              · fixed while the title truncates; flex also suppresses the monospace
              inter-element whitespace gap. %>
          <div class="pito-game-enhanced-message__similar-game-line">
            <span class="pito-game-enhanced-message__similar-game-id text-fg-faded">#<%= result.game.id %></span>
            <%= render(Pito::Shell::InlineSeparatorComponent.new) %>
            <span class="pito-game-enhanced-message__similar-game-title text-fg"><%= result.game.title %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
