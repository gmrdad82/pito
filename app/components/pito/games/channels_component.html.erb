<%# Pito::Games::ChannelsComponent — channel DISTRIBUTION (col 1) + RECOMMENDATION
    (col 2), two 450px columns aligned on desktop, stacked on mobile.
    Intro leads inline so the event timestamp sits on the same row. %>
<span class="pito-game-enhanced-message__intro text-fg"><%= raw(intro) %></span>
<% if channels? %>
  <div class="pito-game-enhanced-message">
    <div class="pito-game-channels">
      <div class="pito-game-channels__col pito-game-channels__col--dist">
        <%= render(Pito::Games::ChannelDistributionComponent.new(
              caption: distribution_caption, shares: shares
            )) %>
      </div>
      <div class="pito-game-channels__col pito-game-channels__col--reco">
        <%= render(Pito::Games::ChannelScoreTableComponent.new(
              results: channel_results, caption: recommendation_caption
            )) %>
      </div>
    </div>
  </div>
<% end %>
