<%# Pito::Achievement::MetricRowComponent
    Material rail + obtained badges for one metric lane — full width, badges
    flowing FLUID left->right (owner G127; the centered towers are gone). %>
<div class="pito-achievement-metric-row flex flex-col gap-2">
  <%= render(Pito::Achievement::TrackComponent.new(label: label, current_value: current_value,
                                                   scope: @entity.class.polymorphic_name, metric: @metric)) %>

  <% if obtained_achievements.any? %>
    <div class="pito-achievement-metric-row__badges flex flex-wrap justify-start gap-2">
      <% obtained_achievements.each do |achievement| %>
        <%= render(Pito::Achievement::BadgeComponent.new(
              metric:      achievement.metric,
              threshold:   achievement.threshold,
              scope:       achievement.achievable_type,
              unlocked_on: achievement.unlocked_at.to_date
            )) %>
      <% end %>
    </div>
  <% end %>
</div>
