<%# Pito::StackPanelComponent — system stack monitoring panel on Home.

    Composes 4 brand sub-panel ViewComponents in a 2x2 grid:

      row 1: Meilisearch | Voyage AI
      row 2: Postgres    | Assets

    The Redis sub-panel was dropped 2026-05-23 (no dedicated VC ever
    existed — Redis was rendered inline via `Sidekiq::CountersComponent`
    here). The Sidekiq counters surface has been retired with it.

    The two reindex confirmation dialogs (Meilisearch + Voyage) sit at
    the bottom of the panel, OUTSIDE the sub-panel grid, so each
    `<dialog>` is a sibling of its click trigger and `showModal()`
    resolves cleanly. Both dialogs share the canonical danger styling
    on the confirm action.

    Phase 2C (2026-05-23) — root element flows through
    `Tui::PanelBase#panel_root_data` so the panel registers as a
    tui-cursor target and a tui-panel-cable subscriber (canonical
    Stimulus + cable wiring). Title sourced from
    `tui.home.panels.stack.title` so the future Ratatui client reads the
    same YAML. %>
<%= content_tag :section,
      class: "pane pane--wide pito-pane pito-pane--full pito-panel pito-panel--stack",
      **panel_data do %>
  <span class="pito-pane__title"><%= title %></span>
  <%# Phase 1D (2026-05-24) — panel-level sync indicator. Disabling here
      cascades to the 4 stack sub-panels (cable suppression layer reads
      both self + parent flags). Replaces the deleted PauseControlComponent
      `||` glyph with the canonical `[ ] sync` checkbox-style indicator. %>
  <span class="pito-pane__title-actions">
    <%= render Tui::SyncIndicatorComponent.new(
      mode: :target,
      target: "home.stack",
      focusable_key: "stack_sync"
    ) %>
  </span>
  <%= render Tui::PanelFieldsetComponent.new do %>
    <%# 2x2 sub-panel grid — see `.pito-stack-grid` in application.css. %>
    <div class="pito-stack-grid">
      <%= render meilisearch_sub_panel %>
      <%= render voyage_sub_panel %>
      <%= render postgres_sub_panel %>
      <%= render assets_sub_panel %>
    </div>
  <% end %>
  <%# FB-126 (2026-05-21) — confirmation dialog mounts for each reindex
      sub-panel. Kept at the bottom of the pane (outside the sub-panel
      grid) so `<dialog>` is a sibling of the click trigger; the
      `Tui::ConfirmationDialogComponent` carries the actual POST form
      with `data-turbo: false` so the redirect-back flow stays intact.
      Both dialogs share the canonical danger styling on the confirm
      action. %>
  <%= render Tui::ConfirmationDialogComponent.new(
    id: "reindex_meilisearch_confirmation",
    title: t("settings.stack.meilisearch_reindex_confirm_title"),
    message: t("settings.stack.meilisearch_reindex_confirm_message"),
    action_label: t("settings.stack.meilisearch_reindex_label"),
    action_path: helpers.settings_stack_meilisearch_reindex_path,
    action_method: :post,
    action_variant: :danger
  ) %>
  <%= render Tui::ConfirmationDialogComponent.new(
    id: "reindex_voyage_confirmation",
    title: t("settings.stack.voyage_reindex_confirm_title"),
    message: t("settings.stack.voyage_reindex_confirm_message"),
    action_label: t("settings.stack.voyage_reindex_label"),
    action_path: helpers.settings_stack_voyage_reindex_path,
    action_method: :post,
    action_variant: :danger
  ) %>
<% end %>
