<%# Sidebar conversation list — Recent section + optional Older section %>
<div class="flex flex-col">
  <%# Recent section %>
  <div class="mb-2">
    <div class="text-orange font-bold mb-1"><%= t("pito.sidebar.conversations.recent") %></div>
    <% recent.each do |conversation| %>
      <div class="pito-conversation-row flex justify-between items-baseline py-1 px-2 rounded cursor-pointer hover:bg-bg-hover <%= "is-current" if current?(conversation) %>"
           data-conversation-uuid="<%= conversation.uuid %>">
        <span class="text-fg truncate mr-2"><%= conversation.display_name %></span>
        <span class="text-fg-dim text-xs shrink-0"><%= formatted_timestamp(conversation) %></span>
      </div>
    <% end %>
  </div>

  <% if show_older_section? %>
    <%# Hairline divider %>
    <hr class="border-line-default my-2">

    <%# Older section %>
    <div class="mb-2">
      <div class="text-orange font-bold mb-1"><%= t("pito.sidebar.conversations.older") %></div>
      <% older.each do |conversation| %>
        <div class="pito-conversation-row flex justify-between items-baseline py-1 px-2 rounded cursor-pointer hover:bg-bg-hover <%= "is-current" if current?(conversation) %>"
             data-conversation-uuid="<%= conversation.uuid %>">
          <span class="text-fg truncate mr-2"><%= conversation.display_name %></span>
          <span class="text-fg-dim text-xs shrink-0"><%= formatted_timestamp(conversation) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
