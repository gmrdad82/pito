<%# Sidebar conversation list — Recent section + optional Older section %>
<div class="flex flex-col">
  <%# Recent section %>
  <div class="mb-2">
    <%= render(Pito::Section::SectionHeaderComponent.new(text: t("pito.sidebar.conversations.recent"), color: :orange)) %>
    <% recent.each do |conversation| %>
      <%= render partial: "conversations/row",
                 locals: { conversation: conversation, current: current?(conversation),
                           timestamp: formatted_timestamp(conversation) } %>
    <% end %>
  </div>

  <% if show_older_section? %>
    <%# Hairline divider %>
    <hr class="border-line-default my-2">

    <%# Older section %>
    <div class="mb-2">
      <%= render(Pito::Section::SectionHeaderComponent.new(text: t("pito.sidebar.conversations.older"), color: :orange)) %>
      <% older.each do |conversation| %>
        <%= render partial: "conversations/row",
                   locals: { conversation: conversation, current: current?(conversation),
                             timestamp: formatted_timestamp(conversation) } %>
      <% end %>
    </div>
  <% end %>
</div>
