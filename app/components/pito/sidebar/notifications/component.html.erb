<%# Sidebar notifications list — stacked rows: relative time, then the full
    (word-wrapped) message. Arrow up/down move the highlight (landing on an
    unread row marks it read); clicking a row toggles read/unread
    (pito--notifications-nav). The list is keyset-paginated: scrolling to the
    bottom (or ↓ at the last row) loads the next page (pito--list-pager). %>
<div class="flex flex-col gap-2" data-controller="pito--notifications-nav pito--list-pager">
  <% if notifications.empty? %>
    <div class="text-fg-dim py-2">No notifications</div>
  <% else %>
    <div id="pito-notifications-list" class="flex flex-col gap-2" data-pito--list-pager-target="list">
      <% notifications.each do |notification| %>
        <%= render "notifications/row", notification: notification %>
      <% end %>
    </div>
    <%= render(Pito::ListPager::SentinelComponent.new(next_url: next_url)) %>
  <% end %>
</div>
