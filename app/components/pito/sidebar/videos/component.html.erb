<%# Videos sidebar body — search input + flat list of videos (id + title + @handle).
    The outer div mounts pito--videos-nav; the input target drives debounced local
    search; the list target is swapped out by the controller when results arrive. %>
<div class="flex flex-col gap-3"
     data-controller="pito--videos-nav">
  <%# Search input — filters the local video library (POST /videos/search-local). %>
  <div class="relative">
    <input type="text"
           class="w-full bg-transparent outline-none border-b border-line-default
                  text-fg pb-1 placeholder:text-fg-faded focus:border-accent"
           placeholder="<%= t('pito.sidebar.videos.search_placeholder') %>"
           autocomplete="off"
           data-pito--videos-nav-target="input">
  </div>

  <%# In-flight shimmer dots while a local search runs (mirrors the IGDB import
      search). Hidden until a query is sent. Clipped to one row at any base size. %>
  <p class="hidden overflow-hidden whitespace-nowrap"
     data-pito--videos-nav-target="shimmer">
    <%= render(Pito::Shell::ShimmerTextComponent.new(text: ". " * 60)) %>
  </p>

  <%# Video rows container — swapped out by the debounced local search; also
      the generic keyset pager's scope (scrolling the sentinel into view
      appends the next 50 via GET /videos/picker). The stable inner id is the
      append target. %>
  <div class="flex flex-col"
       data-controller="pito--list-pager"
       data-pito--videos-nav-target="list">
    <% if empty? %>
      <p class="text-fg-dim py-2"><%= empty_state_text %></p>
    <% else %>
      <div id="pito-videos-picker-rows" class="flex flex-col" data-pito--list-pager-target="list">
        <%= render partial: "videos/picker_rows", locals: { videos: videos } %>
      </div>
      <% if next_cursor.present? %>
        <%= render(Pito::ListPager::SentinelComponent.new(
              next_url: videos_picker_path(after: next_cursor, format: :turbo_stream)
            )) %>
      <% end %>
    <% end %>
  </div>
</div>
