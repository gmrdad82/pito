<%# GamesImport sidebar body.
    The outer div mounts pito--games-search, which drives:
      - Debounced IGDB search via POST /games/search
      - ↑/↓/Enter keyboard navigation through .pito-igdb-row elements
      - Enter on a row → POST /games/import → 5-step progress in this sidebar
    The conversation UUID is carried as a data attribute so the controller
    can tell the backend which conversation to stream progress to.
    The i18n copy strings for searching/no-results are embedded as data
    attributes so the JS can render server-side witty randomised copy. %>
<div class="flex flex-col gap-3"
     data-controller="pito--games-search"
     data-pito--games-search-conversation-uuid-value="<%= conversation_uuid %>"
     data-pito--games-search-prefill-value="<%= prefill %>"
     data-pito--games-search-i18n-searching-value="<%= Pito::Copy.render('pito.copy.games.igdb_searching') %>"
     data-pito--games-search-i18n-no-results-value="<%= Pito::Copy.render('pito.copy.games.igdb_no_results') %>"
     data-pito--games-search-i18n-error-value="<%= t('pito.sidebar.games_import.error') %>"
     data-pito--games-search-i18n-in-library-value="<%= t('pito.sidebar.games_import.in_library') %>"
     data-pito--games-search-i18n-in-library-hint-value="<%= t('pito.sidebar.games_import.in_library_hint') %>"
     data-pito--games-search-i18n-step-labels-value="<%= [Pito::Copy.render('pito.copy.games.import.step1'), Pito::Copy.render('pito.copy.games.import.step2'), Pito::Copy.render('pito.copy.games.import.step3'), Pito::Copy.render('pito.copy.games.import.step4'), Pito::Copy.render('pito.copy.games.import.step5')].to_json %>">

  <%# Search input — styled like the conversation-rename input.
      Native caret styled as a block via .pito-block-caret (caret-shape: block). %>
  <div class="relative">
    <input type="text"
           class="w-full bg-transparent outline-none border-b border-line-default
                  text-fg pb-1 placeholder:text-fg-faded
                  focus:border-accent pito-block-caret"
           placeholder="<%= t('pito.sidebar.games_import.search_placeholder') %>"
           autocomplete="off"
           data-pito--games-search-target="input"
           value="<%= prefill %>">
  </div>

  <%# Shimmer indicator — shown while talking to IGDB (search or import). %>
  <%# Rendered via ShimmerTextComponent; reuses .pito-shimmer, no new keyframes. %>
  <%# The dot run is intentionally longer than the panel and clipped, so the line
      always reaches the input edge on one row regardless of base font size. %>
  <p class="hidden overflow-hidden whitespace-nowrap"
     data-pito--games-search-target="shimmer">
    <%= render(Pito::Shell::ShimmerTextComponent.new(text: ". " * 60)) %>
  </p>

  <%# Status line (shows witty no-results / error copy) %>
  <p class="text-fg-dim hidden"
     data-pito--games-search-target="status"></p>

  <%# Results list — populated by the controller OR replaced by step rows on import %>
  <div class="flex flex-col gap-1"
       data-pito--games-search-target="results">
  </div>
</div>
