<%# Sidebar — in-flow panel that fills the animated #pito-sidebar mount and sits
    side-by-side with the main content (the shell row shrinks to make room). %>
<aside class="relative h-full w-[480px] bg-root border-l border-line-default overflow-hidden flex flex-col">
  <%# Sticky header %>
  <div class="pt-4 px-4">
    <div class="flex justify-between items-start">
      <div>
        <div class="text-cyan font-bold"><%= @title %></div>
        <% if subtitle? %>
          <div class="text-fg-dim"><%= subtitle %></div>
        <% elsif @subtitle_key %>
          <div class="text-fg-dim"><%= t(@subtitle_key, **@subtitle_args) %></div>
        <% end %>
      </div>
      <span class="text-fg-dim shrink-0"><%= t("pito.sidebar.esc_hint") %></span>
    </div>
  </div>

  <%# Scrollable body — hidden scrollbar, keep scrolling. Extra top padding (pt-7)
      clears the pito-scroll-fade-slim top gradient (~16px) so the first row is
      fully visible at scrollTop 0 instead of sitting under the fade. %>
  <div class="pito-hide-scrollbar pito-scroll-fade-slim flex-1 overflow-y-auto p-4 pt-7">
    <%= body %>
  </div>
</aside>
