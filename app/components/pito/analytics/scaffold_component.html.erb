<div class="pito-analytics-enhanced flex flex-col gap-3">
  <div class="pito-analytics-enhanced__intro text-fg"><span data-pito-ts-slot></span><%= raw(@intro) %></div>
  <% if pending? %>
    <%# Progressive: one LOADING cell per metric, each a <token>__metric_<key> swap
        target the per-metric AnalyzeMetricJob fills in independently. %>
    <% if metric_keys.any? %>
      <div class="pito-analytics-enhanced__panel flex gap-6">
        <div class="pito-analytics-scalars">
          <% metric_keys.each do |key| %>
            <%= render(Pito::Analytics::AnalyzeCellComponent.new(key: key, token: token, loading: true)) %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="pito-analytics-enhanced__panel flex gap-6">
      <div class="pito-analytics-scalars">
        <% @cells.each do |cell| %>
          <% if cell[:heart].present? %>
            <%= render(Pito::Analytics::Visualizers::Heart.new(hearts: cell[:heart], caption: cell[:caption])) %>
          <% elsif cell[:chart].present? %>
            <%= render(Pito::Analytics::Visualizers::Area.new(metric: cell[:chart], series: cell[:series], target_daily: cell[:target_daily], caption: cell[:caption], trend: cell.fetch(:trend, true), reference_token: cell[:reference_token], dates: cell[:dates])) %>
          <% elsif cell[:bars].present? %>
            <%= render(Pito::Analytics::Visualizers::Bar.new(bars: cell[:bars], caption: cell[:caption])) %>
          <% elsif cell[:no_data] %>
            <%= render(Pito::Analytics::Visualizers::NoData.new(caption: cell[:caption])) %>
          <% else %>
            <%= render(Pito::Analytics::Slots::Compact.new(name: cell[:label])) { |c| c.with_scalar { raw(cell[:value].to_s) } } %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
