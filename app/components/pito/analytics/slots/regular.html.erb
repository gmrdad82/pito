<%# Regular metric cell: three branches.
    loading:  NoData(:regular) canvas with the LoadingDots comet IN its caption
              slot (beneath the canvas), so the cell is one grid item.
    no_data:  NoData(:regular) canvas + caption slot (terminal state).
    filled:   visualizer slot + caption slot beneath it. %>
<div class="pito-analytics-scalars__cell"<% if dom_id %> id="<%= dom_id %>"<% end %>>
  <% if loading? %>
    <%# Comet rides in the CAPTION slot beneath the canvas (where the metric
        name/value lands), NOT as a sibling floating over the dotted canvas — so
        the cell stays ONE .pito-metric grid item, not two (17.12). %>
    <%= render(Pito::Analytics::Visualizers::NoData.new(size: :regular, caption: render(Pito::Analytics::Support::LoadingDots.new(seed: key)))) %>
  <% elsif no_data? %>
    <%= render(Pito::Analytics::Visualizers::NoData.new(size: :regular)) %>
    <%= caption %>
  <% else %>
    <%= visualizer %>
    <%= caption %>
  <% end %>
</div>
