<%# Scroll-nav wrapper — the Stimulus controller root + two <template>s. The
    controller CREATES a pill (a clone of the matching template) and appends it
    when there are messages above / below, and REMOVES it from the DOM when there
    are none (owner: create/remove, never show/hide). Pills are position:fixed, so
    this wrapper stays zero-height in the flex column. %>
<div data-controller="pito--scroll-nav"
     data-pito--scroll-nav-variants-value="<%= count_variants_json %>">

  <%# TOP pill template — cloned + appended when messages are above the viewport. %>
  <template data-pito--scroll-nav-target="topTemplate">
    <div class="pito-scroll-nav__pill pito-scroll-nav__pill--top">
      <span class="text-fg-dim" data-scroll-nav-count></span>
      <span class="<%= token_class("ctrl+home") %> cursor-pointer"
            data-action="click->pito--scroll-nav#jumpTop">ctrl+home</span>
      <span class="text-fg-dim"><%= jump_to_start %></span>
    </div>
  </template>

  <%# BOTTOM pill template — cloned + appended when messages are below the viewport. %>
  <template data-pito--scroll-nav-target="bottomTemplate">
    <div class="pito-scroll-nav__pill pito-scroll-nav__pill--bottom">
      <span class="text-fg-dim" data-scroll-nav-count></span>
      <span class="<%= token_class("ctrl+end") %> cursor-pointer"
            data-action="click->pito--scroll-nav#jumpBottom">ctrl+end</span>
      <span class="text-fg-dim"><%= jump_to_end %></span>
    </div>
  </template>
</div>
