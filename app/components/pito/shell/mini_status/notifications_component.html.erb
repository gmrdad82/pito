<%# Notification count is MUTED, non-clickable text (item 7): open notifications via
    the ctrl+/ shortcut (kept). The controller stays only for the new-notification
    chime (latest_id). %>
<span class="inline-flex items-center gap-1" data-controller="pito--notifications-count" data-pito--notifications-count-count-value="<%= @count %>" data-pito--notifications-count-latest-id-value="<%= latest_id %>"><%= render(Pito::Keybinding::ShortcutComponent.new(keys: t("pito.shell.mini_status.notifications_hint"))) %><span class="text-fg-faded tabular-nums"><%= t("pito.shell.mini_status.notifications_count", count: @count) %></span></span>
