<%# Inert until pito--pull-refresh clones it under the scrollback's last message
    (Hotwire Native shell AND mobile-web). Opacity is driven by the drag; the
    stacked block reveals as the pane lifts, and .is-armed flips the circle row to
    the action color once releasing would reload. Rows (top→bottom): a filled
    arrow, the shrug + copy (server-resolved 50-variant dictionaries), two more
    arrows, then the filled circle that arms the reload. The arrows/circle are
    decorative ASCII chrome, not translatable copy. %>
<template id="<%= Pito::Shell::PullRefreshHintComponent::TEMPLATE_ID %>">
  <div class="pito-pull-hint" data-pull-refresh-hint>
    <div class="pito-pull-hint__row pito-pull-hint__arrow">▲</div>
    <div class="pito-pull-hint__row pito-pull-hint__shrug-row">
      <span class="pito-pull-hint__shrug"><%= glyph %></span>
      <span class="pito-pull-hint__text"><%= text %></span>
    </div>
    <div class="pito-pull-hint__row pito-pull-hint__arrow">▲</div>
    <div class="pito-pull-hint__row pito-pull-hint__arrow">▲</div>
    <div class="pito-pull-hint__row pito-pull-hint__circle">●</div>
  </div>
</template>
