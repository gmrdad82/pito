<span id="<%= slot_id %>" class="contents">
  <% if named? %>
    <span class="pito-context-meter__name text-fg-dim"><%= title %></span>
  <% else %>
    <%# Empty spacer keeps the meter header's counter right-aligned when the
        conversation is Unnamed — and the slot itself stays in the DOM so a
        live rename (Unnamed → named) has a target to replace. %>
    <span></span>
  <% end %>
</span>
