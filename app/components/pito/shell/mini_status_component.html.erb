<%# whitespace-nowrap: the auth label ("■ nickname") holds an internal space —
    on narrow panels the browser broke the line INSIDE it, splitting the square
    from the nickname (owner bug 2026-07-03). The status bar is one row, always. %>
<span class="inline-flex items-center whitespace-nowrap">
  <%= render(Pito::Shell::MiniStatus::AuthComponent.new(state: @state)) %>
  <%# Notifications — authenticated users only (the ctrl+/ keybinding is dead
      for strangers), in conversation chrome, never on the start screen. %>
  <% if @state && @show_notifications && @notifications > 0 && @mode != :start %>
    <%= render(Pito::Shell::InlineSeparatorComponent.new) %>
    <%= render(Pito::Shell::MiniStatus::NotificationsComponent.new(count: @notifications)) %>
  <% end %>
  <%# ctrl+k commands — shown whenever authenticated (all modes incl. start /
      not_found); hidden only for unauthenticated users. %>
  <% if @state %>
    <%= render(Pito::Shell::InlineSeparatorComponent.new) %>
    <%= render(Pito::Shell::MiniStatus::KeyHintComponent.new(
          hint:      t("pito.shell.mini_status.commands_hint"),
          label:     t("pito.shell.mini_status.commands_label"),
          hint_data: {
            "controller"                   => "pito--platform-key",
            "pito--platform-key-mac-value" => t("pito.shell.mini_status.commands_hint_mac")
          }
        )) %>
  <% end %>
</span>
