<span class="inline-flex items-center">
  <%= render(Pito::Shell::MiniStatus::AuthComponent.new(state: @state)) %>
  <% unless @mode == :start %>
    <% if @show_notifications && @notifications > 0 %>
      <span class="text-fg-faded mx-2">·</span>
      <%= render(Pito::Shell::MiniStatus::NotificationsComponent.new(count: @notifications)) %>
    <% end %>
    <span class="text-fg-faded mx-2">·</span>
    <%= render(Pito::Shell::MiniStatus::KeyHintComponent.new(
          hint:  t("pito.shell.mini_status.autocomplete_hint"),
          label: t("pito.shell.mini_status.autocomplete_label")
        )) %>
    <span class="text-fg-faded mx-2">·</span>
    <%= render(Pito::Shell::MiniStatus::KeyHintComponent.new(
          hint:  t("pito.shell.mini_status.channel_hint"),
          label: t("pito.shell.mini_status.channel_label")
        )) %>
    <span class="text-fg-faded mx-2">·</span>
    <%= render(Pito::Shell::MiniStatus::KeyHintComponent.new(
          hint:  t("pito.shell.mini_status.period_hint"),
          label: t("pito.shell.mini_status.period_label")
        )) %>
    <span class="text-fg-faded mx-2">·</span>
    <%= render(Pito::Shell::MiniStatus::KeyHintComponent.new(
          hint:     t("pito.shell.mini_status.audio_hint"),
          label:    t("pito.shell.mini_status.audio_label"),
          label_id: "pito-audio-label"
        )) %>
    <span class="text-fg-faded mx-2">·</span>
    <%= render(Pito::Shell::MiniStatus::KeyHintComponent.new(
          hint:      t("pito.shell.mini_status.commands_hint"),
          label:     t("pito.shell.mini_status.commands_label"),
          hint_data: {
            "controller"                          => "pito--platform-key",
            "pito--platform-key-mac-value" => t("pito.shell.mini_status.commands_hint_mac")
          }
        )) %>
  <% end %>
</span>
