<%# Inert until pito--pull-refresh clones it onto <body> (Hotwire Native shell
    AND mobile-web touch). The glyph is position:fixed and TRANSPARENT — no
    tile, no border — parked just below the viewport's bottom edge; the
    controller drives its rise 1:1 with the drag, rotates the arrows with the
    pulled distance, and counter-rotates the purple→pito-blue gradient the
    strokes are painted with (the color sweep turns against the arrows). The
    arrow is Lucide `refresh-cw` (ISC), inlined so no external fetch ever
    happens; the gradient stops read the theme's CSS custom properties. %>
<template id="<%= Pito::Shell::PullRefreshSpinnerComponent::TEMPLATE_ID %>">
  <div class="pito-pull-spinner" data-pull-refresh-spinner aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
         fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <defs>
        <linearGradient id="pito-pull-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="var(--accent-purple)" />
          <stop offset="1" stop-color="var(--brand-pito)" />
        </linearGradient>
      </defs>
      <g stroke="url(#pito-pull-grad)">
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
        <path d="M21 3v5h-5" />
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
        <path d="M8 16H3v5" />
      </g>
    </svg>
  </div>
</template>
