<%# Inert until pito--pull-refresh clones it onto <body> (Hotwire Native shell
    AND mobile-web touch). The tile is position:fixed, parked just below the
    viewport's bottom edge; the controller drives its rise 1:1 with the drag and
    spins the arrow with the pulled distance. The arrow is Lucide `refresh-cw`
    (ISC), inlined so no external fetch ever happens. %>
<template id="<%= Pito::Shell::PullRefreshSpinnerComponent::TEMPLATE_ID %>">
  <div class="pito-pull-spinner" data-pull-refresh-spinner aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
      <path d="M21 3v5h-5" />
      <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
      <path d="M8 16H3v5" />
    </svg>
  </div>
</template>
