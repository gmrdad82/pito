<style>
  .pito-comet {
    display: flex;
    gap: 4px;
    align-items: center;
  }
  .pito-comet .dot {
    position: relative;
    width: 8px;
    height: 8px;
    background: var(--fg-faded);
    flex-shrink: 0;
  }

  /* 19.3.8 — Comet bounce, enhanced. Purple head (1.5× scale + 8px glow)
     fading into a pito-blue trail. LTR 1.07s + RTL 0.36s, 1.423s cycle.
     Head scale/glow are pinned back to 1 / none on the stops bracketing
     each head moment so they don't bleed across the dark stretches. */
  .pito-comet .dot:nth-child(1) { animation: pito-c1 1.423s linear infinite; }
  .pito-comet .dot:nth-child(2) { animation: pito-c2 1.423s linear infinite; }
  .pito-comet .dot:nth-child(3) { animation: pito-c3 1.423s linear infinite; }
  .pito-comet .dot:nth-child(4) { animation: pito-c4 1.423s linear infinite; }
  .pito-comet .dot:nth-child(5) { animation: pito-c5 1.423s linear infinite; }
  .pito-comet .dot:nth-child(6) { animation: pito-c6 1.423s linear infinite; }
  .pito-comet .dot:nth-child(7) { animation: pito-c7 1.423s linear infinite; }
  .pito-comet .dot:nth-child(8) { animation: pito-c8 1.423s linear infinite; }

  @keyframes pito-c1 {
    0%             { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    15.74%         { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    31.48%         { background: var(--brand-pito);    opacity: .4; }
    47.22%         { background: var(--brand-pito);    opacity: .15; }
    95.87%         { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    96.875%, 100%  { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
  }
  @keyframes pito-c2 {
    0%               { background: var(--brand-pito);    opacity: .15; }
    8.375%           { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    9.375%           { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    25.115%          { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    40.855%          { background: var(--brand-pito);    opacity: .4; }
    56.595%, 92.75%  { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    93.75%           { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    99%              { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    100%             { background: var(--brand-pito);    opacity: .15; }
  }
  @keyframes pito-c3 {
    0%               { background: var(--brand-pito);    opacity: .15; }
    17.75%           { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    18.75%           { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    34.49%           { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    50.23%           { background: var(--brand-pito);    opacity: .4; }
    65.97%, 89.625%  { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    90.625%          { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    95.875%          { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    100%             { background: var(--brand-pito);    opacity: .15; }
  }
  @keyframes pito-c4 {
    0%               { background: var(--brand-pito);    opacity: .15; }
    27.125%          { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    28.125%          { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    43.865%          { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    59.605%          { background: var(--brand-pito);    opacity: .4; }
    75.345%, 86.5%   { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    87.5%            { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    92.75%           { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    98%              { background: var(--brand-pito);    opacity: .4; }
    100%             { background: var(--brand-pito);    opacity: .15; }
  }
  @keyframes pito-c5 {
    0%               { background: var(--brand-pito);    opacity: .15; }
    36.5%            { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    37.5%            { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    53.24%           { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    68.98%           { background: var(--brand-pito);    opacity: .4; }
    83.375%          { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    84.375%          { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    89.625%          { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    94.875%          { background: var(--brand-pito);    opacity: .4; }
    100%             { background: var(--brand-pito);    opacity: .15; }
  }
  @keyframes pito-c6 {
    0%, 45.875%      { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    46.875%          { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    62.615%          { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    78.355%          { background: var(--brand-pito);    opacity: .4; transform: scale(1); box-shadow: 0 0 0 transparent; }
    81.25%           { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    86.5%            { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    91.75%           { background: var(--brand-pito);    opacity: .4; }
    97%, 100%        { background: var(--brand-pito);    opacity: .15; }
  }
  @keyframes pito-c7 {
    0%, 55.25%       { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    56.25%           { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    71.99%           { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    77.125%          { background: var(--accent-purple); opacity: .8; transform: scale(1); box-shadow: 0 0 0 transparent; }
    78.125%          { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    83.375%          { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    88.625%          { background: var(--brand-pito);    opacity: .4; }
    93.875%, 100%    { background: var(--brand-pito);    opacity: .15; }
  }
  @keyframes pito-c8 {
    0%, 64.625%      { background: var(--brand-pito);    opacity: .15; transform: scale(1); box-shadow: 0 0 0 transparent; }
    65.625%          { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    75%              { background: var(--accent-purple); opacity: 1;  transform: scale(1.5); box-shadow: 0 0 8px var(--accent-purple); z-index: 5; }
    80.25%           { background: var(--accent-purple); opacity: .6; transform: scale(1); box-shadow: 0 0 0 transparent; z-index: 1; }
    85.5%            { background: var(--brand-pito);    opacity: .4; }
    90.75%, 100%     { background: var(--brand-pito);    opacity: .15; }
  }
</style>
<div class="pito-comet">
  <div class="dot"></div><div class="dot"></div><div class="dot"></div>
  <div class="dot"></div><div class="dot"></div><div class="dot"></div>
  <div class="dot"></div><div class="dot"></div>
</div>
