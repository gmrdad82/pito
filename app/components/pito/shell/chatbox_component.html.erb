<%# Chatbox — bar+gap+content via Pito::Segment, two-line layout %>
<%
  input_attrs = { placeholder: placeholder, autocomplete: "off",
                  # Mobile keyboards auto-titleize the first word, which broke
                  # case-sensitive keyword matching ("List games"); disable all
                  # of capitalize/correct/spellcheck (the keyword sanitizer is the
                  # server-side backstop).
                  autocapitalize: "off", autocorrect: "off", spellcheck: "false", rows: 1,
                  class: "text-fg placeholder:text-fg-faded bg-transparent outline-none border-none w-full pito-chatbox__input",
                  data: {} }

  if @reduced
    input_attrs[:data].merge!(
      pito__autosize_target: "field",
      pito__type_fx_target: "field"
    )
  else
    input_attrs[:data].merge!(
      action: "keydown->pito--suggestions#handleKeydown keydown->pito--chat-form#handleKeydown input->pito--suggestions#onInput",
      pito__suggestions_target: "field",
      pito__autosize_target: "field",
      pito__type_fx_target: "field",
      pito__placeholder_rotate_target: "field"
    )
  end

  input_attrs[:data].merge!(@input_data) if @input_data

  if @reduced
    # The field-wrap below carries pito--type-fx + pito--autosize; the reduced
    # chatbox needs no wrapper-level controllers.
    chatbox_controllers = ""
    chatbox_data = {}
  else
    chatbox_controllers = "pito--suggestions pito--chatbox-hints pito--history pito--placeholder-rotate"
    chatbox_data = { "pito--history-entries-value": @history.to_json }
    if @draft_uuid.present?
      chatbox_controllers += " pito--draft"
      chatbox_data[:"pito--draft-uuid-value"] = @draft_uuid
    end
  end
%>
<div id="pito-chatbox" class="chatbox-wrapper" data-controller="<%= chatbox_controllers %>" data-action="click->pito--chat-form#focusField"<% chatbox_data.each do |k, v| %> data-<%= k %>="<%= v %>"<% end %>>
<% unless @reduced %>
<script type="application/json" data-pito--suggestions-target="catalog"><%= catalog_json.html_safe %></script>
<%# Showcase data — cycled into the placeholder by pito--placeholder-rotate; replaced by Turbo Stream after each turn. %>
<script type="application/json" id="pito-showcase-data" data-pito--placeholder-rotate-target="data"><%= showcase_json.html_safe %></script>
<div data-pito--suggestions-target="palette" class="pito-suggestions-palette hidden"></div>
<% end %>
<%= render(Pito::Segment::Component.new(
      accent: :purple,
      background: "var(--bg-elevated)"
    )) do %>
  <div class="flex flex-col">
    <%# Hidden inputs for channel / period (always present when filter is given) %>
    <% if @filter %>
      <%= hidden_field_tag :channel, @filter[:channel], data: { pito__chat_form_target: "channelInput" } %>
      <%= hidden_field_tag :period, @filter[:period], data: { pito__chat_form_target: "periodInput" } %>
    <% end %>

    <%# Single-line chatbox (13.39): the textarea, with an absolute-positioned,
        right-aligned HINT SLOT on the SAME line. Exactly ONE hint shows at a time
        (chatbox-hints controller, item 10):
          • unfocused                     → `c to chat`
          • focused + `list vids/games`   → shift+tab (channel cycler)
          • focused + `analyze`           → shift+space (period cycler)
          • focused + anything else       → nothing
        The cycler spans double as chat-form targets so cycling still syncs. The
        conversation NAME no longer lives here — it moved above the context bar. %>
    <div class="pito-chatbox__field-wrap" data-controller="pito--type-fx pito--autosize"
         data-pito--autosize-autofocus-value="true">
      <%= text_area_tag :input_field, @initial_value, **input_attrs %>
      <% if !@reduced && @filter && @state != :start %>
        <div class="pito-chatbox__hint-slot text-fg-faded">
          <span data-pito--chatbox-hints-target="shiftTabHint" data-pito--chat-form-target="channelDisplay" class="items-center hidden">
            <%= render(Pito::Shell::Chatbox::ChannelComponent.new(channel: @filter[:channel])) %>
          </span>
          <span data-pito--chatbox-hints-target="shiftSpaceHint" data-pito--chat-form-target="periodDisplay" class="items-center hidden">
            <%= render(Pito::Shell::Chatbox::PeriodComponent.new(period: @filter[:period])) %>
          </span>
          <span data-pito--chatbox-hints-target="chatHint" class="items-center hidden"><%= render(Pito::Keybinding::HintComponent.new(shortcut: "c", description: Pito::Copy.render("pito.copy.start_chatting"))) %></span>
        </div>
      <% elsif @reduced || @state == :start %>
        <%# Start screen / 404 / share: a single always-on `c to chat` hint. %>
        <div class="pito-chatbox__hint-slot text-fg-faded">
          <%= render(Pito::Keybinding::HintComponent.new(shortcut: "c", description: Pito::Copy.render("pito.copy.start_chatting"))) %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
</div>
