<%# Chatbox — bar+gap+content via Pito::Segment, two-line layout %>
<%
  input_attrs = { placeholder: placeholder, autocomplete: "off",
                  # Mobile keyboards auto-titleize the first word, which broke
                  # case-sensitive keyword matching ("List games"); disable all
                  # of capitalize/correct/spellcheck (the keyword sanitizer is the
                  # server-side backstop).
                  autocapitalize: "off", autocorrect: "off", spellcheck: "false", rows: 1,
                  class: "text-fg placeholder:text-fg-faded bg-transparent outline-none border-none w-full pito-chatbox__input",
                  data: {} }

  if @reduced
    input_attrs[:data].merge!(
      pito__terminal_caret_target: "field",
      pito__type_fx_target: "field"
    )
  else
    input_attrs[:data].merge!(
      action: "keydown->pito--suggestions#handleKeydown keydown->pito--chat-form#handleKeydown input->pito--suggestions#onInput",
      pito__suggestions_target: "field",
      pito__terminal_caret_target: "field",
      pito__type_fx_target: "field",
      pito__chat_showcase_target: "field"
    )
  end

  input_attrs[:data].merge!(@input_data) if @input_data

  if @reduced
    chatbox_controllers = "pito--terminal-caret pito--cursor-trail pito--type-fx"
    chatbox_data = {}
  else
    chatbox_controllers = "pito--suggestions pito--chatbox-hints pito--history pito--chat-showcase"
    chatbox_data = { "pito--history-entries-value": @history.to_json }
    if @draft_uuid.present?
      chatbox_controllers += " pito--draft"
      chatbox_data[:"pito--draft-uuid-value"] = @draft_uuid
    end
  end
%>
<div id="pito-chatbox" class="chatbox-wrapper" data-controller="<%= chatbox_controllers %>" data-action="click->pito--chat-form#focusField"<% chatbox_data.each do |k, v| %> data-<%= k %>="<%= v %>"<% end %>>
<% unless @reduced %>
<script type="application/json" data-pito--suggestions-target="catalog"><%= catalog_json.html_safe %></script>
<%# Showcase data — cycled by pito--chat-showcase; replaced by Turbo Stream after each turn. %>
<script type="application/json" id="pito-showcase-data" data-pito--chat-showcase-target="data"><%= showcase_json.html_safe %></script>
<div data-pito--suggestions-target="palette" class="pito-suggestions-palette hidden"></div>
<% end %>
<%= render(Pito::Segment::Component.new(
      accent: :purple,
      background: "var(--bg-elevated)"
    )) do %>
  <div class="flex flex-col">
    <%# Hidden inputs for channel / period (always present when filter is given) %>
    <% if @filter %>
      <%= hidden_field_tag :channel, @filter[:channel], data: { pito__chat_form_target: "channelInput" } %>
      <%= hidden_field_tag :period, @filter[:period], data: { pito__chat_form_target: "periodInput" } %>
    <% end %>

    <%# Line 1: text input + terminal block caret overlay %>
    <div class="pito-chatbox__field-wrap" data-controller="pito--terminal-caret pito--cursor-trail pito--type-fx"
         data-pito--terminal-caret-autofocus-value="true">
      <%= text_area_tag :input_field, @initial_value, **input_attrs %>
      <span class="terminal-caret" data-pito--terminal-caret-target="block" aria-hidden="true"></span>
      <%# Showcase ghost — cycles comet-revealed suggestions in the idle empty chatbox. %>
      <% unless @reduced %>
      <div class="pito-showcase-ghost" data-pito--chat-showcase-target="item" aria-hidden="true"></div>
      <% end %>
    </div>
    <%# Line 2: filter context (only shown in :default state, not in reduced mode) %>
    <% if !@reduced && @filter && @state != :start %>
      <div class="flex items-center text-fg-faded pito-chatbox__filter">
        <%= render(Pito::Shell::Chatbox::NameComponent.new(title: @conversation_title)) %>
        <%# Channel/period cyclers (shift+tab / shift+space) — shown ONLY when the
            chatbox is focused. Mutually exclusive with the `m chat` hint below
            (its inverse). The display spans stay in the DOM so chat-form keeps
            their values in sync while hidden. %>
        <span data-pito--chatbox-hints-target="filterHints" class="items-center hidden">
          <span data-pito--chat-form-target="channelDisplay">
            <%= render(Pito::Shell::Chatbox::ChannelComponent.new(channel: @filter[:channel])) %>
          </span>
          <%= render(Pito::Shell::InlineSeparatorComponent.new) %>
          <span data-pito--chat-form-target="periodDisplay">
            <%= render(Pito::Shell::Chatbox::PeriodComponent.new(period: @filter[:period])) %>
          </span>
        </span>
        <span data-pito--chatbox-hints-target="suggestHint" class="items-center hidden"><%= render(Pito::Shell::InlineSeparatorComponent.new) %><%= render(Pito::Keybinding::HintComponent.new(shortcut: "tab", description: "suggest")) %></span>
        <%# `m chat` hint — shown ONLY when the chatbox is NOT focused. No leading
            separator: when it shows, the filter cyclers are hidden, so there's
            nothing to separate it from. %>
        <span data-pito--chatbox-hints-target="chatHint" class="items-center hidden"><%= render(Pito::Keybinding::HintComponent.new(shortcut: "m", description: "chat")) %></span>
      </div>
    <% end %>
  </div>
<% end %>
</div>
