<%# Start screen. Full-viewport centered layout, no auth required. %>
<%# ASCII logo, chatbox at 50vh, tip line + bottom corners below. %>
<%# pito--home-transition wired on the outer wrapper so it can reach all targets. %>

<div class="flex flex-col min-h-screen" data-controller="pito--home-transition">

  <%# Top spacer — pushes centered group toward 50vh %>
  <div class="flex-1" data-pito--home-transition-target="fade"></div>

  <%# Centered group %>
  <div class="flex flex-col items-center">

    <%# ASCII logo — each row is its own logo-row target so the controller can
        stagger them independently, creating an unstable / glitchy dissolve.
        Wrapped in pito--ascii-fit so the fixed-width art scales DOWN to fit a
        narrow (mobile) viewport without touching desktop. %>
    <div class="pito-ascii-fit pito-ascii-fit--center w-full"
         data-controller="pito--ascii-fit"
         data-pito--ascii-fit-origin-value="center">
    <%# Per-glyph cells (built in the component) so pito--logo-reveal can flicker
        them in randomly. Each row stays a logoRow target for the home-transition
        fade. %>
    <pre class="pito-start-screen__logo pito-logo" data-controller="pito--logo-reveal"><%= logo_html %></pre>
    </div>

    <%# 32px gap %>
    <div class="h-8" data-pito--home-transition-target="fade"></div>

    <%# chatboxArea: wraps form + mini-status so they animate as a single unit.
        Width constraint lives here (not on children) so w-full on children resolves
        correctly in the items-center flex context. %>
    <div class="w-full max-w-[600px]"
         data-pito--home-transition-target="chatboxArea"
         data-authenticated="<%= Current.session.present? %>"
         data-filter-channel-label="<%= t("pito.shell.chatbox.filter.channel_label") %>"
         data-filter-period-label="<%= t("pito.shell.chatbox.filter.period_label") %>">

      <div class="px-4">
        <% filter = Current.session.present? ? {
             channel: @channels.any? ? "@all" : "none",
             period: "7d",
             channels: @channels.any? ? ["@all"] + @channels : []
           } : nil %>
        <% form_data = { controller: "pito--chat-form", turbo: true } %>
        <% if filter %>
          <% form_data[:pito__chat_form_channels_value] = filter[:channels].to_json %>
          <% form_data[:pito__chat_form_periods_value] = '["7d","28d","3m","1y","lifetime"]' %>
        <% end %>
        <%= form_with url: chat_path, method: :post,
                      data: form_data,
                      class: "chatbox-form" do |form| %>
          <%= form.hidden_field :input, data: { pito__chat_form_target: "hiddenInput" } %>

          <%= render(Pito::Shell::ChatboxComponent.new(
                state: :start,
                filter: filter,
                # SHOWCASE-START-NOTFOUND: pass seed suggestions so the comet
                # cycles on authenticated visits (non-empty) and the native
                # placeholder shows on unauthenticated visits (empty []).
                suggestions: suggestions,
                input_data: {
                  pito__chat_form_target: "inputField",
                  # Same keydown ORDER as the conversation chatbox
                  # (chatbox_component.html.erb): suggestions FIRST, so an open
                  # palette owns Enter/arrows (accept highlights, no submit —
                  # G62: without it, Enter submitted the raw "/resu" under a
                  # highlighted row). Every non-palette key passes through
                  # untouched (the handler preventDefaults ONLY when accepting),
                  # so the home-transition Enter flow and login submit are
                  # unaffected — incl. exact-complete verbs, which the handler
                  # deliberately lets through to submit.
                  action: "keydown->pito--suggestions#handleKeydown keydown->pito--home-transition#interceptEnter keydown->pito--chat-form#handleKeydown input->pito--suggestions#onInput"
                }
              )) %>
        <% end %>
      </div>

      <%# The old filter-chip <template> is gone: the morph no longer
          injects a filter line — no page renders #pito-chatbox-filter since the
          channel/period meta moved into the hint slot; the leftover
          injection added a 10px ghost to the transition-built chatbox. %>

      <%# Mini-status: glued to chatbox bottom-right, rides with the animation %>
      <div class="mt-2 px-4">
        <div class="flex justify-end">
          <%= render(Pito::Shell::MiniStatusComponent.new(mode: :start, state: Current.session.present?)) %>
        </div>
      </div>

    </div>

  </div>

  <%# Tip — fades + slides DOWN to clear the chatbox path %>
  <div class="flex-1 flex flex-col justify-center items-center p-4"
       data-pito--home-transition-target="tip">
    <%= render(Pito::Tip::Component.new(
          text:              tip,
          badge_text:        badge_text,
          badge_class:       badge_class,
          exclamation_class: exclamation_class
        )) %>
  </div>

  <%# Bottom corners — fades + slides up, delayed after logo %>
  <div class="flex justify-between px-[50px] pb-8"
       data-pito--home-transition-target="corners">
    <a href="<%= @repo_url %>" class="text-fg-dim hover:underline" target="_blank" rel="noopener">
      <%= t("pito.start_screen.repo_link") %>
    </a>
    <a href="<%= @license_url %>" class="text-fg-dim hover:underline" target="_blank" rel="noopener">
      <%= t("pito.start_screen.license_link") %>
    </a>
  </div>

  <%# Pre-rendered conversation chrome — hidden until animation completes %>
  <div data-pito--home-transition-target="conversationChrome" style="display:none;">
    <div class="flex items-center" style="margin-top: 8px;">
      <div style="margin-left: 10px;" data-controller="pito--dots">
        <%= render(Pito::Shell::PostCommandDotsComponent.new) %>
      </div>
      <div id="pito-mini-status" data-pito--home-transition-target="miniStatusSlide" style="margin-left: auto;">
        <%= render(Pito::Shell::MiniStatusComponent.new(
              mode: :connection,
              state: Current.session.present?,
              notifications: Notification.unread.count,
              show_notifications: true
            )) %>
      </div>
    </div>
  </div>

</div>
