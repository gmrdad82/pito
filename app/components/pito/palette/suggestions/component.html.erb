<%# Mode-parameterized suggestions palette — bar+gap+content structure.
    Root carries pito-suggestions-palette for CSS/JS targeting.
    Each item row carries pito-suggestions-row + data-index for JS selection management. %>
<div class="flex pito-suggestions-palette">
  <div class="pito-segment__bar" data-accent="<%= bar_accent %>"></div>
  <div class="pito-segment__gap"></div>
  <div class="flex-1 min-w-0 bg-surface py-2.5 px-1.5">
    <div class="flex flex-col">
      <%# Item list — label in fixed 16ch column, description dim-coloured %>
      <% @items.each_with_index do |item, i| %>
        <div class="pito-suggestions-row py-0.5 px-2.5 <%= 'is-selected' if i == @selected_index %>"
             data-index="<%= i %>">
          <span class="text-fg inline-block" style="width: 16ch;"><%= label_html(item) %></span>
          <span class="text-fg-dim"><%= item[:description] %></span>
          <% if item[:masked] %>
            <span class="text-fg-faded">(hidden)</span>
          <% end %>
        </div>
      <% end %>

      <%# 8px gap + divider + 8px gap %>
      <div class="h-2"></div>
      <%= render(Pito::Separator::DividerLineComponent.new(hairline: true)) %>
      <div class="h-2"></div>

      <%# Input echo line %>
      <div class="flex items-center px-2.5">
        <%= render(Pito::Cursor::Component.new(char: echo_char)) %>
        <span class="text-fg"><%= @typed %></span>
      </div>
    </div>
  </div>
</div>
