<%# Section: orange-bold title + item rows %>
<div style="color: var(--accent-orange); font-weight: bold; margin-bottom: 4px;"><%= @title %></div>
<% @items.each_with_index do |item, idx| %>
  <% item_selected = @selected && idx == @selected_item_index %>
  <div style="display: flex; justify-content: space-between; padding: 2px 0;<%= ' background: var(--border-default);' if item_selected %>">
    <span style="color: var(--fg);"><%= item[:name] %></span>
    <% if item[:shortcut] %>
      <span style="color: var(--fg-dim);"><%= item[:shortcut] %></span>
    <% end %>
  </div>
<% end %>
