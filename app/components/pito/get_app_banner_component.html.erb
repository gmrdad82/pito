<%# Fixed top strip whose visible box is exactly as wide as the conversation:
    the inner wrapper reuses .pito-conversation-col (964px centered on desktop,
    5px-inset full width on mobile) so the banner always tracks the column
    width contract — deliberately NOT page-wide like the dev-only banner.
    Hidden until the Stimulus controller confirms no stored dismissal. %>
<div class="hidden fixed top-0 left-0 right-0 z-40" data-controller="pito--app-banner">
  <div class="pito-conversation-col">
    <div class="bg-surface border-x border-b border-default px-4 py-1 flex items-center justify-between gap-4">
      <span class="text-fg-dim truncate"><%= Pito::Copy.render("pito.copy.get_app.banner") %></span>
      <span class="flex items-center gap-4 shrink-0">
        <%= link_to Pito::Copy.render("pito.copy.get_app.cta"), Pito::GetAppBannerComponent::APK_URL, class: "text-pito" %>
        <button type="button"
                class="text-fg-faded cursor-pointer"
                data-action="pito--app-banner#dismiss"
                aria-label="<%= Pito::Copy.render("pito.copy.get_app.dismiss") %>">[x]</button>
      </span>
    </div>
  </div>
</div>
