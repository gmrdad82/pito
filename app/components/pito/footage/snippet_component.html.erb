<div class="pito-footage-snippet">
  <div class="pito-footage-snippet__hint text-fg-dim"><span data-pito-ts-slot></span><%= hint %></div>
  <div class="pito-footage-snippet__bar">
    <%# A <code> block, NOT <pre>: pito--ascii-fit only scales <pre> descendants, and
        it was shrinking this one-liner to scale(0.41). As <code> with pre-wrap it
        renders full-size and WRAPS to fit (no h-scroll, readable ≤450px on mobile). %>
    <code class="pito-footage-snippet__code"><%= command %></code>
    <%= render(Pito::CopyButtonComponent.new(text: command, aria_label:)) %>
  </div>
</div>
