<div class="pito-footage-import"
     data-controller="pito--footage-import"
     data-pito--footage-import-command-value="<%= command_text %>"
     data-pito--footage-import-feedback-value="<%= feedback_variants_json %>">
  <div class="pito-footage-import__box border border-line-default bg-surface relative"
       data-action="click->pito--footage-import#copy"
       tabindex="0"
       role="button"
       aria-label="<%= t("pito.footage.probe_command.aria_label") %>">
    <div class="py-2 px-3 overflow-x-auto pito-hide-scrollbar">
      <code class="text-fg select-all whitespace-nowrap"><%= command_text %></code>
    </div>
    <div data-pito--footage-import-target="overlay"
         class="pito-footage-import__overlay hidden">
    </div>
  </div>
  <div class="text-right mt-1">
    <%= render(Pito::Keybinding::HintComponent.new(
          shortcut:    t("pito.footage.probe_command.copy_shortcut"),
          description: t("pito.footage.probe_command.copy_hint")
        )) %>
  </div>
</div>
