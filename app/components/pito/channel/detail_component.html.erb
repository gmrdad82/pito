<%# Pito::Channel::DetailComponent — channel detail card for chat messages.
    Two columns: LEFT = banner + hairline + one-line stats counters + Shinies;
    RIGHT = kv-table (Avatar, Handle, Title, Description, Last sync at, links).
    Uses Pito::Detail::CardComponent as the shared two-column shell. %>
<%= render(Pito::Detail::CardComponent.new(
      bem:                  "pito-channel-detail",
      intro:                @intro,
      stat_counter_metrics: stat_counter_metrics,
      shinies:              top_shinies_per_metric,
      right_gap:            "gap-1"
    )) do |card| %>

  <% card.with_image do %>
    <%# Banner (our cached 450×253 16:9 copy) in the top-left spot. When the
        channel has NO banner, the shared click-to-sync placeholder (rect) fills
        the spot (item 22 — supersedes the earlier empty-spot behaviour). The
        avatar still lives in the kv-table on the right. %>
    <div class="pito-channel-detail__banner">
      <%= render Pito::ImageRender.call(
            url:            banner_url,
            shape:          :rect,
            sync_command:   "sync channel #{@channel.at_handle}",
            alt:            @channel.title.to_s,
            html_class:     "block",
            fallback_class: "pito-image-box--rect169"
          ) %>
    </div>
  <% end %>

  <% card.with_body do %>
    <%# kv-table (Avatar, Handle, Title, Description, Last sync at, links) —
        the wrapper div is rendered by the shell; only the content lives here. %>
    <div class="grid grid-cols-[max-content_1fr] gap-x-2 gap-y-1">
      <%# Avatar row — the small 50% (120×120 variant, displayed 60px) circle+ring
          avatar, ALWAYS shown when the channel has an avatar (independent of the
          banner), as the FIRST kv-row above Handle. Two bare grid children (key +
          value) to match KeyValueRowComponent's output. %>
      <span class="text-fg-dim whitespace-nowrap self-center"><%= t("pito.channel.detail.avatar") %></span>
      <span><%= render Pito::ImageRender.call(
            url:            avatar_inline_url,
            shape:          :circle,
            sync_command:   "sync channel #{@channel.at_handle}",
            alt:            @channel.title.to_s,
            html_class:     "pito-channel-detail__avatar-inline block",
            fallback_class: "pito-channel-detail__avatar-inline"
          ) %></span>

      <%# Handle — clickable yellow-shimmer token: prefills `show channel @handle`
          and submits, same affordance as the #id click in show vid/game. %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:        t("pito.channel.detail.handle"),
            key_class:       "text-fg-dim whitespace-nowrap",
            value_component: Pito::Shimmer::TokenComponent.new(
              text:    @channel.at_handle,
              prefill: "show channel #{@channel.at_handle}",
              submit:  true
            )
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.channel.detail.title"),
            value_text:  @channel.title,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <%# Description is no longer a kv-row — it lives in its own hairline-separated
          section below the kv-table (parity with show vid). %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.channel.detail.last_sync_at"),
            value_text:  last_sync_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:        t("pito.channel.detail.youtube_channel"),
            key_class:       "text-fg-dim whitespace-nowrap",
            value_component: Pito::Table::LinkValueComponent.new(url: @channel.youtube_channel_url)
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:        t("pito.channel.detail.youtube_studio"),
            key_class:       "text-fg-dim whitespace-nowrap",
            value_component: Pito::Table::LinkValueComponent.new(url: @channel.youtube_studio_url)
          )) %>
    </div>

    <%# Hairline between the kv-table and the description (parity with show vid). %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-hairline")) %>

    <%# Description — label on its own row, body beneath (like show vid). %>
    <% if description.present? %>
      <div class="text-fg-dim mt-1"><%= t("pito.channel.detail.description") %></div>
      <div class="pito-channel-detail__description text-fg whitespace-pre-wrap"><%= description %></div>
    <% end %>
  <% end %>

<% end %>
