<%# Pito::Channel::ListComponent — wrapping strip of channel cards.
    Each card is the shared Pito::Channel::ItemComponent: avatar + prefill
    @handle + title + one-line stats, no score bar. The recommended-channels
    grid renders the SAME component (score: result.score, plain stats) — they
    differ only by those kwargs. %>
<div class="pito-channel-list">
  <% channels.each do |channel| %>
    <div class="pito-channel-list__card">
      <%= render(Pito::Channel::ItemComponent.new(channel: channel, show_avatar: true, show_stats: true, show_video_count: true)) %>
    </div>
  <% end %>
</div>
