<%# Pito::Channel::ListComponent — wrapping strip of channel cards %>
<div class="pito-channel-list">
  <% channels.each do |channel| %>
    <div class="pito-channel-list__card">
      <%# Avatar — OUR locally-cached ActiveStorage copy (never the YouTube CDN). %>
      <% avatar = channel.avatar_variant_url %>
      <% if avatar %>
        <%= image_tag avatar,
                      alt: channel.title.to_s,
                      class: "pito-channel-list__avatar block" %>
      <% else %>
        <div class="pito-channel-list__avatar pito-channel-list__avatar--placeholder text-fg-faded">
          ?
        </div>
      <% end %>

      <%# Title %>
      <div class="pito-channel-list__title text-fg">
        <%= channel.title.to_s %>
      </div>

      <%# Handle %>
      <div class="pito-channel-list__handle text-cyan">
        <%= channel.at_handle %>
      </div>

      <%# View link on its own line %>
      <div class="pito-channel-list__view">
        <a href="<%= youtube_url_for(channel) %>"
           target="_blank"
           rel="noopener"
           class="pito-channel-list__view-link text-yellow">[view]</a>
      </div>

      <%# Channel id (# prefix) %>
      <div class="pito-channel-list__id text-fg-faded">
        #<%= channel.id %>
      </div>
    </div>
  <% end %>
</div>
