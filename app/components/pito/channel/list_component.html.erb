<%# Pito::Channel::ListComponent — wrapping strip of channel cards.
    Each card is the shared Pito::Channel::ItemComponent: avatar + handle +
    title + #id, with the [view] link (show_visit: true) and no score bar. The
    recommended-channels grid renders the SAME component (show_visit: false +
    a ScoreBarComponent) — they only differ by those two kwargs. %>
<div class="pito-channel-list">
  <% channels.each do |channel| %>
    <div class="pito-channel-list__card">
      <%= render(Pito::Channel::ItemComponent.new(channel: channel, show_visit: true, show_avatar: true, show_stats: true, show_video_count: true)) %>
    </div>
  <% end %>
</div>
