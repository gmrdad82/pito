<%# Pito::Channel::ItemComponent — shared channel item: handle / title,
    with optional ScoreBarComponent (score: N). The @handle always runs
    `show channel @handle` via the pito--chat-prefill controller. %>
<div class="pito-channel-item">
  <%# Avatar (our cached variant) — only when show_avatar: true %>
  <% if show_avatar? %>
    <% if (avatar = avatar_url) %>
      <%= image_tag avatar, alt: channel.title.to_s, class: "pito-channel-item__avatar block" %>
    <% else %>
      <div class="pito-channel-item__avatar pito-channel-item__avatar--placeholder text-fg-faded">?</div>
    <% end %>
  <% end %>

  <%# Handle — clickable prefill token that auto-runs `show channel @handle`. %>
  <div class="pito-channel-item__handle"><%= render(Pito::Shimmer::TokenComponent.new(text: channel.at_handle, prefill: "show channel #{channel.at_handle}", submit: true)) %></div>

  <%# Title %>
  <div class="pito-channel-item__title text-fg">
    <%= channel.title.to_s %>
  </div>

  <%# Score bar — only when a score is provided %>
  <% if score? %>
    <div class="pito-channel-item__score">
      <%= render(Pito::ScoreBarComponent.new(score: score, show_label: false)) %>
    </div>
  <% end %>

  <%# Stats — two rows: row 1 "N Subs · M Views", row 2 "P Vids" (list channels only). %>
  <% if show_stats? %>
    <div class="pito-channel-item__stats">
      <%= render(Pito::Stats::CountersComponent.new(metrics: stat_row1_metrics, align: :center)) %>
      <% if show_video_count? %>
        <%= render(Pito::Stats::CountersComponent.new(metrics: stat_row2_metrics, align: :center)) %>
      <% end %>
    </div>
  <% end %>
</div>
