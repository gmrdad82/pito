<%# Pito::Channel::ItemComponent — shared channel item: handle / title,
    with optional [view] link (show_visit: true) and/or ScoreBarComponent (score: N). %>
<div class="pito-channel-item">
  <%# Avatar (our cached variant) — only when show_avatar: true %>
  <% if show_avatar? %>
    <% if (avatar = avatar_url) %>
      <%= image_tag avatar, alt: channel.title.to_s, class: "pito-channel-item__avatar block" %>
    <% else %>
      <div class="pito-channel-item__avatar pito-channel-item__avatar--placeholder text-fg-faded">?</div>
    <% end %>
  <% end %>

  <%# Handle — a yellow YouTube link on `list channels` (show_visit: true; opens
      the channel in a new tab), plain cyan text on the Game Enhanced surface. The
      link replaces the old separate [view] action. NOT VisitComponent (no auto-nav). %>
  <% if show_visit? %>
    <a href="<%= youtube_url %>"
       target="_blank"
       rel="noopener"
       class="pito-channel-item__handle pito-channel-item__handle--link"><%= render(Pito::Shimmer::TokenComponent.new(text: channel.at_handle)) %></a>
  <% else %>
    <div class="pito-channel-item__handle"><%= render(Pito::Shimmer::TokenComponent.new(text: channel.at_handle)) %></div>
  <% end %>

  <%# Title %>
  <div class="pito-channel-item__title text-fg">
    <%= channel.title.to_s %>
  </div>

  <%# Score bar — only when a score is provided %>
  <% if score? %>
    <div class="pito-channel-item__score">
      <%= render(Pito::ScoreBarComponent.new(score: score, show_label: false)) %>
    </div>
  <% end %>

  <%# Stats — one centered line "subs · vids · views" (list channels only). %>
  <% if show_stats? %>
    <div class="pito-channel-item__stats">
      <%= render(Pito::Stats::CountersComponent.new(metrics: stat_counter_metrics, align: :center)) %>
    </div>
  <% end %>
</div>
