<%= content_tag :section,
      class: "pane pito-pane pito-panel pito-panel--calendar",
      **panel_data do %>
  <span class="pito-pane__title"><%= title %></span>
  <%= render Tui::PanelFieldsetComponent.new do %>
    <%# Legend (always shown) %>
    <%= render Pito::CalendarLegendComponent.new(active_filter: category) %>

    <%# Month grid (month-only; schedule mode dropped) %>
    <%= render Pito::Calendar::MonthGridComponent.new(
          entries:         entries,
          month:           Date.new(year, month, 1),
          today:           today,
          category_filter: category
        ) %>
  <% end %>
<% end %>
