<%= content_tag :section,
      class: "pane pito-pane pito-panel pito-panel--calendar",
      **panel_data do %>
  <span class="pito-pane__title"><%= title %></span>
  <%# View toggle in the title-actions slot — mirrors Meilisearch
      sub-panel's `[reindex]` placement on the top border, right edge.

      2026-05-24 (locked) — active variant renders as plain `label`
      (no surrounding spaces, no brackets); inactive stays bracketed
      `[label]`. Result: when month is current, the slot reads
      `month [schedule]`; toggle and it flips to `[month] schedule`.
      Active also uses section-accent (matches the "actions are always
      accent" lock — the entire toggle reads in one color, distinguished
      only by the bracketed / unbracketed shape).

      2026-05-24 (order) — sync VC is ALWAYS LAST in any panel's action
      list. Full slot reads `month [schedule] [ ] sync`. %>
  <span class="pito-pane__title-actions">
    <%= render Tui::ViewToggleComponent.new(
          views: views,
          current: current_view,
          event_name: "calendar:view-changed",
          active_color: :accent,
          active_style: :plain
        ) %>
    <%= render Tui::SyncIndicatorComponent.new(
          mode: :target,
          target: "home.calendar",
          focusable_key: "calendar_sync"
        ) %>
  </span>
  <%= render Tui::PanelFieldsetComponent.new do %>
    <p class="pito-panel__placeholder">[ <%= current_view %> view TBD ]</p>
  <% end %>
<% end %>
