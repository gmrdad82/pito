<%# @border — bar color (nil = no bar) %>
<%# @background — content background (nil = transparent) %>
<%# Alignment invariant: text sits 22px from the segment's left edge
    regardless of whether the bar is present. %>
<%
  left_pad = @border ? "12px" : "22px"
%>
<div class="flex" style="margin-bottom: 16px;">
  <% if @border %>
    <div style="width: 4px; background: <%= @border %>; flex-shrink: 0;"></div>
    <div style="width: 6px; flex-shrink: 0;"></div>
  <% end %>
  <div class="flex-1" style="min-width: 0;<% if @background %> background: <%= @background %>;<% end %> padding: 10px 16px 10px <%= left_pad %>;">
    <%= content %>
  </div>
</div>
