<%# The /config ai overlay. Mounted on demand (turbo stream) and removed on
    close by pito--ai-picker. Composition only — rows live in
    Picker::ModelRowComponent, provider sections in
    Picker::ProviderSectionComponent; the JS toggles what the server rendered.
    Chrome speaks the Ctrl+K palette language: bold title row with a tappable
    Esc hint, underlined search, yellow section titles. %>
<div id="pito-ai-picker"
     class="fixed inset-0 z-50 flex items-start justify-center pt-[8vh]"
     data-controller="pito--ai-picker"
     data-pito--ai-picker-endpoint-value="/settings/ai">
  <%# Click-away backdrop — dims the app without blurring the terminal grid. %>
  <div class="fixed inset-0 bg-root opacity-60" data-action="click->pito--ai-picker#close"></div>

  <div class="relative w-[600px] bg-surface border border-line-default p-2.5 flex flex-col">
    <%# Title row — palette-style: bold title, active model summary, Esc hint
        (ShortcutComponent = tappable on touch: the tap synthesizes Escape). %>
    <%# Title row — bold title + Esc hint only (owner 2026-07-12: no
        current-model summary in the header; the active row's ✓ carries it). %>
    <div class="flex justify-between items-center gap-2">
      <span class="font-bold text-fg"><%= t("pito.palette.ai_picker.title") %></span>
      <%= render(Pito::Keybinding::ShortcutComponent.new(keys: t("pito.palette.ai_picker.esc_hint"))) %>
    </div>

    <div class="h-3"></div>
    <div class="flex items-center pb-1 border-b border-line-default">
      <input type="text"
             class="bg-transparent text-fg outline-none w-full placeholder:text-fg-dim"
             placeholder="<%= t("pito.palette.ai_picker.search_placeholder") %>"
             autocomplete="off" spellcheck="false"
             data-pito--ai-picker-target="search"
             data-action="input->pito--ai-picker#filter">
    </div>
    <div class="h-2"></div>

    <div class="pito-hide-scrollbar overflow-y-auto flex flex-col gap-2 pito-ai-picker__list"
         data-pito--ai-picker-target="list">
      <% if effort_cyclable? %>
        <button type="button"
                class="flex w-full items-center gap-2 px-1.5 py-0.5 text-left"
                data-pito--ai-picker-target="row"
                data-row-type="effort"
                data-provider="<%= active_provider %>"
                data-value="<%= effort.presence || "off" %>"
                data-action="click->pito--ai-picker#activate">
          <span class="w-2"></span>
          <span class="text-fg-dim">effort</span>
          <span class="text-fg-default" data-pito--ai-picker-target="effortValue"><%= effort_label %></span>
          <span class="ml-auto text-fg-faded">enter cycles</span>
        </button>
      <% else %>
        <%# Read-only — the active provider declares no reasoning (e.g. Sonnet
            via OpenCode), so there is nothing to cycle. Deliberately NOT a
            data-pito--ai-picker-target="row": it stays out of arrow-nav and
            Enter/tap so #cycleEffort can never fire a PATCH the provider
            doesn't support. data-row-type="effort" stays for testability. %>
        <div class="flex w-full items-center gap-2 px-1.5 py-0.5 text-fg-faded" data-row-type="effort">
          <span class="w-2"></span>
          <span>effort: model default — provider manages reasoning</span>
        </div>
      <% end %>

      <% { "conversation" => resolve_entries(conversation_models),
           "favorites"    => resolve_entries(favorites),
           "recents"      => resolve_entries(recents) }.each do |section, entries| %>
        <% next if entries.empty? %>
        <div class="flex flex-col" data-section="<%= section %>">
          <%= render(Pito::Section::SectionHeaderComponent.new(text: t("pito.palette.ai_picker.sections.#{section}"), mb: "0")) %>
          <% entries.each do |entry| %>
            <%= render(Pito::Ai::Picker::ModelRowComponent.new(
                  provider: entry[:provider], id: entry[:id],
                  active:   active?(entry[:provider], entry[:id]),
                  trailing: entry[:label]
                )) %>
          <% end %>
        </div>
      <% end %>

      <% providers.each do |p| %>
        <%= render(Pito::Ai::Picker::ProviderSectionComponent.new(
              provider: p, active_provider:, active_model:, favorites:
            )) %>
      <% end %>
    </div>

    <div class="h-2"></div>
    <%# Footer hints — tappable like the Esc hint above (kbd_click: true is
        the default now; the base pito--kbd-click wiring stays for the
        shimmer/tap styling). Its generic HANDLERS map only knows
        document-global chords (esc, ctrl+k, …), not these list-local ones,
        so each hint ALSO carries a merged click action straight to a public
        pito--ai-picker method — same "controller + action concatenate"
        mechanism the component already documents (STRING data keys so the
        merge concatenates instead of colliding). Every action reads the
        CURRENTLY SELECTED row, same as the physical chord. %>
    <div class="text-fg-faded">
      <%= render(Pito::Keybinding::ShortcutComponent.new(keys: "↑/↓", data: { "action" => "click->pito--ai-picker#hintMove" })) %> choose
      &middot; <%= render(Pito::Keybinding::ShortcutComponent.new(keys: "enter", data: { "action" => "click->pito--ai-picker#hintEnter" })) %> select/connect
      &middot; <%= render(Pito::Keybinding::ShortcutComponent.new(keys: "ctrl+f", data: { "action" => "click->pito--ai-picker#hintFavorite" })) %> favorite
      &middot; <%= render(Pito::Keybinding::ShortcutComponent.new(keys: "ctrl+x", data: { "action" => "click->pito--ai-picker#hintClearKey" })) %> clear key
    </div>
    <%# Transient feedback line — "model saved", "key cleared", errors. %>
    <div class="text-fg-dim" aria-live="polite" data-pito--ai-picker-target="status"></div>
  </div>
</div>
