<%# Pito::ScoreBarComponent — KEPT BUT UNUSED — no host screen yet. %>
<% s = score %>
<% if s.nil? && !resyncing? %>
  <span class="pito-score-bar pito-score-bar--muted"
        data-tier="missing">
    <% if show_label? %><span class="pito-score-bar__label"><%= score_label %></span><% end %>
    <span class="pito-score-bar__track">
      <span class="pito-score-bar__bracket">[</span>
      <span class="pito-score-bar__fill"><%= fill_text %></span>
      <span class="pito-score-bar__bracket">]</span>
    </span>
  </span>
<% else %>
  <span class="pito-score-bar"
        data-score="<%= s %>"
        data-tier="<%= tier %>"
        data-resyncing="<%= resyncing? ? "yes" : "no" %>">
    <% if show_label? %><span class="pito-score-bar__label"><%= score_label %></span><% end %>
    <%# Tick + bubble live INSIDE the track so their left:% maps across the
        full-width bar (not the label). %>
    <span class="pito-score-bar__track">
      <span class="pito-score-bar__bracket">[</span>
      <span class="pito-score-bar__fill pito-bar-shimmer pito-bar-reveal <%= shimmer_offset_class %>" data-controller="pito--bar-reveal"><%= fill_text %></span>
      <span class="pito-score-bar__bracket">]</span>
      <% if overlay? %>
        <%# Marker on the bar line: the tick at the (1–99 clamped) score position,
            with the score value inline beside it — left of the tick when score<50,
            right when >=50 (13.4). %>
        <span class="pito-score-bar__marker <%= value_side_class %>" data-accent="score" style="left: <%= overlay_position_percent %>%;">
          <span class="pito-score-bar__tick">|</span>
          <span class="pito-score-bar__value"><%= s %></span>
        </span>
      <% end %>
    </span>
  </span>
<% end %>
