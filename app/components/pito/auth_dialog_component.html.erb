<%# Pito::AuthDialogComponent — full-viewport non-dismissible TOTP login overlay.
    Structural chrome: .pito-auth-overlay (fixed fullscreen) + .pito-auth-dialog.pito-pane.
    All interactive and content elements are ViewComponent renders. %>
<div class="pito-auth-overlay" role="dialog" aria-modal="true" aria-labelledby="auth-dialog-title">
  <div class="pito-auth-dialog pito-pane" data-controller="pito-auth-dialog" data-tui-cursor-focused="yes">
    <span class="pito-pane__title" id="auth-dialog-title"><%= t("tui.auth.title") %></span>

    <% if login_error %>
      <%= render Tui::HintComponent.new(text: login_error, severity: :danger) %>
    <% end %>

    <%= form_with url: "/login", method: :post, scope: nil do %>
      <%= render Tui::TotpCodeComponent.new(field: :code, mode: :digits, autofocus: true,
            data: { pito_auth_dialog_target: "totpField" }) %>
      <%= render Tui::TotpCodeComponent.new(field: :backup_code, mode: :backup,
            hidden: true,
            data: { pito_auth_dialog_target: "backupField" }) %>

      <div class="pito-auth-dialog__actions">
        <%= render Tui::ActionComponent.new(label: t("tui.auth.submit_label"), as: :submit) %>
        <%= render Tui::ActionComponent.new(
              label: t("tui.auth.use_backup_label"),
              as: :button,
              data: {
                action: "click->pito-auth-dialog#toggleBackup",
                pito_auth_dialog_target: "toggleBtn",
                use_backup_label: t("tui.auth.use_backup_label"),
                use_totp_label: t("tui.auth.use_totp_label")
              }) %>
      </div>
    <% end %>

    <% if totp_not_enrolled? %>
      <div class="pito-auth-dialog__code-block">
        <%= render Tui::HintComponent.new(text: t("tui.auth.code_block_intro")) %>
        <%= render Tui::CodeComponent.new(
              text: "bin/rails pito:auth:enroll",
              copyable: true,
              copied_message: t("tui.auth.copied_label"),
              copy_label: t("tui.auth.copy_label")) %>
      </div>
    <% end %>
  </div>
</div>
