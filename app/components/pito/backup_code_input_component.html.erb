<%# Pito::BackupCodeInputComponent — 8 discrete boxes + hidden aggregation field.
    The `backup-code-input` Stimulus controller wires per-box input, keydown,
    and paste handlers, distributes alphanumeric chars, and writes the
    concatenated 8-char string into the hidden field on every change. %>
<div class="totp-modal-boxes"
     data-controller="backup-code-input"
     data-backup-code-input-field-value="<%= @field %>">
  <% 8.times do |i| %>
    <input type="text"
           maxlength="1"
           inputmode="text"
           autocomplete="<%= i.zero? ? "one-time-code" : "off" %>"
           <% if i.zero? && autofocus? %>autofocus<% end %>
           aria-label="backup code character <%= i + 1 %>"
           class="totp-modal-box"
           data-backup-code-input-target="char"
           data-action="input->backup-code-input#onInput change->backup-code-input#onInput keydown->backup-code-input#onKeydown paste->backup-code-input#onPaste blur->backup-code-input#onCellBlur">
  <% end %>
  <input type="hidden"
         name="<%= @field %>"
         value=""
         data-backup-code-input-target="hidden">
</div>
