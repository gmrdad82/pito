<%# Pito::Video::LinkedGameCardComponent — linked-game card mirroring game detail.
    LEFT = big 374×210 Ken-Burns cover. RIGHT = a kv-table (no bars): title, id,
    genres, perspective, theme, publisher, developer, release, total footage,
    price. Two columns on desktop, stacking single-column on mobile (<768px). %>
<div class="pito-video-linked-game-card flex flex-col md:flex-row gap-4 md:items-start">

  <%# ── Left column: big cover bounded to the 450×253 16:9 box, panning
      vertically (Ken-Burns) via pito-cover-pan. Shares the show-game cover CSS
      (.pito-video-linked-game-card__cover + .pito-cover-pan). Missing → the
      shared click-to-sync placeholder (rect). ───── %>
  <div class="pito-video-linked-game-card__cover">
    <%= render Pito::ImageRender.call(
          url:            cover_url,
          shape:          :rect,
          sync_command:   "sync game ##{@game.id}",
          alt:            title.to_s,
          html_class:     "block pito-cover-pan",
          fallback_class: "pito-image-box--rect169"
        ) %>
  </div>

  <%# Mobile-only hairline between the stacked columns (hidden at md: and up,
      where the two-column layout needs no divider). %>
  <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-col-divider md:hidden")) %>

  <%# ── Right column: kv-table ─────────────────────────────────────────────── %>
  <div class="pito-video-linked-game-card__fields grid grid-cols-[max-content_1fr] gap-x-2 gap-y-1 flex-1 min-w-0">
    <%= render(Pito::Table::KeyValueRowComponent.new(
          key_text:    t("pito.game.detail.title"),
          value_text:  title,
          key_class:   "text-fg-dim whitespace-nowrap",
          value_class: "text-fg"
        )) %>

    <%= render(Pito::Table::KeyValueRowComponent.new(
          key_text:        t("pito.game.detail.id"),
          key_class:       "text-fg-dim whitespace-nowrap",
          value_component: Pito::Shimmer::TokenComponent.new(text: "##{@game.id}", extra_class: "tabular-nums", prefill: "show game ##{@game.id}", submit: true)
        )) %>

    <% if genres_label.present? %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.genres"),
            value_text:  genres_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>
    <% end %>

    <% if perspectives_label.present? %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.perspective"),
            value_text:  perspectives_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>
    <% end %>

    <% if themes_label.present? %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.themes"),
            value_text:  themes_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>
    <% end %>

    <% if release_label.present? %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.game.detail.release"),
            value_text:  release_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>
    <% end %>

    <%= render(Pito::Table::KeyValueRowComponent.new(
          key_text:    t("pito.game.detail.footage"),
          value_text:  footage_label,
          key_class:   "text-fg-dim whitespace-nowrap",
          value_class: "text-fg"
        )) %>

    <%= render(Pito::Table::KeyValueRowComponent.new(
          key_text:    t("pito.game.detail.price"),
          value_text:  price_label,
          key_class:   "text-fg-dim whitespace-nowrap",
          value_class: "text-fg tabular-nums"
        )) %>

    <%= render(Pito::Table::KeyValueRowComponent.new(
          key_text:    t("pito.game.detail.last_sync_at"),
          value_text:  last_sync_label,
          key_class:   "text-fg-dim whitespace-nowrap",
          value_class: "text-fg"
        )) %>
  </div>

</div>
