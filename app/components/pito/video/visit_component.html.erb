<%# Pito::Video::VisitComponent — auto-visit redirect for a video %>
<% if visited? %>
  <%# Consumed state: past-tense line + a manual [view] link. No controller,
      no shimmer, no auto-click — safe to re-render on every page refresh. %>
  <div class="pito-video-visit pito-video-visit--visited">
    <span class="text-fg-dim"><%= copy_text %></span>
    <a href="<%= target_url %>"
       target="_blank"
       rel="noopener"
       class="pito-video-visit__view-link text-yellow">[view]</a>
  </div>
<% else %>
  <%# Active state: shimmer copy + hidden anchor. pito--auto-visit clicks it
      once after the delay, then POSTs to consume so the persisted event flips
      to :visited and never auto-clicks again. %>
  <div data-controller="pito--auto-visit"
       data-pito--auto-visit-delay-value="1000"
       data-pito--auto-visit-link-id-value="<%= unique_id %>"
       data-pito--auto-visit-consume-url-value="<%= Rails.application.routes.url_helpers.video_visit_consume_path %>">
    <span class="pito-network-shimmer"
          data-pito--auto-visit-target="copy"><%= copy_text %></span>
    <a id="<%= unique_id %>"
       href="<%= target_url %>"
       target="_blank"
       rel="noopener"
       class="hidden"
       data-pito--auto-visit-target="link">Visit <%= video.title %></a>
  </div>
<% end %>
