<%# Pito::Video::DetailComponent — video detail card for chat messages.
    Two columns: LEFT = thumbnail + hairline + one-line v/L/C stats + legend + Shinies;
    RIGHT = kv-table (Title first), hairline, then Description. %>
<div class="pito-video-detail flex flex-col md:flex-row gap-4 md:items-start">

  <%# ── Left column: intro (with timestamp slot), thumbnail, stats, legend, Shinies ── %>
  <div class="pito-video-detail__left flex flex-col gap-3">

    <% if @intro.present? %>
      <div class="pito-video-detail__intro text-fg"><span data-pito-ts-slot></span><%= @intro %></div>
    <% end %>

    <%# Thumbnail or placeholder %>
    <div class="pito-video-detail__thumbnail">
      <% if thumbnail_attached? && (url = thumbnail_url) %>
        <%= image_tag url, alt: @video.title, class: "block" %>
      <% else %>
        <div class="text-fg-dim"><%=t "pito.video.detail.no_thumbnail" %></div>
      <% end %>
    </div>

    <%# Hairline separating the thumbnail from the stats %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded)) %>

    <%# Stats — bold heading (Pito::Copy) + one-line counters (V/L/C), left. %>
    <div class="pito-video-detail__stats flex flex-col gap-1">
      <div class="pito-video-detail__stats-heading text-fg-dim font-bold"><%= Pito::Copy.render("pito.copy.stats.heading") %></div>
      <%= render(Pito::Stats::CountersComponent.new(metrics: stat_counter_metrics, align: :left)) %>
    </div>

    <%# Shinies — only when the video has at least one achievement. Badges align
        left (inner text stays centered); the legend below is left-aligned too. %>
    <% if @video.achievements.any? %>
      <div class="flex flex-col gap-1">
        <div class="pito-video-detail__shinies-heading text-fg-dim font-bold"><%= Pito::Copy.render("pito.copy.shinies.heading") %></div>
        <div class="pito-video-detail__shinies flex flex-wrap gap-2">
          <% top_shinies_per_metric.each do |a| %>
            <%= render(Pito::Achievement::BadgeComponent.new(threshold: a.threshold, metric: a.metric, unlocked_on: a.unlocked_at.to_date)) %>
          <% end %>
        </div>
        <p class="pito-video-detail__shinies-legend text-fg-dim italic text-left"><%= Pito::Copy.render("pito.copy.shinies.legend") %></p>
      </div>
    <% end %>
  </div>

  <%# ── Right column: kv-table (Title first), hairline, then Description ──
      Title is the first kv row so it lives in the same grid as the metadata.
      whitespace-pre-wrap on the description body preserves YouTube line breaks. %>
  <div class="pito-video-detail__right flex flex-col gap-1 flex-1 min-w-0">
    <%# KV table — Title row first, then ID, YouTube ID, and optional metadata %>
    <div class="grid grid-cols-[max-content_1fr] gap-x-2 gap-y-1">
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.video.detail.title"),
            value_text:  @video.title,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:        t("pito.video.detail.id"),
            key_class:       "text-fg-dim whitespace-nowrap",
            value_component: Pito::Shimmer::TokenComponent.new(text: "##{@video.id}", extra_class: "tabular-nums")
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.video.detail.youtube_id"),
            value_text:  @video.youtube_video_id,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <% if category_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.category"),
              value_text:  category_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if duration_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.duration"),
              value_text:  duration_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if privacy_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.privacy"),
              value_text:  privacy_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if tags_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.tags"),
              value_text:  tags_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>
    </div>

    <%# Hairline between the KV table and the description %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-hairline")) %>

    <%# Description — label on its own row, body beneath %>
    <% if description.present? %>
      <div class="text-fg-dim mt-1"><%= t("pito.video.detail.description") %></div>
      <div class="pito-video-detail__description text-fg whitespace-pre-wrap"><%= description %></div>
    <% end %>
  </div>

</div>
