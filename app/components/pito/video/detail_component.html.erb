<%# Pito::Video::DetailComponent — video detail card for chat messages.
    Two columns: LEFT = thumbnail + hairline + one-line stats counters + Shinies;
    RIGHT = kv-table (Title first), hairline, then Description.
    Uses Pito::Detail::CardComponent as the shared two-column shell. %>
<%= render(Pito::Detail::CardComponent.new(
      bem:                  "pito-video-detail",
      intro:                @intro,
      stat_counter_metrics: stat_counter_metrics,
      shinies:              top_shinies_per_metric,
      right_gap:            "gap-1"
    )) do |card| %>

  <% card.with_image do %>
    <%# Thumbnail — or the shared click-to-sync placeholder (rect) when missing. %>
    <div class="pito-video-detail__thumbnail">
      <%= render Pito::ImageRender.call(
            url:            thumbnail_url,
            shape:          :rect,
            sync_command:   "sync vid ##{@video.id}",
            alt:            @video.title.to_s,
            html_class:     "block",
            fallback_class: "pito-image-box--rect169"
          ) %>
    </div>
  <% end %>

  <% card.with_body do %>
    <%# KV table — Title row first, then ID, YouTube ID, and optional metadata.
        The wrapper div is rendered by the shell; only the content lives here. %>
    <div class="grid grid-cols-[max-content_1fr] gap-x-2 gap-y-1">
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.video.detail.title"),
            value_text:  @video.title,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:        t("pito.video.detail.id"),
            key_class:       "text-fg-dim whitespace-nowrap",
            value_component: Pito::Shimmer::TokenComponent.new(text: "##{@video.id}", extra_class: "tabular-nums", prefill: "show video ##{@video.id}", submit: true)
          )) %>

      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.video.detail.youtube_id"),
            value_text:  @video.youtube_video_id,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>

      <% if category_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.category"),
              value_text:  category_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if duration_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.duration"),
              value_text:  duration_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <% if privacy_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.privacy"),
              value_text:  privacy_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <%# Publish at — the scheduled go-live timestamp, its own named field
          directly after Visibility (only present for scheduled vids). %>
      <% if publish_at_label.present? %>
        <%= render(Pito::Table::KeyValueRowComponent.new(
              key_text:    t("pito.video.detail.publish_at"),
              value_text:  publish_at_label,
              key_class:   "text-fg-dim whitespace-nowrap",
              value_class: "text-fg"
            )) %>
      <% end %>

      <%# Last sync at — directly after visibility (privacy); tags are no longer a
          kv-row, they live in their own section below the description. %>
      <%= render(Pito::Table::KeyValueRowComponent.new(
            key_text:    t("pito.video.detail.last_sync_at"),
            value_text:  last_sync_label,
            key_class:   "text-fg-dim whitespace-nowrap",
            value_class: "text-fg"
          )) %>
    </div>

    <%# Hairline between the KV table and the description %>
    <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-hairline")) %>

    <%# Description — label on its own row, body beneath %>
    <% if description.present? %>
      <div class="text-fg-dim mt-1"><%= t("pito.video.detail.description") %></div>
      <div class="pito-video-detail__description text-fg whitespace-pre-wrap"><%= description %></div>
    <% end %>

    <%# Tags — its own hairline-separated section below the description, rendered
        like Description (label row + comma-joined tags beneath), not a kv-row. %>
    <% if tags_label.present? %>
      <%= render(Pito::Separator::DividerLineComponent.new(hairline: true, tone: :faded, extra_classes: "pito-detail-hairline")) %>
      <div class="text-fg-dim mt-1"><%= t("pito.video.detail.tags") %></div>
      <div class="pito-video-detail__tags text-fg whitespace-pre-wrap"><%= tags_label %></div>
    <% end %>
  <% end %>

<% end %>
