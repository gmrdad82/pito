<%# Pito::Video::ListComponent — compact list of video rows for `list videos`.
    Each row: title, channel @handle, privacy label, and #id for `show video <id>`. %>
<div class="pito-video-list">
  <% videos.each do |video| %>
    <div class="pito-video-list__row">
      <span class="pito-video-list__id text-cyan tabular-nums">#<%= video.id %></span>
      <span class="pito-video-list__title text-fg"><%= video.title %></span>
      <span class="pito-video-list__channel text-fg-dim"><%= video.channel.at_handle %></span>
      <% if (label = privacy_label_for(video)) %>
        <span class="pito-video-list__privacy text-fg-faded"><%= label %></span>
      <% end %>
    </div>
  <% end %>
</div>
