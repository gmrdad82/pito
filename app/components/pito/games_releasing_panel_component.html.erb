<%= content_tag :section,
      class: "pane pito-pane pito-panel pito-panel--games-releasing",
      **panel_data do %>
  <span class="pito-pane__title"><%= title %></span>
  <%# 2026-05-25 — content round. `axis: :horizontal` flips the
      auto-mounted scroll indicator to its horizontal mode (left/right
      glyphs on the BOTTOM border; scroll surface owns `overflow-x: auto`
      with `overflow-y: hidden` via the `.upcoming-tile-shelf` CSS hook
      applied via `class_name:`). %>
  <%= render Tui::PanelFieldsetComponent.new(
        class_name: "upcoming-tile-shelf",
        axis: :horizontal
      ) do %>
    <% if empty? %>
      <p class="pito-panel__placeholder"><%= empty_hint %></p>
    <% else %>
      <div class="upcoming-tile-shelf__row">
        <% upcoming_games.each do |game| %>
          <%= render Pito::GamesReleasing::ShelfTileComponent.new(game: game) %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
