<%# Beta 4 F3-DEEP-A — TUI revamp.
    QR-code section rendered inside a Tui::FramedPanelComponent so the
    framed hairline visually owns the scan step. White bg on the inner
    inline-block stays — QR modules (black on transparent) need the
    contrast to scan reliably regardless of theme. %>
<%= render Tui::FramedPanelComponent.new(title: "scan with authenticator app") do %>
  <div style="margin: 4px 0 8px;">
    <div style="background: #ffffff; padding: 8px; display: inline-block;">
      <%= qr_svg %>
    </div>
  </div>
  <p class="text-muted" style="margin: 8px 0 4px;">
    or paste this seed manually:
  </p>
  <pre style="font-family: inherit; font-size: 13px; padding: 6px 8px; margin: 0; white-space: pre-wrap; word-break: break-all; background: var(--color-bg-alt); border: 1px solid var(--color-border); font-variant-numeric: tabular-nums;"><%= @seed %></pre>
<% end %>

<div style="height: 12px;"></div>

<h2>enter code</h2>
<%= form_with url: settings_security_totp_path, method: :post, data: { turbo: false } do %>
  <div style="margin: 6px 0 8px;">
    <label class="form-label">6-digit code from your authenticator app</label>
    <%= render TotpCodeInputComponent.new(field: :code, autofocus: true) %>
  </div>
  <button type="submit" class="bracketed" style="cursor: pointer; background: none; border: none; padding: 0; color: var(--color-link); font: inherit;">[<span class="bl">verify</span>]</button>
<% end %>
