<%# Pito::Stack::VoyageSubPanelComponent — Voyage AI sub-panel inside
    the stack panel on Home.

    FB-63-V4 (2026-05-20) — V4 title-in-border chrome (title left,
    chip + `[reindex]` right). The wrapping `.pito-sub-panel`
    surrounds `<div id="voyage_section">` so the Turbo Stream replace
    inside `_voyage_section.html.erb` keeps repainting only the stats
    + running-state block; the V4 chrome (chip + `[reindex]`) lives
    here in the parent and stays put.

    FB-126 (2026-05-21) — `[reindex]` opens a confirmation dialog
    mounted by the parent `Pito::StackPanelComponent` (id
    `reindex_voyage_confirmation`).

    FB-166 — same Ruby-driven focusable contract as the Meilisearch
    sub-panel. %>
<%= render Tui::SubPanelComponent.new(title: t("settings.voyage.heading"), panel_commands: panel_commands) do |c| %>
  <% c.with_actions do %>
    <span>
      <% _voyage_f = focusables.first %>
      <span <%= "hidden" if reindex_running? %>>
        <%# ADR 0018 — `data-action-name` routes the click
            through `window.Pito.dispatchAction(:reindex_voyage)`. %>
        <%= render Tui::ActionButtonComponent.new(
          action_name: :reindex_voyage,
          label: t("settings.stack.voyage_reindex_label"),
          focusable: _voyage_f,
          data: { reindex_brand: "voyage" },
        ) %>
      </span>
      <span <%= "hidden" unless reindex_running? %>>
        <%= render Tui::ReindexProgressComponent.new(brand: "voyage") %>
      </span>
    </span>
  <% end %>
  <p class="pito-sub-panel__hint <%= hint_color_class %>"><%= hint_text %></p>
  <%= helpers.turbo_stream_from "reindex_status" %>
  <%# 2026-05-25 — pass current sort params as locals so the sortable
      embeds table inside the partial emits `sort_link_to` headers with
      the correct active-column class on first paint. %>
  <%= render "settings/voyage_section", voyage_sort: current_sort, voyage_dir: current_dir %>
<% end %>
