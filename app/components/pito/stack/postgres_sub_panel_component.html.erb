<%# Pito::Stack::PostgresSubPanelComponent — PostgreSQL sub-panel
    inside the stack panel on Home. FB-63-V4 — V4 title-in-border.
    Phase 1D — status chip removed; hint line added at body top. %>
<%= render Tui::SubPanelComponent.new(title: t("settings.stack.postgres"), focusable_key: "postgres") do |c| %>
  <p class="pito-sub-panel__hint <%= hint_color_class %>"><%= hint_text %></p>

  <% if status[:connected] && table_breakdown.any? %>
    <div data-controller="sortable-table" data-sortable-table-id-value="stack-postgres">
      <table class="tui-table tui-table--stack" data-sortable-table-target="table">
        <thead>
          <%# FB (2026-05-24) — header row focusable. Inert style so the
              row doesn't paint a focus tint; the cursor just gets a
              stop here so `s` / `S` fire scoped to this sub-panel. %>
          <tr data-tui-focusable="postgres_header"
              data-tui-focusable-key="postgres_header"
              data-tui-focusable-style="inert">
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_model"), sort_type: "string")) %>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_rows"), sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_size"), sort_type: "number", numeric: true)) %>
          </tr>
        </thead>
        <tbody>
          <% table_breakdown.each do |row| %>
            <% _row_key = "row_" + row[:label].to_s.parameterize(separator: "_") %>
            <tr class="tui-table__row"
                data-tui-focusable="<%= _row_key %>"
                data-tui-focusable-key="<%= _row_key %>"
                data-tui-focusable-style="row"
                data-tui-cursor-target="row">
              <td class="tui-table__td"><%= row[:label] %></td>
              <td class="tui-table__td tui-table__td--right num">
                <span data-sort-value="<%= row[:count] || -1 %>">
                  <%= row[:count] ? number_with_delimiter(row[:count]) : "—" %>
                </span>
              </td>
              <td class="tui-table__td tui-table__td--right num">
                <span data-sort-value="<%= row[:size_bytes] || -1 %>">
                  <%= helpers.human_filesize_int(row[:size_bytes]) %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
