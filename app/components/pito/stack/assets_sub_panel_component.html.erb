<%# Pito::Stack::AssetsSubPanelComponent — assets storage sub-panel
    inside the stack panel on Home. FB-63-V4 — V4 title-in-border.
    Phase 1D — status chip removed; hint line added at body top. %>
<%= render Tui::SubPanelComponent.new(title: t("settings.stack.assets"), focusable_key: "assets") do |c| %>
  <% c.with_actions do %>
    <%# Phase 1D (2026-05-24) — sub-panel sync indicator. Assets has no
        other border action so this is the sole occupant of the slot. %>
    <%= render Tui::SyncIndicatorComponent.new(
      mode: :target,
      target: "home.stack.assets",
      parent_target: "home.stack",
      focusable_key: "assets_sync"
    ) %>
  <% end %>
  <p class="pito-sub-panel__hint <%= hint_color_class %>"><%= hint_text %></p>

  <% if breakdown.any? %>
    <div data-controller="sortable-table" data-sortable-table-id-value="stack-assets">
      <table class="tui-table tui-table--stack tui-table--3col-aligned" data-sortable-table-target="table">
        <thead>
          <%# FB (2026-05-24) — header row focusable. Inert style so the
              row doesn't paint a focus tint; the cursor just gets a
              stop here so `s` / `S` fire scoped to this sub-panel. %>
          <tr data-tui-focusable="assets_header"
              data-tui-focusable-key="assets_header"
              data-tui-focusable-style="inert">
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_category"), sort_type: "string")) %>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_files"), sort_type: "number", numeric: true)) %>
            <%= render(SortableHeaderComponent.new(label: t("settings.stack.col_size"), sort_type: "number", numeric: true)) %>
          </tr>
        </thead>
        <tbody>
          <% breakdown.each do |row| %>
            <% _row_key = "row_" + row[:label].to_s.parameterize(separator: "_") %>
            <tr class="tui-table__row"
                data-tui-focusable="<%= _row_key %>"
                data-tui-focusable-key="<%= _row_key %>"
                data-tui-focusable-style="row"
                data-tui-cursor-target="row">
              <td class="tui-table__td"><%= row[:label] %></td>
              <td class="tui-table__td tui-table__td--right num">
                <span data-sort-value="<%= row[:file_count] || -1 %>">
                  <%= row[:file_count] ? number_with_delimiter(row[:file_count]) : "—" %>
                </span>
              </td>
              <td class="tui-table__td tui-table__td--right num">
                <span data-sort-value="<%= row[:size_bytes] || -1 %>">
                  <%= helpers.human_filesize_int(row[:size_bytes]) %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
