<%# Pito::Stack::AssetsSubPanelComponent — assets storage sub-panel
    inside the stack panel on Home. FB-63-V4 — V4 title-in-border.
    Phase 1D — status chip removed; hint line added at body top.

    2026-05-25 — Migrated from SortableHeaderComponent (client-side,
    hash-driven) to server-side sort via `sort_link_to`. The
    `data-controller="sortable-table"` wrapper is removed; sort state
    is resolved from `?assets_sort=…&assets_dir=…` query params on
    first paint. Default: files desc. %>
<%= render Tui::SubPanelComponent.new(title: t("settings.stack.assets"), focusable_key: "assets", panel_commands: panel_commands) do |c| %>
  <p class="pito-sub-panel__hint <%= hint_color_class %>"><%= hint_text %></p>

  <% if breakdown.any? %>
    <table class="tui-table tui-table--stack tui-table--3col-aligned">
      <thead>
        <%# Server-side sort headers. `sort_link_to` emits
            `<a class="sort-asc">` / `<a class="sort-desc">` on the
            active column; CSS `:has(> a.sort-asc)` picks up the V4
            underline on first paint without client JS. %>
        <tr data-tui-focusable="assets_header"
            data-tui-focusable-key="assets_header"
            data-tui-focusable-style="inert">
          <th class="tui-table__th tui-table__th--left sortable">
            <%= helpers.sort_link_to(t("settings.stack.col_category"), "category", current_sort: current_sort, current_dir: current_dir, sort_param: "assets_sort", dir_param: "assets_dir") %>
          </th>
          <th class="tui-table__th tui-table__th--right num sortable">
            <%= helpers.sort_link_to(t("settings.stack.col_files"), "files", current_sort: current_sort, current_dir: current_dir, sort_param: "assets_sort", dir_param: "assets_dir") %>
          </th>
          <th class="tui-table__th tui-table__th--right num sortable">
            <%= helpers.sort_link_to(t("settings.stack.col_size"), "size", current_sort: current_sort, current_dir: current_dir, sort_param: "assets_sort", dir_param: "assets_dir") %>
          </th>
        </tr>
      </thead>
      <tbody>
        <% breakdown.each do |row| %>
          <% _row_key = "row_" + row[:label].to_s.parameterize(separator: "_") %>
          <tr class="tui-table__row"
              data-tui-focusable="<%= _row_key %>"
              data-tui-focusable-key="<%= _row_key %>"
              data-tui-focusable-style="row"
              data-tui-cursor-target="row">
            <td class="tui-table__td"><%= row[:label] %></td>
            <td class="tui-table__td tui-table__td--right num">
              <%= row[:file_count] ? number_with_delimiter(row[:file_count]) : "—" %>
            </td>
            <td class="tui-table__td tui-table__td--right num">
              <%= helpers.human_filesize_int(row[:size_bytes]) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% end %>
