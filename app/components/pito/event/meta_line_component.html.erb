<div class="pito-echo__meta">
  <% if formatted_timestamp %>
    <span class="text-fg-faded"><%= formatted_timestamp %></span>
  <% end %>
  <% if @handle %>
    <% if formatted_timestamp %>
      <%= render(Pito::Shell::InlineSeparatorComponent.new) %>
    <% end %>
    <%= render(Pito::Event::HandleComponent.new(@handle)) %>
    <%# `· shift+r` affordance — the pito--lasthashtag controller unhides this on
        ONLY the most recent hashtag segment, so shift+r (caret at start) reuses
        this handle. Hidden by default; the controller hops it to the latest. %>
    <span data-pito-lasthashtag-hint class="hidden">
      <%= render(Pito::Shell::InlineSeparatorComponent.new) %><span class="text-yellow">shift+r</span>
    </span>
  <% end %>
  <% if @channel.present? %>
    <% if formatted_timestamp || @handle %>
      <%= render(Pito::Shell::InlineSeparatorComponent.new) %>
    <% end %>
    <%= render(Pito::Event::ChannelHandleComponent.new(@channel)) %>
  <% end %>
</div>
