<%= render(Pito::Segment::Component.new(accent:, background:)) do %>
  <%# Full-content typewriter: outer div owns the controller so the body types
      in document order. Only wraps when there is a plain-text body to anchor
      the animation. %>
  <% if !html && body %>
    <div data-controller="pito--typewriter">
      <%= render(Pito::Event::BodyComponent.new(
            body:             body,
            html:             html,
            detail:           expand_detail,
            typewriter:       true,
            owner_controller: false,
            timestamp:        @timestamp
          )) %>
    </div>
  <% else %>
    <%= render(Pito::Event::BodyComponent.new(
          body:       body,
          html:       html,
          detail:     expand_detail,
          typewriter: false,
          timestamp:  @timestamp
        )) %>
  <% end %>
  <% if meta_handle || channel %>
    <%= render(Pito::Event::MetaLineComponent.new(
          handle:  meta_handle,
          channel: channel
        )) %>
  <% end %>
<% end %>
