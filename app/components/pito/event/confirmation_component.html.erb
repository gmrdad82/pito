<%= render(Pito::Segment::Component.new(accent: :orange, background:, id: dom_id)) do %>
  <div class="flex flex-col">
    <%# Processing indicator (Braille + verb, inside segment above body) %>
    <% if processing? %>
      <%= render(Pito::Event::ConfirmationSpinnerComponent.new(
            frames_json: braille_frames_json,
            word:        processing_word
          )) %>
    <% end %>

    <%# Body + optional expand detail (pending state only) %>
    <%= render(Pito::Event::ExpandableBodyComponent.new(
          body:           body,
          html:           html?,
          expand_detail:  expandable? ? expand_detail : [],
          expand_label:   t("pito.confirmation.expand_hint"),
          collapse_label: t("pito.confirmation.expand_collapse_hint")
        )) %>

    <%# Follow-up affordance (#<handle> confirm · cancel) — hidden once consumed %>
    <% if reply_handle.present? && !resolved? %>
      <%= render(Pito::FollowUp::AffordanceComponent.new(
            handle:   reply_handle,
            usage:    affordance_usage,
            consumed: reply_consumed?
          )) %>
    <% end %>

    <%# Meta line: timestamp only (no handle — shown via affordance above) %>
    <%= render(Pito::Event::MetaLineComponent.new(timestamp: @timestamp)) %>
  </div>
<% end %>
