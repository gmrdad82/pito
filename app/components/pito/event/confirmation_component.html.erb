<%= render(Pito::Segment::Component.new(accent: :orange, background:, id: dom_id, scrollback_message: true)) do %>
  <div class="flex flex-col">
    <%# Processing indicator (Braille + verb, inside segment above body) %>
    <% if processing? %>
      <%= render(Pito::Event::ConfirmationSpinnerComponent.new(
            frames_json: braille_frames_json,
            word:        processing_word
          )) %>
    <% end %>

    <%# Body + stats detail (shown while pending; hidden once resolved).
        Wrapped in a div so the timestamp + body stay inline — a bare
        BodyComponent would let flex-col row-split its two spans.

        Typewriter is mounted ONLY in the pending (initial) state — its skip
        guards (!__pitoReady / reduced-motion / fx off) still make a pending
        prompt already in scrollback render instant, so only a freshly-broadcast
        prompt types. The processing / resolved renders (Turbo replace_event
        swaps) carry NO typewriter controller, so a state transition shows the
        new content instantly and never re-types. %>
    <div>
      <%= render(Pito::Event::BodyComponent.new(
            body:       body,
            html:       html?,
            detail:     expandable? ? expand_detail : [],
            typewriter: pending?,
            timestamp:  @timestamp
          )) %>
    </div>

    <%# Single meta line — `timestamp · #handle` while still awaiting a reply
        (#<handle> confirm / cancel). Handle drops once consumed/resolved.
        There is NO separate usage/affordance line. %>
    <%= render(Pito::Event::MetaLineComponent.new(
          handle: (reply_handle.present? && !resolved? && !reply_consumed? ? reply_handle : nil)
        )) %>
  </div>
<% end %>
