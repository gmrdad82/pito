<%= render(Pito::Segment::Component.new(accent: :orange, background:, id: dom_id)) do %>
  <div class="flex flex-col">
    <%# Processing indicator (Braille + verb, inside segment above body) %>
    <% if processing? %>
      <%= render(Pito::Event::ConfirmationSpinnerComponent.new(
            frames_json: braille_frames_json,
            word:        processing_word
          )) %>
    <% end %>

    <%# Body + stats detail (shown while pending; hidden once resolved) %>
    <%= render(Pito::Event::BodyComponent.new(
          body:      body,
          html:      html?,
          detail:    expandable? ? expand_detail : [],
          timestamp: @timestamp
        )) %>

    <%# Single meta line — `timestamp · #handle` while still awaiting a reply
        (#<handle> confirm / cancel). Handle drops once consumed/resolved.
        There is NO separate usage/affordance line. %>
    <%= render(Pito::Event::MetaLineComponent.new(
          handle: (reply_handle.present? && !resolved? && !reply_consumed? ? reply_handle : nil)
        )) %>
  </div>
<% end %>
