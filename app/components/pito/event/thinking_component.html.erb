<% if resolved? %>
  <%= render(Pito::Segment::Component.new(id: dom_id)) do %>
    <%# Wrap in .pito-thinking so the glyph hangs left to the SAME message-border
        column the braille spinner used while thinking (13.19). %>
    <span class="pito-thinking pito-thinking--resolved">
      <span class="pito-thinking__glyph"><%= resolved_glyph %></span>
      <span class="pito-thinking__message" data-controller="pito--turn-complete"><%= resolved_message %></span>
    </span>
  <% end %>
<% else %>
  <%= render(Pito::Segment::Component.new(id: dom_id)) do %>
    <span class="pito-thinking"
          data-controller="pito--thinking"
          data-pito--thinking-frames-value="<%= braille_frames_json %>"
          data-pito--thinking-words-value="<%= doing_words_json %>"
          data-pito--thinking-order-value="<%= order_json %>"
          data-pito--thinking-started-at-value="<%= started_at_ms %>"
          data-pito--thinking-interval-value="<%= interval_ms %>">
      <span class="pito-thinking__braille pito-shimmer" data-pito--thinking-target="braille">⠋</span>
      <span class="pito-thinking__word pito-shimmer" data-pito--thinking-target="word"><%= current_word %>…</span>
    </span>
  <% end %>
<% end %>
