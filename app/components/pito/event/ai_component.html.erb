<%= render(Pito::Segment::Component.new(accent: pending? ? :surface : :ai, content_class: pending? ? nil : "pito-ai-surface", msg_bg: "var(--bg-surface)", fx: @payload[:fx], id: dom_id, scrollback_message: true)) do %>
  <% if pending? %>
    <%# The loop is running — the tile wears the FULL :system dress (surface
        bar, transparent background) and only promotes to the AI chrome when
        the answer lands. The slot opens with a witty handshake line (the
        model takes a beat before its first tool call), then the Broadcaster
        narrates each tool read; both shimmer like the Thinking block. %>
    <div id="<%= blocks_slot_id %>" class="flex flex-col gap-2"></div>
    <div id="<%= status_slot_id %>" class="text-fg-faded pito-network-shimmer"><%= handshake_line %></div>
  <% else %>
    <%# The bottom padding keeps the last line clear of the ✨ badge (which
        pins itself to the surrounding .pito-ai-surface tile's corner). %>
    <div class="flex flex-col gap-2 pb-4">
      <% blocks.each_with_index do |block, idx| %>
        <% if idx.zero? && text_block?(block) %>
          <%# The timestamp rides INSIDE the first text block (inline flow), so
              "05:22 Iată…" gets its space and wrapped lines return to the left
              margin instead of hanging indented under the prefix. %>
          <%= render(component_for(block, timestamp: timestamp)) %>
        <% elsif idx.zero? %>
          <div><%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: timestamp)) %></div>
          <%= render(component_for(block)) %>
        <% else %>
          <%= render(component_for(block)) %>
        <% end %>
      <% end %>
      <%# The established meta footer — shimmer #handle + the clickable shift+r
          reply affordance, exactly like every other repliable message. %>
      <%= render(Pito::Event::MetaLineComponent.new(handle: reply_handle)) %>
      <%= render(Pito::Event::Ai::ModelBadgeComponent.new(
            model: model,
            cost_amount: @payload[:cost_amount], cost_currency: @payload[:cost_currency],
            cost_estimated: @payload[:cost_estimated] == true
          )) %>
    </div>
  <% end %>
<% end %>
