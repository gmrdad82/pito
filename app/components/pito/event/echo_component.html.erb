<%= render(Pito::Segment::Component.new(accent: :purple, background: "var(--bg-elevated)")) do %>
  <span class="text-fg"><%= @text %></span>
  <div class="pito-echo__meta">
    <span class="text-fg-faded"><%= @timestamp ? @timestamp.strftime("%-l:%M %p") : "" %></span>
    <span class="text-fg-faded"> · </span>
    <span class="text-yellow"><%= t("pito.shell.chatbox.default_channel") %></span>
  </div>
<% end %>
