<%= render(Pito::Segment::Component.new(accent:, background:, id: dom_id, scrollback_message: true)) do %>
  <% if sections.any? %>
    <%# Sections mode: body + all section detail, rendered instantly (item 18). %>
    <% if html %>
      <div data-controller="pito--ascii-fit">
        <% if body %>
          <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= raw(body) %></span>
        <% end %>
        <div class="mt-1.5 border-t border-line-default pt-1.5">
          <%= render(Pito::Keybinding::TableComponent.new(sections: sections)) %>
        </div>
      </div>
    <% else %>
      <div>
        <% if body %>
          <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= body %></span>
        <% end %>
        <div class="mt-1.5 border-t border-line-default pt-1.5">
          <div class="flex flex-col gap-3">
            <% sections.each do |section| %>
              <div class="flex flex-col gap-1">
                <div class="text-yellow font-bold mb-1"><%= section[:title] %></div>
                <% Array(section[:rows]).each do |row| %>
                  <div class="flex gap-4">
                    <%= render(Pito::Table::KeyValueRowComponent.new(
                          key_text:    row[:key],
                          value_text:  row[:value],
                          key_class:   "text-cyan whitespace-nowrap shrink-0 w-44",
                          value_class: "text-fg-dim"
                        )) %>
                    <% if row[:value2].present? %>
                      <span class="text-cyan whitespace-nowrap"><%= row[:value2] %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <%# No sections: body (via BodyComponent) + the table_rows grid + info_lines,
        all rendered instantly (item 18: text reveal removed). %>
    <% if !html && body %>
      <div>
        <%= render(Pito::Event::BodyComponent.new(
              body:      body,
              html:      html,
              detail:    expand_detail,
              timestamp: @timestamp
            )) %>
        <% if table_rows.any? %>
          <% norm_rows = normalized_table_rows %>
          <% heading_cells = table_heading_cells %>
          <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
          <div class="pito-data-grid<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>" data-cols="<%= table_col_count(n_cols) %>" data-fixed-leading="<%= fixed_leading %>" data-fixed-trailing="<%= fixed_trailing %>">
            <% heading_cells.each do |cell| %>
              <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
            <% end %>
            <% norm_rows.each do |cells| %>
              <% cells.each do |cell| %>
                <%= render_cell_span(cell) %>
              <% end %>
            <% end %>
          </div>
        <% end %>
        <% if info_lines.any? %>
          <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
            <% info_lines.each do |line| %>
              <div><%= render_info_line(line) %></div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% elsif html %>
      <%# html: true — the whole card (body + grid + info-lines) renders instantly
          (item 18: text reveal removed). The ascii-fit controller stays for
          html/ascii-art width fitting. %>
      <div>
        <div data-controller="pito--ascii-fit">
          <%= render(Pito::Event::BodyComponent.new(
                body:      body,
                html:      html,
                detail:    expand_detail,
                timestamp: @timestamp
              )) %>
          <% if table_rows.any? %>
            <% norm_rows = normalized_table_rows %>
            <% heading_cells = table_heading_cells %>
            <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
            <div class="pito-data-grid<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>" data-cols="<%= table_col_count(n_cols) %>" data-fixed-leading="<%= fixed_leading %>" data-fixed-trailing="<%= fixed_trailing %>">
              <% heading_cells.each do |cell| %>
                <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
              <% end %>
              <% norm_rows.each do |cells| %>
                <% cells.each do |cell| %>
                  <%= render_cell_span(cell) %>
                <% end %>
              <% end %>
            </div>
          <% end %>
          <% if info_lines.any? %>
            <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
              <% info_lines.each do |line| %>
                <div><%= render_info_line(line) %></div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <%# Neither html nor a plain-text body (rare: a bare table). %>
      <%= render(Pito::Event::BodyComponent.new(
            body:      body,
            html:      html,
            detail:    expand_detail,
            timestamp: @timestamp
          )) %>
      <% if table_rows.any? %>
        <% norm_rows = normalized_table_rows %>
        <% heading_cells = table_heading_cells %>
        <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
        <div class="pito-data-grid<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>" data-cols="<%= table_col_count(n_cols) %>" data-fixed-leading="<%= fixed_leading %>" data-fixed-trailing="<%= fixed_trailing %>">
          <% heading_cells.each do |cell| %>
            <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
          <% end %>
          <% norm_rows.each do |cells| %>
            <% cells.each do |cell| %>
              <%= render_cell_span(cell) %>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if info_lines.any? %>
        <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
          <% info_lines.each do |line| %>
            <div><%= render_info_line(line) %></div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
  <%# Witty italic footer after the table rows (list messages) naming the
      columns that can still be added — or that everything is shown. %>
  <% if list_footer %>
    <div class="pito-list-footer text-fg-dim italic mt-2"><%= list_footer %></div>
  <% end %>
  <% if @suggestion %>
    <%= render(Pito::Event::SegmentSuggestionComponent.new(suggestion: @suggestion)) %>
  <% end %>
  <% if meta_handle || channel %>
    <%= render(Pito::Event::MetaLineComponent.new(
          handle:  meta_handle,
          channel: channel
        )) %>
  <% end %>
<% end %>
