<%= render(Pito::Segment::Component.new(accent:, background:)) do %>
  <% if sections.any? %>
    <%# Sections mode: body + top hint visible when collapsed;
        sections + bottom hint visible when expanded. %>
    <div data-controller="pito--expand"
         data-pito--expand-expand-label-value="<%= expand_label %>"
         data-pito--expand-collapse-label-value="<%= collapse_label %>">
      <% if body %>
        <span class="text-fg"><%= html ? raw(body) : body %></span>
      <% end %>
      <% expand_lines.each do |line| %>
        <div class="text-fg"><%= line %></div>
      <% end %>
      <%# Top hint — hidden when expanded %>
      <div data-pito--expand-target="hint" class="mt-1">
        <%= render(Pito::Keybinding::HintComponent.new(
              shortcut:    "ctrl+|",
              description: expand_label
            )) %>
      </div>
      <%# Detail — hidden when collapsed %>
      <div data-pito--expand-target="detail" class="hidden mt-1.5 border-t border-line-default pt-1.5">
        <%= render(Pito::Keybinding::TableComponent.new(sections: sections)) %>
      </div>
      <%# Bottom hint — hidden when collapsed; description carries hintLabel for text swap. %>
      <div data-pito--expand-target="hintAfter" class="hidden mt-1.5 border-t border-line-faded pt-1.5">
        <%= render(Pito::Keybinding::HintComponent.new(
              shortcut:       "ctrl+|",
              description:    expand_label,
              description_data: { "pito--expand-target" => "hintLabel" }
            )) %>
      </div>
    </div>
  <% else %>
    <%= render(Pito::Event::ExpandableBodyComponent.new(
          body:              body,
          html:              html,
          expand_lines:      expand_lines,
          expand_detail:     expand_detail,
          expand_more_count: expand_more_count,
          expand_label:      expand_label,
          collapse_label:    collapse_label
        )) %>
  <% end %>
  <% if table_rows.any? %>
    <div class="flex flex-col gap-1<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>">
      <% table_rows.each do |row| %>
        <div class="flex gap-2">
          <span class="<%= row.fetch(:key_class, 'text-cyan') %> whitespace-nowrap shrink-0"><%= row[:key] %></span>
          <span class="<%= row.fetch(:value_class, 'text-fg-dim') %>"><%= row[:value] %></span>
        </div>
      <% end %>
    </div>
  <% end %>
  <% if info_lines.any? %>
    <div class="mt-2 border-t border-line-default pt-2">
      <% info_lines.each do |line| %>
        <div class="text-fg-dim"><%= line %></div>
      <% end %>
    </div>
  <% end %>
  <% if @suggestion %>
    <%= render(Pito::Event::SegmentSuggestionComponent.new(suggestion: @suggestion)) %>
  <% end %>
  <% if handle || channel %>
    <%= render(Pito::Event::MetaLineComponent.new(
          handle:  handle,
          channel: channel
        )) %>
  <% end %>
<% end %>
