<%= render(Pito::Segment::Component.new(accent:, background:, id: dom_id)) do %>
  <% if sections.any? %>
    <%# Sections mode: body + top hint visible when collapsed;
        sections + bottom hint visible when expanded.
        Full-content typewriter: outer div owns the controller so body,
        expand_lines, section headers, and all kv leaf spans type in order. %>
    <div data-controller="pito--expand"
         data-pito--expand-expand-label-value="<%= expand_label %>"
         data-pito--expand-collapse-label-value="<%= collapse_label %>">
      <% if html %>
        <%# html: true — no typewriter, render everything instantly %>
        <% if body || expand_lines.any? %>
          <span class="text-fg"><%= raw(body) %></span>
          <% expand_lines.each do |line| %>
            <div class="text-fg"><%= line %></div>
          <% end %>
        <% end %>
        <div data-pito--expand-target="hint" class="mt-1">
          <%= render(Pito::Keybinding::HintComponent.new(
                shortcut:    "ctrl+|",
                description: expand_label
              )) %>
        </div>
        <div data-pito--expand-target="detail" class="hidden mt-1.5 border-t border-line-default pt-1.5">
          <%= render(Pito::Keybinding::TableComponent.new(sections: sections)) %>
        </div>
        <div data-pito--expand-target="hintAfter" class="hidden mt-1.5 border-t border-line-faded pt-1.5">
          <%= render(Pito::Keybinding::HintComponent.new(
                shortcut:       "ctrl+|",
                description:    expand_label,
                description_data: { "pito--expand-target" => "hintLabel" }
              )) %>
        </div>
      <% else %>
        <%# Plain-text: typewriter controller covers the full content region %>
        <div data-controller="pito--typewriter">
          <% if body || expand_lines.any? %>
            <span class="text-fg" data-pito--typewriter-target="body"><%= body %></span>
            <% expand_lines.each do |line| %>
              <div class="text-fg" data-pito--typewriter-target="prose"><%= line %></div>
            <% end %>
          <% end %>
          <%# Top hint — chrome, renders instantly (no prose target) %>
          <div data-pito--expand-target="hint" class="mt-1">
            <%= render(Pito::Keybinding::HintComponent.new(
                  shortcut:    "ctrl+|",
                  description: expand_label
                )) %>
          </div>
          <%# Detail — section headers + kv rows tagged as prose targets so they
              type in place inside their own grid/flex cells %>
          <div data-pito--expand-target="detail" class="hidden mt-1.5 border-t border-line-default pt-1.5">
            <div class="flex flex-col gap-3">
              <% sections.each do |section| %>
                <div class="flex flex-col gap-1">
                  <div class="text-yellow font-bold mb-1" data-pito--typewriter-target="prose"><%= section[:title] %></div>
                  <% Array(section[:rows]).each do |row| %>
                    <div class="flex gap-4">
                      <%= render(Pito::Table::KeyValueRowComponent.new(
                            key_text:    row[:key],
                            value_text:  row[:value],
                            key_class:   "text-cyan whitespace-nowrap shrink-0 w-44",
                            value_class: "text-fg-dim",
                            key_data:    { "pito--typewriter-target" => "prose" },
                            value_data:  { "pito--typewriter-target" => "prose" }
                          )) %>
                      <% if row[:value2].present? %>
                        <span class="text-cyan whitespace-nowrap" data-pito--typewriter-target="prose"><%= row[:value2] %></span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
          <%# Bottom hint — chrome, renders instantly %>
          <div data-pito--expand-target="hintAfter" class="hidden mt-1.5 border-t border-line-faded pt-1.5">
            <%= render(Pito::Keybinding::HintComponent.new(
                  shortcut:       "ctrl+|",
                  description:    expand_label,
                  description_data: { "pito--expand-target" => "hintLabel" }
                )) %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# No sections: outer typewriter wrapper covers body (via ExpandableBodyComponent
        with owner_controller: false) AND the table_rows grid below it.
        info_lines contain HTML code highlights so they render instantly.
        Only emit the typewriter wrapper when there IS a plain-text body to
        anchor it (controller guards against empty body targets internally,
        but the spec also checks that no controller appears on nil-body renders). %>
    <% if !html && body %>
      <div data-controller="pito--typewriter">
        <%= render(Pito::Event::ExpandableBodyComponent.new(
              body:              body,
              html:              html,
              expand_lines:      expand_lines,
              expand_detail:     expand_detail,
              expand_more_count: expand_more_count,
              expand_label:      expand_label,
              collapse_label:    collapse_label,
              typewriter:        true,
              owner_controller:  false
            )) %>
        <% if table_rows.any? %>
          <% norm_rows = normalized_table_rows %>
          <% heading_cells = table_heading_cells %>
          <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
          <div class="grid <%= table_grid_cols(n_cols) %> gap-x-2 gap-y-1<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>">
            <% heading_cells.each do |cell| %>
              <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
            <% end %>
            <% norm_rows.each do |cells| %>
              <% cells.each do |cell| %>
                <span class="<%= cell[:class] %>" data-pito--typewriter-target="prose"><%= cell[:text] %></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
        <% if info_lines.any? %>
          <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
            <% info_lines.each do |line| %>
              <div><%= render_info_line(line) %></div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%# html: true — render everything instantly, no typewriter %>
      <%= render(Pito::Event::ExpandableBodyComponent.new(
            body:              body,
            html:              html,
            expand_lines:      expand_lines,
            expand_detail:     expand_detail,
            expand_more_count: expand_more_count,
            expand_label:      expand_label,
            collapse_label:    collapse_label,
            typewriter:        false
          )) %>
      <% if table_rows.any? %>
        <% norm_rows = normalized_table_rows %>
        <% heading_cells = table_heading_cells %>
        <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
        <div class="grid <%= table_grid_cols(n_cols) %> gap-x-2 gap-y-1<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>">
          <% heading_cells.each do |cell| %>
            <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
          <% end %>
          <% norm_rows.each do |cells| %>
            <% cells.each do |cell| %>
              <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if info_lines.any? %>
        <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
          <% info_lines.each do |line| %>
            <div><%= render_info_line(line) %></div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
  <% if @suggestion %>
    <%= render(Pito::Event::SegmentSuggestionComponent.new(suggestion: @suggestion)) %>
  <% end %>
  <% if @timestamp || meta_handle || channel %>
    <%= render(Pito::Event::MetaLineComponent.new(
          timestamp: @timestamp,
          handle:    meta_handle,
          channel:   channel
        )) %>
  <% end %>
<% end %>
