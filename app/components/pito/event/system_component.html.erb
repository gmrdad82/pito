<%= render(Pito::Segment::Component.new(accent:, background:, id: dom_id)) do %>
  <% if sections.any? %>
    <%# Sections mode: body + all section detail rendered always-visible.
        Plain-text bodies type in order via the typewriter controller. %>
    <% if html %>
      <%# html: true — no typewriter, render everything instantly %>
      <% if body %>
        <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= raw(body) %></span>
      <% end %>
      <div class="mt-1.5 border-t border-line-default pt-1.5">
        <%= render(Pito::Keybinding::TableComponent.new(sections: sections)) %>
      </div>
    <% else %>
      <%# Plain-text: typewriter controller covers the full content region %>
      <div<% unless reply_consumed %> data-controller="pito--typewriter"<% end %>>
        <% if body %>
          <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg" data-pito--typewriter-target="body"><%= body %></span>
        <% end %>
        <div class="mt-1.5 border-t border-line-default pt-1.5">
          <div class="flex flex-col gap-3">
            <% sections.each do |section| %>
              <div class="flex flex-col gap-1">
                <div class="text-yellow font-bold mb-1" data-pito--typewriter-target="prose"><%= section[:title] %></div>
                <% Array(section[:rows]).each do |row| %>
                  <div class="flex gap-4">
                    <%= render(Pito::Table::KeyValueRowComponent.new(
                          key_text:    row[:key],
                          value_text:  row[:value],
                          key_class:   "text-cyan whitespace-nowrap shrink-0 w-44",
                          value_class: "text-fg-dim",
                          key_data:    { "pito--typewriter-target" => "prose" },
                          value_data:  { "pito--typewriter-target" => "prose" }
                        )) %>
                    <% if row[:value2].present? %>
                      <span class="text-cyan whitespace-nowrap" data-pito--typewriter-target="prose"><%= row[:value2] %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <%# No sections: outer typewriter wrapper covers body (via BodyComponent
        with owner_controller: false) AND the table_rows grid below it.
        info_lines contain HTML code highlights so they render instantly.
        Only emit the typewriter wrapper when there IS a plain-text body to
        anchor it (controller guards against empty body targets internally,
        but the spec also checks that no controller appears on nil-body renders). %>
    <% if !html && body %>
      <div<% unless reply_consumed %> data-controller="pito--typewriter"<% end %>>
        <%= render(Pito::Event::BodyComponent.new(
              body:             body,
              html:             html,
              detail:           expand_detail,
              typewriter:       true,
              owner_controller: false,
              timestamp:        @timestamp
            )) %>
        <% if table_rows.any? %>
          <% norm_rows = normalized_table_rows %>
          <% heading_cells = table_heading_cells %>
          <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
          <div class="pito-data-grid<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>" data-cols="<%= table_col_count(n_cols) %>" data-fixed-leading="<%= fixed_leading %>" data-fixed-trailing="<%= fixed_trailing %>">
            <% heading_cells.each do |cell| %>
              <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
            <% end %>
            <% norm_rows.each do |cells| %>
              <% cells.each do |cell| %>
                <% if cell[:html] %>
                  <span class="<%= cell[:class] %>" data-pito--typewriter-target="htmlProse"><%= raw cell[:text] %></span>
                <% else %>
                  <span class="<%= cell[:class] %>" data-pito--typewriter-target="prose"><%= cell[:text] %></span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        <% end %>
        <% if info_lines.any? %>
          <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
            <% info_lines.each do |line| %>
              <div><%= render_info_line(line) %></div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%# html: true — render everything instantly, no typewriter %>
      <%= render(Pito::Event::BodyComponent.new(
            body:         body,
            html:         html,
            detail:       expand_detail,
            typewriter:   false,
            timestamp:    @timestamp
          )) %>
      <% if table_rows.any? %>
        <% norm_rows = normalized_table_rows %>
        <% heading_cells = table_heading_cells %>
        <% n_cols = [ heading_cells.size, norm_rows.map(&:size).max.to_i, 2 ].max %>
        <div class="pito-data-grid<%= body ? ' mt-2 border-t border-line-default pt-2' : '' %>" data-cols="<%= table_col_count(n_cols) %>" data-fixed-leading="<%= fixed_leading %>" data-fixed-trailing="<%= fixed_trailing %>">
          <% heading_cells.each do |cell| %>
            <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
          <% end %>
          <% norm_rows.each do |cells| %>
            <% cells.each do |cell| %>
              <% if cell[:html] %>
                <span class="<%= cell[:class] %>"><%= raw cell[:text] %></span>
              <% else %>
                <span class="<%= cell[:class] %>"><%= cell[:text] %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if info_lines.any? %>
        <%= render(Pito::Separator::DividerLineComponent.new(spacing: "2")) do %>
          <% info_lines.each do |line| %>
            <div><%= render_info_line(line) %></div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
  <%# Witty italic footer after the table rows (list messages) naming the
      columns that can still be added — or that everything is shown. %>
  <% if list_footer %>
    <div class="pito-list-footer text-fg-dim italic mt-2"><%= list_footer %></div>
  <% end %>
  <% if @suggestion %>
    <%= render(Pito::Event::SegmentSuggestionComponent.new(suggestion: @suggestion)) %>
  <% end %>
  <% if meta_handle || channel %>
    <%= render(Pito::Event::MetaLineComponent.new(
          handle:  meta_handle,
          channel: channel
        )) %>
  <% end %>
<% end %>
