<%= render(Pito::Segment::Component.new(accent:, background:, id: dom_id, scrollback_message: true)) do %>
  <% if sections.any? %>
    <%# Sections mode: body + all section detail, rendered instantly. %>
    <% if html %>
      <div data-controller="pito--ascii-fit">
        <% if body %>
          <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= raw(body) %></span>
        <% end %>
        <div class="mt-1.5 border-t border-line-default pt-1.5">
          <%= render(Pito::Keybinding::TableComponent.new(sections: sections)) %>
        </div>
      </div>
    <% else %>
      <div>
        <% if body %>
          <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= body %></span>
        <% end %>
        <div class="mt-1.5 border-t border-line-default pt-1.5">
          <div class="flex flex-col gap-3">
            <% sections.each do |section| %>
              <div class="flex flex-col gap-1">
                <div class="text-yellow font-bold mb-1"><%= section[:title] %></div>
                <% Array(section[:rows]).each do |row| %>
                  <div class="flex gap-4">
                    <%= render(Pito::Table::KeyValueRowComponent.new(
                          key_text:    row[:key],
                          value_text:  row[:value],
                          key_class:   "text-cyan whitespace-nowrap shrink-0 w-44",
                          value_class: "text-fg-dim"
                        )) %>
                    <% if row[:value2].present? %>
                      <span class="text-cyan whitespace-nowrap"><%= row[:value2] %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <%# No sections: body (via BodyComponent) + the table_rows grid + info_lines,
        all rendered instantly (text reveal removed). %>
    <% if !html && body %>
      <div>
        <%= render(Pito::Event::BodyComponent.new(
              body:      body,
              html:      html,
              detail:    expand_detail,
              timestamp: @timestamp
            )) %>
        <% dg_rows = normalized_table_rows; dg_heads = table_heading_cells; dg_n = [ dg_heads.size, dg_rows.map(&:size).max.to_i, 2 ].max %>
        <%= render(Pito::Event::DataGridComponent.new(heading_cells: dg_heads, rows: dg_rows, col_count: table_col_count(dg_n), fixed_leading: fixed_leading, fixed_trailing: fixed_trailing, has_body: body.present?, info_lines: info_lines)) %>
      </div>
    <% elsif html %>
      <%# html: true — the whole card (body + grid + info-lines) renders instantly
          (text reveal removed). The ascii-fit controller stays for
          html/ascii-art width fitting. %>
      <div>
        <div data-controller="pito--ascii-fit">
          <%= render(Pito::Event::BodyComponent.new(
                body:      body,
                html:      html,
                detail:    expand_detail,
                timestamp: @timestamp
              )) %>
          <% dg_rows = normalized_table_rows; dg_heads = table_heading_cells; dg_n = [ dg_heads.size, dg_rows.map(&:size).max.to_i, 2 ].max %>
          <%= render(Pito::Event::DataGridComponent.new(heading_cells: dg_heads, rows: dg_rows, col_count: table_col_count(dg_n), fixed_leading: fixed_leading, fixed_trailing: fixed_trailing, has_body: body.present?, info_lines: info_lines)) %>
        </div>
      </div>
    <% else %>
      <%# Neither html nor a plain-text body (rare: a bare table). %>
      <%= render(Pito::Event::BodyComponent.new(
            body:      body,
            html:      html,
            detail:    expand_detail,
            timestamp: @timestamp
          )) %>
      <% dg_rows = normalized_table_rows; dg_heads = table_heading_cells; dg_n = [ dg_heads.size, dg_rows.map(&:size).max.to_i, 2 ].max %>
      <%= render(Pito::Event::DataGridComponent.new(heading_cells: dg_heads, rows: dg_rows, col_count: table_col_count(dg_n), fixed_leading: fixed_leading, fixed_trailing: fixed_trailing, has_body: body.present?, info_lines: info_lines)) %>
    <% end %>
  <% end %>
  <%# Witty italic footer after the table rows (list messages) naming the
      columns that can still be added — or that everything is shown. %>
  <% if list_footer %>
    <div class="pito-list-footer text-fg-dim italic mt-2"><%= list_footer %></div>
  <% end %>
  <% if @suggestion %>
    <%= render(Pito::Event::SegmentSuggestionComponent.new(suggestion: @suggestion)) %>
  <% end %>
  <%# Meta line (handle/channel) renders through a SLOT filled at serve time
      (Pito::Stream::EventRenderer#fill_meta_slot) — the handle affordance is
      the only thing that changes on old messages (consumption), so keeping it
      OUT of the markup makes the fragment cache-stable (same pattern as
      data-pito-ts-slot). Emitted whenever a handle/channel COULD
      render; the filler decides liveness from the payload. %>
  <% if meta_slot? %>
    <div data-pito-meta-slot></div>
  <% end %>
<% end %>
