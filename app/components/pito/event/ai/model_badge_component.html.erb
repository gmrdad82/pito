<%# Lucide `sparkles` (ISC), inlined like the pull-refresh arrow so nothing is
    fetched. Every badge embeds the same gradient def under the same id —
    browsers resolve url(#…) to the first identical definition, so stacked :ai
    messages all paint the same purple→pito-blue sweep. %>
<div class="pito-ai-model-badge">
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
       fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <defs>
      <linearGradient id="pito-ai-badge-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--accent-purple)" />
        <stop offset="1" stop-color="var(--brand-pito)" />
      </linearGradient>
    </defs>
    <g stroke="url(#pito-ai-badge-grad)">
      <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" />
      <path d="M20 3v4" />
      <path d="M22 5h-4" />
      <path d="M4 17v2" />
      <path d="M5 18H3" />
    </g>
  </svg>
  <span><%= model %></span>
</div>
