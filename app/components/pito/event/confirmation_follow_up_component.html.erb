<%= render(Pito::Segment::Component.new(accent: :orange, background:, id: dom_id)) do %>
  <div class="flex flex-col">
    <%# Outcome text — standalone follow-up message; timestamp leads the first line. %>
    <% if outcome_text.present? %>
      <div><%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= raw(outcome_text) %></span></div>
    <% end %>
  </div>
<% end %>
