<%= render(Pito::Segment::Component.new(accent: :orange, background:)) do %>
  <div class="flex flex-col">
    <%# Processing indicator (Braille + verb, inside segment above body) %>
    <% if processing? %>
      <div class="pito-thinking mb-1">
        <span class="pito-thinking__braille pito-shimmer"
              data-controller="pito--thinking"
              data-pito--thinking-frames-value="<%= braille_frames_json %>"
              data-pito--thinking-target="braille">⠋</span>
        <span class="pito-thinking__word pito-shimmer"><%= processing_word %>…</span>
      </div>
    <% end %>

    <%# Body text %>
    <span class="text-fg"><%= @body %></span>

    <%# Resolved outcome appended below a hairline %>
    <% if resolved? %>
      <div class="border-t border-line-faded mt-1.5 pt-1.5">
        <span class="text-fg"><%= @outcome_text %></span>
      </div>
    <% end %>

    <%# Meta line: timestamp · #handle · @all %>
    <div class="pito-echo__meta">
      <span class="text-fg-faded"><%= @timestamp ? @timestamp.strftime("%-l:%M %p") : "" %></span>
      <% if @handle %>
        <span class="text-fg-faded mx-2">·</span>
        <span class="text-fg-dim">#<%= @handle %></span>
      <% end %>
      <% if @authenticated %>
        <span class="text-fg-faded mx-2">·</span>
        <span class="text-cyan"><%= t("pito.shell.chatbox.default_channel") %></span>
      <% end %>
    </div>
  </div>
<% end %>
