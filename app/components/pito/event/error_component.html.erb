<%= render(Pito::Segment::Component.new(accent: :red)) do %>
  <div>
    <%# Main text renders as HTML (copy-built, may carry <span>/<br>). The raw
        machine `detail` below stays escaped. Builders must escape any
        user-supplied interpolation in the text. %>
    <%= render(Pito::Event::TimestampPrefixComponent.new(timestamp: @timestamp)) %><span class="text-fg"><%= raw(@text) %></span>
    <% if @credentials %>
      <%= render(Pito::Separator::DividerLineComponent.new(extra_classes: "flex flex-col gap-1 font-mono")) do %>
        <% credential_rows.each do |row| %>
          <%= render(Pito::Table::KeyValueRowComponent.new(
                key_text:      "#{row[:label]}:",
                value_text:    row[:display],
                key_class:     "text-fg-dim whitespace-nowrap shrink-0",
                value_class:   "#{row[:present] ? 'text-green' : 'text-red'} break-all",
                wrapper_class: "flex items-center gap-1"
              )) %>
        <% end %>
      <% end %>
    <% elsif @detail %>
      <div class="mt-1.5 text-fg-dim font-mono border-t border-line-default pt-1.5 break-all"><%= @detail %></div>
    <% end %>
  </div>
<% end %>
