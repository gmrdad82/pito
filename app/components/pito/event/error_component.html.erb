<%= render(Pito::Segment::Component.new(accent: :red)) do %>
  <div<% if @detail %> data-controller="pito--expand"
       data-pito--expand-expand-label-value="<%= t('pito.event.expand.expand_hint') %>"
       data-pito--expand-collapse-label-value="<%= t('pito.event.expand.collapse_hint') %>"<% end %>>
    <span class="text-fg"><%= @text %></span>
    <% if @credentials %>
      <div class="mt-1.5 flex flex-col gap-1 font-mono border-t border-line-default pt-1.5">
        <% credential_rows.each do |row| %>
          <div class="flex items-center gap-1">
            <span class="text-fg-dim whitespace-nowrap shrink-0"><%= row[:label] %>:</span>
            <span class="<%= row[:present] ? 'text-green' : 'text-red' %> break-all"><%= row[:display] %></span>
          </div>
        <% end %>
      </div>
    <% elsif @detail %>
      <div data-pito--expand-target="hint" class="mt-1">
        <%= render(Pito::Keybinding::HintComponent.new(
              shortcut:    "ctrl+|",
              description: t("pito.event.expand.expand_hint")
            )) %>
      </div>
      <div data-pito--expand-target="detail" class="hidden mt-1.5 text-fg-dim font-mono border-t border-line-default pt-1.5 break-all"><%= @detail %></div>
    <% end %>
  </div>
<% end %>
