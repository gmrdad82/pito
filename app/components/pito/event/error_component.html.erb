<%= render(Pito::Segment::Component.new(accent: :red)) do %>
  <div data-controller="pito--expand"
       data-pito--expand-expand-label-value="<%= t('pito.event.expand.expand_hint') %>"
       data-pito--expand-collapse-label-value="<%= t('pito.event.expand.collapse_hint') %>">
    <span class="text-fg"><%= @text %></span>
    <% if @credentials || @detail %>
      <div data-pito--expand-target="hint" class="mt-1">
        <span class="font-bold text-yellow">ctrl+o</span>
        <span data-pito--expand-target="hintLabel" class="text-fg-dim ml-1"><%= t("pito.event.expand.expand_hint") %></span>
      </div>
      <div data-pito--expand-target="detail" class="hidden mt-1.5 font-mono text-xs border-t border-line-default pt-1.5">
        <% if @credentials %>
          <div class="flex flex-col gap-1">
            <% credential_rows.each do |row| %>
              <div class="flex items-center gap-1">
                <span class="<%= row[:present] ? 'text-green' : 'text-red' %> shrink-0"><%= row[:present] ? "✓" : "✗" %></span>
                <span class="text-fg-dim shrink-0"><%= row[:label] %></span>
                <span class="<%= row[:present] ? 'text-green' : 'text-red' %> break-all"><%= row[:value] %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <span class="text-fg-dim break-all"><%= @detail %></span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
