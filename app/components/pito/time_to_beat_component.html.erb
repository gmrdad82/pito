<%# Pito::TimeToBeatComponent — KEPT BUT UNUSED — no host screen yet. %>
<div class="pito-ttb" data-component="time-to-beat">
  <%# Witty label, left of the bar (aligned to the bar row via CSS margin-top).
      A left gutter keeps the bar + all the %-positioned rows in one shared
      coordinate space so ticks and hour labels stay aligned. %>
  <span class="pito-ttb__label"><%= bar_label %></span>
  <div class="pito-ttb__body">
  <%# Row 1 — Footage value bubble. %>
  <div class="pito-ttb__values pito-ttb__values--top">
    <% if render_footage_tick? %>
      <%# Footage uses the SAME mark as the ScoreBar needle: a value bubble
          with a ▼ arrow, snapped to its cell midpoint on the 0..completionist
          axis (T17.4). %>
      <div class="pito-ttb__footage-bubble"
           data-accent="footage"
           style="left: <%= footage_position %>%;">
        <span class="pito-ttb__footage-bubble-num"><%= footage_value_label %></span>
        <span class="pito-ttb__footage-bubble-arrow">&#9660;</span>
      </div>
    <% end %>
  </div>

  <%# Row 2 — the bar.
      The `=` fill glyphs carry the per-game ADAPTIVE heat ramp: the inline
      `background-image` from `gradient_stops` (HEAT_THRESHOLDS projected onto
      0..completionist) is clipped to the glyphs via `background-clip: text`,
      so the color under each cell is the heat color for that cell's absolute
      hour count (T17.5). A short game stays green/lime; a marathon goes
      pink. The bar element itself keeps a plain background so the brackets
      and ticks read cleanly on top. %>
  <div class="pito-ttb__bar-row">
    <span class="pito-ttb__bar">
      <span class="pito-ttb__track">
        <span class="pito-ttb__bracket">[</span>
        <span class="pito-ttb__fill"
              style="background-image: linear-gradient(to right in oklch, <%= gradient_stops %>);"><%= fill_text %></span>
        <span class="pito-ttb__bracket">]</span>
      </span>
      <%# Pillar ticks: a `|` mark per pillar, snapped to its cell midpoint on
          the 0..completionist axis and absolutely positioned via left:%
          (completionist always at 98.75%). The footage tick is drawn as the
          ▼ bubble above, so only the three pillars render a `|` here. %>
      <% tick_overlays.reject { |t| t[:key] == :footage }.each do |tick| %>
        <span class="pito-ttb__tick <%= tick[:token_class] %>"
              data-accent="<%= tick[:key] %>"
              style="left: <%= tick[:position] %>%;">|</span>
      <% end %>
    </span>
  </div>

  <%# Row 3 — pillar hour values below the bar. %>
  <div class="pito-ttb__values pito-ttb__values--bottom">
    <% pillar_label_data.each do |label_data| %>
      <span class="pito-ttb__value pito-ttb__value--pillar <%= pillar_bottom_label_alignment_class %>"
            data-pillar="<%= label_data[:key] %>"
            style="left: <%= label_data[:effective_position] %>%;">
        <%= label_data[:label] %>
      </span>
    <% end %>
  </div>

  <%# Row 4 — legend. Each pillar legend item is only shown when IGDB
      returned data for that pillar (hours[key] > 0). Absent pillars are
      omitted from both the ticks and the legend (rule 3). %>
  <div class="pito-ttb__legend">
    <% if hours[:main].to_i.positive? %>
      <span class="pito-ttb__legend-item">
        <span class="pito-ttb__legend-tick" data-accent="main">|</span>
        <span class="pito-ttb__legend-label"><%= self.class.pillar_label[:main] %></span>
      </span>
    <% end %>
    <% if hours[:extras].to_i.positive? %>
      <span class="pito-ttb__legend-item">
        <span class="pito-ttb__legend-tick" data-accent="extras">|</span>
        <span class="pito-ttb__legend-label"><%= self.class.pillar_label[:extras] %></span>
      </span>
    <% end %>
    <% if hours[:completionist].to_i.positive? %>
      <span class="pito-ttb__legend-item">
        <span class="pito-ttb__legend-tick" data-accent="completionist">|</span>
        <span class="pito-ttb__legend-label"><%= self.class.pillar_label[:completionist] %></span>
      </span>
    <% end %>
    <% if render_footage_tick? %>
      <span class="pito-ttb__legend-item">
        <span class="pito-ttb__legend-tick" data-accent="footage">|</span>
        <span class="pito-ttb__legend-label"><%= footage_caption %></span>
      </span>
    <% end %>
  </div>
  </div>
</div>
