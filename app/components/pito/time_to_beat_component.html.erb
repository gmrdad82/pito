<%# Pito::TimeToBeatComponent — KEPT BUT UNUSED — no host screen yet. %>
<div class="pito-ttb" data-component="time-to-beat">
  <%# Witty label, left of the bar (aligned to the bar row via CSS margin-top).
      A left gutter keeps the bar + all the %-positioned rows in one shared
      coordinate space so ticks and hour labels stay aligned. %>
  <span class="pito-ttb__label"><%= bar_label %></span>
  <div class="pito-ttb__body">
  <%# Row 1 — the bar.
      The `=` fill glyphs carry the per-game ADAPTIVE heat ramp: the inline
      `background-image` from `gradient_stops` (HEAT_THRESHOLDS projected onto
      0..completionist) is clipped to the glyphs via `background-clip: text`,
      so the color under each cell is the heat color for that cell's absolute
      hour count. A short game stays green/lime; a marathon goes
      pink. The bar element itself keeps a plain background so the brackets
      and ticks read cleanly on top. %>
  <div class="pito-ttb__bar-row">
    <span class="pito-ttb__bar">
      <span class="pito-ttb__track">
        <span class="pito-ttb__bracket">[</span>
        <%# Two background layers, both clipped to the `=` glyphs (see
            .pito-ttb__fill + .pito-bar-shimmer): layer 1 is the moving pito-blue
            highlight band (--pito-bar-band from .pito-bar-shimmer); layer 2 is the
            per-game heat ramp. Keeping the band first/topmost lets the heat read
            through its transparent flanks while only the band sweeps. %>
        <span class="pito-ttb__fill pito-bar-shimmer pito-bar-reveal <%= shimmer_offset_class %>"
              data-controller="pito--bar-reveal"
              style="background-image: var(--pito-bar-band, linear-gradient(transparent, transparent)), linear-gradient(to right in oklch, <%= gradient_stops %>);"><%= fill_text %></span>
        <span class="pito-ttb__bracket">]</span>
      </span>
      <%# Ticks: a `|` mark per tick — main / extras / completionist AND footage —
          snapped to its cell midpoint and absolutely positioned via left:%. %>
      <% tick_overlays.each do |tick| %>
        <span class="pito-ttb__tick <%= tick[:token_class] %>"
              data-accent="<%= tick[:key] %>"
              style="left: <%= tick[:position] %>%;">|</span>
      <% end %>
      <%# Current-tracker value inline on the `=` line — adjacent to its | tick,
          left or right depending on tick position. Omitted entirely when the
          caller passed levels without a current tracker. %>
      <% if render_footage_tick? %>
        <span class="pito-ttb__footage-marker <%= footage_inline_side_class %>"
              data-accent="footage"
              style="left: <%= footage_position %>%;"><%= footage_inline_label %></span>
      <% end %>
    </span>
  </div>

  <%# Row 2 — pillar hour values below the bar. %>
  <div class="pito-ttb__values pito-ttb__values--bottom">
    <% pillar_label_data.each do |label_data| %>
      <span class="pito-ttb__value pito-ttb__value--pillar <%= label_alignment_class(label_data[:effective_position]) %>"
            data-pillar="<%= label_data[:key] %>"
            style="left: <%= label_data[:effective_position] %>%;">
        <%= label_data[:label] %>
      </span>
    <% end %>
  </div>

  <%# Row 3 — legend (legend_pillars omits pillars IGDB has no data for). %>
  <div class="pito-ttb__legend">
    <% legend_pillars.each do |key| %>
      <span class="pito-ttb__legend-item">
        <span class="pito-ttb__legend-tick" data-accent="<%= key %>">|</span>
        <span class="pito-ttb__legend-label"><%= level_label(key) %></span>
      </span>
    <% end %>
  </div>
  </div>
</div>
