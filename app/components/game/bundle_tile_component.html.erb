<%# Phase 27 Wave F (2026-05-17) — Verbatim port of
    `app/views/games/_bundle_for_shelf_tile.html.erb`. Keep the two
    in sync until VC5 swaps the partial's render for this component;
    the partial is still the live wiring at this dispatch.

    2026-05-18 — extended for `size: :shelf` (98 × 130 bare cover,
    no caption) and `mode: :suggest` (button_to POST → add target_game
    to this bundle). Both default to the original grid + modal-trigger
    behavior so existing callers (`_bundles_for_shelf`, the create
    Turbo Stream) render unchanged.

    2026-05-18 (live cover refresh) — the cover-wrap markup is now
    extracted into `app/views/games/_bundle_tile_cover.html.erb` so
    the same render path drives both initial render and the Turbo
    Stream `replace` broadcast `BundleCoverBuild` fires after a
    membership change rebuilds the composite. The component also
    mounts a `turbo_stream_from "bundle_cover:<id>"` subscription so
    wherever the tile renders (/games shelf, /games/:id bundles
    section, create.turbo_stream replacement) the page automatically
    receives those broadcasts. %>
<%= helpers.turbo_stream_from "bundle_cover:#{bundle.id}" %>
<% if suggest_mode? %>
  <%# `mode: :suggest` — RIGHT half of the /games/:id bundles section.
      Click POSTs `/bundles/:slug/members` with the target game id
      (BundleMembersController#create). `source=games_show` instructs
      the controller to redirect back to /games/:id (instead of the
      bundle show page) with "added to <bundle name>." in the flash. %>
  <%= button_to add_member_url,
                method: :post,
                params: { game_id: target_game.id, source: "games_show" },
                form: { class: "bundle-tile bundle-tile--suggest",
                        style: "margin: 0; flex: 0 0 auto; display: inline-flex; flex-direction: column; align-items: flex-start; gap: 4px; width: #{width}px;",
                        data: { bundle_id: bundle.id } },
                class: "bundle-tile-suggest-button",
                aria: { label: aria_label },
                title: aria_label do %>
    <%= render "games/bundle_tile_cover",
               bundle: bundle,
               width: width,
               height: height,
               overflow_n: overflow_n %>
    <% if show_caption? %>
      <span class="tile-caption-title bundle-tile-name"
            style="font-size: 11px; max-width: <%= width %>px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-align: left;">
        <%= bundle.name %>
      </span>
    <% end %>
  <% end %>
<% else %>
  <a id="bundle-tile-<%= bundle.id %>"
     href="<%= fallback_href %>"
     class="bundle-tile"
     data-bundle-id="<%= bundle.id %>"
     data-controller="bundles-modal-trigger"
     data-action="click->bundles-modal-trigger#open"
     data-bundles-modal-trigger-url-value="<%= pane_url %>"
     data-bundles-modal-trigger-title-value="<%= bundle.name %>"
     data-bundles-modal-trigger-update-url-value="<%= update_url %>"
     data-bundles-modal-trigger-delete-confirm-id-value="<%= delete_confirm_id %>"
     title="<%= bundle.name %>"
     style="flex: 0 0 auto; display: inline-flex; flex-direction: column; align-items: flex-start; gap: 4px; text-decoration: none; color: inherit; cursor: pointer; width: <%= width %>px;">
    <%# 2026-05-17 — wrap the cover (composite img OR fallback SVGs) in
        a `position: relative` container so the `+N` overflow overlay
        below can anchor flush to the bottom-right corner. Mirrors the
        `.tile-cover` wrapper in `_tile.html.erb`. %>
    <%= render "games/bundle_tile_cover",
               bundle: bundle,
               width: width,
               height: height,
               overflow_n: overflow_n %>
    <% if show_caption? %>
      <%# 2026-05-17 — title styling aligned with the letter shelf rich tile
          (`_tile.html.erb` `.tile-caption-title`): inherits the default
          text color (NOT `text-muted`), 11px font-size matching the grid
          caption, left-aligned, single-line ellipsis-truncated to the
          150px cover width. Anchor's `align-items: flex-start` (above)
          keeps the title flush left under the cover. %>
      <span class="tile-caption-title bundle-tile-name"
            style="font-size: 11px; max-width: <%= width %>px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-align: left;">
        <%= bundle.name %>
      </span>
    <% end %>
  </a>
<% end %>
