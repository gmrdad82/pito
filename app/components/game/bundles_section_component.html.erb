<section class="game-bundles" aria-label="bundles">
  <h2>bundles</h2>
  <div class="shelf-row" data-controller="steam-shelf">
    <% if both_empty? %>
      <div class="shelf-empty-tile" aria-label="nothing yet">
        <span>nothing</span>
        <span>yet</span>
      </div>
    <% else %>
      <% bundles_in.each do |bundle| %>
        <%= render(Game::BundleTileComponent.new(bundle: bundle)) %>
      <% end %>
      <%# 2026-05-19 — Cover-art-style separator tile replaces the
          vertical hairline divider. Rendered whenever the RIGHT half
          has suggestions (which, given `both_empty?` is false above,
          means whenever `bundles_suggested.any?`). When `bundles_in`
          is empty, the separator is the FIRST child of the shelf — the
          CSS rule on `.game-bundles .shelf-row:has(.bundles-suggested-separator:first-child)`
          zeros the row gap so the tile butts against the pane edge. %>
      <% if bundles_suggested.any? %>
        <%= render(Game::BundlesSuggestedSeparatorComponent.new) %>
      <% end %>
      <% bundles_suggested.each do |bundle| %>
        <%= render(Game::BundleTileComponent.new(
              bundle: bundle,
              mode: :suggest, target_game: @game)) %>
      <% end %>
    <% end %>
  </div>
</section>
