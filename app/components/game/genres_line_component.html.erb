<%# 2026-05-19 (Wave B) — while `@game.resyncing?` is true the genre
    line renders as a `sync-indicator` dot-loader (`=---` cycling at
    phase offset 0) so the stale, refreshing signal is visible across
    the whole zone, not just the kv-table sync row. The static genre
    tokens render once the resync clears (Turbo morph / auto-refresh
    swap). %>
<% if resyncing? %>
  <div class="game-genres game-genres--syncing"
       style="margin: 0 0 4px 0;"
       data-controller="sync-indicator"
       data-sync-indicator-frames-value="<%= Game::GenresLineComponent::SYNC_INDICATOR_FRAMES.to_json %>"
       data-sync-indicator-phase-offset-value="<%= Game::GenresLineComponent::SYNC_INDICATOR_PHASE_OFFSET %>"
       data-resyncing="yes"
       aria-live="polite"><%= Game::GenresLineComponent::SYNC_INDICATOR_FRAMES[Game::GenresLineComponent::SYNC_INDICATOR_PHASE_OFFSET] %></div>
<% else %>
  <div class="game-genres" style="margin: 0 0 4px 0;">
    <% if genres_list.any? %>
      <% genres_list.each_with_index do |g, i| %>
        <% if i.zero? %>
          <strong><%= helpers.genre_display_name(g) %></strong>
        <% else %>
          <span><%= helpers.genre_display_name(g) %></span>
        <% end %>
        <% if i < genres_list.length - 1 %> · <% end %>
      <% end %>
    <% else %>
      <em class="text-muted">—</em>
    <% end %>
  </div>
<% end %>
