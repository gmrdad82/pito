<%= helpers.turbo_frame_tag frame_id do %>
  <% if query_blank? %>
    <p class="text-muted"><%= t("search.everywhere.blank_query") %></p>
  <% elsif truly_empty? %>
    <p class="text-muted"><%= t("search.everywhere.empty.all") %></p>
  <% else %>
    <% sections_in_order.each do |section| %>
      <%= render Search::EverywhereSectionComponent.new(
            hits: section[:hits],
            kind: section[:kind]
          ) %>
    <% end %>
  <% end %>
<% end %>
