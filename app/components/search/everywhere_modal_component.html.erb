<%# Phase 37 — "everywhere" omnisearch modal shell.

    Reuses the existing `.omnisearch-modal` / `.omnisearch-input` CSS
    classes by pure class-name reference (no JS-class coupling — the
    Stimulus controller binds via `data-controller`, not via the
    visual class). Existing /games omnisearch modal is unaffected
    because both surfaces use the same visual contract intentionally.

    The `data-everywhere-modal-context-value` data attr is harmless
    if the `omnisearch-modal` controller doesn't read it — it carries
    the current path forward to the results frame URL via the input
    handler in a future wave. For now the server can also derive
    context from the `?context=` query param the controller appends
    via `url`. %>
<dialog id="<%= dialog_id %>"
        class="omnisearch-modal"
        data-controller="omnisearch-modal"
        data-omnisearch-modal-url-value="<%= url %>"
        data-omnisearch-modal-min-chars-value="1"
        data-omnisearch-modal-frame-id-value="<%= results_frame_id %>"
        data-everywhere-modal-context-value="<%= current_path %>"
        data-action="click->omnisearch-modal#clickOutside keydown->omnisearch-modal#keydown">
  <div class="omnisearch-modal-inner">
    <input type="search"
           class="omnisearch-input"
           placeholder="<%= placeholder %>"
           autocomplete="off"
           data-omnisearch-modal-target="input"
           data-action="input->omnisearch-modal#search keydown.enter->omnisearch-modal#search" />
    <div class="omnisearch-results" style="margin-top: 16px;">
      <%= helpers.turbo_frame_tag results_frame_id %>
    </div>
    <div class="modal-footer">
      <%= render(BracketedMutedLinkComponent.new(
            label: t("common.actions.close"),
            href: "#",
            data: { action: "click->omnisearch-modal#close" }
          )) %>
    </div>
  </div>
</dialog>
