# Copy to .env.development and .env.test for local use.
# CI uses its own env vars (see .github/workflows/ci.yml).

# MySQL — kept temporarily during the Postgres cutover window.
# Removed in the post-verification cleanup pass (spec section 4b).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307

# Postgres (Phase 2). Connection metadata only — secrets (database name,
# username, password) live in Rails encrypted credentials under the
# `:postgres` block. See `bin/rails credentials:edit`.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

REDIS_URL=redis://127.0.0.1:6380/0
MEILISEARCH_URL=http://127.0.0.1:7700
MAX_PANES=3
PANE_TITLE_LENGTH=14
