# Copy to .env for local use.
#
# ── Two environments ──────────────────────────────────────────────────
#
# bin/dev  — local Ruby process. RSpec runs here too.
#            Postgres: local or Docker on the host port below.
#            ActiveStorage: tmp/storage (Rails default).
#
# bin/boot — Docker production stack (postgres_data + rails_storage
#            named volumes). Requires RAILS_MASTER_KEY.

# ── bin/boot (production Docker) ─────────────────────────────────────
# Get from config/master.key or 1Password.
# RAILS_MASTER_KEY=

# ── Ports ─────────────────────────────────────────────────────────────
WEB_PORT=3027
POSTGRES_PORT=54327

# ── Postgres (bin/dev) ────────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
