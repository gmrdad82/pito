# Copy to .env.development and .env.test for local use.
# CI uses its own env vars (see .github/workflows/ci.yml).

# Postgres connection metadata only — secrets (database name,
# username, password) live in Rails encrypted credentials under the
# `:postgres` block. See `bin/rails credentials:edit`.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

REDIS_URL=redis://127.0.0.1:6380/0
MEILISEARCH_URL=http://127.0.0.1:7700
MAX_PANES=3
PANE_TITLE_LENGTH=14

# Phase 4 — Project Workspace volumes. NOT secrets; these are paths the
# Rails app reads at runtime. Production cuts over to /var/lib/pito-* on
# the Hetzner managed volumes; locally the user can point them at any
# writable directory on the host (or leave the defaults if running as root
# on a dev VM).
#
# PITO_ASSETS_PATH backs Active Storage's `local` disk service
# (config/storage.yml). PITO_NOTES_PATH backs the project notes filesystem
# layout under <PITO_NOTES_PATH>/<tenant_id>/projects/<project_id>/<file>.md.
# Production cuts over to /var/lib/pito-* on the Hetzner managed volumes
# (no .env in production). Locally, point these at writable paths inside
# the repo's tmp/ tree so `bin/dev` runs without root.
PITO_ASSETS_PATH=tmp/pito-assets
PITO_NOTES_PATH=tmp/pito-notes

# Voyage AI embedding-call gating lives in AppSetting (Phase 4 §3.5,
# 2026-05-04 post-review refinement). Flipped at runtime via the Settings
# UI; defaults to `false` (dev/test) so Voyage never fires on dummy data.
# The Voyage API key itself lives in Rails encrypted credentials.
