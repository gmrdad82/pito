# How env vars load (there is NO dotenv-rails gem):
#
#   • Native dev (bin/dev): foreman auto-loads ONLY a file literally named
#     `.env` (NOT .env.development / .env.test / .env.op — those are yours and
#     are inert to pito). So for local dev: `cp .env.example .env`.
#   • Docker (the ./pito install dir): `docker compose` auto-reads the `.env`
#     in that dir. The install/update scripts WRITE that `.env` for you
#     (PITO_APP_BASE_URL, PITO_TAG). You normally don't edit it by hand.
#
# So the two `.env` files are different files in different places: a dev one
# next to this repo, and a prod one in your ./pito install dir.

# ── Native dev (bin/dev → http://localhost:3027) ─────────────────────────
WEB_PORT=3027
POSTGRES_PORT=54327
POSTGRES_HOST=127.0.0.1
# Dev runs on localhost:3027. PITO_APP_BASE_URL below does NOTHING in dev —
# the dev host allow-list (incl. any tunnel hostname like app.pitomd.com) is
# the gitignored config/initializers/local_hosts.rb, not this file.

# ── Docker production (the ./pito install dir's .env) ────────────────────
# Master key — get from config/master.key or 1Password (install.sh generates it).
# RAILS_MASTER_KEY=
#
# Public host pito is reached at IN PRODUCTION — drives Host Authorization, URL
# helpers, and asset delivery (config.asset_host). Defaults to the local Docker
# port (http://localhost:3028). Set it to your tunnel / domain for remote access;
# SSL is always forced, so a non-localhost host MUST sit behind a TLS proxy
# (e.g. a Cloudflare Tunnel). Read by docker compose only — not by bin/dev.
# PITO_APP_BASE_URL=https://app.pitomd.com
#
# Image tag to run (defaults to :latest). Pin a release, e.g. 0.7.0.
# PITO_TAG=latest
