#!/usr/bin/env bash
# bin/boot — Start the pito production stack in Docker.
#
# Requires Docker with the Compose plugin (docker compose v2).
# RAILS_MASTER_KEY must be set in the environment or in .env.

set -euo pipefail

for arg in "$@"; do
  case "$arg" in
    --help|-h)
      echo "Usage: bin/boot"
      echo "  Starts the pito production stack (Postgres + Rails)."
      echo "  RAILS_MASTER_KEY must be set in the environment or .env."
      exit 0
      ;;
    *)
      echo "Unknown flag: $arg"
      echo "Run  bin/boot --help  for usage."
      exit 1
      ;;
  esac
done

if [ -z "${RAILS_MASTER_KEY:-}" ] && [ ! -f config/master.key ]; then
  echo "ERROR: RAILS_MASTER_KEY env var or config/master.key is required."
  exit 1
fi

echo "→ Starting pito in production mode…"
exec docker compose up --build "$@"
