#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Starting dev Postgres (docker-compose.dev.yml) =="
  # Native dev runs Rails on the host; only Postgres lives in Docker. `--wait`
  # blocks until the postgres healthcheck passes, so no manual poll loop is needed.
  # (Was: `docker compose up -d` — the *production* pito-boot stack — plus a wait
  # on a non-existent `redis` service that hung for 60s then aborted.)
  system! "docker compose -f docker-compose.dev.yml up -d --wait postgres"

  # Check if credentials have Postgres config
  begin
    creds = Rails rescue nil
    unless system("bin/rails runner 'Rails.application.credentials.dig(:postgres, :development, :database)' 2>/dev/null")
      puts "\n!  Postgres credentials not configured yet."
      puts "   Run: bin/rails credentials:edit --environment development"
      puts "   Add a :postgres block with this shape:"
      puts ""
      puts "   postgres:"
      puts "     development:"
      puts "       database: pito_development"
      puts "       username: pito"
      puts "       password: <your-password>"
      puts "     test:"
      puts "       database: pito_test"
      puts "       username: pito"
      puts "       password: <your-password>"
      puts ""
    end
  rescue
    # Credentials not set up yet, that's fine
  end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  # Phase 3 — Step C (5c-settings-ui-and-docs.md). Pepper credential
  # pre-flight. The seed step (db:seed runs as part of db:prepare on a
  # fresh DB) mints a `dev` API token whose digest is HMAC-SHA256 over
  # the `:tokens.pepper` credential. Without the pepper the digest would
  # be computed against `nil`, breaking auth on first request — and the
  # `ApiToken.digest` call itself raises before mint. Check up front so
  # the failure message points the user at the fix.
  #
  # CI / test environments never have `config/master.key` (by design), so
  # the credential cannot be read there. The seed body skips the dev-token
  # mint with a warning when `:tokens.pepper` is missing in non-development
  # envs; mirror that here so `bin/setup` under `RAILS_ENV=test` does not
  # block CI.
  pepper_required = (ENV["RAILS_ENV"] || "development") == "development"
  if pepper_required && !system("bin/rails runner 'exit Rails.application.credentials.dig(:tokens, :pepper).present? ? 0 : 1' 2>/dev/null")
    puts ""
    puts "!  Missing :tokens.pepper credential."
    puts ""
    puts "   The auth foundation HMACs every token digest with a server-side"
    puts "   pepper. Set it once on a fresh install:"
    puts ""
    puts "     bin/rails credentials:edit"
    puts ""
    puts "   Add the following block (generate the value with"
    puts "   `openssl rand -hex 32`):"
    puts ""
    puts "     tokens:"
    puts "       pepper: <64-char hex>"
    puts ""
    puts "   Then re-run bin/setup."
    exit 1
  end

  # Phase 7.5 §05 — `pito-assets` volume root. Active Storage's `:local`
  # service and the `Pito::AssetsRoot` helper both resolve their on-disk
  # root from `PITO_ASSETS_PATH` (defaulting to `/var/lib/pito-assets` in
  # production). On a dev box the committed `.env.example` points at
  # `tmp/pito-assets`. Create the directory up front so first-write paths
  # (`bin/rails console` smoke checks, the seed-time game cover_art) don't
  # blow up on a missing parent. Relative env values anchor to the repo
  # root; absolute values are honored verbatim. The `/var/lib/pito-assets`
  # default is skipped when not writable (production sets it up via the
  # Docker volume mount, not `bin/setup`).
  raw_assets_path = ENV.fetch("PITO_ASSETS_PATH", "/var/lib/pito-assets")
  resolved_assets_path =
    if File.absolute_path?(raw_assets_path)
      raw_assets_path
    else
      File.expand_path(raw_assets_path, APP_ROOT)
    end
  default_in_use = ENV["PITO_ASSETS_PATH"].nil? || ENV["PITO_ASSETS_PATH"].to_s.empty?
  parent = File.dirname(resolved_assets_path)
  if default_in_use && !File.writable?(parent)
    puts "\n== Skipping pito-assets path =="
    puts "   PITO_ASSETS_PATH is unset and the default (#{resolved_assets_path}) is"
    puts "   not writable. Production deployments mount the `pito-assets` Docker"
    puts "   volume at this location; for dev, set PITO_ASSETS_PATH to a writable"
    puts "   directory (see .env.example)."
  else
    FileUtils.mkdir_p(resolved_assets_path)
    puts "\n== Pito assets root ready at #{resolved_assets_path} =="
  end

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Setup complete =="
  puts "Run bin/dev to start the app."
end
