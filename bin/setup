#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Starting Docker services =="
  system! "docker compose up -d"

  puts "\n== Waiting for services to be healthy =="
  timeout = 60
  elapsed = 0
  loop do
    mysql_healthy = `docker compose ps --format json mysql 2>/dev/null`.include?('"healthy"')
    redis_healthy = `docker compose ps --format json redis 2>/dev/null`.include?('"healthy"')
    meili_healthy = `docker compose ps --format json meilisearch 2>/dev/null`.include?('"healthy"')

    if mysql_healthy && redis_healthy && meili_healthy
      puts "All services healthy."
      break
    end

    if elapsed >= timeout
      abort "ERROR: Services did not become healthy within #{timeout}s. Run: docker compose ps"
    end

    sleep 2
    elapsed += 2
  end

  # Check if credentials have MySQL config
  begin
    creds = Rails rescue nil
    unless system("bin/rails runner 'Rails.application.credentials.dig(:mysql, :development, :database)' 2>/dev/null")
      puts "\n⚠  MySQL credentials not configured yet."
      puts "   Run: EDITOR=vim rails credentials:edit"
      puts "   Add this block:"
      puts ""
      puts "   mysql:"
      puts "     development:"
      puts "       database: pito_development"
      puts "       username: root"
      puts "       password: \"\""
      puts "     test:"
      puts "       database: pito_test"
      puts "       username: root"
      puts "       password: \"\""
      puts ""
    end
  rescue
    # Credentials not set up yet, that's fine
  end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Setup complete =="
  puts "Run bin/dev to start the app."
end
