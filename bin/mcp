#!/usr/bin/env ruby
# MCP (Model Context Protocol) server for pito — shell mode (no tools registered)
# Tools to be re-added when MCP architecture is revisited.

$stderr = File.open(File::NULL, "w") unless ENV["MCP_DEBUG"]
ENV["RAILS_ENV"] ||= "development"
require_relative "../config/environment"
$stderr = STDERR if ENV["MCP_DEBUG"]

require "mcp"
require "mcp/server/transports/stdio_transport"

server = MCP::Server.new(
  name: "pito",
  version: (File.read(Rails.root.join("VERSION")).strip rescue "0.0.0"),
  instructions: "MCP server shell (no tools registered)"
)

transport = MCP::Server::Transports::StdioTransport.new(server)
transport.open
