#!/usr/bin/env bash
# bin/test
#
# Local test runner with shortcuts. Caps parallel workers at 4.
# Skips the per-run `db:test:prepare` when the schema has not changed
# (see `bin/test-prepare`).
#
# Shortcuts:
#
#     bin/test              Fast default. Skips system specs (excluded by
#                           `.rspec`'s `--tag ~type:system`). Runs in parallel.
#
#     bin/test all          Full suite INCLUDING system specs (Capybara/Chrome).
#                           Slower; equivalent to what CI runs.
#
#     bin/test failed       Re-run only the failures from the last run.
#                           Serial (parallel_rspec doesn't share the failures
#                           cache across workers cleanly).
#
#     bin/test <files...>   Run a specific subset. Serial. Honors `.rspec` tag
#                           exclusions, so pass a `spec/system/...` path
#                           explicitly to run a system spec.
#
#     bin/test --help       Print this help.
#
# CI uses its own invocation in `.github/workflows/ci.yml` and intentionally
# bypasses `.rspec` so the full suite still runs in CI.

set -euo pipefail

cd "$(dirname "$0")/.."

usage() {
  sed -n '2,28p' "$0" | sed 's/^#$//; s/^# //'
}

export PARALLEL_TEST_PROCESSORS=4

cmd="${1-}"

case "$cmd" in
  -h|--help|help)
    usage
    exit 0
    ;;

  all)
    # Run everything, including system specs. We bypass `.rspec` (which
    # excludes `type:system`) by passing `--options /dev/null` and re-adding
    # the only flag it carried (`--require spec_helper`). parallel_tests'
    # `-o` flag forwards args to each rspec worker; the `--` separator
    # syntax causes parallel_rspec to treat `--options` as a file path.
    bin/test-prepare
    exec bundle exec parallel_rspec -o '--options /dev/null --require spec_helper' spec/
    ;;

  failed)
    # `--only-failures` reads `.rspec_status` (or whatever `example_status_persistence_file_path`
    # points to). parallel_rspec splits work across workers and doesn't merge
    # the failures cache cleanly, so we run serially here.
    exec bundle exec rspec --only-failures
    ;;

  "")
    # Fast default. `.rspec` excludes system specs.
    bin/test-prepare
    exec bundle exec parallel_rspec
    ;;

  *)
    # Treat all remaining args as RSpec file/dir arguments. Serial; no prep
    # (the caller is iterating fast and knows the schema state).
    exec bundle exec rspec "$@"
    ;;
esac
