#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Ensure the dev Postgres container is up and healthy before Rails starts.
docker compose -f docker-compose.dev.yml up -d --wait --remove-orphans postgres

# Default to port 3027 if not specified
export PORT="${PORT:-3027}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

exec foreman start -f Procfile.dev "$@"
