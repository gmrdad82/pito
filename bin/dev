#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Ensure the dev Postgres container is up and healthy before Rails starts.
docker compose -f docker-compose.dev.yml up -d --wait --remove-orphans postgres

# AI sidecars (embedder + nlmapper) boot WITHOUT --wait: their first boot
# downloads models for minutes, and Puma must not block on that — the app
# treats an unreachable sidecar as "feature degraded", never an error.
docker compose -f docker-compose.dev.yml up -d embedder nlmapper

# Default to port 3027 if not specified
export PORT="${PORT:-3027}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

# Recurring/background jobs are OFF in dev by default: the default Procfile.dev
# omits the SolidQueue supervisor, so config/recurring.yml's development schedule
# (nightly_sync → YouTube, release_countdown → Discord, …) never fires locally.
# Chat-triggered jobs still run in-process via the :async adapter.
# Opt back in (e.g. to test the scheduler) with PITO_DEV_JOBS=1.
PROCFILE="Procfile.dev"
if [ "${PITO_DEV_JOBS:-}" = "1" ]; then
  PROCFILE="Procfile.dev.jobs"
  echo "→ PITO_DEV_JOBS=1: starting with the SolidQueue supervisor (recurring jobs ON)."
fi

exec foreman start -f "$PROCFILE" "$@"
