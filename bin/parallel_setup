#!/usr/bin/env bash
# bin/parallel_setup
#
# Provision per-process Postgres test databases used by `parallel_rspec`.
#
# parallel_tests creates one DB per process suffixed by TEST_ENV_NUMBER
# (`pito_test`, `pito_test_2`, ..., `pito_test_<N>`). We cap N at 4 via
# PARALLEL_TEST_PROCESSORS so local machines with high core counts don't
# over-provision DBs the suite never uses. The same cap is applied in
# `bin/test`.
#
# After running this once the parallel runner is good to go:
#
#     bin/test                   # or: bundle exec parallel_rspec spec/
#
# Re-run any time the schema changes; `parallel:load_schema` is idempotent.

set -euo pipefail

export PARALLEL_TEST_PROCESSORS=4

cd "$(dirname "$0")/.."

bundle exec rake parallel:create parallel:load_schema
