---
// Base layout for the pito apex marketing site.
//
// Minimal hero-card surface — no header, no footer, no nav, no theme toggle.
// Renders a centered About-style card on a near-black background. Mirrors
// the Rails app's `AboutModalComponent` HTML structure minus the dialog
// chrome. Future Theta-phase pages may reintroduce chrome; this layout
// stays bare for the early-launch teaser.
//
// Dark theme only. No system-preference detection, no toggle. The single
// `<meta name="color-scheme" content="dark">` hint tells the UA which
// scheme to use for form controls and scrollbars; the rest of the surface
// is locked dark via `global.css`.

import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { execFileSync } from "node:child_process";

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "pito ~ best YouTube tool",
  description = "best YouTube tool",
} = Astro.props;

// Read version from the project's root VERSION file at build time, mirroring
// the Rails app's `application_helper#app_version`. Falls back to "unknown"
// rather than crashing the build if unreadable.
const versionPath = resolve(process.cwd(), "../../VERSION");
let version = "unknown";
try {
  version = readFileSync(versionPath, "utf-8").trim();
} catch (_) {
  // Keep the "unknown" fallback.
}

// Capture the current short SHA at build time so the rendered card always
// reflects the deployed revision. Mirrors `ApplicationHelper#git_sha`.
// `execFileSync` (no shell) keeps this safe — the arguments are static
// literals. If git is unavailable (tarball deploy, etc.) the SHA falls
// back to null and the template renders an em-dash.
let sha: string | null = null;
try {
  sha = execFileSync("git", ["rev-parse", "--short", "HEAD"], {
    encoding: "utf-8",
  }).trim();
} catch (_) {
  sha = null;
}

const commitUrl = sha ? `https://github.com/gmrdad82/pito/commit/${sha}` : null;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="application-name" content="pito" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f0f10" />
    <meta name="color-scheme" content="dark" />

    {/*
      Icon discovery — apex domain's favicon and OpenGraph hints. Mirrors
      the Rails app's surface. Favicon PNG set + site.webmanifest +
      browserconfig.xml generated from the apex Pito mark.
    */}
    <link rel="icon" href="/favicon.ico?v=2" type="image/x-icon" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#0f0f10" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta property="og:title" content="pito" />
    <meta property="og:description" content="best YouTube tool" />
    <meta property="og:image" content="https://pitomd.com/favicon-256x256.png?v=2" />
    <meta property="og:url" content="https://pitomd.com" />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <main class="hero-card">
      <img src="/favicon-128x128.png?v=2" alt="pito" class="hero-logo" />

      <div class="hero-name">pito</div>
      <div class="hero-subtitle">best YouTube tool</div>

      {/*
        Astro hero K-V: version + revision ONLY.
        DO NOT add an env row (Rails.env is meaningless on a static deploy).
        Accent color is fixed to Dracula Purple (#bd93f9) — no section variants
        because Astro is a single-page surface. See pito Rails app for the
        section-variant theme system (channels=red, games=blue, settings=orange).
      */}
      <dl class="hero-meta">
        <dt>version</dt>
        <dd>v{version}</dd>
        <dt>revision</dt>
        <dd>
          {commitUrl && sha ? (
            <a
              href={commitUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bracketed-link"
            >[<span>{sha}</span>]</a>
          ) : (
            <span class="em-dash">&mdash;</span>
          )}
        </dd>
      </dl>

      <p class="hero-copyright">&copy; {year} &mdash; all rights reserved.</p>

      <slot />
    </main>
  </body>
</html>
