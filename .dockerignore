# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory.
/.git/
/.gitignore

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all default key files.
/config/master.key
/config/credentials/*.key

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore assets + dev Active Storage blobs (avatars/thumbnails/covers live under
# public/pito-storage in development — must never be baked into a local build).
/public/assets
/public/pito-storage

# Ignore JS deps — PITO runs on importmap (no node build at runtime); node_modules
# is dev-only (vitest). ~41 MB never belongs in the image.
/node_modules

# Ignore tests + coverage. The image ships BUNDLE_WITHOUT="development test", so the
# test gems aren't installed and specs can't run in it anyway.
/spec
/coverage

# Ignore docs + media (guides + the ~14 MB theme gallery / feature GIFs). None of it
# is read at runtime — keep it out of the published image too.
/docs

# Ignore CI service files.
/.github

# Ignore development files
/.devcontainer

# Ignore Docker-related files
/.dockerignore
/Dockerfile*
